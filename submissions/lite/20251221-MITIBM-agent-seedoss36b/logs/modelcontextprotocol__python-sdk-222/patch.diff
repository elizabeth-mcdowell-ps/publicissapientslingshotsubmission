@@ -0,0 +1,65 @@
+"""Script to test multiple results from resources and tools."""
+
+import asyncio
+from typing import List
+
+from mcp.server.fastmcp.server import FastMCP
+from mcp.server.lowlevel.helper_types import ReadResourceContents
+from mcp.types import TextContent, EmbeddedResource
+
+
+async def main():
+    """Run the test."""
+    mcp = FastMCP()
+
+    # Test multiple results from a tool
+    @mcp.tool()
+    def multiple_results_tool() -> List[TextContent]:
+        """Return multiple text content items."""
+        return [
+            TextContent(type="text", text="Result 1"),
+            TextContent(type="text", text="Result 2"),
+        ]
+
+    # Test multiple results from a resource using list of strings
+    @mcp.resource("resource://multiple-strings")
+    def multiple_strings_resource() -> List[str]:
+        """Return multiple strings."""
+        return ["Result 1", "Result 2"]
+    
+    # Test multiple results from a resource using ReadResourceContents
+    @mcp.resource("resource://multiple-contents")
+    def multiple_contents_resource() -> List[ReadResourceContents]:
+        """Return multiple ReadResourceContents."""
+        return [
+            ReadResourceContents(content="Result 1", mime_type="text/plain"),
+            ReadResourceContents(content="Result 2", mime_type="text/plain"),
+        ]
+
+    # Create a context and call the tool
+    context = mcp.get_context()
+    
+    print("Testing tool with multiple results:")
+    try:
+        tool_result = await mcp.call_tool("multiple_results_tool", {})
+        print(f"Tool result: {tool_result}")
+    except Exception as e:
+        print(f"Tool error: {e}")
+    
+    print("\nTesting resource with multiple string results:")
+    try:
+        resource_result = await mcp.read_resource("resource://multiple-strings")
+        print(f"Resource result (strings): {resource_result}")
+    except Exception as e:
+        print(f"Resource error: {e}")
+        
+    print("\nTesting resource with multiple ReadResourceContents results:")
+    try:
+        resource_result = await mcp.read_resource("resource://multiple-contents")
+        print(f"Resource result (contents): {resource_result}")
+    except Exception as e:
+        print(f"Resource error: {e}")
+
+
+if __name__ == "__main__":
+    asyncio.run(main())
