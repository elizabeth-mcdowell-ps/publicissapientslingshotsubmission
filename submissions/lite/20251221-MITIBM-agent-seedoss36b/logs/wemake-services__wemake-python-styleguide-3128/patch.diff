+import tokenize
+from io import BytesIO
+
+from wemake_python_styleguide.options.config import Configuration
+from wemake_python_styleguide.visitors.tokenize.primitives import WrongNumberTokenVisitor
+
+def generate_tokens(code):
+    """Generate tokens from a string."""
+    return list(tokenize.tokenize(BytesIO(code.encode('utf-8')).readline))
+
+def check_number(number_str):
+    """Check if a number string would trigger a violation."""
+    code = f"x = {number_str}"
+    tokens = generate_tokens(code)
+    
+    # Find the number token
+    number_token = None
+    for token in tokens:
+        if token.type == tokenize.NUMBER:
+            number_token = token
+            break
+    
+    if not number_token:
+        return False
+    
+    # Create a visitor and check the number
+    visitor = WrongNumberTokenVisitor(Configuration(), file_tokens=tokens)
+    visitor._check_underscored_number(number_token)
+    
+    # Return True if there are violations, False otherwise
+    return bool(visitor._violations)
+
+# Test valid numbers (should not trigger violations)
+valid_numbers = [
+    '1_000',
+    '10_000',
+    '100_000',
+    '1_000_000',
+    '1_000_000_000',
+    '+1_000',
+    '-1_000',
+]
+
+# Test invalid numbers (should trigger violations)
+invalid_numbers = [
+    '1_00',
+    '10_00',
+    '100_0',
+    '1_0000',
+    '10_0_000',
+]
+
+print("Testing valid numbers (should not trigger violations):")
+for num in valid_numbers:
+    result = check_number(num)
+    print(f"  {num}: {'FAIL - Violation triggered' if result else 'PASS - No violation'}")
+
+print("\nTesting invalid numbers (should trigger violations):")
+for num in invalid_numbers:
+    result = check_number(num)
+    print(f"  {num}: {'PASS - Violation triggered' if result else 'FAIL - No violation'}")
