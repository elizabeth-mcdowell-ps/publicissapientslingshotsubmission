+"""
+Test script to directly test the WrongNumberTokenVisitor implementation.
+"""
+
+import tokenize
+from io import BytesIO
+
+from wemake_python_styleguide.visitors.tokenize.primitives import WrongNumberTokenVisitor
+
+class MockOptions:
+    """Mock options class for testing."""
+    def __init__(self):
+        pass
+
+def get_tokens(code):
+    """Get tokens from a string."""
+    return list(tokenize.tokenize(BytesIO(code.encode('utf-8')).readline))
+
+def test_number(number_str):
+    """Test if a number string triggers a violation."""
+    code = f"x = {number_str}"
+    tokens = get_tokens(code)
+    
+    visitor = WrongNumberTokenVisitor(MockOptions(), file_tokens=tokens)
+    
+    # Find the number token
+    for token in tokens:
+        if token.type == tokenize.NUMBER:
+            visitor._check_underscored_number(token)
+            break
+    
+    return bool(visitor.violations)
+
+# Test cases
+test_cases = [
+    # Valid cases (should not trigger violations)
+    ('1_000', False),
+    ('10_000', False),
+    ('100_000', False),
+    ('1_000_000', False),
+    ('1_000.0', False),
+    ('0x1_234', False),
+    
+    # Invalid cases (should trigger violations)
+    ('1_00', True),
+    ('10_00', True),
+    ('100_0', True),
+    ('1_00.0', True),
+]
+
+# Run tests
+print("Testing WrongNumberTokenVisitor._check_underscored_number:")
+print("=" * 60)
+
+for number_str, should_trigger in test_cases:
+    has_violation = test_number(number_str)
+    result = 'PASS' if has_violation == should_trigger else 'FAIL'
+    
+    print(f"{number_str}: {result}")
+    if result == 'FAIL':
+        print(f"  Expected: {'violation' if should_trigger else 'no violation'}")
+        print(f"  Got: {'violation' if has_violation else 'no violation'}")
+
+print("=" * 60)
