         # Correct:
         phone = 88313443
         million = 1000000
+        # Or with proper underscore usage:
+        million = 1_000_000
+        billion = 1_000_000_000
 
         # Wrong:
         phone = 8_83_134_43
         million = 100_00_00
 
     .. versionadded:: 0.1.0
+    .. versionchanged:: 0.x.0
+       Now allows underscores that separate groups of 3 digits.
 
     """
 
