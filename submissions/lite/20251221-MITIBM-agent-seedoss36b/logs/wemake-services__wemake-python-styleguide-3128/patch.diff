+"""
+Test script to verify the implementation of the underscored number rule.
+This script creates Python files with different number formats and runs
+the linter to check if the correct violations are reported.
+"""
+
+import os
+import subprocess
+import tempfile
+
+def create_temp_file(content):
+    """Create a temporary Python file with the given content."""
+    fd, path = tempfile.mkstemp(suffix='.py')
+    with os.fdopen(fd, 'w') as f:
+        f.write(content)
+    return path
+
+def run_flake8(file_path):
+    """Run flake8 on the given file and return the output."""
+    try:
+        result = subprocess.run(
+            ['python', '-m', 'flake8', file_path, '--select=WPS303'],
+            capture_output=True,
+            text=True,
+            check=False,
+        )
+        return result.stdout.strip()
+    except Exception as e:
+        return f"Error running flake8: {e}"
+
+# Test cases
+test_cases = [
+    # Valid cases (should not trigger WPS303)
+    {
+        'name': 'Valid: 1_000',
+        'code': 'x = 1_000',
+        'should_trigger': False,
+    },
+    {
+        'name': 'Valid: 10_000',
+        'code': 'x = 10_000',
+        'should_trigger': False,
+    },
+    {
+        'name': 'Valid: 100_000',
+        'code': 'x = 100_000',
+        'should_trigger': False,
+    },
+    {
+        'name': 'Valid: 1_000_000',
+        'code': 'x = 1_000_000',
+        'should_trigger': False,
+    },
+    {
+        'name': 'Valid: Floating point 1_000.0',
+        'code': 'x = 1_000.0',
+        'should_trigger': False,
+    },
+    {
+        'name': 'Valid: Hex 0x1_234',
+        'code': 'x = 0x1_234',
+        'should_trigger': False,
+    },
+    
+    # Invalid cases (should trigger WPS303)
+    {
+        'name': 'Invalid: 1_00',
+        'code': 'x = 1_00',
+        'should_trigger': True,
+    },
+    {
+        'name': 'Invalid: 10_00',
+        'code': 'x = 10_00',
+        'should_trigger': True,
+    },
+    {
+        'name': 'Invalid: 100_0',
+        'code': 'x = 100_0',
+        'should_trigger': True,
+    },
+    {
+        'name': 'Invalid: Floating point 1_00.0',
+        'code': 'x = 1_00.0',
+        'should_trigger': True,
+    },
+]
+
+# Run tests
+print("Running tests for underscored number rule (WPS303)...")
+print("=" * 60)
+
+for test_case in test_cases:
+    file_path = create_temp_file(test_case['code'])
+    output = run_flake8(file_path)
+    
+    has_violation = 'WPS303' in output
+    expected = test_case['should_trigger']
+    
+    result = 'PASS' if has_violation == expected else 'FAIL'
+    
+    print(f"{test_case['name']}: {result}")
+    if result == 'FAIL':
+        print(f"  Expected: {'violation' if expected else 'no violation'}")
+        print(f"  Got: {'violation' if has_violation else 'no violation'}")
+        if output:
+            print(f"  Output: {output}")
+    
+    # Clean up
+    os.remove(file_path)
+
+print("=" * 60)
+print("Tests completed.")
