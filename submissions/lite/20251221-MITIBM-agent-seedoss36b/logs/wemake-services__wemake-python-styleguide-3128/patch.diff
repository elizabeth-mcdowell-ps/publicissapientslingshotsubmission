+import re
+
+def check_underscored_number(number_str):
+    """
+    Check if a number string follows the rule:
+    Underscores should only separate groups of 3 digits.
+    """
+    # Remove any sign prefix for validation
+    number_str = number_str.lstrip('+-')
+    
+    # Handle hexadecimal, binary, and octal numbers
+    if number_str.startswith(('0x', '0X', '0b', '0B', '0o', '0O')):
+        # For non-decimal numbers, we don't enforce the 3-digit rule
+        return True
+    
+    # Handle floating-point numbers
+    if '.' in number_str:
+        # Split into integer and fractional parts
+        int_part, frac_part = number_str.split('.')
+        
+        # Check integer part
+        if '_' in int_part:
+            parts = int_part.split('_')
+            if any(len(part) != 3 for part in parts[1:]):
+                return False
+        
+        # Check fractional part
+        if '_' in frac_part:
+            parts = frac_part.split('_')
+            if any(len(part) != 3 for part in parts[:-1]):
+                return False
+        
+        return True
+    
+    # Handle integer numbers
+    if '_' in number_str:
+        # Split by underscores
+        parts = number_str.split('_')
+        
+        # First part can be any length
+        # All subsequent parts must be exactly 3 digits
+        return not any(len(part) != 3 for part in parts[1:])
+    
+    return True  # No underscores, so it's valid
+
+# Test valid numbers (should return True)
+valid_numbers = [
+    # Regular integers with proper underscore placement
+    '1_000',
+    '10_000',
+    '100_000',
+    '1_000_000',
+    '1_000_000_000',
+    '+1_000',
+    '-1_000',
+    
+    # Floating-point numbers with proper underscore placement
+    '1_000.0',
+    '1_000.000',
+    '1_000.000_001',
+    
+    # Hexadecimal, binary, and octal numbers (not enforcing 3-digit rule)
+    '0x1_234',
+    '0b1010_1010',
+    '0o123_456',
+]
+
+# Test invalid numbers (should return False)
+invalid_numbers = [
+    # Integers with improper underscore placement
+    '1_00',
+    '10_00',
+    '100_0',
+    '1_0000',
+    '10_0_000',
+    
+    # Floating-point numbers with improper underscore placement
+    '1_00.0',
+    '10_00.0',
+    '1_000.0_1',
+    '1_000.00_1',
+]
+
+print("Testing valid numbers (should return True):")
+for num in valid_numbers:
+    result = check_underscored_number(num)
+    print(f"  {num}: {'PASS' if result else 'FAIL'}")
+
+print("\nTesting invalid numbers (should return False):")
+for num in invalid_numbers:
+    result = check_underscored_number(num)
+    print(f"  {num}: {'FAIL' if result else 'PASS'}")
