diff --git a/verify_fix.py b/verify_fix.py
new file mode 100644
index 00000000..4c8c95de
--- /dev/null
+++ b/verify_fix.py
@@ -0,0 +1,66 @@
+import os
+import sys
+import asyncio
+import json
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, '/testbed')
+
+# Import the functions we want to test
+from reflex.model import get_db_status
+from reflex.app import health
+
+async def test_with_empty_db_url():
+    """Test the health check with an empty DB_URL."""
+    # Set DB_URL to empty string
+    os.environ["DB_URL"] = ""
+    
+    # Test get_db_status
+    db_status = await get_db_status()
+    print(f"DB status with empty DB_URL: {db_status}")
+    assert db_status is None, f"Expected None, got {db_status}"
+    
+    # Test health endpoint
+    response = await health()
+    health_data = json.loads(response.body)
+    print(f"Health response with empty DB_URL: {health_data}")
+    assert health_data["db"] == "NA", f"Expected 'NA', got {health_data['db']}"
+    assert health_data["status"] is True, f"Expected True, got {health_data['status']}"
+    assert response.status_code == 200, f"Expected 200, got {response.status_code}"
+
+async def test_with_none_db_url():
+    """Test the health check with a None DB_URL."""
+    # Set DB_URL to None (by deleting the environment variable)
+    if "DB_URL" in os.environ:
+        del os.environ["DB_URL"]
+    
+    # Test get_db_status
+    db_status = await get_db_status()
+    print(f"DB status with None DB_URL: {db_status}")
+    assert db_status is None, f"Expected None, got {db_status}"
+    
+    # Test health endpoint
+    response = await health()
+    health_data = json.loads(response.body)
+    print(f"Health response with None DB_URL: {health_data}")
+    assert health_data["db"] == "NA", f"Expected 'NA', got {health_data['db']}"
+    assert health_data["status"] is True, f"Expected True, got {health_data['status']}"
+    assert response.status_code == 200, f"Expected 200, got {response.status_code}"
+
+async def main():
+    try:
+        print("Testing with empty DB_URL...")
+        await test_with_empty_db_url()
+        
+        print("\nTesting with None DB_URL...")
+        await test_with_none_db_url()
+        
+        print("\nAll tests passed!")
+    except Exception as e:
+        print(f"Error occurred: {e}")
+        import traceback
+        traceback.print_exc()
+        sys.exit(1)
+
+if __name__ == "__main__":
+    asyncio.run(main())
