@@ -0,0 +1,59 @@
+from faker import Faker
+from datetime import timezone, datetime, timedelta
+
+# Create a Faker instance
+faker = Faker()
+
+# Get current time once for all tests
+now = datetime.now(timezone.utc)
+print(f"Current time: {now}")
+
+print("\nTesting with negative time delta:")
+try:
+    # This should now work correctly with our fix
+    deadline = faker.date_time(end_datetime="-1w", tzinfo=timezone.utc)
+    print(f"Generated date_time with end_datetime='-1w': {deadline}")
+    
+    # Verify that the date is in the past (before now)
+    print(f"Is generated date in the past? {deadline < now}")
+    
+    # Calculate the expected time range (approximately 1 week ago)
+    one_week_ago = now - timedelta(weeks=1)
+    print(f"Approximately one week ago: {one_week_ago}")
+    print(f"Is generated date close to one week ago? {abs((deadline - one_week_ago).total_seconds()) < 86400}")  # Within a day
+    
+except ValueError as e:
+    print(f"Error: {e}")
+
+print("\nTesting with positive time delta:")
+try:
+    # Test with a positive time delta
+    future_date = faker.date_time(end_datetime="+1w", tzinfo=timezone.utc)
+    print(f"Generated date_time with end_datetime='+1w': {future_date}")
+    
+    # Verify that the date is in the future (after now)
+    print(f"Is generated date in the future? {future_date > now}")
+    
+    # Calculate the expected time range (approximately 1 week in the future)
+    one_week_future = now + timedelta(weeks=1)
+    print(f"Approximately one week in the future: {one_week_future}")
+    print(f"Is generated date close to one week in the future? {abs((future_date - one_week_future).total_seconds()) < 86400}")  # Within a day
+    
+except ValueError as e:
+    print(f"Error: {e}")
+
+print("\nTesting with explicit start and end datetimes:")
+try:
+    # Test with explicit start and end datetimes
+    start_date = datetime(2020, 1, 1, tzinfo=timezone.utc)
+    end_date = datetime(2020, 12, 31, tzinfo=timezone.utc)
+    
+    specific_date = faker.date_time_between(start_date=start_date, end_date=end_date)
+    print(f"Generated date_time between {start_date} and {end_date}: {specific_date}")
+    
+    # Verify that the date is within the specified range
+    print(f"Is generated date after start date? {specific_date >= start_date}")
+    print(f"Is generated date before end date? {specific_date <= end_date}")
+    
+except ValueError as e:
+    print(f"Error: {e}")
