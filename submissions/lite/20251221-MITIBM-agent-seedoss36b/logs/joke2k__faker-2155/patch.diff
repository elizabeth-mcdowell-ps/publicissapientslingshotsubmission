+    
+    # Test with start > end
+    result = linux_provider._rand_seconds(0, -604800)
+    print(f"Linux _rand_seconds result: {result}")
+except ValueError as e:
+    print(f"Linux _rand_seconds error: {e}")
+except Exception as e:
+    print(f"Other error: {e}")
