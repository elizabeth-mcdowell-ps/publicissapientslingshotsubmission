+import os
+import sys
+import tempfile
+import io
+from unittest.mock import patch, MagicMock
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, '/testbed')
+
+from flexget.plugins.clients.qbittorrent import OutputQBitTorrent
+from flexget.entry import Entry
+
+# Simulate the error directly
+def test_multipart_encoding_with_float():
+    print("Testing multipart encoding with float value...")
+    
+    # Create a BytesIO object to simulate the body in encode_multipart_formdata
+    body = io.BytesIO()
+    
+    try:
+        # This is what happens in urllib3.filepost.encode_multipart_formdata
+        # when a float is passed as data
+        body.write(1.25)  # This should fail with TypeError
+        print("No error occurred (unexpected)")
+    except TypeError as e:
+        print(f"Error occurred as expected: {e}")
+    
+    # Now try with a string conversion (our fix)
+    try:
+        body.write(str(1.25).encode())  # This should work
+        print("String conversion works as expected")
+    except Exception as e:
+        print(f"String conversion failed (unexpected): {e}")
+
+# Test the specific issue in the qBittorrent plugin
+def test_qbittorrent_multipart_data():
+    print("\nTesting qBittorrent multipart data creation...")
+    
+    # Create a dictionary with a float value
+    data = {'ratioLimit': 1.25}
+    
+    # This is what happens in add_torrent_file and add_torrent_url methods before the fix
+    multipart_data_before = {k: (None, v) for k, v in data.items()}
+    print(f"Multipart data before fix: {multipart_data_before}")
+    
+    # This is what happens with our fix
+    multipart_data_after = {k: (None, str(v) if isinstance(v, (int, float)) else v) for k, v in data.items()}
+    print(f"Multipart data after fix: {multipart_data_after}")
+    
+    # Simulate the request with files parameter using our fix
+    try:
+        # Mock the requests.Session.request method
+        with patch('requests.Session.request') as mock_request:
+            # Create a mock response
+            mock_response = MagicMock()
+            mock_response.text = "Ok."
+            mock_request.return_value = mock_response
+            
+            # Create a session and make a request with the fixed data
+            from requests import Session
+            session = Session()
+            response = session.request('post', 'http://example.com', files=multipart_data_after)
+            
+            print("Request with fixed data succeeded (expected)")
+    except Exception as e:
+        print(f"Request with fixed data failed (unexpected): {e}")
+
+# Test the actual qBittorrent plugin methods
+def test_qbittorrent_plugin_methods():
+    print("\nTesting qBittorrent plugin methods with our fix...")
+    
+    # Create a mock entry
+    entry = Entry(title='Test Entry', url='http://example.com/test.torrent')
+    entry['file'] = '/tmp/test.torrent'  # This file doesn't need to exist for our test
+    
+    # Create data with a float ratio_limit
+    data = {'ratioLimit': 1.25}
+    
+    # Create a qBittorrent plugin instance
+    qbt = OutputQBitTorrent()
+    
+    # Mock the _request method to avoid actual HTTP requests
+    qbt._request = MagicMock(return_value=True)
+    qbt.connected = True
+    qbt.url = 'http://example.com'
+    qbt.api_url_upload = '/api/v2/torrents/add'
+    qbt.api_url_download = '/api/v2/torrents/add'  # Add this for add_torrent_url
+    
+    # Test add_torrent_file with a patch to avoid opening the file
+    with patch('builtins.open', MagicMock()):
+        try:
+            qbt.add_torrent_file(entry, data, verify_cert=False)
+            print("add_torrent_file method succeeded with float ratio_limit (expected)")
+        except Exception as e:
+            print(f"add_torrent_file method failed (unexpected): {e}")
+    
+    # Test add_torrent_url
+    try:
+        qbt.add_torrent_url(entry, data, verify_cert=False)
+        print("add_torrent_url method succeeded with float ratio_limit (expected)")
+    except Exception as e:
+        print(f"add_torrent_url method failed (unexpected): {e}")
+
+# Test edge cases
+def test_edge_cases():
+    print("\nTesting edge cases...")
+    
+    # Create a qBittorrent plugin instance
+    qbt = OutputQBitTorrent()
+    
+    # Mock the _request method to avoid actual HTTP requests
+    qbt._request = MagicMock(return_value=True)
+    qbt.connected = True
+    qbt.url = 'http://example.com'
+    qbt.api_url_upload = '/api/v2/torrents/add'
+    qbt.api_url_download = '/api/v2/torrents/add'
+    
+    # Create a mock entry
+    entry = Entry(title='Test Entry', url='http://example.com/test.torrent')
+    entry['file'] = '/tmp/test.torrent'
+    
+    # Test with various edge cases
+    edge_cases = [
+        {'name': 'None value', 'data': {'ratioLimit': None}},
+        {'name': 'Zero value', 'data': {'ratioLimit': 0.0}},
+        {'name': 'Negative value', 'data': {'ratioLimit': -1.5}},
+        {'name': 'Very small float', 'data': {'ratioLimit': 0.0000001}},
+        {'name': 'Very large float', 'data': {'ratioLimit': 1000000.5}},
+        {'name': 'Scientific notation', 'data': {'ratioLimit': 1e-10}},
+        {'name': 'Mixed types', 'data': {'ratioLimit': 1.5, 'intValue': 10, 'strValue': 'test'}}
+    ]
+    
+    for case in edge_cases:
+        print(f"\nTesting {case['name']}...")
+        data = case['data']
+        
+        # Test add_torrent_file
+        with patch('builtins.open', MagicMock()):
+            try:
+                qbt.add_torrent_file(entry, data, verify_cert=False)
+                print(f"add_torrent_file succeeded with {case['name']}")
+            except Exception as e:
+                print(f"add_torrent_file failed with {case['name']}: {e}")
+        
+        # Test add_torrent_url
+        try:
+            qbt.add_torrent_url(entry, data, verify_cert=False)
+            print(f"add_torrent_url succeeded with {case['name']}")
+        except Exception as e:
+            print(f"add_torrent_url failed with {case['name']}: {e}")
+
+if __name__ == "__main__":
+    test_multipart_encoding_with_float()
+    test_qbittorrent_multipart_data()
+    test_qbittorrent_plugin_methods()
+    test_edge_cases()
