+#!/usr/bin/env python3
+
+import sys
+import os
+import base64
+from yt_dlp.cookies import YDLLogger
+
+def main():
+    logger = YDLLogger()
+    print("Testing the fix for non-UTF-8 cookie data directly...")
+    
+    # Create a non-UTF-8 byte string
+    non_utf8_bytes = b'valid_utf8_part\xff\xfe\xfd\xfc'
+    
+    # Test the original implementation (simulated)
+    print("\n=== Original Implementation (simulated) ===")
+    try:
+        # This will fail with UnicodeDecodeError
+        result = non_utf8_bytes.decode()
+        print(f"Decoded: {result}")
+    except UnicodeDecodeError:
+        print("UnicodeDecodeError: Cannot decode the byte string as UTF-8")
+        print("In the original implementation, this would return None")
+    
+    # Test our fixed implementation (simulated)
+    print("\n=== Fixed Implementation (simulated) ===")
+    try:
+        # Try to decode as UTF-8
+        result = non_utf8_bytes.decode()
+        print(f"Decoded as UTF-8: {result}")
+    except UnicodeDecodeError:
+        # If that fails, use the binary data directly
+        print("UnicodeDecodeError: Cannot decode the byte string as UTF-8")
+        print("In our fixed implementation, we return the binary data directly")
+        
+        # For cookie values, we base64 encode the binary data
+        b64_value = base64.b64encode(non_utf8_bytes).decode()
+        print(f"Base64 encoded value: {b64_value}")
+        
+        # We can decode it back to get the original binary data
+        decoded = base64.b64decode(b64_value)
+        print(f"Decoded back to binary: {decoded}")
+        print(f"Matches original: {decoded == non_utf8_bytes}")
+    
+    print("\nOur fix ensures that non-UTF-8 cookie data is preserved")
+    print("This allows all cookies to be used, even if they contain binary data")
+
+if __name__ == "__main__":
+    main()
