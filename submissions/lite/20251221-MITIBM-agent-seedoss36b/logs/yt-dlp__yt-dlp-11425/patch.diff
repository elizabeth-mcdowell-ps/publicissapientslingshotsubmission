+#!/usr/bin/env python3
+
+import sys
+import os
+from yt_dlp.cookies import _decrypt_aes_cbc_multi, YDLLogger, _process_chrome_cookie
+from yt_dlp.aes import unpad_pkcs7
+import base64
+
+def main():
+    logger = YDLLogger()
+    print("Testing the fix for non-UTF-8 cookie data...")
+    
+    # Create a non-UTF-8 byte string that would cause the issue
+    non_utf8_bytes = b'valid_utf8_part\xff\xfe\xfd\xfc'
+    
+    # Test case 1: Non-UTF-8 data
+    print("\n=== Test Case 1: Non-UTF-8 data ===")
+    test_decryption(non_utf8_bytes, logger)
+    
+    # Test case 2: Empty value
+    print("\n=== Test Case 2: Empty value ===")
+    test_decryption(b'', logger)
+    
+    # Test case 3: Value with null bytes
+    print("\n=== Test Case 3: Value with null bytes ===")
+    test_decryption(b'value\x00with\x00null\x00bytes', logger)
+    
+    # Test case 4: Normal UTF-8 value
+    print("\n=== Test Case 4: Normal UTF-8 value ===")
+    test_decryption(b'normal utf-8 value', logger)
+    
+    print("\nThe fix allows all types of data to be preserved in cookies")
+    print("This ensures that all cookies can be used, even if they contain binary data")
+
+def test_decryption(test_bytes, logger):
+    # We'll create a mock function that returns our test data
+    def mock_decrypt_bytes(ciphertext, key, iv):
+        if not test_bytes:
+            return b'\x01'  # Add minimal padding for empty value
+        return test_bytes + b'\x01'  # Add padding for unpad_pkcs7
+    
+    # We also need to mock unpad_pkcs7 to return our test data directly
+    def mock_unpad_pkcs7(data):
+        return test_bytes
+    
+    # Monkey patch the functions temporarily
+    import yt_dlp.aes
+    original_decrypt_func = yt_dlp.aes.aes_cbc_decrypt_bytes
+    original_unpad_func = yt_dlp.aes.unpad_pkcs7
+    yt_dlp.aes.aes_cbc_decrypt_bytes = mock_decrypt_bytes
+    yt_dlp.aes.unpad_pkcs7 = mock_unpad_pkcs7
+    
+    try:
+        # Test the fixed _decrypt_aes_cbc_multi function
+        result = _decrypt_aes_cbc_multi(b'dummy_ciphertext', [b'A'*16], logger)
+        
+        if result is None:
+            print("ERROR: Decryption failed")
+            return
+            
+        print(f"Decryption result type: {type(result)}")
+        if isinstance(result, bytes):
+            print(f"Decryption returned bytes: {result}")
+        else:
+            print(f"Decryption returned string: {result}")
+        
+        # Now test the _process_chrome_cookie function
+        class MockDecryptor:
+            def decrypt(self, encrypted_value):
+                return test_bytes
+        
+        is_encrypted, cookie = _process_chrome_cookie(
+            MockDecryptor(),
+            b'example.com',
+            b'cookie_name',
+            b'',  # Empty value means it's encrypted
+            b'encrypted_value',
+            b'/',
+            1234567890,
+            True
+        )
+        
+        if cookie is None:
+            print("ERROR: Cookie processing failed")
+        else:
+            print(f"Cookie value: {cookie.value}")
+            
+            # Check if the value is base64 encoded
+            is_b64 = is_base64(cookie.value)
+            print(f"Is base64 encoded: {is_b64}")
+            
+            if is_b64:
+                decoded = base64.b64decode(cookie.value)
+                print(f"Decoded value: {decoded}")
+                print(f"Decoded value matches original: {decoded == test_bytes}")
+            elif test_bytes:
+                # If not base64 encoded, it should be a direct string conversion
+                print(f"String value matches original decoded: {cookie.value == test_bytes.decode()}")
+    finally:
+        # Restore the original functions
+        yt_dlp.aes.aes_cbc_decrypt_bytes = original_decrypt_func
+        yt_dlp.aes.unpad_pkcs7 = original_unpad_func
+
+def is_base64(s):
+    try:
+        return base64.b64encode(base64.b64decode(s)).decode() == s
+    except Exception:
+        return False
+
+if __name__ == "__main__":
+    main()
