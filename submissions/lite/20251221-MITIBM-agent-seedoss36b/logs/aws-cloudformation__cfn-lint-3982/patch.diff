+#!/usr/bin/env python
+
+import os
+import sys
+import yaml
+
+# Add the src directory to the path so we can import cfnlint
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'src'))
+
+import cfnlint.api
+
+# Create a CloudFormation template with duplicate Sid in IAM Role inline policy
+template_dict = {
+    'AWSTemplateFormatVersion': '2010-09-09',
+    'Description': 'Test',
+    'Resources': {
+        'ScheduleRole': {
+            'Type': 'AWS::IAM::Role',
+            'Properties': {
+                'AssumeRolePolicyDocument': {
+                    'Statement': [
+                        {
+                            'Effect': 'Allow',
+                            'Principal': {
+                                'Service': 'scheduler.amazonaws.com'
+                            },
+                            'Action': 'sts:AssumeRole'
+                        }
+                    ]
+                },
+                'Policies': [
+                    {
+                        'PolicyName': 'InlinePolicy',
+                        'PolicyDocument': {
+                            'Version': '2012-10-17',
+                            'Statement': [
+                                {
+                                    'Sid': 'KMSAccess',
+                                    'Effect': 'Allow',
+                                    'Action': [
+                                        'kms:Decrypt',
+                                        'kms:GenerateDataKey',
+                                        'kms:Encrypt'
+                                    ],
+                                    'Resource': '*'
+                                },
+                                {
+                                    'Sid': 'KMSAccess',
+                                    'Effect': 'Allow',
+                                    'Action': [
+                                        'kms:Decrypt',
+                                        'kms:GenerateDataKey',
+                                        'kms:Encrypt'
+                                    ],
+                                    'Resource': '*'
+                                }
+                            ]
+                        }
+                    }
+                ]
+            }
+        }
+    }
+}
+
+# Write the template to a file
+with open('/tmp/duplicate_sid_template.yaml', 'w') as f:
+    yaml.dump(template_dict, f)
+
+# Run cfn-lint on the template
+print("Running cfn-lint on template with duplicate Sid values...")
+template_file = '/tmp/duplicate_sid_template.yaml'
+matches = cfnlint.api.lint(template_file)
+
+# Print the results
+if matches:
+    print(f"Found {len(matches)} issues:")
+    for match in matches:
+        print(f"Rule {match.rule.id}: {match.message}")
+else:
+    print("No issues found - cfn-lint did not detect the duplicate Sid problem!")
+
+# Clean up
+os.remove('/tmp/duplicate_sid_template.yaml')
