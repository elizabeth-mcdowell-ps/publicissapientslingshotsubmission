+"""
+Test script to verify IPython extension loading behavior.
+"""
+
+import sys
+from unittest.mock import MagicMock
+
+# Mock IPython environment
+class MockIPython:
+    def register_magic_function(self, func, magic_name):
+        print(f"Registered magic function: {magic_name}")
+
+# Create a mock ipython object
+ipython = MockIPython()
+
+# Test loading kedro.ipython extension
+print("Testing %load_ext kedro.ipython:")
+try:
+    import kedro.ipython
+    kedro.ipython.load_ipython_extension(ipython)
+    print("Successfully loaded kedro.ipython extension")
+except Exception as e:
+    print(f"Error loading kedro.ipython extension: {e}")
+
+# Test loading kedro extension (which doesn't exist yet)
