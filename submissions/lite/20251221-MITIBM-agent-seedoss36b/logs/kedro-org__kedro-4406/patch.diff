+    import kedro
+    if hasattr(kedro, 'load_ipython_extension'):
+        kedro.load_ipython_extension(ipython)
+        print("Successfully loaded kedro extension")
+    else:
+        print("kedro module doesn't have load_ipython_extension function")
+except Exception as e:
+    print(f"Error loading kedro extension: {e}")
