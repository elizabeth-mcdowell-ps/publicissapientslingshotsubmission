+"""
+This script checks the target file to see where INTERFACE_LINK_DIRECTORIES is being set.
+"""
+
+import os
+import tempfile
+import shutil
+
+# Create a temporary directory for our test
+temp_dir = tempfile.mkdtemp()
+try:
+    os.chdir(temp_dir)
+    print(f"Working in temporary directory: {temp_dir}")
+
+    # Create a simple conanfile.py for a library
+    with open("conanfile.py", "w") as f:
+        f.write("""
+from conan import ConanFile
+
+class HelloConan(ConanFile):
+    name = "hello"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+    generators = "CMakeDeps"
+    
+    def package_info(self):
+        self.cpp_info.libs = ["hello"]
+        # This property should no longer have any effect
+        self.cpp_info.set_property("cmake_set_interface_link_directories", False)
+""")
+
+    # Create the package
+    os.system("conan export .")
+    
+    # Create a consumer project
+    os.makedirs("consumer", exist_ok=True)
+    os.chdir("consumer")
+    
+    with open("conanfile.txt", "w") as f:
+        f.write("""
+[requires]
+hello/1.0
+
+[generators]
+CMakeDeps
+""")
+
+    # Install dependencies
+    os.system("conan install . --build=missing")
+    
+    # Check the target file
+    target_files = [f for f in os.listdir(".") if f.startswith("hello-Target-")]
+    if target_files:
+        target_file = target_files[0]
+        print(f"Found target file: {target_file}")
+        
+        with open(target_file, "r") as f:
+            content = f.read()
+        
+        # Print the entire file
+        print("\nTarget file content:")
+        print("=" * 80)
+        print(content)
+        print("=" * 80)
+        
+        # Find all occurrences of INTERFACE_LINK_DIRECTORIES
+        print("\nLines containing INTERFACE_LINK_DIRECTORIES:")
+        lines = content.split("\n")
+        for i, line in enumerate(lines):
+            if "INTERFACE_LINK_DIRECTORIES" in line:
+                print(f"Line {i+1}: {line}")
+                # Print some context
+                start = max(0, i-5)
+                end = min(len(lines), i+5)
+                print("Context:")
+                for j in range(start, end+1):
+                    if j == i:
+                        print(f">>> {lines[j]}")
+                    else:
+                        print(f"    {lines[j]}")
+                print()
+    else:
+        print("No target file found")
+
+finally:
+    # Clean up
+    shutil.rmtree(temp_dir)
+    print(f"Cleaned up temporary directory: {temp_dir}")
