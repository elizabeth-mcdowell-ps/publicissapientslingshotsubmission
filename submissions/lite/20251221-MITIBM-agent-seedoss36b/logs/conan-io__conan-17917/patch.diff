diff --git a/fix_cmakedeps.py b/fix_cmakedeps.py
new file mode 100644
index 000000000..c057cd722
--- /dev/null
+++ b/fix_cmakedeps.py
@@ -0,0 +1,63 @@
+"""
+This script removes the cmake_set_interface_link_directories property from the CMakeDeps generator
+since it's not actually controlling anything in Conan 2.
+"""
+
+import os
+
+# Path to the file that needs to be modified
+cmakedeps_path = "/testbed/conan/tools/cmake/cmakedeps/cmakedeps.py"
+
+# Read the file
+with open(cmakedeps_path, "r") as f:
+    content = f.read()
+
+# Find the list of properties in the set_property method
+start_index = content.find("def set_property(self, dep, prop, value, build_context=False):")
+end_index = content.find("def get_property(self, prop, dep, comp_name=None, check_type=None):")
+
+if start_index != -1 and end_index != -1:
+    docstring_start = content.find('"""', start_index)
+    docstring_end = content.find('"""', docstring_start + 3) + 3
+    
+    docstring = content[docstring_start:docstring_end]
+    
+    # Remove the cmake_set_interface_link_directories from the docstring
+    new_docstring = docstring.replace(", `cmake_set_interface_link_directories`", "")
+    
+    # Replace the docstring
+    content = content[:docstring_start] + new_docstring + content[docstring_end:]
+    
+    # Write the modified content back to the file
+    with open(cmakedeps_path, "w") as f:
+        f.write(content)
+    
+    print(f"Successfully removed cmake_set_interface_link_directories from the docstring in {cmakedeps_path}")
+else:
+    print(f"Could not find the set_property method in {cmakedeps_path}")
+
+# Path to the target_configuration.py file
+target_config_path = "/testbed/conan/tools/cmake/cmakedeps/templates/target_configuration.py"
+
+# Read the file
+with open(target_config_path, "r") as f:
+    content = f.read()
+
+# Find the part where the property is used
+start_index = content.find("        auto_link = self.cmakedeps.get_property(\"cmake_set_interface_link_directories\",")
+if start_index != -1:
+    line_end = content.find("\n", start_index)
+    next_line_end = content.find("\n", line_end + 1)
+    
+    # Replace the line that gets the property with a line that always sets auto_link to True
+    content = content[:start_index] + "        auto_link = True" + content[next_line_end:]
+    
+    # Write the modified content back to the file
+    with open(target_config_path, "w") as f:
+        f.write(content)
+    
+    print(f"Successfully modified the auto_link property in {target_config_path}")
+else:
+    print(f"Could not find the auto_link property in {target_config_path}")
+
+print("Fix completed. The cmake_set_interface_link_directories property has been removed from the documentation and is no longer used in the code.")
