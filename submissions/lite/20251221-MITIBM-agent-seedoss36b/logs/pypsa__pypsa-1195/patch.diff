+#!/usr/bin/env python3
+
+import pypsa
+import pandas as pd
+import numpy as np
+
+# Create a simple network
+n = pypsa.Network()
+
+# Add a bus
+n.add("Bus", "bus0")
+
+# Add a generator with start-up and shut-down costs
+n.add("Generator", "gen0", 
+      bus="bus0", 
+      p_nom=100, 
+      marginal_cost=10,
+      p_min_pu=0.1,
+      committable=True,
+      start_up_cost=1000,
+      shut_down_cost=500)
+
+# Add a generator with quadratic marginal costs
+n.add("Generator", "gen1", 
+      bus="bus0", 
+      p_nom=100, 
+      marginal_cost=20,
+      marginal_cost_quadratic=0.01)
+
+# Add a load
+n.add("Load", "load0", bus="bus0", p_set=80)
+
+# Create snapshots
+n.set_snapshots(range(4))
+
+# Set load values
+n.loads_t.p_set = pd.DataFrame(
+    {"load0": [50, 80, 100, 50]},
+    index=n.snapshots
+)
+
+# Optimize the network
+n.optimize(solver_name="glpk")
+
+# Print the total system costs
+print("\nTotal system costs:")
+print(f"OPEX: {n.statistics.opex().sum()}")
+print(f"CAPEX: {n.statistics.capex().sum()}")
+print(f"Total: {n.statistics.opex().sum() + n.statistics.capex().sum()}")
+
+# Print the objective value
+print(f"\nObjective value: {n.objective}")
+
+# Print the start-up and shut-down costs
+print("\nStart-up and shut-down events:")
+print(n.generators_t.status.loc[:, "gen0"])
+print(n.generators_t.start_up.loc[:, "gen0"])
+print(n.generators_t.shut_down.loc[:, "gen0"])
+
+# Print the generator dispatch
+print("\nGenerator dispatch:")
+print(n.generators_t.p.loc[:, ["gen0", "gen1"]])
+
+# Calculate the expected total costs manually
+marginal_costs = (n.generators_t.p.loc[:, "gen0"] * n.generators.marginal_cost["gen0"]).sum()
+quadratic_costs = (n.generators_t.p.loc[:, "gen1"]**2 * n.generators.marginal_cost_quadratic["gen1"]).sum()
+start_up_costs = (n.generators_t.start_up.loc[:, "gen0"] * n.generators.start_up_cost["gen0"]).sum()
+shut_down_costs = (n.generators_t.shut_down.loc[:, "gen0"] * n.generators.shut_down_cost["gen0"]).sum()
+
+print("\nManual cost calculation:")
+print(f"Marginal costs: {marginal_costs}")
+print(f"Quadratic costs: {quadratic_costs}")
+print(f"Start-up costs: {start_up_costs}")
+print(f"Shut-down costs: {shut_down_costs}")
+print(f"Total manual costs: {marginal_costs + quadratic_costs + start_up_costs + shut_down_costs}")
