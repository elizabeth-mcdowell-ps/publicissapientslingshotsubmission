+#!/usr/bin/env python3
+import os
+import sys
+import codecs
+import yaml
+import logging
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, '/testbed')
+
+# Configure logging
+logging.basicConfig(level=logging.DEBUG)
+logger = logging.getLogger('lastgenre')
+
+# Import the plugin directly to test our fix
+from beetsplug.lastgenre import LastGenrePlugin
+from unittest.mock import Mock
+
+# Initialize the plugin
+plugin = LastGenrePlugin()
+
+# Create a mock for pylast.Tag
+class MockTag:
+    def __init__(self, name, weight):
+        self.item = Mock()
+        self.item.get_name = lambda: name
+        self.weight = weight
+
+# Test the _tags_for method directly with mock data
+def test_with_tags(tags):
+    # Create a mock object with get_top_tags method
+    mock_obj = Mock()
+    mock_obj.get_top_tags = lambda: tags
+    
+    # Call the _tags_for method
+    result = plugin._tags_for(mock_obj)
+    return result
+
+# Test the _resolve_genres method with our fix
+def test_genre_resolution(tag_names):
+    print(f"Input tags: {tag_names}")
+    
+    # Call the _resolve_genres method
+    result = plugin._resolve_genres(tag_names)
+    
+    print(f"Resolved genres: {result}")
+    print("-" * 50)
+    return result
+
+# Test cases
+print("Case 1: Children's music with lower weight than metal")
+tags = test_with_tags([MockTag("Grindcore", 50), MockTag("Children's Music", 30)])
+print(f"Tags returned from _tags_for: {tags}")
+test_genre_resolution(tags)
+
+print("Case 2: Children's music with higher weight than metal")
+tags = test_with_tags([MockTag("Children's Music", 60), MockTag("Grindcore", 50)])
+print(f"Tags returned from _tags_for: {tags}")
+test_genre_resolution(tags)
+
+print("Case 3: Only children's music")
+tags = test_with_tags([MockTag("Children's Music", 60)])
+print(f"Tags returned from _tags_for: {tags}")
+test_genre_resolution(tags)
+
+print("Case 4: Only metal")
+tags = test_with_tags([MockTag("Grindcore", 50)])
+print(f"Tags returned from _tags_for: {tags}")
+test_genre_resolution(tags)
+
+print("Case 5: Children's music with melodic death metal")
