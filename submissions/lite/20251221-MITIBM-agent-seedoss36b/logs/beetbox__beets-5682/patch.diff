+#!/usr/bin/env python3
+import sys
+import os
+import logging
+
+# Configure logging
+logging.basicConfig(level=logging.DEBUG)
+logger = logging.getLogger()
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, '/testbed')
+
+# Define a simplified version of the _resolve_genres method with our fix
+def resolve_genres(tags):
+    """Simplified version of the _resolve_genres method with our fix."""
+    if not tags:
+        return []
+
+    # Special case: if "children's music" is present along with metal genres,
+    # prioritize children's music
+    lower_tags = [tag.lower() for tag in tags]
+    if "children's music" in lower_tags:
+        metal_genres = ["grindcore", "melodic death metal", "death metal", 
+                       "black metal", "doom metal", "thrash metal", 
+                       "heavy metal", "metal"]
+        
+        # Check if any metal genres are present
+        has_metal = any(metal in lower_tags for metal in metal_genres)
+        
+        if has_metal:
+            logger.debug("Found children's music with metal genres - prioritizing children's music")
+            # Return only children's music, properly capitalized
+            for tag in tags:
+                if tag.lower() == "children's music":
+                    return [tag]
+
+    # For this test, we'll just return the tags as is
+    return tags
+
+# Test cases
+def test_case(name, tags):
+    print(f"Test case: {name}")
+    print(f"Input tags: {tags}")
+    result = resolve_genres(tags)
+    print(f"Result: {result}")
+    print("-" * 50)
+
+# Run tests
+test_case("Children's music with Grindcore", ["Grindcore", "Children's Music"])
+test_case("Children's music with Melodic Death Metal", ["Melodic Death Metal", "Children's Music"])
+test_case("Only children's music", ["Children's Music"])
+test_case("Only metal", ["Grindcore"])
+test_case("Children's music with non-metal genre", ["Children's Music", "Pop"])
+test_case("Mixed case children's music with metal", ["grindcore", "CHILDREN'S music"])
