+#!/usr/bin/env python3
+import sys
+import os
+import logging
+from unittest.mock import Mock, patch
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, '/testbed')
+
+from beetsplug.lastgenre import LastGenrePlugin, LASTFM
+from beets import config
+from beets.library import Item
+
+# Configure logging
+logging.basicConfig(level=logging.DEBUG)
+logger = logging.getLogger('lastgenre')
+
+# Create a mock item for children's music
+def create_mock_item(title, artist="Various Artists", album=""):
+    return Item({
+        'title': title,
+        'artist': artist,
+        'albumartist': artist,
+        'album': album,
+        'genre': '',  # Empty genre
+    })
+
+# Create a mock for pylast.Album to simulate the issue
+class MockPylastTag:
+    def __init__(self, name, weight):
+        self.item = Mock()
+        self.item.get_name = lambda: name
+        self.weight = weight
+
+class MockPylastAlbum:
+    def __init__(self, tags):
+        self.tags = tags
+        
+    def get_top_tags(self):
+        return self.tags
+
+# Mock the LASTFM.get_album method to return our mock album
+def mock_get_album(artist, album_name):
+    print(f"Getting album for {artist} - {album_name}")
+    
+    # Simulate the issue where children's albums get metal tags
+    if "Kinderlieder" in album_name:
+        if "Volume 02" in album_name:
+            # This simulates the first album getting Grindcore
+            return MockPylastAlbum([
+                MockPylastTag("Grindcore", 50),
+                MockPylastTag("Children's Music", 30)  # Lower weight
+            ])
+        else:
+            # This simulates the second album getting Melodic Death Metal
+            return MockPylastAlbum([
+                MockPylastTag("Melodic Death Metal", 50),
+                MockPylastTag("Children's Music", 30)  # Lower weight
+            ])
+    
+    return MockPylastAlbum([])
+
+# Initialize the plugin
+plugin = LastGenrePlugin()
+
+# Test with children's music albums
+albums = [
+    create_mock_item("Children's Song", album="Best of Kinderlieder, Volume 02"),
+    create_mock_item("Children's Song", album="Die 50 schönsten Kinderlieder")
+]
+
+# Patch the LASTFM.get_album method
+with patch('beetsplug.lastgenre.LASTFM.get_album', side_effect=mock_get_album):
+    # Process each album
+    for album in albums:
+        # Get the genre
+        genre, source = plugin._get_genre(album)
+        print(f"Album: {album['album']}")
+        print(f"Genre: {genre}")
+        print(f"Source: {source}")
+        print("-" * 50)
