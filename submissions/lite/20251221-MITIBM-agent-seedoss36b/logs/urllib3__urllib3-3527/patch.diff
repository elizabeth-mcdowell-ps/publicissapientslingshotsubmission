+                # Shutdown the socket to interrupt any blocked read operations
+                try:
+                    sock.shutdown(socket.SHUT_RDWR)
+                except (OSError, socket.error):
+                    # Socket might already be closed or disconnected
+                    pass
+                
+                # Close the socket
+                sock.close()
+            except (OSError, socket.error):
+                # Handle any errors during socket closure
+                pass
