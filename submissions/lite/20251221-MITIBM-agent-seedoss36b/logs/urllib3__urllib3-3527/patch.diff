+            import struct
+            
+            # Save a reference to the socket and clear it from the connection
+            # to prevent further use
+            self._connection.sock = None
+            
+            try:
+                # Set SO_LINGER to force abortive close (sends RST)
+                # This will cause any blocked read operations to fail immediately
+                l_onoff = 1
+                l_linger = 0
+                sock.setsockopt(socket.SOL_SOCKET, socket.SO_LINGER, 
+                               struct.pack('ii', l_onoff, l_linger))
