+import threading
+import time
+import http.server
+import socketserver
+import urllib3
+import logging
+
+# Set up logging
+logging.basicConfig(level=logging.INFO, format='%(threadName)s [%(thread)d] %(message)s')
+logger = logging.getLogger(__name__)
+
+# Global flag to control server
+server_running = True
+# Global response object to be shared between threads
+shared_response = None
+# Event to signal when response is ready
+response_ready = threading.Event()
+
+class SlowChunkedHandler(http.server.BaseHTTPRequestHandler):
+    def do_GET(self):
+        self.send_response(200)
+        self.send_header('Content-Type', 'text/plain')
+        self.send_header('Transfer-Encoding', 'chunked')
+        self.end_headers()
+        
+        # Send first chunk
+        logger.info("starting stream")
+        self.wfile.write(b"a\r\n")  # 10 bytes in hex
+        self.wfile.write(b"0123456789\r\n")
+        self.wfile.flush()
+        logger.info("wrote 10 bytes")
+        
+        # Wait indefinitely - simulating a slow server
+        while server_running:
+            time.sleep(0.1)
+
+def run_server():
+    # Allow socket address reuse
+    socketserver.TCPServer.allow_reuse_address = True
+    with socketserver.TCPServer(("localhost", 9999), SlowChunkedHandler) as httpd:
+        logger.info("listening on port 9999")
+        httpd.serve_forever()
+
+def client_thread():
+    global shared_response
+    
+    logger.info("opening connection")
+    http = urllib3.PoolManager()
+    shared_response = http.request(
+        "GET",
+        "http://localhost:8888/",
+        preload_content=False,
+    )
+    
+    # Signal that response is ready
+    response_ready.set()
+    
+    # Read first chunk
+    logger.info("reading data")
+    data = shared_response.read(10)
+    logger.info(f"read 10 bytes")
+    
+    # Now we're blocked waiting for more data
+    logger.info("waiting for more data...")
+    try:
+        data = shared_response.read()
+        logger.info(f"read more data: {data!r}")
+    except Exception as e:
+        logger.info(f"failed: {e}")
+    
+    logger.info("no longer reading")
+
+def main():
+    global server_running
+    
+    # Start server in a daemon thread
+    logger.info("starting server")
+    server_thread = threading.Thread(target=run_server, name="server", daemon=True)
+    server_thread.start()
+    
+    # Give server time to start
+    time.sleep(1)
+    
+    # Start client in another thread
+    logger.info("starting client")
+    client = threading.Thread(target=client_thread, name="client")
+    client.start()
+    
+    # Wait for response to be created
+    response_ready.wait()
+    
+    # Wait a bit for client to start reading
+    logger.info("sleeping a while")
+    time.sleep(2)
+    
+    # Try to close the response from main thread
+    logger.info("about to close response")
+    shared_response.close()
+    logger.info("closed response")
+    
+    # Wait for client to finish
+    client.join(timeout=5)
+    if client.is_alive():
+        logger.info("client thread is still running after timeout!")
+    else:
+        logger.info("client thread has exited")
+    
+    # Clean up
+    server_running = False
+    logger.info("about to clear connection pool")
+    shared_response.connection_pool.clear()
+    logger.info("cleared connection pool")
+    logger.info("exiting")
+
+if __name__ == "__main__":
+    main()
