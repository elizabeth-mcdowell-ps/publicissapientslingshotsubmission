+        """
+        Close this response and release the associated connection.
+        
+        This method ensures that the socket is closed even if another thread
+        is blocked on a read operation.
+        """
+        # First, check if we have a socket to close directly
+        sock = None
+        if self._connection and hasattr(self._connection, "sock"):
+            sock = self._connection.sock
+        
+        # If we have a socket, forcibly close it to interrupt any blocked operations
+        if sock:
