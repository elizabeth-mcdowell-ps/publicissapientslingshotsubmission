@@ -0,0 +1,48 @@
+"""
+Test script to verify the send_event method in SessionClient.
+"""
+from llama_deploy import LlamaDeployClient, ControlPlaneConfig
+from llama_index.core.workflow import Event
+
+class TestEvent(Event):
+    message: str
+    value: int
+
+def main():
+    # Create a client and session
+    client = LlamaDeployClient(ControlPlaneConfig(), timeout=10)
+    
+    # List available services
+    services = client.list_services()
+    print(f"Available services: {[s.service_name for s in services]}")
+    
+    if not services:
+        print("No services available. Please make sure the control plane is running with services registered.")
+        return
+    
+    # Create a session
+    session = client.create_session()
+    print(f"Created session with ID: {session.session_id}")
+    
+    # Use the first available service
+    service_name = services[0].service_name
+    print(f"Using service: {service_name}")
+    
+    # Start a task
+    task_id = session.run_nowait(service_name, arg1="test_value")
+    print(f"Started task with ID: {task_id}")
+    
+    # Send an event
+    event = TestEvent(message="Hello from client", value=42)
+    try:
+        session.send_event(event)
+        print("Successfully sent event!")
+    except Exception as e:
+        print(f"Error sending event: {e}")
+    
+    # Clean up
+    client.delete_session(session.session_id)
+    print("Session deleted")
+
+if __name__ == "__main__":
+    main()
