+    async def send_event(self, event: Event) -> None:
+        """Send an event to the current task's stream.
+        
+        This is equivalent to ctx.write_event_to_stream(event) in a workflow step.
+        
+        Args:
+            event (Event): The event to send to the stream.
+            
+        Raises:
+            ValueError: If there is no current task in the session.
+        """
+        # Get the current task
+        current_task = await self.get_current_task()
+        if current_task is None:
+            raise ValueError("No current task in session to send event to")
+            
+        task_id = current_task.task_id
+        
+        # Create a TaskStream object
+        task_stream = TaskStream(
+            task_id=task_id,
+            session_id=self.session_id,
+            data=event.model_dump(),
+            index=0  # The server will handle the actual indexing
+        )
+        
+        # Send the event to the control plane
+        async with httpx.AsyncClient(timeout=self.timeout) as client:
+            response = await client.post(
+                f"{self.control_plane_url}/sessions/{self.session_id}/tasks/{task_id}/stream",
+                json=task_stream.model_dump(),
+            )
+            response.raise_for_status()
 
