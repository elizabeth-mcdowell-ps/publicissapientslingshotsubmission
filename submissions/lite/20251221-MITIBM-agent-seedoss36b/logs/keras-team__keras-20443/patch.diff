diff --git a/keras/src/utils/traceback_utils.py b/keras/src/utils/traceback_utils.py
index 88c3e9ac0..e0db0bb98 100644
--- a/keras/src/utils/traceback_utils.py
+++ b/keras/src/utils/traceback_utils.py
@@ -234,8 +234,43 @@ def format_argument_value(value):
         else:
             tensor_cls = "array"
 
-        return (
-            f"{tensor_cls}(shape={value.shape}, "
-            f"dtype={backend.standardize_dtype(value.dtype)})"
-        )
-    return repr(value)
+        try:
+            # Use ASCII-compatible representation to avoid encoding issues
+            shape_str = str(value.shape)
+            dtype_str = str(backend.standardize_dtype(value.dtype))
+            return f"{tensor_cls}(shape={shape_str}, dtype={dtype_str})"
+        except UnicodeEncodeError:
+            # Fallback to a simpler representation if encoding issues occur
+            return f"{tensor_cls}(shape=..., dtype=...)"
+    
+    # For non-tensor values, we need to handle potential encoding issues
+    try:
+        # First try the standard repr
+        result = repr(value)
+        
+        # Test if the result can be encoded with a restrictive encoding
+        # This simulates what would happen on Windows with 'charmap' codec
+        try:
+            # Try encoding with ASCII - if this works, it will work everywhere
+            result.encode('ascii', errors='strict')
+            return result
+        except UnicodeEncodeError:
+            # If it contains non-ASCII characters, we need a different approach
+            if isinstance(value, (str, bytes)):
+                # For string types, truncate and indicate there are special chars
+                if len(value) > 20:
+                    return f"'{value[:17]}...' (contains special characters)"
+                else:
+                    return f"'{value}' (contains special characters)"
+            elif isinstance(value, (list, tuple)):
+                # For sequences, return type and length
+                return f"{type(value).__name__}(length={len(value)}, contains special characters)"
+            elif isinstance(value, dict):
+                # For dictionaries, return type and size
+                return f"{type(value).__name__}(size={len(value)}, contains special characters)"
+            else:
+                # For other types, just return the type name
+                return f"{type(value).__name__}(contains special characters)"
+    except Exception:
+        # Last resort fallback
+        return str(type(value).__name__)
