new file mode 100644
index 00000000..0ca03acc
--- /dev/null
+++ b/torchtune/rlhf/compiled_trajectory.py
@@ -0,0 +1,223 @@
+# Copyright (c) Meta Platforms, Inc. and affiliates.
+# All rights reserved.
+#
+# This source code is licensed under the BSD-style license found in the
+# LICENSE file in the root directory of this source tree.
+
+import torch
+from torchtune import rlhf, generation, training
+from torchtune.rlhf import Trajectory
+from typing import List, Optional, Tuple
+
+
+def process_trajectory(
+    policy_model: torch.nn.Module,
+    ref_policy_model: torch.nn.Module,
+    value_model: torch.nn.Module,
+    reward_model: torch.nn.Module,
+    query_responses: torch.Tensor,
+    logits: torch.Tensor,
+    context_length: int,
+    max_generated_tokens: int,
+    temperature: float,
+    stop_token_ids: torch.Tensor,
+    tokenizer_pad_id: int,
+    penalise_no_eos: bool = False,
+    min_response_length: int = 0,
+    reward_penalty: float = -1.0,
+) -> Trajectory:
+    """
+    Process a trajectory after generation. This function handles steps 2-6 of trajectory generation:
+    
+    2. Estimate logprobs of the generated responses using the current policy.
+    3. Estimate values from the generated responses using the current value function.
+    4. Replace any tokens in the response after the first stop token (usually EOS token) with padding,
+        producing truncated responses.
+    5. Run the reward model on the (query, truncated-response) pairs.
+    6. Mask out all the invalid values in the trajectory due to padding tokens.
+    
+    Args:
+        policy_model: The policy model
+        ref_policy_model: The reference policy model
+        value_model: The value model
+        reward_model: The reward model
+        query_responses: The generated query responses tensor
+        logits: The logits from generation
+        context_length: The length of the context
+        max_generated_tokens: Maximum number of tokens to generate
+        temperature: Temperature for sampling
+        stop_token_ids: List of stop token IDs
+        tokenizer_pad_id: Padding token ID
+        penalise_no_eos: Whether to penalize sequences without EOS tokens
+        min_response_length: Minimum response length
+        reward_penalty: Penalty for sequences without EOS tokens
+        
+    Returns:
+        Trajectory: A trajectory object containing all the processed data
+    """
+    batch_size = query_responses.shape[0]
+    responses = query_responses[:, context_length:].clone()
+    query_response_padding_masks = query_responses != tokenizer_pad_id
+
+    # Create attention masks and position IDs for any padding tokens in inputs
+    masks = generation.get_causal_mask_from_padding_mask(
+        query_response_padding_masks
+    )
+    position_ids = generation.get_position_ids_from_padding_mask(
+        query_response_padding_masks
+    )
+
+    # Estimate logprobs of the responses using the current policy
+    logits = logits[:, context_length - 1:]
+    logprobs = rlhf.logits_to_logprobs(logits, responses, temperature)
+
+    # Estimate logprobs of the responses using the reference policy
+    ref_logits = ref_policy_model(
+        query_responses, input_pos=position_ids, mask=masks
+    )
+    ref_logits = rlhf.truncate_sequence_for_logprobs(ref_logits, context_length)
+    ref_logprobs = rlhf.logits_to_logprobs(ref_logits, responses, temperature)
+
+    # Estimate values from the responses using the value function
+    values = value_model(query_responses, input_pos=position_ids, mask=masks)
+    values = rlhf.truncate_sequence_for_logprobs(values, context_length).squeeze(-1)
+
+    # Replace any tokens in the responses after the first stop token with padding
+    response_padding_masks, responses = rlhf.truncate_sequence_at_first_stop_token(
+        responses, stop_token_ids, tokenizer_pad_id
+    )
+
+    # Run the reward model on the (query, truncated-response) pairs
+    scores = reward_model(
+        torch.cat([query_responses[:, :context_length], responses], dim=1),
+        input_pos=position_ids,
+        mask=masks,
+    )
+
+    # The scores from the reward model are the logits for the last non-padding token
+    seq_lens = training.get_unmasked_sequence_lengths(response_padding_masks)
+    scores = scores[torch.arange(batch_size), seq_lens + context_length].squeeze(-1)
+
+    # Apply penalties for sequences without EOS tokens or shorter than a certain length
+    if penalise_no_eos or min_response_length:
+        reward_penalty_mask = rlhf.get_reward_penalty_mask(
+            response_padding_masks,
+            seq_lens,
+            penalise_no_eos,
+            min_response_length,
+        )
+        scores[reward_penalty_mask] = reward_penalty
+
+    # Mask out all the invalid values in the trajectory due to padding tokens
+    logprobs[response_padding_masks] = 1.0
+    ref_logprobs[response_padding_masks] = 1.0
+
+    # Values are masked out *after* the last valid token in the response
+    value_seq_idxs = torch.where(
+        (seq_lens > 0) & (seq_lens < max_generated_tokens - 1),
+        seq_lens + 1,
+        seq_lens,
+    )
+    value_padding_masks = response_padding_masks.clone()
+    value_padding_masks[
+        torch.arange(batch_size, device=value_padding_masks.device),
+        value_seq_idxs,
+    ] = False
+
+    values[value_padding_masks] = 0.0
+
+    return Trajectory(
+        query_responses=query_responses,
+        logprobs=logprobs,
+        ref_logprobs=ref_logprobs,
+        values=values,
+        masks=masks,
+        position_ids=position_ids,
+        response_padding_masks=response_padding_masks,
+        value_padding_masks=value_padding_masks,
+        value_seq_idxs=value_seq_idxs,
+        scores=scores,
+        seq_lens=seq_lens,
+    )
+
+
+def ppo_loss_step(
+    policy_model: torch.nn.Module,
+    value_model: torch.nn.Module,
+    loss_fn: torch.nn.Module,
+    trajectory: Trajectory,
+    advantages: torch.Tensor,
+    returns: torch.Tensor,
+    context_length: int,
+    temperature: float,
+    gradient_accumulation_steps: int,
+) -> rlhf.PPOStats:
+    """
+    Perform a single PPO optimization step over a batch of trajectories.
+    
+    Args:
+        policy_model: The policy model
+        value_model: The value model
+        loss_fn: The PPO loss function
+        trajectory: A batch of trajectories
+        advantages: Advantages corresponding to the trajectories
+        returns: Returns corresponding to the trajectories
+        context_length: Input ids sequence length
+        temperature: Temperature for sampling
+        gradient_accumulation_steps: Number of gradient accumulation steps
+        
+    Returns:
+        PPOStats: Statistics from the PPO step
+    """
+    # Estimate logprobs from the policy at the current optimization step
+    pi_logits = policy_model(
+        trajectory.query_responses,
+        input_pos=trajectory.position_ids,
+        mask=trajectory.masks,
+    )
+    pi_logits = rlhf.truncate_sequence_for_logprobs(pi_logits, context_length)
+    pi_logprobs = rlhf.logits_to_logprobs(
+        pi_logits, trajectory.query_responses[:, context_length:], temperature
+    )
+    pi_logprobs[trajectory.response_padding_masks] = 1.0
+
+    # Estimate the values from the value function at the current optimization step
+    phi_values = value_model(
+        trajectory.query_responses,
+        input_pos=trajectory.position_ids,
+        mask=trajectory.masks,
+    )
+
+    phi_values = rlhf.truncate_sequence_for_logprobs(
+        phi_values, context_length
+    ).squeeze(-1)
+    phi_values[trajectory.value_padding_masks] = 0.0
+
+    # Calculate PPO loss
+    loss, policy_loss, value_loss, ratios, clipfrac = loss_fn(
+        trajectory.logprobs,
+        pi_logprobs,
+        advantages,
+        trajectory.values,
+        phi_values,
+        returns,
+        padding_masks=~trajectory.response_padding_masks,
+        value_padding_masks=~trajectory.value_padding_masks,
+    )
+
+    loss /= gradient_accumulation_steps
+    loss.backward()
+
+    with torch.no_grad():
+        approx_policy_kls = (
+            0.5 * (pi_logprobs - trajectory.logprobs).pow(2)
+        ).mean()
+
+    return rlhf.PPOStats(
+        loss,
+        policy_loss / gradient_accumulation_steps,
+        value_loss / gradient_accumulation_steps,
+        ratios / gradient_accumulation_steps,
+        clipfrac / gradient_accumulation_steps,
+        approx_policy_kls / gradient_accumulation_steps,
+    )
