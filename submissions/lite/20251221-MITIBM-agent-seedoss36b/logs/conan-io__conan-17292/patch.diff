+from conan.tools.microsoft.msbuild import MSBuild
+from unittest.mock import MagicMock
+
+# Mock a conanfile
+conanfile = MagicMock()
+conanfile.settings.get_safe.return_value = "x86_64"
+
+# Test case 1: With a specific CPU count
+conanfile.conf.get.side_effect = lambda key, **kwargs: 2 if key == "tools.microsoft.msbuild:max_cpu_count" else None
+msbuild = MSBuild(conanfile)
+cmd = msbuild.command("test.sln")
+print("Test case 1 (specific CPU count):")
+print(cmd)
+print()
+
+# Test case 2: Without max_cpu_count set
+conanfile.conf.get.side_effect = lambda key, **kwargs: None
+msbuild = MSBuild(conanfile)
+cmd = msbuild.command("test.sln")
+print("Test case 2 (no max_cpu_count):")
+print(cmd)
+print()
+
+# Test case 3: Use all CPUs with True value
+conanfile.conf.get.side_effect = lambda key, **kwargs: True if key == "tools.microsoft.msbuild:max_cpu_count" else None
+msbuild = MSBuild(conanfile)
+cmd = msbuild.command("test.sln")
+print("Test case 3 (use all CPUs - new behavior):")
+print(cmd)
+print()
