+import json
+import tempfile
+import os
+import subprocess
+
+# Create a temporary OpenAPI schema file
+schema = {
+    "openapi": "3.0.0",
+    "info": {
+      "title": "Test API",
+      "version": "1.0.0"
+    },
+    "paths": {},
+    "components": {
+      "schemas": {
+        "Authority": {
+          "type": "integer",
+          "enum": [1000, 100, 10, 0],
+          "title": "Authority",
+          "description": "example"
+        },
+        "Referrer": {
+                "properties": {
+                    "permission": {
+                        "$ref": "#/components/schemas/Authority",
+                        "description": "The permission that the principals will be granted. ",
+                        "default": 0
+                    }
+                },
+                "additionalProperties": False,
+                "type": "object",
+                "title": "Referrer",
+                "description": "example"
+            }
+      }
+    }
+}
+
+# Create temporary files
+with tempfile.NamedTemporaryFile(suffix='.json', delete=False) as schema_file:
+    schema_file.write(json.dumps(schema).encode('utf-8'))
+    schema_path = schema_file.name
+
+with tempfile.NamedTemporaryFile(suffix='.py', delete=False) as output_file:
+    output_path = output_file.name
+
+# Run the code generator
+cmd = [
+    "python", "-m", "datamodel_code_generator",
+    "--input", schema_path,
+    "--output", output_path,
+    "--field-constraints",
+    "--output-model-type", "pydantic_v2.BaseModel",
+    "--set-default-enum-member"
+]
+
+print(f"Running command: {' '.join(cmd)}")
+result = subprocess.run(cmd, capture_output=True, text=True)
+
+print("\nCommand output:")
+print(result.stdout)
+if result.stderr:
+    print("Errors:")
+    print(result.stderr)
+
+# Print the generated code
+print("\nGenerated code:")
+with open(output_path, 'r') as f:
+    print(f.read())
+
+# Clean up temporary files
+os.unlink(schema_path)
+os.unlink(output_path)
\ No newline at end of file
