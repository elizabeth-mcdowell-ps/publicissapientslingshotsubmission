index 00000000..f9f4f3ae
--- /dev/null
+++ b/modified_walrus_visitor.py
@@ -0,0 +1,36 @@
+import ast
+
+def is_inside_comprehension(node: ast.AST) -> bool:
+    """Check if a node is inside a comprehension or generator expression."""
+    parent = getattr(node, 'parent', None)
+    while parent is not None:
+        if isinstance(parent, (
+            ast.ListComp,
+            ast.SetComp,
+            ast.DictComp,
+            ast.GeneratorExp,
+        )):
+            return True
+        parent = getattr(parent, 'parent', None)
+    return False
+
+# Test with a simple AST
+code = "[user for user_id in user_ids if (user := get_user(user_id)) is not None]"
+tree = ast.parse(code)
+
+# Add parent references to all nodes
+for parent in ast.walk(tree):
+    for child in ast.iter_child_nodes(parent):
+        child.parent = parent
+
+# Find the NamedExpr node
+named_expr = None
+for node in ast.walk(tree):
+    if isinstance(node, ast.NamedExpr):
+        named_expr = node
+        break
+
+if named_expr:
+    print(f"Is inside comprehension: {is_inside_comprehension(named_expr)}")
+else:
+    print("No NamedExpr found")
