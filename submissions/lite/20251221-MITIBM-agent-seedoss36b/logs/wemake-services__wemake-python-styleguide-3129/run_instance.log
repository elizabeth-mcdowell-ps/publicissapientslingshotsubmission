diff --git a/wemake_python_styleguide/violations/consistency.py b/wemake_python_styleguide/violations/consistency.py
index 275e2820..617bbea5 100644
--- a/wemake_python_styleguide/violations/consistency.py
+++ b/wemake_python_styleguide/violations/consistency.py
@@ -1403,16 +1403,20 @@ class InconsistentReturnVariableViolation(ASTViolation):
 @final
 class WalrusViolation(ASTViolation):
     """
-    Forbid walrus operator.
+    Forbid walrus operator except in comprehensions.
 
     Reasoning:
         Code with ``:=`` is hardly readable.
         It has big problems with scoping and reading order.
         And it can lead to a huge mess inside your code.
         Python is not expression-based.
+        
+        However, in comprehensions and generator expressions, the walrus operator
+        can be useful and improve readability.
 
     Solution:
         Don't use fancy stuff, use good old assignments.
+        Only use walrus operator in comprehensions and generator expressions.
 
     Example::
 
@@ -1420,16 +1424,21 @@ class WalrusViolation(ASTViolation):
         some = call()
         if some:
             print(some)
+            
+        # Also correct:
+        users = [user for user_id in user_ids if (user := get_user(user_id)) is not None]
 
         # Wrong:
         if some := call():
             print(some)
 
     .. versionadded:: 0.14.0
+    .. versionchanged:: 0.19.2
+       Now allows walrus operator in comprehensions and generator expressions.
 
     """
 
-    error_template = 'Found walrus operator'
+    error_template = 'Found walrus operator outside of comprehension'
     code = 332
 
 
diff --git a/wemake_python_styleguide/visitors/ast/operators.py b/wemake_python_styleguide/visitors/ast/operators.py
index af12dac0..1ac80876 100644
--- a/wemake_python_styleguide/visitors/ast/operators.py
+++ b/wemake_python_styleguide/visitors/ast/operators.py
@@ -221,12 +221,35 @@ class WrongMathOperatorVisitor(base.BaseNodeVisitor):
 
 @final
 class WalrusVisitor(base.BaseNodeVisitor):
-    """We use this visitor to find walrus operators and ban them."""
+    """
+    We use this visitor to find walrus operators and ban them.
+    
+    Except when used in comprehensions or generator expressions.
+    """
 
     def visit_NamedExpr(
         self,
         node: ast.NamedExpr,
     ) -> None:
-        """Disallows walrus ``:=`` operator."""
-        self.add_violation(consistency.WalrusViolation(node))
+        """
+        Disallows walrus ``:=`` operator.
+        
+        Except when used in comprehensions or generator expressions.
+        """
+        if not self._is_inside_comprehension(node):
+            self.add_violation(consistency.WalrusViolation(node))
         self.generic_visit(node)
+        
+    def _is_inside_comprehension(self, node: ast.AST) -> bool:
+        """Check if a node is inside a comprehension or generator expression."""
+        parent = getattr(node, 'parent', None)
+        while parent is not None:
+            if isinstance(parent, (
+                ast.ListComp,
+                ast.SetComp,
+                ast.DictComp,
+                ast.GeneratorExp,
+            )):
+                return True
+            parent = getattr(parent, 'parent', None)
+        return False
diff --git a/wemake_python_styleguide/visitors/base.py b/wemake_python_styleguide/visitors/base.py
index c777f44b..31758b2b 100644
--- a/wemake_python_styleguide/visitors/base.py
+++ b/wemake_python_styleguide/visitors/base.py
@@ -190,8 +190,16 @@ class BaseNodeVisitor(ast.NodeVisitor, BaseVisitor):
     @final
     def run(self) -> None:
         """Recursively visits all ``ast`` nodes. Then executes post hook."""
+        # Add parent references to all nodes
+        self._add_parent_refs(self.tree)
         self.visit(self.tree)
         self._post_visit()
+        
+    def _add_parent_refs(self, node: ast.AST) -> None:
+        """Add parent references to all nodes in the tree."""
+        for child in ast.iter_child_nodes(node):
+            child.parent = node  # type: ignore
+            self._add_parent_refs(child)
 
 
