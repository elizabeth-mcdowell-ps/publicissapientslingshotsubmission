@@ -0,0 +1,56 @@
+import os
+import textwrap
+import tempfile
+import shutil
+import sys
+from conan.api.conan_api import ConanAPI
+from conan.api.model import RecipeReference
+from conan.api.model.remote import LOCAL_RECIPES_INDEX
+
+# Create a temporary folder for our local-recipes-index
+repo_folder = tempfile.mkdtemp()
+print(f"Created temporary repo folder: {repo_folder}")
+
+# Create a simple recipe structure
+config_yml = textwrap.dedent("""\
+    versions:
+      "0.1":
+        folder: all
+    """)
+
+conanfile = textwrap.dedent("""\
+    from conan import ConanFile
+
+    class PkgRecipe(ConanFile):
+        name = "pkg"
+        version = "0.1"
+    """)
+
+# Create the directory structure
+os.makedirs(os.path.join(repo_folder, "recipes", "pkg", "all"), exist_ok=True)
+
+# Save the files
+with open(os.path.join(repo_folder, "recipes", "pkg", "config.yml"), "w") as f:
+    f.write(config_yml)
+
+with open(os.path.join(repo_folder, "recipes", "pkg", "all", "conanfile.py"), "w") as f:
+    f.write(conanfile)
+
+try:
+    # Add the local-recipes-index remote using CLI command
+    os.system(f'conan remote add local "{repo_folder}" --type=local-recipes-index')
+    
+    # Try to get a recipe with a specific revision using CLI
+    ref = "pkg/0.1#some_revision"
+    print(f"Trying to get recipe with revision: {ref}")
+    
+    # This should fail with a clear error message
+    result = os.system(f'conan download {ref} --remote=local')
+    if result != 0:
+        print(f"Command failed with exit code: {result}")
+    
+finally:
+    # Clean up
+    os.system('conan remote remove local')
+    shutil.rmtree(repo_folder)
+    print("Cleaned up temporary folder")
