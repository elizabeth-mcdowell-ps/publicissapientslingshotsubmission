+import asyncio
+import json
+import traceback
+from typing import Any, Sequence
+
+from mcp.types import TextContent, ImageContent, EmbeddedResource
+
+# Define a constant for the user_id argument
+USER_ID_ARG = "user_id"
+
+# Mock Gmail service class
+class GmailService:
+    def __init__(self, user_id: str):
+        self.user_id = user_id
+        
+    def query_emails(self, query: str, max_results: int = 100):
+        # Simulate returning some email data
+        return [
+            {"id": "1", "subject": "Test Email", "body": "This is a test email"},
+            {"id": "2", "subject": "Another Email", "body": "This is another test email"}
+        ]
+
+# Mock tool handler
+class ToolHandler:
+    def run_tool(self, args: dict) -> Sequence[TextContent | ImageContent | EmbeddedResource]:
+        user_id = args.get(USER_ID_ARG)
+        if not user_id:
+            raise RuntimeError(f"Missing required argument: {USER_ID_ARG}")
+
+        gmail_service = GmailService(user_id=user_id)
+        query = args.get('query')
+        max_results = args.get('max_results', 100)
+        emails = gmail_service.query_emails(query=query, max_results=max_results)
+
+        return [
+            TextContent(
+                type="text",
+                text=json.dumps(emails, indent=2)
+            )
+        ]
+
+# Mock tool handler registry
+def get_tool_handler(name: str) -> ToolHandler | None:
+    if name == "gmail":
+        return ToolHandler()
+    return None
+
+async def call_tool(name: str, arguments: Any) -> Sequence[TextContent | ImageContent | EmbeddedResource]:
+    """Handle tool calls for command line run."""
+    
+    if not isinstance(arguments, dict):
+        raise RuntimeError("arguments must be dictionary")
+    
+    if USER_ID_ARG not in arguments:
+        raise RuntimeError("user_id argument is missing in dictionary.")
+
+    # Simulate setup_oauth2
+    print(f"Setting up OAuth2 for user: {arguments.get(USER_ID_ARG, '')}")
+
+    tool_handler = get_tool_handler(name)
+    if not tool_handler:
+        raise ValueError(f"Unknown tool: {name}")
+
+    try:
+        return tool_handler.run_tool(arguments)
+    except Exception as e:
+        print(f"Error: {str(e)}")
+        # This is the problematic line - it re-raises the exception but loses the original traceback
+        raise RuntimeError(f"Caught Exception. Error: {str(e)}")
+
+# Fixed version of call_tool that preserves the original exception
+async def call_tool_fixed(name: str, arguments: Any) -> Sequence[TextContent | ImageContent | EmbeddedResource]:
+    """Handle tool calls for command line run with improved error handling."""
+    
+    if not isinstance(arguments, dict):
+        raise RuntimeError("arguments must be dictionary")
+    
+    if USER_ID_ARG not in arguments:
+        raise RuntimeError("user_id argument is missing in dictionary.")
+
+    # Simulate setup_oauth2
+    print(f"Setting up OAuth2 for user: {arguments.get(USER_ID_ARG, '')}")
+
+    tool_handler = get_tool_handler(name)
+    if not tool_handler:
+        raise ValueError(f"Unknown tool: {name}")
+
+    try:
+        return tool_handler.run_tool(arguments)
+    except Exception as e:
+        print(f"Error in fixed version: {str(e)}")
+        # Log the error but don't re-raise a new exception
+        print(f"Original exception traceback:")
+        traceback.print_exc()
+        # Re-raise the original exception
+        raise
+
+# Test function to reproduce the error
+async def test_error():
+    # Test case 1: Original implementation with missing user_id
+    print("Test case 1: Original implementation with missing user_id")
+    try:
+        result = await call_tool("gmail", {"query": "test"})
+        print(f"Success: {result}")
+    except Exception as e:
+        print(f"Caught exception: {type(e).__name__}: {e}")
+        print("Traceback:")
+        traceback.print_exc()
+    
+    print("\n" + "="*50 + "\n")
+    
+    # Test case 2: Fixed implementation with missing user_id
+    print("Test case 2: Fixed implementation with missing user_id")
+    try:
+        result = await call_tool_fixed("gmail", {"query": "test"})
+        print(f"Success: {result}")
+    except Exception as e:
+        print(f"Caught exception: {type(e).__name__}: {e}")
+        print("Traceback:")
+        traceback.print_exc()
+
+if __name__ == "__main__":
+    asyncio.run(test_error())
