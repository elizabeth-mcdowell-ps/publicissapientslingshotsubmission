+import numpy as np
+import pyarrow as pa
+import shapely
+from shapely import box
+
+print("Testing from_ragged_array with sliced input")
+print("===========================================")
+
+# Create a more complex example with multiple polygons
+polygon1 = box(0, 0, 5, 5)
+polygon2 = box(5, 5, 10, 10)
+polygon3 = box(10, 10, 15, 15)
+polygon_arr = np.array([polygon1, polygon2, polygon3])
+
+print("Original polygon array:", polygon_arr)
+
+# Convert shapely array into GeoArrow Polygon array
+geom_type, coord_arr, (offsets1, offsets2) = shapely.to_ragged_array(polygon_arr)
+print("\nAfter to_ragged_array:")
+print("Geometry type:", geom_type)
+print("Coordinates shape:", coord_arr.shape)
+print("Offsets1:", offsets1)
+print("Offsets2:", offsets2)
+
+_parr = pa.FixedSizeListArray.from_arrays(coord_arr.flatten(), 2)
+_parr1 = pa.ListArray.from_arrays(pa.array(offsets1), _parr)
+parr = pa.ListArray.from_arrays(pa.array(offsets2), _parr1)
+
+# Test 1: Slice to get just the middle polygon
+print("\nTest 1: Slice to get just the middle polygon")
+print("--------------------------------------------")
+arrow_polygon_slice = parr.slice(1, 1)
+
+# Coords for the entire buffer
+coords = arrow_polygon_slice.values.values.values.to_numpy().reshape(-1, 2)
+
+# indices into the ring array for *just* the sliced part
+offsets2 = np.asarray(arrow_polygon_slice.offsets)
+
+# indices into the coordinate array for the whole buffer
+offsets1 = np.asarray(arrow_polygon_slice.values.offsets)
+
+print("Coordinates shape:", coords.shape)
+print("Offsets1:", offsets1)
+print("Offsets2:", offsets2)
+
+offsets = (offsets1, offsets2)
+
+try:
+    result = shapely.from_ragged_array(geom_type, coords, offsets)
+    print("Success! Result:", result)
+    print("Expected polygon:", polygon2)
+    print("Matches expected:", np.array_equal(result, np.array([polygon2])))
+except ValueError as e:
+    print("Error:", e)
+
+# Test 2: Create a case with larger coordinate array than needed
+print("\nTest 2: Create a case with larger coordinate array than needed")
+print("-----------------------------------------------------------")
+try:
+    # Use the original coordinates and offsets from the first test
+    # But add extra coordinates at the end that shouldn't be used
+    extra_coords = np.vstack([coord_arr, np.array([[100, 100], [200, 200], [300, 300]])])
+    print("Original coords shape:", coord_arr.shape)
+    print("Extra coords shape:", extra_coords.shape)
+    print("Offsets1:", offsets1)
+    print("Offsets2:", offsets2)
+    
+    # Use the same offsets as before, but with the larger coordinate array
+    result = shapely.from_ragged_array(geom_type, extra_coords, (offsets1, offsets2))
+    print("Success! Result:", result)
+    print("Expected polygon:", polygon2)
+    print("Matches expected:", np.array_equal(result, np.array([polygon2])))
+except ValueError as e:
+    print("Error:", e)
+
+# Test 3: Test with LineString
+print("\nTest 3: Test with LineString")
+print("---------------------------")
+try:
+    # Create a LineString example
+    from shapely import LineString
+    line1 = LineString([(0, 0), (1, 1), (2, 2)])
+    line2 = LineString([(3, 3), (4, 4), (5, 5)])
+    line3 = LineString([(6, 6), (7, 7), (8, 8)])
+    line_arr = np.array([line1, line2, line3])
+    
+    print("Original line array:", line_arr)
+    
+    # Convert to ragged array
+    geom_type, coord_arr, (offsets1,) = shapely.to_ragged_array(line_arr)
+    print("Geometry type:", geom_type)
+    print("Coordinates shape:", coord_arr.shape)
+    print("Offsets1:", offsets1)
+    
+    # Add extra coordinates
+    extra_coords = np.vstack([coord_arr, np.array([[100, 100], [200, 200]])])
+    print("Extra coords shape:", extra_coords.shape)
+    
+    # Slice to get just the middle linestring
+    slice_offsets = np.array([3, 6])  # Indices for line2
+    
+    # Use all coordinates but only the middle linestring
+    result = shapely.from_ragged_array(geom_type, extra_coords, (slice_offsets,))
+    print("Success! Result:", result)
+    print("Expected linestring:", line2)
+    print("Matches expected:", np.array_equal(result, np.array([line2])))
+except ValueError as e:
+    print("Error:", e)
+except Exception as e:
+    print("Unexpected error:", e)
+
+print("\nAll tests completed successfully!")
