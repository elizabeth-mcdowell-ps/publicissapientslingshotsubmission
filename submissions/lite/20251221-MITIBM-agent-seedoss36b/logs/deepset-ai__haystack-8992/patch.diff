+import io
+import os
+from pathlib import Path
+import tempfile
+import codecs
+
+# Create a simple text file with non-UTF-8 encoding
+def create_test_file():
+    # Create a temporary directory
+    temp_dir = tempfile.mkdtemp()
+    text_path = os.path.join(temp_dir, "test_cp1252.txt")
+    
+    # Create text with CP1252 encoding (Windows-1252)
+    text = "Test with special characters: é è ç ñ ü ö ä ß\nMore special characters: © ® ™ € £ ¥ § ¶"
+    
+    # Write with CP1252 encoding
+    with codecs.open(text_path, 'w', encoding='cp1252') as f:
+        f.write(text)
+    
+    return text_path, temp_dir
+
+# Test with text file encoding
+def test_encoding_detection():
+    from haystack.dataclasses import ByteStream
+    
+    text_path, temp_dir = create_test_file()
+    print(f"Created test file at: {text_path}")
+    
+    # Read the file with different encodings and show the results
+    print("\nReading with UTF-8 (incorrect):")
+    try:
+        with open(text_path, 'r', encoding='utf-8') as f:
+            content = f.read()
+            print(content)
+    except UnicodeDecodeError as e:
+        print(f"Error: {e}")
+    
+    print("\nReading with CP1252 (correct):")
+    with open(text_path, 'r', encoding='cp1252') as f:
+        content = f.read()
+        print(content)
+    
+    # Read as bytes and detect encoding
+    print("\nDetecting encoding with chardet:")
+    import chardet
+    with open(text_path, 'rb') as f:
+        raw_data = f.read()
+        result = chardet.detect(raw_data)
+        print(f"Detected encoding: {result}")
+    
+    # Create a ByteStream with the raw data
+    bytestream = ByteStream(data=raw_data, meta={"file_path": text_path})
+    
+    # This is what we need to implement in the converters
+    print("\nConverting with detected encoding:")
+    detected_encoding = result['encoding']
+    if detected_encoding:
+        decoded_text = raw_data.decode(detected_encoding)
+        print(decoded_text)
+    
+    return text_path, temp_dir
+
+if __name__ == "__main__":
+    print("Testing encoding detection for non-UTF-8 text...")
+    text_path, temp_dir = test_encoding_detection()
+    
+    # Clean up
+    os.remove(text_path)
+    os.rmdir(temp_dir)
