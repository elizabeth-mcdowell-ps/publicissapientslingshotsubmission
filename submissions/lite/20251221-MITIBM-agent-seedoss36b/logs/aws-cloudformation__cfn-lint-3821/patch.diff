@@ -0,0 +1,51 @@
+#!/usr/bin/env python
+
+import os
+import sys
+import yaml
+from cfnlint.rules.resources.HardCodedArnProperties import HardCodedArnProperties
+from cfnlint.template import Template
+
+# Create a template with CloudFront OAI ARN
+template_content = """
+AWSTemplateFormatVersion: 2010-09-09
+Resources:
+  Resource:
+    Type: AWS::S3::BucketPolicy
+    Properties:
+      Bucket: bucket
+      PolicyDocument:
+        Version: 2012-10-17
+        Statement:
+          - Effect: Allow
+            Principal:
+              AWS: !Sub arn:${AWS::Partition}:iam::cloudfront:user/CloudFront Origin Access Identity E15MNIMTCFKK4C
+            Action: s3:GetObject
+            Resource: arn:aws:s3:::bucket/*
+"""
+
+# Write the template to a file
+with open('/tmp/template.yaml', 'w') as f:
+    f.write(template_content)
+
+# Parse the template
+template_obj = yaml.safe_load(template_content)
+cfn = Template(template_obj, [], "/tmp/template.yaml")
+
+# Configure the rule to check for accountId
+rule = HardCodedArnProperties()
+rule.configure(accountId=True)
+
+# Run the check
+matches = rule.match(cfn)
+
+# Print the results
+if matches:
+    print("Error: Found issues with CloudFront OAI ARN:")
+    for match in matches:
+        print(f"  {match}")
+else:
+    print("Success: No issues found with CloudFront OAI ARN")
+
+# Clean up
+os.remove('/tmp/template.yaml')
\ No newline at end of file
