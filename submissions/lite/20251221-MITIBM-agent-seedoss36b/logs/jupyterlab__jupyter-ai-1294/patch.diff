+#!/usr/bin/env python3
+"""
+Installation script for fixing Jupyter AI compatibility issues.
+This script provides two options:
+1. Pin Jupyter AI to version 2.30.0 (recommended)
+2. Fix existing configuration files by adding the embeddings_fields field
+"""
+
+import argparse
+import json
+import os
+import subprocess
+import sys
+from pathlib import Path
+
+def pin_jupyter_ai_version():
+    """
+    Install Jupyter AI version 2.30.0 to fix the compatibility issue.
+    """
+    try:
+        print("Installing jupyter-ai==2.30.0...")
+        subprocess.check_call([sys.executable, "-m", "pip", "install", "jupyter-ai==2.30.0"])
+        print("Successfully installed jupyter-ai==2.30.0")
+        return True
+    except subprocess.CalledProcessError as e:
+        print(f"Error installing jupyter-ai: {e}")
+        return False
+
+def fix_config_file(config_path):
+    """
+    Add embeddings_fields to the config file if it's missing.
+    
+    Args:
+        config_path: Path to the config file
+        
+    Returns:
+        bool: True if the file was modified, False otherwise
+    """
+    try:
+        # Read the existing config
+        with open(config_path, 'r') as f:
+            config = json.load(f)
+        
+        # Check if embeddings_fields is missing
+        if 'embeddings_fields' not in config:
+            print(f"Adding missing 'embeddings_fields' to {config_path}")
+            config['embeddings_fields'] = {}
+            
+            # Write the updated config
+            with open(config_path, 'w') as f:
+                json.dump(config, f, indent=2)
+            
+            return True
+        else:
+            print(f"'embeddings_fields' already exists in {config_path}")
+            return False
+    except Exception as e:
+        print(f"Error processing {config_path}: {e}")
+        return False
+
+def find_and_fix_configs():
+    """
+    Find and fix all Jupyter AI config files in the user's home directory.
+    
+    Returns:
+        int: Number of files fixed
+    """
+    # Common locations for Jupyter AI config files
+    possible_paths = [
+        os.path.join(os.path.expanduser("~"), ".jupyter", "jupyter_ai", "config.json"),
+        os.path.join(os.path.expanduser("~"), ".local", "share", "jupyter", "jupyter_ai", "config.json"),
+    ]
+    
+    # Add any additional paths from environment variables
+    jupyter_data_dir = os.environ.get("JUPYTER_DATA_DIR")
+    if jupyter_data_dir:
+        possible_paths.append(os.path.join(jupyter_data_dir, "jupyter_ai", "config.json"))
+    
+    fixed_count = 0
+    for path in possible_paths:
+        if os.path.exists(path):
+            if fix_config_file(path):
+                fixed_count += 1
+    
+    return fixed_count
+
+def main():
+    parser = argparse.ArgumentParser(description="Fix Jupyter AI compatibility issues")
+    parser.add_argument("--method", choices=["pin", "fix-config", "both"], default="both",
+                      help="Method to use: pin (install v2.30.0), fix-config (add embeddings_fields), or both (default)")
+    parser.add_argument("--config", help="Path to a specific config file to fix")
+    
+    args = parser.parse_args()
+    
+    if args.method in ["pin", "both"]:
+        pin_jupyter_ai_version()
+    
+    if args.method in ["fix-config", "both"]:
+        if args.config:
+            if os.path.exists(args.config):
+                if fix_config_file(args.config):
+                    print(f"Successfully fixed {args.config}")
+                else:
+                    print(f"No changes needed for {args.config}")
+            else:
+                print(f"Error: File not found: {args.config}")
+        else:
+            fixed_count = find_and_fix_configs()
+            if fixed_count > 0:
+                print(f"Successfully fixed {fixed_count} configuration file(s)")
+            else:
+                print("No configuration files needed fixing or none were found")
+
+if __name__ == "__main__":
+    main()
