+import json
+import os
+import tempfile
+from jupyter_ai.models import GlobalConfig
+from jupyter_ai.config_manager import ConfigManager
+import logging
+
+# Create a temporary config file
+with tempfile.NamedTemporaryFile(mode='w+', delete=False) as temp_file:
+    config_data = {
+        "model_provider_id": "amazon-bedrock",
+        "embeddings_provider_id": None,
+        "send_with_shift_enter": False,
+        "fields": {},
+        "api_keys": {},
+        "completions_model_provider_id": None,
+        "completions_fields": {}
+        # Missing embeddings_fields
+    }
+    json.dump(config_data, temp_file)
+    temp_file_path = temp_file.name
+
+# Create a temporary schema file
+schema_file_path = None
+with tempfile.NamedTemporaryFile(mode='w+', delete=False) as schema_file:
+    schema_data = {
+        "title": "Jupyter AI configuration",
+        "$schema": "https://json-schema.org/draft/2020-12/schema",
+        "type": "object",
+        "properties": {
+            "model_provider_id": {
+                "type": ["string", "null"],
+                "default": None
+            },
+            "embeddings_provider_id": {
+                "type": ["string", "null"],
+                "default": None
+            },
+            "completions_model_provider_id": {
+                "type": ["string", "null"],
+                "default": None
+            },
+            "api_keys": {
+                "type": "object",
+                "default": {}
+            },
+            "send_with_shift_enter": {
+                "type": "boolean",
+                "default": False
+            },
+            "fields": {
+                "type": "object",
+                "default": {}
+            },
+            "embeddings_fields": {
+                "type": "object",
+                "default": {}
+            },
+            "completions_fields": {
+                "type": "object",
+                "default": {}
+            }
+        }
+    }
+    json.dump(schema_data, schema_file)
+    schema_file_path = schema_file.name
+
+try:
+    # Setup logging
+    logger = logging.getLogger("test")
+    logger.setLevel(logging.INFO)
+    handler = logging.StreamHandler()
+    logger.addHandler(handler)
+    
+    # Create config manager with our test files
+    config_manager = ConfigManager(
+        log=logger,
+        lm_providers={},
+        em_providers={},
+        defaults={},
+        config_path=temp_file_path,
+        schema_path=schema_file_path
+    )
+    
+    # Try to read the config
+    print("Trying to read config...")
+    try:
+        config = config_manager._read_config()
+        print("Success! Config read successfully.")
+        print(f"Config: {config}")
+    except Exception as e:
+        print(f"Error reading config: {e}")
+        
+finally:
+    # Clean up temporary files
+    if os.path.exists(temp_file_path):
+        os.unlink(temp_file_path)
+    if schema_file_path and os.path.exists(schema_file_path):
+        os.unlink(schema_file_path)
