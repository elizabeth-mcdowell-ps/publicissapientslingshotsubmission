+#!/usr/bin/env python3
+import sys
+import os
+sys.path.append('/testbed')
+
+from privacyidea.lib.policy import set_policy
+from privacyidea.models import db, Policy
+from privacyidea.app import create_app
+
+# Create the Flask app
+app = create_app(config_name='testing')
+
+# Create an application context
+with app.app_context():
+    # Create a policy with a text field containing a comma
+    policy_name = "test_sms_policy"
+    
+    print(f"Creating policy '{policy_name}' with comma in text field...")
+    
+    # Set the policy with a text field containing a comma
+    smstext = "Dear customer, Your verification token is {otp}. Your support Team."
+    set_policy(
+        name=policy_name,
+        scope="authentication",
+        action=f"smstext={smstext}",
+        realm="*",
+        active=True
+    )
+    
+    print("Policy created successfully.")
+    
+    # Retrieve the policy from the database to check if the text was saved correctly
+    policy = Policy.query.filter_by(name=policy_name).first()
+    
+    if policy:
+        print("\nRetrieved policy from database:")
+        print(f"Name: {policy.name}")
+        print(f"Scope: {policy.scope}")
+        print(f"Action: {policy.action}")
+        
+        # Parse the action string to extract the smstext value
+        action_parts = policy.action.split("=", 1)
+        if len(action_parts) == 2 and action_parts[0].strip() == "smstext":
+            saved_text = action_parts[1]
+            print(f"\nSaved smstext: '{saved_text}'")
+            
+            if saved_text == smstext:
+                print("\nSUCCESS: The text was saved correctly with the comma.")
+            elif saved_text == "Dear customer":
+                print("\nERROR: The text was truncated at the comma as described in the issue.")
+            else:
+                print(f"\nUNEXPECTED RESULT: The text was saved differently than expected.")
+        else:
+            print("\nERROR: Could not parse the action string to extract smstext.")
+    else:
+        print(f"\nERROR: Could not retrieve policy '{policy_name}' from database.")
+    
+    # Clean up: Delete the test policy
+    if policy:
+        db.session.delete(policy)
+        db.session.commit()
+        print(f"\nPolicy '{policy_name}' deleted successfully.")
