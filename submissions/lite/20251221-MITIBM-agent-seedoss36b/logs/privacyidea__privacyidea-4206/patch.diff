+#!/usr/bin/env python3
+import requests
+import json
+import sys
+
+# Configuration
+BASE_URL = "http://localhost:5000"
+ADMIN_USER = "admin"
+ADMIN_PASS = "admin"
+
+# Get authentication token
+def get_auth_token():
+    auth_url = f"{BASE_URL}/auth"
+    auth_data = {
+        "username": ADMIN_USER,
+        "password": ADMIN_PASS
+    }
+    
+    response = requests.post(auth_url, data=auth_data)
+    if response.status_code != 200:
+        print(f"Authentication failed: {response.text}")
+        sys.exit(1)
+    
+    result = response.json()
+    return result.get("result", {}).get("value", {}).get("token", "")
+
+# Create a policy with a text field containing a comma
+def create_policy_with_comma(auth_token):
+    policy_name = "test_sms_policy"
+    policy_url = f"{BASE_URL}/policy/{policy_name}"
+    
+    policy_data = {
+        "scope": "authentication",
+        "action": "smstext=Dear customer, Your verification token is {otp}. Your support Team.",
+        "realm": "*",
+        "active": True
+    }
+    
+    headers = {
+        "PI-Authorization": auth_token
+    }
+    
+    response = requests.post(policy_url, data=policy_data, headers=headers)
+    if response.status_code != 200:
+        print(f"Failed to create policy: {response.text}")
+        sys.exit(1)
+    
+    print("Policy created successfully.")
+    return policy_name
+
+# Get policy details to check if the text was saved correctly
+def get_policy_details(auth_token, policy_name):
+    policy_url = f"{BASE_URL}/policy/{policy_name}"
+    
+    headers = {
+        "PI-Authorization": auth_token
+    }
+    
+    response = requests.get(policy_url, headers=headers)
+    if response.status_code != 200:
+        print(f"Failed to get policy details: {response.text}")
+        sys.exit(1)
+    
+    result = response.json()
+    policies = result.get("result", {}).get("value", [])
+    
+    if not policies:
+        print("No policy found.")
+        return
+    
+    policy = policies[0]
+    action = policy.get("action", {})
+    smstext = action.get("smstext", "")
+    
+    print(f"Retrieved policy action 'smstext': {smstext}")
+    return smstext
+
+# Delete the test policy
+def delete_policy(auth_token, policy_name):
+    policy_url = f"{BASE_URL}/policy/{policy_name}"
+    
+    headers = {
+        "PI-Authorization": auth_token
+    }
+    
+    response = requests.delete(policy_url, headers=headers)
+    if response.status_code != 200:
+        print(f"Failed to delete policy: {response.text}")
+        sys.exit(1)
+    
+    print("Policy deleted successfully.")
+
+# Main function
+def main():
+    print("Getting authentication token...")
+    auth_token = get_auth_token()
+    
+    print("\nCreating policy with comma in text field...")
+    policy_name = create_policy_with_comma(auth_token)
+    
+    print("\nRetrieving policy to check if text was saved correctly...")
+    smstext = get_policy_details(auth_token, policy_name)
+    
+    # Check if the text was truncated at the comma
+    expected_text = "Dear customer, Your verification token is {otp}. Your support Team."
+    if smstext == expected_text:
+        print("\nSUCCESS: The text was saved correctly with the comma.")
+    elif smstext == "Dear customer":
+        print("\nERROR: The text was truncated at the comma as described in the issue.")
+    else:
+        print(f"\nUNEXPECTED RESULT: The text was saved as: '{smstext}'")
+    
+    print("\nCleaning up: Deleting test policy...")
+    delete_policy(auth_token, policy_name)
+
+if __name__ == "__main__":
+    main()
