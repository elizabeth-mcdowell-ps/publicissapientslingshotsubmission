@@ -0,0 +1,79 @@
+import json
+import tempfile
+from pathlib import Path
+
+# Create a temporary file with the example schema
+schema = {
+  "openapi": "3.0.0",
+  "info": {
+    "title": "API Documentation",
+    "contact": {
+      "name": "API Support",
+      "email": "api@api.com"
+    },
+    "description": "API documentation",
+    "version": "v4"
+  },
+  "components": {
+    "schemas": {
+      "Activity_base": {
+        "type": "object",
+        "properties": {
+          "date": {
+            "type": "string",
+            "format": "date",
+            "description": "The date the Activity was performed (as a ISO-8601 date)"
+          }
+        }
+      }
+    }
+  }
+}
+
+# Write schema to a temporary file
+with tempfile.NamedTemporaryFile(suffix='.json', delete=False) as f:
+    f.write(json.dumps(schema).encode('utf-8'))
+    schema_path = f.name
+
+# Run the code generator
+import subprocess
+output_path = Path(tempfile.mktemp(suffix='.py'))
+cmd = [
+    "datamodel-codegen",
+    "--use-standard-collections",
+    "--use-schema-description",
+    "--use-double-quotes",
+    "--input-file-type", "openapi",
+    "--target-python-version", "3.10",
+    "--encoding", "utf8",
+    "--input", schema_path,
+    "--output", str(output_path)
+]
+
+subprocess.run(cmd, check=True)
+
+# Print the generated model
+print("\nGenerated model:")
+print("-" * 40)
+with open(output_path, 'r') as f:
+    print(f.read())
+
+# Try to import the generated model to see if it crashes
+print("\nTrying to import the model:")
+print("-" * 40)
+try:
+    import sys
+    sys.path.append(str(output_path.parent))
+    import importlib.util
+    spec = importlib.util.spec_from_file_location("models", output_path)
+    models = importlib.util.module_from_spec(spec)
+    spec.loader.exec_module(models)
+    print("Successfully imported the model")
+except Exception as e:
+    print(f"Error importing the model: {e}")
+    import traceback
+    traceback.print_exc()
+
+# Clean up
+Path(schema_path).unlink()
+output_path.unlink()
\ No newline at end of file
