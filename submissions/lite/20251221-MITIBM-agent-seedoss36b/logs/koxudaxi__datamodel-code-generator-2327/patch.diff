--- /dev/null
+++ b/test_recursion.py
@@ -0,0 +1,26 @@
+from datetime import date
+from typing import Optional
+
+from pydantic import BaseModel, Field
+
+# This is the problematic code pattern mentioned in the PR
+class ActivityBase(BaseModel):
+    date: Optional[date] = Field(
+        None, description="The date the Activity was performed (as a ISO-8601 date)"
+    )
+
+# This is what we want to generate instead
+class ActivityBaseFixed(BaseModel):
+    date: Optional["datetime.date"] = Field(
+        None, description="The date the Activity was performed (as a ISO-8601 date)"
+    )
+
+print("Model defined successfully")
+print("Creating an instance...")
+try:
+    instance = ActivityBase(date="2023-01-01")
+    print(f"Instance created: {instance}")
+except Exception as e:
+    print(f"Error creating instance: {e}")
+    import traceback
+    traceback.print_exc()
