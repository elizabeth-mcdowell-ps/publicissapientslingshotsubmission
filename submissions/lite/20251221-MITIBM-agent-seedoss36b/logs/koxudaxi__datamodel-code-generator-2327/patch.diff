+    exec(model_code)
+
+# Create an instance of the model
+instance = ActivityBase(date="2023-01-01")
+print(f"Instance created successfully: {{instance}}")
+print(f"Date: {{instance.date}}")
+print(f"Date type: {{type(instance.date)}}")
+""")
