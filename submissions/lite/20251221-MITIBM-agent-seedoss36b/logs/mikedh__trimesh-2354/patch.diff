+import os
+import numpy as np
+import trimesh
+
+# Create a directory for inputs if it doesn't exist
+os.makedirs('./inputs', exist_ok=True)
+
+# Create an SVG with arcs for testing
+arc_svg = """<?xml version="1.0" encoding="UTF-8" standalone="no"?>
+<svg width="100mm" height="50mm" viewBox="0 0 100 50" version="1.1" xmlns="http://www.w3.org/2000/svg">
+  <path d="M 0,0 L 80,0 A 17.5,17.5 0 0,0 0,35 L 80,35 Z" fill="none" stroke="black" />
+</svg>
+"""
+
+# Create an SVG with Bezier curves for testing (similar to what Inkscape would produce)
+bezier_svg = """<?xml version="1.0" encoding="UTF-8" standalone="no"?>
+<svg width="100mm" height="50mm" viewBox="0 0 100 50" version="1.1" xmlns="http://www.w3.org/2000/svg">
+  <path d="M 0,0 L 80,0 C 80,0 -17.5,0 -17.5,17.5 C -17.5,35 0,35 0,35 L 80,35 Z" fill="none" stroke="black" />
+</svg>
+"""
+
+# Save the SVGs
+with open('./inputs/shape.svg', 'w') as f:
+    f.write(arc_svg)
+
+with open('./inputs/shape_ink.svg', 'w') as f:
+    f.write(bezier_svg)
+
+# Load the SVGs and try to create meshes
+print("Loading SVGs and creating meshes...")
+
+shape_svg = trimesh.load_path('./inputs/shape.svg')
+print("Shape SVG loaded, vertices:", shape_svg.vertices.shape)
+print("Shape SVG entities:", len(shape_svg.entities))
+
+shape_svg.fill_gaps()
+print("After fill_gaps(), entities:", len(shape_svg.entities))
+
+try:
+    shape_mesh = shape_svg.extrude(3)
+    print("Shape mesh created successfully")
+    print("Shape mesh is watertight:", shape_mesh.is_watertight)
+    print("Shape mesh volume:", shape_mesh.volume)
+except Exception as e:
+    print("Error creating shape mesh:", e)
+
+shape_ink_svg = trimesh.load_path('./inputs/shape_ink.svg')
+print("\nShape Ink SVG loaded, vertices:", shape_ink_svg.vertices.shape)
+print("Shape Ink SVG entities:", len(shape_ink_svg.entities))
+
+try:
+    shape_ink_mesh = shape_ink_svg.extrude(3)
+    print("Shape Ink mesh created successfully")
+    print("Shape Ink mesh is watertight:", shape_ink_mesh.is_watertight)
+    print("Shape Ink mesh volume:", shape_ink_mesh.volume)
+except Exception as e:
+    print("Error creating shape ink mesh:", e)
+
+# Print comparison information
+print("\nComparison:")
+print("bounds:")
+print(shape_svg.bounds)
+print("-----===-----")
+print(shape_ink_svg.bounds)
+
+print("\nvertices:")
+print(shape_svg.vertices)
+print("-----===-----")
+print(shape_ink_svg.vertices)
+
+print("\ncentroid:")
+print(shape_svg.centroid)
+print("-----===-----")
+print(shape_ink_svg.centroid)
+
+print("\nlength:")
+print(shape_svg.length)
+print("-----===-----")
+print(shape_ink_svg.length)
+
+print("\narea:")
+print(shape_svg.area)
+print("-----===-----")
+print(shape_ink_svg.area)
+
+print("\nidentifier:")
+print(shape_svg.identifier)
+print("-----===-----")
+print(shape_ink_svg.identifier)
