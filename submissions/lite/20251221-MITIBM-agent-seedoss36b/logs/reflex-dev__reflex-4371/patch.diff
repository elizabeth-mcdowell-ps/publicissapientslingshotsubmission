+import reflex as rx
+
+class TableState(rx.State):
+    password = "secret123"
+    search: str = ""
+
+    def apply_search(self, search: str) -> None:
+        self.search = search
+        print(f"Search value: {search}")
+        print(f"Password value: {self.password}")
+        if search == "password":
+            print("Search value is 'password'")
+            # This is where the issue happens - when search is "password", 
+            # it will call the password's setter instead of setting search to "password"
+
+# Create a simple app to test
+app = rx.App()
+
+@app.page("/")
+def index():
+    return rx.vstack(
+        rx.heading("Test App"),
+        rx.text(f"Password: {TableState.password}"),
+        rx.text(f"Search: {TableState.search}"),
+        rx.input(
+            value=TableState.search,
+            on_change=TableState.apply_search,
+            placeholder="Enter search term",
+        ),
+        rx.button("Clear Search", on_click=lambda: TableState.apply_search("")),
+        rx.button("Set Search to 'password'", on_click=lambda: TableState.apply_search("password")),
+    )
+
+# For testing without running the app
+if __name__ == "__main__":
+    state = TableState()
