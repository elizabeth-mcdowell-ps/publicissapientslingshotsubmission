+"""Manual test to verify the fix."""
+
+# Simulate the behavior of the fixed setvar method
+
+class SimpleState:
+    """A simple state class to verify the fix."""
+    
+    def __init__(self):
+        self.password = "secret123"
+        self.search = ""
+    
+    def set_search(self, value):
+        """Setter for search."""
+        print(f"set_search called with value: {value}")
+        self.search = value
+        
+    def set_password(self, value):
+        """Setter for password."""
+        print(f"set_password called with value: {value}")
+        self.password = value
+        
+    def setvar_old(self, var_name, value):
+        """Simulate the old problematic setvar method."""
+        print(f"setvar_old called with var_name: {var_name}, value: {value}")
+        
+        # This is the problematic line - when var_name is "search" and value is "password",
+        # if there's a variable named "password", it might be confused
+        setter_name = "set_" + var_name
+        
+        # Simulate the issue by checking if value is a string that matches a variable name
+        if isinstance(value, str) and hasattr(self, value):
+            print(f"  WARNING: Value '{value}' matches a variable name!")
+            # In the bug scenario, this would happen implicitly
+            # value = getattr(self, value)
+            # print(f"  Using the variable's value instead: {value}")
+        
+        getattr(self, setter_name)(value)
+        
+    def setvar_fixed(self, var_name, value):
+        """Simulate the fixed setvar method."""
+        print(f"setvar_fixed called with var_name: {var_name}, value: {value}")
+        
+        # Get the setter method for the variable
+        setter_name = "set_" + var_name
+        setter = getattr(self, setter_name)
+        
+        # Call the setter with the value
+        # This ensures that the value is treated as a literal value
+        # and not as a reference to another state variable
+        setter(value)
+        
+    def apply_search_old(self, search_term):
+        """Apply a search term using the old method."""
+        print(f"Before setting search (old): search={self.search}, password={self.password}")
+        self.setvar_old("search", search_term)
+        print(f"After setting search (old): search={self.search}, password={self.password}")
+        
+    def apply_search_fixed(self, search_term):
+        """Apply a search term using the fixed method."""
+        print(f"Before setting search (fixed): search={self.search}, password={self.password}")
+        self.setvar_fixed("search", search_term)
+        print(f"After setting search (fixed): search={self.search}, password={self.password}")
+
+# Create an instance and test
+if __name__ == "__main__":
+    state = SimpleState()
+    
+    print("Initial state:")
+    print(f"Password: {state.password}")
+    print(f"Search: {state.search}")
+    
+    print("\n--- Testing with normal value ---")
+    print("\nOld method - Setting search to 'hello':")
+    state.apply_search_old("hello")
+    
+    print("\nFixed method - Setting search to 'hello':")
+    state.apply_search_fixed("hello")
+    
+    print("\n--- Testing with problematic value ---")
+    print("\nOld method - Setting search to 'password':")
+    state.apply_search_old("password")
+    
+    print("\nFixed method - Setting search to 'password':")
+    state.apply_search_fixed("password")
+    
+    # Verify final state
+    print("\nFinal state:")
+    print(f"Password: {state.password}")
+    print(f"Search: {state.search}")
