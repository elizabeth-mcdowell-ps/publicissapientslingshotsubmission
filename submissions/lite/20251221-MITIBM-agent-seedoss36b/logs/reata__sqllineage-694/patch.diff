@@ -0,0 +1,22 @@
+from ...helpers import assert_table_lineage_equal
+
+
+def test_bigquery_insert_without_into():
+    """Test BigQuery INSERT statement without the INTO keyword."""
+    assert_table_lineage_equal(
+        "INSERT `project.dataset.table_2` SELECT * FROM `project.dataset.table_1`",
+        {"project.dataset.table_1"},
+        {"project.dataset.table_2"},
+        dialect="bigquery",
+        test_sqlparse=False,  # SQLParse doesn't support BigQuery INSERT without INTO
+    )
+
+
+def test_bigquery_insert_with_into():
+    """Test BigQuery INSERT statement with the INTO keyword (for comparison)."""
+    assert_table_lineage_equal(
+        "INSERT INTO `project.dataset.table_2` SELECT * FROM `project.dataset.table_1`",
+        {"project.dataset.table_1"},
+        {"project.dataset.table_2"},
+        dialect="bigquery",
+    )
