+    
+    # Create a state dict with properly initialized magnitude parameters
+    sd = {}
+    for name, module in dora_modules.items():
+        # If magnitude is on meta device, we need to create a new parameter
+        if module.magnitude.is_meta:
+            # Create a new magnitude parameter with ones (will be properly initialized later)
+            # Use the same shape and dtype as the original magnitude parameter
+            shape = module.magnitude.shape
+            dtype = module.weight.dtype if not module.weight.is_meta else torch.float32
+            device = next((p.device for p in module.parameters() if not p.is_meta), torch.device("cpu"))
+            
+            # Create a new magnitude parameter with ones
+            # This is just a placeholder - the actual values will be set properly during training
+            new_magnitude = torch.ones(shape, dtype=dtype, device=device)
+            sd[f"{name}.magnitude"] = new_magnitude
+    
+    # Load the state dict with assign=True to update the parameters
+    if sd:
+        model.load_state_dict(sd, strict=False, assign=True)
