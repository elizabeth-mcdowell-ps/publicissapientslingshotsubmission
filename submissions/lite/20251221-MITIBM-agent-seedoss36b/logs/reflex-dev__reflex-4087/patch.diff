+"""Comprehensive test for the reset() method fix."""
+
+import copy
+from typing import Dict, Any, Optional
+
+class SimpleState:
+    """A simplified version of the BaseState class."""
+    
+    # Class-level default for private attribute
+    _private_var = 20
+    
+    def __init__(self):
+        self.public_var = 10
+        self._private_var = 20  # Same as class default
+        self._runtime_var = 30  # No class default
+        self._special_var = {}  # Mutable default
+        self.substates = {}
+        self._was_touched = False  # Special attribute that should not be reset
+        self._backend_vars = {}    # Special attribute that should not be reset
+    
+    def reset(self):
+        """Reset all the base vars and private attributes to their default values."""
+        # Reset public attributes
+        self.public_var = 10
+        
+        # Reset private attributes
+        # Skip special internal attributes that should not be reset
+        skip_attrs = {"_was_touched", "_backend_vars", "substates"}
+        
+        for prop_name in list(self.__dict__.keys()):
+            if prop_name.startswith("_") and prop_name not in skip_attrs:
+                # Get the class attribute default value if it exists
+                cls = type(self)
+                if hasattr(cls, prop_name):
+                    default_value = getattr(cls, prop_name)
+                    # Use deepcopy to avoid shared references
+                    setattr(self, prop_name, copy.deepcopy(default_value))
+                else:
+                    # If no default value exists at class level, set to None
+                    setattr(self, prop_name, None)
+        
+        # Recursively reset the substates
+        for substate in self.substates.values():
+            substate.reset()
+    
+    def __str__(self):
+        attrs = []
+        for name, value in self.__dict__.items():
+            if name not in ["substates", "_was_touched", "_backend_vars"]:
+                attrs.append(f"{name}: {value}")
+        return ", ".join(attrs)
+
+class SubState(SimpleState):
+    """A substate class."""
+    
+    # Different class-level default
+    _private_var = 15
+    
+    def __init__(self, parent=None):
+        super().__init__()
+        self.parent = parent
+        self.public_var = 5
+        self._private_var = 15
+        self._substate_var = 40  # Unique to substate
+
+# Create the states
+main_state = SimpleState()
+sub_state = SubState(parent=main_state)
+main_state.substates["sub"] = sub_state
+
+# Mark special attributes
+main_state._was_touched = True
+sub_state._was_touched = True
+
+print("Initial state:")
+print(f"Main state: {main_state}")
+print(f"Sub state: {sub_state}")
+
+# Modify the values
+main_state.public_var = 100
+main_state._private_var = 200
+main_state._runtime_var = 300
+main_state._special_var["key"] = "value"
+sub_state.public_var = 50
+sub_state._private_var = 150
+sub_state._runtime_var = 350
+sub_state._substate_var = 450
+
+print("\nAfter modification:")
+print(f"Main state: {main_state}")
+print(f"Sub state: {sub_state}")
+
+# Reset the states
+main_state.reset()
+
+print("\nAfter reset:")
+print(f"Main state: {main_state}")
+print(f"Sub state: {sub_state}")
+
+# Check if special attributes were preserved
+print("\nSpecial attributes:")
+print(f"Main state._was_touched: {main_state._was_touched}")
+print(f"Sub state._was_touched: {sub_state._was_touched}")
