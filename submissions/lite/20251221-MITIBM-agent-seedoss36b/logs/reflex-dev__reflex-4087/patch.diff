@@ -0,0 +1,53 @@
+"""Script to reproduce the issue with reset() not clearing private attributes."""
+
+import asyncio
+from reflex.state import BaseState
+
+class SubState(BaseState):
+    count: int = 0
+    _private_count: int = 0
+    
+    def increment(self):
+        self.count += 1
+        self._private_count += 1
+        print(f"SubState - count: {self.count}, _private_count: {self._private_count}")
+
+class MainState(BaseState):
+    value: int = 0
+    _private_value: int = 0
+    
+    def increment(self):
+        self.value += 1
+        self._private_value += 1
+        print(f"MainState - value: {self.value}, _private_value: {self._private_value}")
+    
+    async def reset_all(self):
+        # Get the substate and reset it
+        substate = await self.get_state(SubState)
+        print("\nBefore reset:")
+        print(f"MainState - value: {self.value}, _private_value: {self._private_value}")
+        print(f"SubState - count: {substate.count}, _private_count: {substate._private_count}")
+        
+        # Reset both states
+        self.reset()
+        substate.reset()
+        
+        print("\nAfter reset:")
+        print(f"MainState - value: {self.value}, _private_value: {self._private_value}")
+        print(f"SubState - count: {substate.count}, _private_count: {substate._private_count}")
+
+async def main():
+    # Create instances
+    main_state = MainState()
+    sub_state = SubState(parent_state=main_state)
+    main_state.substates["SubState"] = sub_state
+    
+    # Increment values
+    main_state.increment()
+    sub_state.increment()
+    
+    # Try to reset
+    await main_state.reset_all()
+
+if __name__ == "__main__":
+    asyncio.run(main())
