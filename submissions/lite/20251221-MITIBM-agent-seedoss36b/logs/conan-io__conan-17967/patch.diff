+#!/usr/bin/env python
+
+import os
+import tempfile
+import shutil
+from pathlib import Path
+
+# Mock classes to simulate the behavior
+class MockRequirement:
+    def __init__(self, name, build=False, direct=True, test=False, skip=False):
+        self.ref = MockReference(name)
+        self.build = build
+        self.direct = direct
+        self.test = test
+        self.skip = skip
+        
+    def copy_requirement(self):
+        return MockRequirement(self.ref.name, self.build, self.direct, self.test, self.skip)
+
+class MockReference:
+    def __init__(self, name):
+        self.name = name
+        
+    def __eq__(self, other):
+        return self.name == other.name
+        
+    def __str__(self):
+        return self.name
+
+class MockCppInfo:
+    def __init__(self):
+        self.includedirs = []
+        self.libdirs = []
+        self.bindirs = []
+        self.libs = []
+        self.defines = []
+        self.cxxflags = []
+        self.cflags = []
+        self.sharedlinkflags = []
+        self.exelinkflags = []
+        self.frameworks = []
+        self.frameworkdirs = []
+        self.rootpath = "/path/to/package"
+        self.components = {}
+        self.requires = []
+        self.system_libs = []
+        
+    def has_components(self):
+        return bool(self.components)
+        
+    def parsed_requires(self):
+        return []
+
+class MockDependency:
+    def __init__(self, name):
+        self.ref = MockReference(name)
+        self.cpp_info = MockCppInfo()
+        self.dependencies = MockDependencies()
+        
+    def __eq__(self, other):
+        return self.ref.name == other.ref.name
+
+class MockDependencies:
+    def __init__(self):
+        self._deps = {}
+        
+    def filter(self, *args, **kwargs):
+        return self
+        
+    def transitive_requires(self, other):
+        return other
+        
+    def values(self):
+        return list(self._deps.values())
+        
+    def items(self):
+        return self._deps.items()
+        
+    def __getitem__(self, key):
+        return self._deps[key]
+
+class MockSettings:
+    def __init__(self):
+        self.build_type = "Release"
+        self.os = "Windows"
+        self.compiler = "Visual Studio"
+        self.compiler.version = "17"
+        self.arch = "x86_64"
+
+class MockConanFile:
+    def __init__(self):
+        self.dependencies = MockDependencies()
+        self._conan_node = MockNode()
+        self.settings = MockSettings()
+        self.folders = MockFolders()
+        
+class MockNode:
+    def __init__(self):
+        self.replaced_requires = {}
+        
+# Import the actual MSBuildDeps class
+from conan.tools.microsoft.msbuilddeps import MSBuildDeps
+
+def test_msbuilddeps_with_replace_requires():
+    print("Testing MSBuildDeps with replace_requires...")
+    
+    # Create a temporary directory for output
+    temp_dir = tempfile.mkdtemp()
+    try:
+        # Setup mock objects
+        conanfile = MockConanFile()
+        
+        # Create the generator
+        generator = MSBuildDeps(conanfile)
+        generator.output_folder = temp_dir
+        
+        # Setup the scenario from PR description:
+        # wt requires sqlite3, but sqlite3 is replaced with sqlite3see
+        
+        # Create the dependencies
+        wt_req = MockRequirement("wt")
+        sqlite3_req = MockRequirement("sqlite3")
+        sqlite3see_req = MockRequirement("sqlite3see")
+        
+        # Setup the replacement
+        conanfile._conan_node.replaced_requires = {"sqlite3/1.0": sqlite3see_req}
+        
+        # Create mock dependencies
+        wt_dep = MockDependency("wt")
+        sqlite3see_dep = MockDependency("sqlite3see")
+        
+        # Setup wt to depend on sqlite3
+        wt_dep.dependencies._deps[sqlite3_req] = sqlite3see_dep
+        
+        # Generate property sheets
+        # This is where we'd normally call generator.generate()
+        # But we'll simulate just the part that's relevant to our issue
+        
+        # Simulate the _package_props_files method for wt
+        print("\nSimulating property sheet generation for wt:")
+        
+        # Get the dependencies that wt would include in its property sheet
+        from conan.internal.model.dependencies import get_transitive_requires
+        
+        # Manually set up the dependencies for the test
+        conanfile.dependencies._deps[wt_req] = wt_dep
+        conanfile.dependencies._deps[sqlite3see_req] = sqlite3see_dep
+        
+        # This is what happens in _package_props_files
+        pkg_deps = get_transitive_requires(conanfile, wt_dep)
+        
+        # Print the dependencies that would be included in the property sheet
+        print("Dependencies that would be included in wt's property sheet:")
+        for req, dep in pkg_deps.items():
+            print(f"  - {req.ref.name}")
+        
+        # The bug is that pkg_deps contains sqlite3, not sqlite3see
+        # So the property sheet for wt will try to import conan_sqlite3.props
+        # But that file doesn't exist, only conan_sqlite3see.props exists
+        
+        print("\nThis demonstrates the bug: wt's property sheet would try to import")
+        print("conan_sqlite3.props, but that file doesn't exist because sqlite3")
+        print("was replaced with sqlite3see.")
+        
+    finally:
+        # Clean up
+        shutil.rmtree(temp_dir)
+
+if __name__ == "__main__":
+    test_msbuilddeps_with_replace_requires()
