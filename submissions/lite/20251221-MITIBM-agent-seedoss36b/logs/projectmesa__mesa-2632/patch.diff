+import matplotlib.pyplot as plt
+import numpy as np
+from mesa import Model
+from mesa.space import HexMultiGrid
+from mesa.agent import Agent
+from mesa.visualization.mpl_space_drawing import draw_hex_grid
+
+# Create a simple model class
+class HexGridModel(Model):
+    def __init__(self, width=5, height=5):
+        super().__init__()
+        self.grid = HexMultiGrid(width, height, torus=False)
+        self.running = True
+        
+        # Add a center agent
+        self.center_pos = (2, 2)
+        center_agent = CenterAgent(1, self)
+        self.grid.place_agent(center_agent, self.center_pos)
+        
+        # Get neighbors and add neighbor agents
+        neighbors = self.grid.get_neighborhood(self.center_pos, include_center=False)
+        for i, pos in enumerate(neighbors):
+            neighbor_agent = NeighborAgent(i+2, self)
+            self.grid.place_agent(neighbor_agent, pos)
+        
+        print("Center position:", self.center_pos)
+        print("Neighbor positions:", neighbors)
+
+# Agent classes
+class CenterAgent(Agent):
+    def __init__(self, unique_id, model):
+        super().__init__(unique_id, model)
+
+class NeighborAgent(Agent):
+    def __init__(self, unique_id, model):
+        super().__init__(unique_id, model)
+
+# Create the model
+model = HexGridModel()
+
+# Define portrayal function for visualization
+def agent_portrayal(agent):
+    if agent is None:
+        return None
+    
+    if isinstance(agent, CenterAgent):
+        return {"color": "blue", "size": 100}
+    else:
+        return {"color": "orange", "size": 100}
+
+# Create a figure and visualize
+fig, ax = plt.subplots(figsize=(8, 8))
+draw_hex_grid(model.grid, agent_portrayal, ax=ax)
+plt.title("HexGrid Visualization (Fixed)")
+plt.savefig("hexgrid_fixed.png")
+plt.show()
