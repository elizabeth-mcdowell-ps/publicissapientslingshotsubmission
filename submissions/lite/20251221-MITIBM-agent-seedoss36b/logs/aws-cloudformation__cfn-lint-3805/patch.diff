@@ -0,0 +1,51 @@
+#!/usr/bin/env python
+
+import json
+import sys
+from pathlib import Path
+
+# Import cfnlint
+sys.path.insert(0, str(Path(__file__).parent))
+from src.cfnlint.api import lint
+from src.cfnlint.rules.resources.iam.ManagedPolicySize import ManagedPolicySize
+
+# Create a template with a large IAM ManagedPolicy
+template = {
+    "AWSTemplateFormatVersion": "2010-09-09",
+    "Resources": {
+        "BedrockStudioServiceRolePolicy": {
+            "Type": "AWS::IAM::ManagedPolicy",
+            "Properties": {
+                "ManagedPolicyName": "BedrockServiceRolePolicy",
+                "PolicyDocument": {
+                    "Version": "2012-10-17",
+                    "Statement": [
+                        # Generate a large policy document with many actions to exceed the 6144 limit
+                        {"Effect": "Allow", "Action": [f"service:Action{i}" for i in range(1000)], "Resource": "*"}
+                    ]
+                }
+            }
+        }
+    }
+}
+
+# Write the template to a file
+template_file = Path(__file__).parent / "test_template.json"
+with open(template_file, "w") as f:
+    json.dump(template, f, indent=2)
+
+# Read the template file as a string
+with open(template_file, "r") as f:
+    template_str = f.read()
+
+# Run cfn-lint on the template with our new rule
+rule = ManagedPolicySize()
+matches = rule.match_json(template_str)
+
+# Print the results
+print(f"Found {len(matches)} issues:")
+for match in matches:
+    print(f"{match.rule.id}: {match.message}")
+
+# Clean up
+template_file.unlink()
