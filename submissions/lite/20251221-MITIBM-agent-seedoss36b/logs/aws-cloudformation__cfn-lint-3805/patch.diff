@@ -0,0 +1,90 @@
+"""
+Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.
+SPDX-License-Identifier: MIT-0
+"""
+
+import json
+import re
+from typing import Any
+
+from cfnlint.helpers import FUNCTIONS
+from cfnlint.jsonschema import ValidationError
+from cfnlint.rules import CloudFormationLintRule
+
+
+class ManagedPolicySize(CloudFormationLintRule):
+    """Check if an IAM ManagedPolicy size is within the limit"""
+
+    id = "E3511"
+    shortdesc = "Check if an IAM ManagedPolicy size is within the limit"
+    description = "Check if an IAM ManagedPolicy size is within the limit. IAM doesn't count whitespace when calculating the size of a policy against this limit."
+    source_url = "https://docs.aws.amazon.com/IAM/latest/UserGuide/reference_iam-quotas.html#reference_iam-quotas-entity-length"
+    tags = ["resources", "iam", "managedpolicy", "size"]
+
+    def _remove_whitespace(self, policy_str):
+        """Remove whitespace from policy string"""
+        return re.sub(r'\s', '', policy_str)
+
+    def _remove_functions(self, obj: Any) -> Any:
+        """Replaces intrinsic functions with string"""
+        if isinstance(obj, dict):
+            new_obj = {}
+            if len(obj) == 1:
+                k = next(iter(obj))
+                v = obj[k]
+                if k in FUNCTIONS:
+                    return ""
+                else:
+                    new_obj[k] = self._remove_functions(v)
+                    return new_obj
+            else:
+                for k, v in obj.items():
+                    new_obj[k] = self._remove_functions(v)
+                return new_obj
+        elif isinstance(obj, list):
+            new_list = []
+            for v in obj:
+                new_list.append(self._remove_functions(v))
+            return new_list
+
+        return obj
+
+    def match(self, cfn):
+        """Check IAM ManagedPolicy size"""
+        matches = []
+
+        resources = cfn.get_resources(['AWS::IAM::ManagedPolicy'])
+
+        for resource_name, resource in resources.items():
+            properties = resource.get('Properties', {})
+            policy_document = properties.get('PolicyDocument')
+            
+            if not policy_document:
+                continue
+
+            # Handle both string and object policy documents
+            if isinstance(policy_document, str):
+                try:
+                    policy_str = policy_document
+                except Exception:
+                    # If we can't parse the policy, skip it
+                    continue
+            else:
+                # For object policy documents, convert to JSON string
+                try:
+                    # Remove intrinsic functions before serializing
+                    clean_policy = self._remove_functions(policy_document)
+                    policy_str = json.dumps(clean_policy)
+                except Exception:
+                    # If we can't serialize the policy, skip it
+                    continue
+
+            # Remove whitespace to match IAM's calculation method
+            compact_policy = self._remove_whitespace(policy_str)
+            
+            # Check if the policy exceeds the 6144 character limit
+            if len(compact_policy) > 6144:
+                message = f"IAM ManagedPolicy {resource_name} size ({len(compact_policy)}) exceeds the limit of 6144 characters (compact size without whitespace)"
+                matches.append(self.create_match(message, resource_name, cfn))
+
+        return matches
