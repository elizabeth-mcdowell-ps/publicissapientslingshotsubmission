+"""
+Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.
+SPDX-License-Identifier: MIT-0
+"""
+
+import json
+from test.testlib.testcase import BaseTestCase
+
+from cfnlint.rules.resources.iam.ManagedPolicySize import ManagedPolicySize
+
+
+class TestManagedPolicySize(BaseTestCase):
+    """Test IAM ManagedPolicy Size"""
+
+    def setUp(self):
+        """Setup"""
+        super(TestManagedPolicySize, self).setUp()
+        self.collection.register(ManagedPolicySize())
+        self.success_templates = [
+            'test/fixtures/templates/good/resources/iam/managed_policy.yaml',
+        ]
+
+    def test_file_positive(self):
+        """Test Positive"""
+        self.helper_file_positive()
+
+    def test_file_negative(self):
+        """Test failure"""
+        self.helper_file_negative('test/fixtures/templates/bad/resources/iam/managed_policy_size.yaml', 1)
+
+    def test_policy_size_object(self):
+        """Test policy size with object"""
+        template = {
+            'Resources': {
+                'ManagedPolicy': {
+                    'Type': 'AWS::IAM::ManagedPolicy',
+                    'Properties': {
+                        'PolicyDocument': {
+                            'Version': '2012-10-17',
+                            'Statement': [
+                                {
+                                    'Effect': 'Allow',
+                                    'Action': ['service:Action' + str(i) for i in range(1000)],
+                                    'Resource': '*'
+                                }
+                            ]
+                        }
+                    }
+                }
+            }
+        }
+
+        # Convert to JSON string to simulate CloudFormation template
+        template_str = json.dumps(template)
+        
+        # Run the rule
+        matches = self.run_check(ManagedPolicySize(), template_str)
+        
+        # Should have one match (error)
+        self.assertEqual(len(matches), 1)
+        
+    def test_policy_size_string(self):
+        """Test policy size with string"""
+        # Create a large policy document as a string
+        actions = ', '.join([f'"service:Action{i}"' for i in range(1000)])
+        policy_str = f'{{"Version": "2012-10-17", "Statement": [{{"Effect": "Allow", "Action": [{actions}], "Resource": "*"}}]}}'
+        
+        template = {
+            'Resources': {
+                'ManagedPolicy': {
+                    'Type': 'AWS::IAM::ManagedPolicy',
+                    'Properties': {
+                        'PolicyDocument': policy_str
+                    }
+                }
+            }
+        }
+
+        # Convert to JSON string to simulate CloudFormation template
+        template_str = json.dumps(template)
+        
+        # Run the rule
+        matches = self.run_check(ManagedPolicySize(), template_str)
+        
+        # Should have one match (error)
+        self.assertEqual(len(matches), 1)
+        
+    def test_policy_size_small(self):
+        """Test policy size with small policy"""
+        template = {
+            'Resources': {
+                'ManagedPolicy': {
+                    'Type': 'AWS::IAM::ManagedPolicy',
+                    'Properties': {
+                        'PolicyDocument': {
+                            'Version': '2012-10-17',
+                            'Statement': [
+                                {
+                                    'Effect': 'Allow',
+                                    'Action': ['service:Action1', 'service:Action2'],
+                                    'Resource': '*'
+                                }
+                            ]
+                        }
+                    }
+                }
+            }
+        }
+
+        # Convert to JSON string to simulate CloudFormation template
+        template_str = json.dumps(template)
+        
+        # Run the rule
+        matches = self.run_check(ManagedPolicySize(), template_str)
+        
+        # Should have no matches (no errors)
+        self.assertEqual(len(matches), 0)
