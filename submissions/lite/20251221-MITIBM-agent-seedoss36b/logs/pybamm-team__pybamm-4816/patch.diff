new file mode 100644
index 000000000..ab816c84c
--- /dev/null
+++ b/test_axen_ocp.py
@@ -0,0 +1,64 @@
+import pybamm
+import matplotlib.pyplot as plt
+import numpy as np
+
+# Create a model with Axen OCP
+options = {"open-circuit potential": "Axen"}
+model = pybamm.lithium_ion.DFN(options=options)
+
+# Create a parameter set with silicon electrode (which typically shows hysteresis)
+parameter_values = pybamm.ParameterValues("Chen2020_composite")
+
+# Define lithiation and delithiation OCP functions for negative electrode
+def neg_ocp_lith(sto):
+    # Example lithiation curve (simplified)
+    return 0.1 + 1.5 * np.exp(-80 * (sto - 0.1)) - 0.05 * sto
+
+def neg_ocp_delith(sto):
+    # Example delithiation curve (simplified)
+    return 0.2 + 1.5 * np.exp(-80 * (sto - 0.1)) - 0.05 * sto
+
+parameter_values.update({
+    "Negative electrode lithiation OCP [V]": neg_ocp_lith,
+    "Negative electrode delithiation OCP [V]": neg_ocp_delith,
+}, check_already_exists=False)
+
+# Set hysteresis parameters
+parameter_values.update({
+    "Negative particle hysteresis lithiation decay rate": 1.0,
+    "Negative particle hysteresis delithiation decay rate": 0.5,
+    "Initial hysteresis state in negative electrode": 0.5,
+    "Positive particle hysteresis lithiation decay rate": 0.0,
+    "Positive particle hysteresis delithiation decay rate": 0.0,
+    "Initial hysteresis state in positive electrode": 0.0,
+}, check_already_exists=False)
+
+# Create experiment with charge and discharge
+experiment = pybamm.Experiment(
+    [
+        "Discharge at C/5 for 2 hours",
+        "Rest for 30 minutes",
+        "Charge at C/5 for 2 hours",
+        "Rest for 30 minutes",
+    ]
+)
+
+# Simulate
+sim = pybamm.Simulation(model, parameter_values=parameter_values, experiment=experiment)
+sim.solve()
+
+# Plot results
+solution = sim.solution
+t = solution["Time [h]"].entries
+voltage = solution["Terminal voltage [V]"].entries
+
+plt.figure()
+plt.plot(t, voltage)
+plt.xlabel("Time [h]")
+plt.ylabel("Voltage [V]")
+plt.title("Axen OCP Model Simulation")
+plt.grid(True)
+plt.savefig("axen_ocp_test.png")
+
+print("Simulation completed successfully!")
+print("The Axen OCP model has been implemented and tested.")
