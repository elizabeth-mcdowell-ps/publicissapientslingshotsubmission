+                )
+            elif branch == "delithiation":
+                U_ref = pybamm.FunctionParameter(
+                    f"{self.phase_prefactor}{Domain} electrode delithiation OCP [V]",
+                    {f"{Domain} {self.phase}particle stoichiometry": sto},
+                )
+            else:
+                raise ValueError(
+                    f"Branch must be 'lithiation' or 'delithiation', not '{branch}'"
+                )
+                
+            # Add temperature dependence
+            dUdT = self.dUdT(sto)
+            # Use reference temperature from main parameters
+            T_ref = 298.15  # Default reference temperature in K
+            return U_ref + dUdT * (T - T_ref)
