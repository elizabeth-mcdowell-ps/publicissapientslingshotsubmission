+from pathlib import Path
+import time
+from haystack.core.pipeline import Pipeline
+from haystack.testing.sample_components import AddFixedValue, Double
+
+def create_complex_pipeline():
+    """Create a complex pipeline to potentially trigger timeout issues"""
+    pipe = Pipeline()
+    
+    # Add many components to make the diagram more complex
+    for i in range(10):
+        pipe.add_component(f"add_{i}", AddFixedValue(add=i))
+        pipe.add_component(f"double_{i}", Double())
+    
+    # Create many connections
+    for i in range(9):
+        pipe.connect(f"add_{i}", f"add_{i+1}")
+        pipe.connect(f"double_{i}", f"double_{i+1}")
+        pipe.connect(f"add_{i}", f"double_{i}")
+        pipe.connect(f"double_{i}", f"add_{i+1}")
+    
+    # Connect the last components
+    pipe.connect("add_9", "double_9")
+    
+    return pipe
+
+def main():
+    # Create a complex pipeline
+    print("Creating pipeline...")
+    pipe = create_complex_pipeline()
+    
+    # Try to draw the pipeline
+    output_path = Path("pipeline_diagram.png")
+    print(f"Drawing pipeline to {output_path}...")
+    
+    start_time = time.time()
+    try:
+        pipe.draw(path=output_path)
+        print(f"Pipeline drawing completed in {time.time() - start_time:.2f} seconds")
+    except Exception as e:
+        print(f"Error drawing pipeline after {time.time() - start_time:.2f} seconds: {e}")
+    
+if __name__ == "__main__":
+    main()
