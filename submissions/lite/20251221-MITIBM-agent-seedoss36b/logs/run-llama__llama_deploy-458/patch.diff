+import unittest
+from unittest.mock import patch, MagicMock, AsyncMock
+import json
+import sys
+import asyncio
+
+# Add the testbed directory to the Python path
+sys.path.append('/testbed')
+
+# Import the function we want to test
+from llama_deploy.apiserver.routers.deployments import create_deployment_task
+from llama_deploy.types import TaskDefinition
+
+class TestCreateDeploymentTask(unittest.TestCase):
+    def setUp(self):
+        # Create mock objects
+        self.mock_deployment = MagicMock()
+        self.mock_deployment.default_service = "default-service"
+        self.mock_deployment.service_names = ["default-service", "custom-service"]
+        
+        # Mock session
+        self.mock_session = AsyncMock()
+        self.mock_session.run = AsyncMock(return_value="Test result")
+        self.mock_session.id = "test-session-id"
+        
+        # Mock client
+        self.mock_client = MagicMock()
+        self.mock_client.core.sessions.create = AsyncMock(return_value=self.mock_session)
+        self.mock_client.core.sessions.get = AsyncMock(return_value=self.mock_session)
+        self.mock_client.core.sessions.delete = AsyncMock()
+        
+        # Set up the deployment client
+        self.mock_deployment.client = self.mock_client
+    
+    async def test_with_service_parameter(self):
+        """Test that the 'service' parameter is correctly used."""
+        # Create a task definition with 'service' parameter
+        task_definition = {
+            "input": json.dumps({"test_key": "test_value"}),
+            "service": "custom-service"
+        }
+        
+        # Mock the manager.get_deployment function
+        with patch('llama_deploy.apiserver.routers.deployments.manager') as mock_manager:
+            mock_manager.get_deployment.return_value = self.mock_deployment
+            
+            # Call the function
+            response = await create_deployment_task(
+                deployment_name="test-deployment",
+                task_definition=task_definition,
+                session_id=None
+            )
+            
+            # Verify the session.run was called with the correct service name
+            self.mock_session.run.assert_called_once()
+            args, kwargs = self.mock_session.run.call_args
+            self.assertEqual(args[0], "custom-service")
+            
+            # Verify the session was deleted
+            self.mock_client.core.sessions.delete.assert_called_once_with(self.mock_session.id)
+    
+    async def test_with_agent_id_parameter(self):
+        """Test that the 'agent_id' parameter is correctly used."""
+        # Create a task definition with 'agent_id' parameter
+        task_definition = {
+            "input": json.dumps({"test_key": "test_value"}),
+            "agent_id": "custom-service"
+        }
+        
+        # Mock the manager.get_deployment function
+        with patch('llama_deploy.apiserver.routers.deployments.manager') as mock_manager:
+            mock_manager.get_deployment.return_value = self.mock_deployment
+            
+            # Call the function
+            response = await create_deployment_task(
+                deployment_name="test-deployment",
+                task_definition=task_definition,
+                session_id=None
+            )
+            
+            # Verify the session.run was called with the correct service name
+            self.mock_session.run.assert_called_once()
+            args, kwargs = self.mock_session.run.call_args
+            self.assertEqual(args[0], "custom-service")
+            
+            # Verify the session was deleted
+            self.mock_client.core.sessions.delete.assert_called_once_with(self.mock_session.id)
+    
+    async def test_with_default_service(self):
+        """Test that the default service is used when no service is specified."""
+        # Create a task definition with no service parameter
+        task_definition = {
+            "input": json.dumps({"test_key": "test_value"})
+        }
+        
+        # Mock the manager.get_deployment function
+        with patch('llama_deploy.apiserver.routers.deployments.manager') as mock_manager:
+            mock_manager.get_deployment.return_value = self.mock_deployment
+            
+            # Call the function
+            response = await create_deployment_task(
+                deployment_name="test-deployment",
+                task_definition=task_definition,
+                session_id=None
+            )
+            
+            # Verify the session.run was called with the default service name
+            self.mock_session.run.assert_called_once()
+            args, kwargs = self.mock_session.run.call_args
+            self.assertEqual(args[0], "default-service")
+            
+            # Verify the session was deleted
+            self.mock_client.core.sessions.delete.assert_called_once_with(self.mock_session.id)
+
+def run_tests():
+    # Create a test suite
+    suite = unittest.TestSuite()
+    
+    # Add the test cases
+    test_case = TestCreateDeploymentTask()
+    suite.addTest(asyncio.run(test_case.test_with_service_parameter()))
+    suite.addTest(asyncio.run(test_case.test_with_agent_id_parameter()))
+    suite.addTest(asyncio.run(test_case.test_with_default_service()))
+    
+    # Run the tests
+    runner = unittest.TextTestRunner()
+    runner.run(suite)
+
+if __name__ == "__main__":
+    # Run the tests
+    asyncio.run(TestCreateDeploymentTask().test_with_service_parameter())
+    asyncio.run(TestCreateDeploymentTask().test_with_agent_id_parameter())
+    asyncio.run(TestCreateDeploymentTask().test_with_default_service())
+    print("All tests passed!")
