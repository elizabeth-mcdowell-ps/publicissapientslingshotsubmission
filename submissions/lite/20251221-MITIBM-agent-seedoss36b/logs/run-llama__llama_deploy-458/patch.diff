+"""
+This is a simple test to verify our fix for the service parameter issue.
+
+The issue is that when calling the API endpoint to run a specific deployment service,
+the service parameter is being ignored. The fix is to modify the deployments.py router
+to handle both 'service' and 'agent_id' parameters.
+
+Our changes:
+1. Changed the parameter type from TaskDefinition to dict in create_deployment_task
+2. Added code to convert 'service' to 'agent_id' if present
+3. Then created a TaskDefinition from the modified dict
+4. Made the same changes to create_deployment_task_nowait for consistency
+"""
+
+import json
+
+def test_service_parameter_fix():
+    # Test case 1: Using 'service' parameter
+    task_definition_with_service = {
+        "input": json.dumps({"test_key": "test_value"}),
+        "service": "custom-service"
+    }
+    
+    # This simulates our fix in the deployments.py router
+    if "service" in task_definition_with_service and task_definition_with_service.get("agent_id") is None:
+        task_definition_with_service["agent_id"] = task_definition_with_service.pop("service")
+    
+    # Verify the 'service' parameter was correctly converted to 'agent_id'
+    assert "service" not in task_definition_with_service, "The 'service' parameter should be removed"
+    assert task_definition_with_service["agent_id"] == "custom-service", "The 'agent_id' should be set to 'custom-service'"
+    
+    print("✅ Test case 1 passed: 'service' parameter is correctly converted to 'agent_id'")
+    
+    # Test case 2: Using 'agent_id' parameter
+    task_definition_with_agent_id = {
+        "input": json.dumps({"test_key": "test_value"}),
+        "agent_id": "custom-service"
+    }
+    
+    # This simulates our fix in the deployments.py router
+    if "service" in task_definition_with_agent_id and task_definition_with_agent_id.get("agent_id") is None:
+        task_definition_with_agent_id["agent_id"] = task_definition_with_agent_id.pop("service")
+    
+    # Verify the 'agent_id' parameter is preserved
+    assert task_definition_with_agent_id["agent_id"] == "custom-service", "The 'agent_id' should remain 'custom-service'"
+    
+    print("✅ Test case 2 passed: 'agent_id' parameter is preserved")
+    
+    # Test case 3: Using both 'service' and 'agent_id' parameters (agent_id should take precedence)
+    task_definition_with_both = {
+        "input": json.dumps({"test_key": "test_value"}),
+        "service": "service-value",
+        "agent_id": "agent-id-value"
+    }
+    
+    # This simulates our fix in the deployments.py router
+    if "service" in task_definition_with_both and task_definition_with_both.get("agent_id") is None:
+        task_definition_with_both["agent_id"] = task_definition_with_both.pop("service")
+    
+    # Verify that 'agent_id' takes precedence over 'service'
+    assert "service" in task_definition_with_both, "The 'service' parameter should be preserved"
+    assert task_definition_with_both["agent_id"] == "agent-id-value", "The 'agent_id' should remain 'agent-id-value'"
+    
+    print("✅ Test case 3 passed: 'agent_id' takes precedence over 'service' when both are present")
+    
+    print("\nAll tests passed! The fix correctly handles the 'service' parameter.")
+
+if __name__ == "__main__":
+    test_service_parameter_fix()
