+import asyncio
+import json
+import httpx
+from typing import Dict, Any
+
+async def make_api_call(server: str, deployment: str, payload: Dict[str, Any]) -> httpx.Response:
+    """Make an API call to the deployment tasks/run endpoint"""
+    url = f"{server}/deployments/{deployment}/tasks/run"
+    print(f"Making API call to {url} with payload: {payload}")
+    
+    async with httpx.AsyncClient() as client:
+        try:
+            response = await client.post(url, json=payload)
+            print(f"Status code: {response.status_code}")
+            print(f"Response: {response.text}")
+            return response
+        except Exception as e:
+            print(f"Error: {e}")
+            raise
+
+async def test_service_parameter():
+    # Replace these with appropriate values for your environment
+    server = "http://localhost:4501"  # Default API server URL
+    deployment = "test-deployment"    # Replace with an actual deployment name
+    service = "custom-service"        # Service name that should be used
+    args = {"test_key": "test_value"} # Test arguments
+    
+    # Test with 'service' parameter (should work with our fix)
+    print("\n=== Testing with 'service' parameter ===")
+    service_payload = {"input": json.dumps(args), "service": service}
+    try:
+        response = await make_api_call(server, deployment, service_payload)
+        if response.status_code == 200:
+            print("✅ Success: The API call with 'service' parameter worked!")
+        else:
+            print("❌ Error: The API call with 'service' parameter failed!")
+    except Exception as e:
+        print(f"❌ Error with 'service' parameter: {e}")
+    
+    # Test with 'agent_id' parameter (should work in both original and fixed code)
+    print("\n=== Testing with 'agent_id' parameter ===")
+    agent_id_payload = {"input": json.dumps(args), "agent_id": service}
+    try:
+        response = await make_api_call(server, deployment, agent_id_payload)
+        if response.status_code == 200:
+            print("✅ Success: The API call with 'agent_id' parameter worked!")
+        else:
+            print("❌ Error: The API call with 'agent_id' parameter failed!")
+    except Exception as e:
+        print(f"❌ Error with 'agent_id' parameter: {e}")
+
+if __name__ == "__main__":
+    asyncio.run(test_service_parameter())
