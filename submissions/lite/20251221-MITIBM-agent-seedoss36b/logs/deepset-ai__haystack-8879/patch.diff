+"""
+This script verifies that our fix for the streaming + tools issue works correctly.
+It directly tests the _convert_streaming_chunks_to_chat_message method with malformed JSON.
+"""
+
+import json
+from unittest.mock import MagicMock
+from haystack.components.generators.chat.openai import OpenAIChatGenerator
+from haystack.dataclasses import StreamingChunk
+from haystack.utils import Secret
+
+# Create a generator instance
+generator = OpenAIChatGenerator(
+    api_key=Secret.from_token("dummy-key"),
+    model="gpt-3.5-turbo"
+)
+
+# Create a mock chunk with malformed JSON in tool calls
+mock_chunk = MagicMock()
+mock_chunk.model = "gpt-3.5-turbo"
+mock_choice = MagicMock()
+mock_choice.finish_reason = "stop"
+mock_chunk.choices = [mock_choice]
+
+# Create a streaming chunk with malformed JSON in tool calls
+streaming_chunk = StreamingChunk(
+    content="Natural Language Processing",
+    meta={
+        "tool_calls": [
+            MagicMock(
+                id="call_50zabXcv03CQ88cylmKt6Jbl",
+                function=MagicMock(
+                    name="rag_pipeline_tool",
+                    arguments='{"query": "NLP"'  # Intentionally malformed JSON
+                )
+            )
+        ],
+        "received_at": "2023-09-24T12:00:00Z"
+    }
+)
+
+# Test the _convert_streaming_chunks_to_chat_message method
+print("Testing _convert_streaming_chunks_to_chat_message with malformed JSON...")
+result = generator._convert_streaming_chunks_to_chat_message(mock_chunk, [streaming_chunk])
+
+print("\nResult:")
+print(f"Text: {result.text}")
+print(f"Tool calls: {result.tool_calls}")
+
+# Verify that tool_calls is not empty even with malformed JSON
+if result.tool_calls:
+    print("\nSuccess! Tool calls are included even with malformed JSON.")
+    print(f"Tool call ID: {result.tool_calls[0].id}")
+    print(f"Tool name: {result.tool_calls[0].tool_name}")
+    print(f"Arguments: {result.tool_calls[0].arguments}")
+else:
+    print("\nFailed! Tool calls are empty.")
+
+# Simulate the tutorial code that was failing
+tool_result_messages = []
+if result.tool_calls:
+    for tool_call in result.tool_calls:
+        print(f"\nProcessing tool call: {tool_call.tool_name}")
+        # We can now process the tool call even if the original JSON was malformed
+        # because we have an empty dict for arguments instead of nothing
+        tool_result_messages.append(MagicMock())
+
+# This line was failing in the tutorial
+messages = [MagicMock()] + [result] + tool_result_messages
+print(f"\nCombined messages length: {len(messages)}")
+print("Test passed! The fix works correctly.")
