+"""
+This script verifies that our fix for the streaming + tools issue works correctly.
+It simulates a scenario with malformed JSON in tool calls.
+"""
+
+import json
+from unittest.mock import MagicMock, patch
+from haystack.components.generators.chat import OpenAIChatGenerator
+from haystack.dataclasses import ChatMessage, StreamingChunk
+from haystack.tools.tool import Tool
+
+# Define a simple tool
+def rag_pipeline_tool(query: str) -> str:
+    """
+    A simple RAG pipeline tool that returns a fixed response for testing.
+    
+    Args:
+        query: The query to search for
+        
+    Returns:
+        A response to the query
+    """
+    return f"Here's information about: {query}"
+
+# Create a tool instance
+tool = Tool(
+    name="rag_pipeline_tool",
+    description="Search for information using RAG",
+    function=rag_pipeline_tool,
+    parameters={"type": "object", "properties": {"query": {"type": "string"}}, "required": ["query"]}
+)
+
+# Create a user message
+user_messages = [ChatMessage.from_user("What is NLP? Use the rag_pipeline_tool to find out.")]
+
+# Define a streaming callback to capture chunks
+chunks = []
+def streaming_callback(chunk):
+    chunks.append(chunk)
+    print(f"Received chunk: {chunk}")
+
+# Create a custom mock for the OpenAI client
+class MockOpenAI:
+    def __init__(self, *args, **kwargs):
+        pass
+    
+    @property
+    def chat(self):
+        return self
+    
+    @property
+    def completions(self):
+        return self
+    
+    def create(self, **kwargs):
+        # Create a mock for the streaming response
+        class MockStream:
+            def __iter__(self):
+                # Create a mock for the chat completion chunk with malformed JSON
+                mock_chunk = MagicMock()
+                mock_choice = MagicMock()
+                mock_choice.delta.content = "Natural Language Processing"
+                mock_choice.delta.tool_calls = [
+                    MagicMock(
+                        index=0,
+                        id="call_50zabXcv03CQ88cylmKt6Jbl",
+                        function=MagicMock(
+                            name="rag_pipeline_tool",
+                            arguments='{"query": "NLP"'  # Intentionally malformed JSON
+                        )
+                    )
+                ]
+                mock_choice.finish_reason = None
+                mock_chunk.choices = [mock_choice]
+                mock_chunk.model = "gpt-3.5-turbo"
+                
+                yield mock_chunk
+        
+        # Make the mock stream look like a Stream object
+        mock_stream = MockStream()
+        
+        # Add the Stream type to make isinstance(mock_stream, Stream) return True
+        from openai import Stream
+        mock_stream.__class__ = type('MockStream', (MockStream, Stream), {})
+        
+        return mock_stream
+
+# Initialize the OpenAI chat generator with streaming and tools
+from haystack.utils import Secret
+generator = OpenAIChatGenerator(
+    api_key=Secret.from_token("dummy-key"),
+    model="gpt-3.5-turbo",
+    tools=[tool]
+)
+
+# Patch the client after initialization
+generator.client = MockOpenAI()
+
+# Run the generator with streaming
+try:
+    print("Running with streaming + tools...")
+    response = generator.run(
+        messages=user_messages,
+        streaming_callback=streaming_callback
+    )
+    
+    print("\nResponse:", response)
+    
+    # Process tool calls if any
+    tool_result_messages = []
+    for reply in response["replies"]:
+        print(f"\nReply: {reply}")
+        print(f"Tool calls: {reply.tool_calls}")
+        
+        if reply.tool_calls:
+            for tool_call in reply.tool_calls:
+                print(f"Tool call: {tool_call.tool_name}, Arguments: {tool_call.arguments}")
+                # Execute the tool if arguments are valid
+                if tool_call.tool_name == "rag_pipeline_tool" and tool_call.arguments:
+                    try:
+                        result = rag_pipeline_tool(**tool_call.arguments)
+                        # Create a tool result message
+                        tool_result_message = ChatMessage.from_tool_result(
+                            content=result,
+                            tool_call_id=tool_call.id
+                        )
+                        tool_result_messages.append(tool_result_message)
+                    except Exception as e:
+                        print(f"Error executing tool: {e}")
+    
+    # This is where the error occurred in the tutorial
+    # Now it should work because tool_result_messages is defined
+    messages = user_messages + response["replies"] + tool_result_messages
+    
+    print("\nTool result messages:", tool_result_messages)
+    print("\nCombined messages:", messages)
+    print("\nTest passed! The fix works correctly.")
+    
+except Exception as e:
+    print(f"Error occurred: {type(e).__name__}: {e}")
+    import traceback
+    traceback.print_exc()
