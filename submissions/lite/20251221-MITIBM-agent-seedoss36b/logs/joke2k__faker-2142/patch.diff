@@ -66,3 +66,33 @@ class Provider(BankProvider):
     def bank(self) -> str:
         """Generate a bank name."""
         return self.random_element(self.banks)
+        
+    def bban(self) -> str:
+        """Generate a Belgian Basic Bank Account Number (BBAN).
+        
+        Belgian BBAN consists of 3-digit bank code, 7-digit account number,
+        and 2-digit check digits. The check digits are calculated as 
+        97 - (account_number % 97) or 00 if the result is 97.
+        """
+        # Generate the bank code (3 digits) and account number (7 digits)
+        bank_code = self.numerify("###")
+        account_number = self.numerify("#######")
+        
+        # Calculate the check digits (last 2 digits)
+        # The check digits are calculated as 97 - (number % 97)
+        # If the result is 97, the check digits are 00
+        number = int(bank_code + account_number)
+        remainder = number % 97
+        
+        # Special case: if remainder is 0, check digits should be 97
+        # Otherwise, check digits are 97 - remainder
+        if remainder == 0:
+            check_digits = 97
+        else:
+            check_digits = 97 - remainder
+            
+        # Format as two digits (00-97)
+        check_digits_str = f"{check_digits:02d}"
+            
+        # Combine to form the complete 12-digit BBAN
+        return f"{bank_code}{account_number}{check_digits_str}"
