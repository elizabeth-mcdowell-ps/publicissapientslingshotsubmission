+#!/usr/bin/env python3
+
+import os
+import sys
+from pathlib import Path
+
+# First, let's check if the embedding model exists
+from instructlab.defaults import DEFAULTS
+from instructlab.cli.model.download import download
+
+# Mock the download function to avoid actual downloads
+from unittest.mock import patch, MagicMock
+import click
+
+# Get the embedding model path
+embedding_model_path = Path(DEFAULTS.MODELS_DIR) / DEFAULTS.GRANITE_EMBEDDING_MODEL_NAME
+
+print(f"Checking embedding model path: {embedding_model_path}")
+
+# Create a mock context
+ctx = MagicMock()
+ctx.obj.config.general.log_level = "info"
+
+# Check if the embedding model is included in the default repositories
+print("\nChecking if embedding model is included in default repositories...")
+repositories = download.params[0].default
+print(f"Default repositories: {repositories}")
+
+if DEFAULTS.GRANITE_EMBEDDING_MODEL_NAME in repositories:
+    print(f"SUCCESS: Embedding model {DEFAULTS.GRANITE_EMBEDDING_MODEL_NAME} is included in default repositories")
+else:
+    print(f"FAILURE: Embedding model {DEFAULTS.GRANITE_EMBEDDING_MODEL_NAME} is NOT included in default repositories")
+
+# Check if the corresponding release and filename are properly set
+releases = download.params[1].default
+filenames = download.params[2].default
+
+print(f"\nDefault releases: {releases}")
+print(f"Default filenames: {filenames}")
+
+# Check if the lengths match
+if len(repositories) == len(releases) == len(filenames):
+    print("SUCCESS: The lengths of repositories, releases, and filenames match")
+else:
+    print("FAILURE: The lengths of repositories, releases, and filenames do not match")
+    print(f"Repositories: {len(repositories)}, Releases: {len(releases)}, Filenames: {len(filenames)}")
+
+# Find the index of the embedding model in repositories
+try:
+    embedding_index = repositories.index(DEFAULTS.GRANITE_EMBEDDING_MODEL_NAME)
+    print(f"\nEmbedding model found at index {embedding_index}")
+    print(f"Corresponding release: {releases[embedding_index]}")
+    print(f"Corresponding filename: {filenames[embedding_index]}")
+except ValueError:
+    print("\nEmbedding model not found in repositories list")
+
+print("\nVerification complete!")
