+import os
+import trimesh
+import numpy as np
+
+# Create a temporary directory for testing
+os.makedirs('./temp', exist_ok=True)
+
+# Test all SVG elements
+svg_content = """<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg">
+  <!-- Rectangle -->
+  <rect x="10" y="10" width="80" height="40" fill="none" stroke="black" stroke-width="1"/>
+  
+  <!-- Circle -->
+  <circle cx="150" cy="30" r="20" fill="none" stroke="black" stroke-width="1"/>
+  
+  <!-- Ellipse -->
+  <ellipse cx="50" cy="100" rx="40" ry="20" fill="none" stroke="black" stroke-width="1"/>
+  
+  <!-- Line -->
+  <line x1="100" y1="80" x2="180" y2="120" stroke="black" stroke-width="1"/>
+  
+  <!-- Polyline -->
+  <polyline points="10,150 30,130 50,150 70,130 90,150" fill="none" stroke="black" stroke-width="1"/>
+  
+  <!-- Polygon -->
+  <polygon points="120,130 140,150 160,150 180,130 150,110" fill="none" stroke="black" stroke-width="1"/>
+  
+  <!-- Path -->
+  <path d="M 10,180 Q 50,120 90,180 T 170,180" fill="none" stroke="black" stroke-width="1"/>
+</svg>"""
+
+svg_path = './temp/comprehensive_test.svg'
+with open(svg_path, "w") as file:
+    file.write(svg_content)
+
+print("Testing comprehensive SVG with multiple elements...")
+try:
+    path = trimesh.load_path(svg_path, file_type='svg')
+    print("Path loaded successfully")
+    print(f"Number of entities: {len(path.entities)}")
+    print(f"Number of vertices: {len(path.vertices)}")
+    
+    # Verify we have the expected number of entities (7 elements in the SVG)
+    assert len(path.entities) > 0, "No entities were loaded"
+    
+    # Extrude to test if the paths are valid
+    mesh = path.extrude(3)
+    print("Mesh extruded successfully")
+    
+    # The mesh might be a list of meshes if there are multiple disconnected paths
+    if isinstance(mesh, list):
+        print(f"Mesh is a list of {len(mesh)} meshes")
+        
+        # Create a scene with all meshes
+        scene = trimesh.Scene()
+        for i, m in enumerate(mesh):
+            scene.add_geometry(m, node_name=f"mesh_{i}")
+        
+        # Export the scene to GLTF
+        gltf_path = './temp/comprehensive_test.glb'
+        scene.export(gltf_path)
+        print(f"Scene exported to {gltf_path}")
+        
+        # Verify the GLTF file exists and has content
+        assert os.path.exists(gltf_path), "GLTF file was not created"
+        assert os.path.getsize(gltf_path) > 0, "GLTF file is empty"
+    else:
+        # Export to STL to verify the mesh is valid
+        stl_path = './temp/comprehensive_test.stl'
+        mesh.export(stl_path)
+        print(f"Mesh exported to {stl_path}")
+        
+        # Verify the STL file exists and has content
+        assert os.path.exists(stl_path), "STL file was not created"
+        assert os.path.getsize(stl_path) > 0, "STL file is empty"
+    
+    print("All tests passed!")
+except Exception as e:
+    print(f"Error: {e}")
+
+# Clean up
+import shutil
+shutil.rmtree('./temp')
