+import os
+import tempfile
+import shutil
+import subprocess
+from pathlib import Path
+
+# Create a temporary directory for our test
+temp_dir = tempfile.mkdtemp()
+print(f"Created temporary directory: {temp_dir}")
+
+try:
+    # Create a package with both regular requires and test_requires
+    pkg_dir = os.path.join(temp_dir, "pkg")
+    os.makedirs(pkg_dir)
+    
+    # Create a simple dependency package
+    dep_dir = os.path.join(temp_dir, "dep")
+    os.makedirs(dep_dir)
+    
+    with open(os.path.join(dep_dir, "conanfile.py"), "w") as f:
+        f.write("""
+from conan import ConanFile
+from conan.tools.files import copy
+
+class DepPackage(ConanFile):
+    name = "dep_pkg"
+    version = "1.0"
+    
+    def package(self):
+        copy(self, "conanfile.py", self.source_folder, self.package_folder)
+""")
+    
+    # Create the main package with both regular requires and test_requires
+    with open(os.path.join(pkg_dir, "conanfile.py"), "w") as f:
+        f.write("""
+from conan import ConanFile
+from conan.tools.files import copy
+
+class TestPackage(ConanFile):
+    name = "test_pkg"
+    version = "1.0"
+    
+    def requirements(self):
+        self.requires("dep_pkg/1.0")
+    
+    def build_requirements(self):
+        self.test_requires("non_existent_pkg/1.0")
+    
+    def package(self):
+        copy(self, "conanfile.py", self.source_folder, self.package_folder)
+""")
+    
+    # First create the dependency package
+    os.chdir(dep_dir)
+    print("\nCreating dependency package:")
+    subprocess.run(["conan", "create", "."], check=True)
+    
+    # Now try to export-pkg the main package with our fix
+    os.chdir(pkg_dir)
+    print("\nRunning export-pkg with our fix (should skip test dependencies but process regular dependencies):")
+    result = subprocess.run(["conan", "export-pkg", ".", "--name=test_pkg", "--version=1.0"], 
+                           capture_output=True, text=True)
+    print(result.stdout)
+    print(result.stderr)
+    
+    # Check if the non-existent package was searched for
+    if "non_existent_pkg/1.0" in result.stdout:
+        print("ERROR: The fix didn't work! Still searching for test dependencies.")
+    else:
+        print("SUCCESS: The fix worked! No search for test dependencies.")
+    
+    # Check if the package was successfully created
+    if "Package folder" in result.stdout:
+        print("SUCCESS: Package was created successfully.")
+    else:
+        print("ERROR: Package was not created!")
+        
+    # Now check if we can install the package, which would verify that dependencies were processed
+    print("\nTesting if the package can be installed (verifies dependencies were processed):")
+    install_result = subprocess.run(["conan", "install", "--requires=test_pkg/1.0"], 
+                                   capture_output=True, text=True)
+    print(install_result.stdout)
+    
+    if "dep_pkg/1.0" in install_result.stdout:
+        print("SUCCESS: Regular dependencies are still processed correctly.")
+    else:
+        print("ERROR: Regular dependencies are not being processed!")
+    
+finally:
+    # Clean up
+    shutil.rmtree(temp_dir)
+    print(f"\nRemoved temporary directory: {temp_dir}")
