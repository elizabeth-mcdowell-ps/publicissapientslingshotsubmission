+import sys
+import traceback
+from starlette.middleware.base import BaseHTTPMiddleware
+from starlette.applications import Starlette
+from starlette.routing import Route
+from starlette.requests import Request
+from starlette.responses import JSONResponse
+
+# Create a custom exception
+class MyExc(Exception):
+    pass
+
+# Define route handlers
+async def main_route(request):
+    raise MyExc("Exception from main route")
+
+async def private_route(request):
+    raise MyExc("Exception from private route")
+
+# Create the main app
+main_app = Starlette(debug=True)
+main_app.add_route("/info", main_route)
+
+# Create the private app
+private_app = Starlette(debug=True)
+private_app.add_route("/info", private_route)
+
+# Mount the private app
+main_app.mount("/private", private_app)
+
+# Add middleware
+class CustomMiddleware(BaseHTTPMiddleware):
+    async def dispatch(self, request, call_next):
+        return await call_next(request)
+
+main_app.add_middleware(CustomMiddleware)
+
+# Test function to simulate requests
+async def test_routes():
+    from starlette.testclient import TestClient
+    
+    client = TestClient(main_app)
+    
+    print("Testing main route...")
+    try:
+        response = client.get("/info")
+        print(f"Response: {response.status_code}")
+    except Exception as e:
+        print(f"Exception caught: {e}")
+        traceback.print_exc()
+    
+    print("\nTesting private route...")
+    try:
+        response = client.get("/private/info")
+        print(f"Response: {response.status_code}")
+    except Exception as e:
+        print(f"Exception caught: {e}")
+        traceback.print_exc()
+
+# Run the test
+if __name__ == "__main__":
+    import asyncio
+    asyncio.run(test_routes())
