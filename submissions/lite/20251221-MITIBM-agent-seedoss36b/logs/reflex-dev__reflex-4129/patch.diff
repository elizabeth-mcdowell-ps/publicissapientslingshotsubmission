+import pickle
+
+# Cache for dynamically created classes
+_dynamic_classes = {}
+
+def register_dynamic_class(cls):
+    """Register a dynamically created class to enable pickling."""
+    class_name = cls.__name__
+    _dynamic_classes[class_name] = cls
+    globals()[class_name] = cls
+    return cls
+
+# Base class
+class BaseClass:
+    def __init__(self, value=""):
+        self.value = value
+
+# Static class
+class StaticClass(BaseClass):
+    pass
+
+# Function that creates a dynamic class
+def create_dynamic_class():
+    class DynamicClass(BaseClass):
+        def __str__(self):
+            return f"DynamicClass with value: {self.value}"
+    
+    # Without registration, this will fail to pickle
+    return DynamicClass
+
+# Function that creates a registered dynamic class
+def create_registered_dynamic_class():
+    class RegisteredDynamicClass(BaseClass):
+        def __str__(self):
+            return f"RegisteredDynamicClass with value: {self.value}"
+    
+    # Register the class to enable pickling
+    return register_dynamic_class(RegisteredDynamicClass)
+
+# Create instances
+static_instance = StaticClass("static")
+dynamic_class = create_dynamic_class()
+dynamic_instance = dynamic_class("dynamic")
+registered_class = create_registered_dynamic_class()
+registered_instance = registered_class("registered")
+
+print("Testing pickling of static class instance:")
+try:
+    static_pickle = pickle.dumps(static_instance)
+    static_unpickled = pickle.loads(static_pickle)
+    print(f"Success! Unpickled value: {static_unpickled.value}")
+except Exception as e:
+    print(f"Failed: {e}")
+
+print("\nTesting pickling of dynamic class instance (should fail):")
+try:
+    dynamic_pickle = pickle.dumps(dynamic_instance)
+    dynamic_unpickled = pickle.loads(dynamic_pickle)
+    print(f"Success! Unpickled value: {dynamic_unpickled.value}")
+except Exception as e:
+    print(f"Failed: {e}")
+
+print("\nTesting pickling of registered dynamic class instance:")
+try:
+    registered_pickle = pickle.dumps(registered_instance)
+    registered_unpickled = pickle.loads(registered_pickle)
+    print(f"Success! Unpickled value: {registered_unpickled.value}")
+except Exception as e:
+    print(f"Failed: {e}")
