+def saturation_vapor_pressure(temp_air):
+    r"""
+    Calculate the saturation vapor pressure of water at a given temperature.
+
+    Uses the Gueymard 1993 correlation for saturation vapor pressure.
+
+    Parameters
+    ----------
+    temp_air : numeric
+        ambient air temperature :math:`T`. [C]
+
+    Returns
+    -------
+    e_s : numeric
+        saturation vapor pressure. [millibar]
+
+    References
+    ----------
+    .. [1] C. Gueymard, Assessment of the Accuracy and Computing Speed of
+       simplified saturation vapor equations using a new reference
+       dataset, J. of Applied Meteorology 1993, vol. 32(7), pp.
+       1294-1300.
+    """
+    T = temp_air + 273.15  # Convert to Kelvin                  # noqa: N806
+    
+    # Eq. 1 from Gueymard 1993
+    e_s = np.exp(22.330 - 49.140*(100/T) - 10.922*(100/T)**2 - 0.39015*T/100)
+    
+    return e_s
+
+
+def relative_humidity_from_dewpoint(temp_air, temp_dew):
+    r"""
+    Calculate relative humidity from air temperature and dew point temperature.
+
+    The relative humidity is calculated using the saturation vapor pressure
+    at the air temperature and dew point temperature.
+
+    Parameters
+    ----------
+    temp_air : numeric
+        ambient air temperature. [C]
+    temp_dew : numeric
+        dew point temperature. [C]
+
+    Returns
+    -------
+    relative_humidity : numeric
+        relative humidity. [%]
+
+    Notes
+    -----
+    The formula used is:
+
+    .. math::
+        RH = 100 \frac{e_s(T_d)}{e_s(T)}
+
+    where :math:`RH` is the relative humidity (%), :math:`e_s(T_d)` is the
+    saturation vapor pressure at the dew point temperature, and :math:`e_s(T)`
+    is the saturation vapor pressure at the air temperature.
+
+    References
+    ----------
+    .. [1] MetPy relative_humidity_from_dewpoint function:
+       https://unidata.github.io/MetPy/latest/api/generated/metpy.calc.relative_humidity_from_dewpoint.html
+    """
+    # Calculate saturation vapor pressure at dew point temperature
+    e_s_dewpoint = saturation_vapor_pressure(temp_dew)
+    
+    # Calculate saturation vapor pressure at air temperature
+    e_s_air = saturation_vapor_pressure(temp_air)
+    
+    # Calculate relative humidity
+    relative_humidity = 100.0 * e_s_dewpoint / e_s_air
+    
+    # Ensure relative humidity is between 0 and 100%
+    relative_humidity = np.minimum(np.maximum(relative_humidity, 0), 100)
+    
+    return relative_humidity
+
