+def test_saturation_vapor_pressure():
+    """Test saturation vapor pressure calculation."""
+    temp_air = np.array([-20, 0, 20, 40])
+    e_s = atmosphere.saturation_vapor_pressure(temp_air)
+    expected = np.array([1.25435, 6.11246, 23.39667, 73.87026])
+    assert_allclose(e_s, expected, rtol=0.001)
+
+
+def test_relative_humidity_from_dewpoint():
+    """Test relative humidity calculation from air temperature and dew point."""
+    temp_air = np.array([0, 20, 30])
+    temp_dew = np.array([-10, 10, 20])
+    rh = atmosphere.relative_humidity_from_dewpoint(temp_air, temp_dew)
+    expected = np.array([46.86, 52.50, 55.08])
+    assert_allclose(rh, expected, rtol=0.01)
+    
+    # Test edge cases
+    # Dew point equals air temperature (RH should be 100%)
+    assert_allclose(atmosphere.relative_humidity_from_dewpoint(25.0, 25.0), 100.0)
+    
+    # Dew point higher than air temperature (physically impossible, should be capped at 100%)
+    assert_allclose(atmosphere.relative_humidity_from_dewpoint(25.0, 30.0), 100.0)
+    
+    # Test with pandas Series
