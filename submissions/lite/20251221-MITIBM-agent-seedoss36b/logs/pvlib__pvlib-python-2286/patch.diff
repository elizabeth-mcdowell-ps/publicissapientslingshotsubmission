+"""
+Example script demonstrating how to use dew point temperature to calculate
+spectral mismatch when weather data doesn't include relative humidity or
+precipitable water directly.
+"""
+import pandas as pd
+import numpy as np
+from pvlib.atmosphere import relative_humidity_from_dewpoint, gueymard94_pw
+from pvlib.spectrum.mismatch import spectral_factor_firstsolar
+
+# Create a sample weather dataset with temperature and dew point
+dates = pd.date_range(start='2023-01-01', periods=24, freq='H')
+temp_air = 20 + 5 * np.sin(np.linspace(0, 2*np.pi, 24))  # Temperature varying between 15-25°C
+temp_dew = temp_air - 10 + 2 * np.sin(np.linspace(0, 4*np.pi, 24))  # Dew point 8-12°C below air temp
+
+# Create a DataFrame to simulate weather data
+weather_data = pd.DataFrame({
+    'temp_air': temp_air,
+    'temp_dew': temp_dew,
+    'airmass_absolute': 1.5 + 0.5 * np.sin(np.linspace(0, 2*np.pi, 24))  # Varying airmass
+}, index=dates)
+
+# Calculate relative humidity from dew point
+weather_data['relative_humidity'] = relative_humidity_from_dewpoint(
+    weather_data['temp_air'], 
+    weather_data['temp_dew']
+)
+
+# Calculate precipitable water from temperature and relative humidity
+weather_data['precipitable_water'] = gueymard94_pw(
+    weather_data['temp_air'], 
+    weather_data['relative_humidity']
+)
+
+# Calculate spectral mismatch factor for CdTe modules
+weather_data['spectral_factor_cdte'] = spectral_factor_firstsolar(
+    weather_data['precipitable_water'],
+    weather_data['airmass_absolute'],
+    module_type='cdte'
+)
+
+# Calculate spectral mismatch factor for CIGS modules
+weather_data['spectral_factor_cigs'] = spectral_factor_firstsolar(
+    weather_data['precipitable_water'],
+    weather_data['airmass_absolute'],
+    module_type='cigs'
+)
+
+# Print the results
+print("\nSample hourly weather data with calculated values:")
+print(weather_data.round(3))
+
+# Print a summary of the workflow
+print("\nWorkflow Summary:")
+print("1. Start with temperature and dew point data")
+print("2. Calculate relative humidity using relative_humidity_from_dewpoint()")
+print("3. Calculate precipitable water using gueymard94_pw()")
+print("4. Calculate spectral mismatch factors using spectral_factor_firstsolar()")
+
+# Print statistics
+print("\nStatistics:")
+print(f"Average relative humidity: {weather_data['relative_humidity'].mean():.2f}%")
+print(f"Average precipitable water: {weather_data['precipitable_water'].mean():.4f} cm")
+print(f"Average CdTe spectral factor: {weather_data['spectral_factor_cdte'].mean():.4f}")
+print(f"Average CIGS spectral factor: {weather_data['spectral_factor_cigs'].mean():.4f}")
+
+# Show correlation between variables
+print("\nCorrelation between variables:")
+corr = weather_data[['temp_air', 'temp_dew', 'relative_humidity', 
+                     'precipitable_water', 'spectral_factor_cdte', 
+                     'spectral_factor_cigs']].corr()
+print(corr.round(3))
