+#!/usr/bin/env python
+
+import sys
+import json
+from pathlib import Path
+
+# Add the src directory to the Python path
+sys.path.insert(0, str(Path(__file__).parent / "src"))
+
+from cfnlint.rules.resources.stepfunctions.StateMachineDefinition import StateMachineDefinition
+from cfnlint.jsonschema import Validator
+from cfnlint.template import Template
+
+# Load the template
+with open('statemachine.json', 'r') as f:
+    template_str = f.read()
+    template_json = json.loads(template_str)
+
+# Create a template object
+template = Template(template_str, 'statemachine.json')
+
+# Get the StateMachine resource
+resources = template.get_resources(['AWS::StepFunctions::StateMachine'])
+if not resources:
+    print("No StateMachine resources found")
+    sys.exit(1)
+
+# Create the rule
+rule = StateMachineDefinition()
+
+# Run the rule
+matches = []
+for resource_name, resource in resources.items():
+    print(f"Checking resource: {resource_name}")
+    properties = resource.get('Properties', {})
+    definition_string = properties.get('DefinitionString', {})
+    print(f"DefinitionString: {json.dumps(definition_string, indent=2)}")
+    
+    # Create a validator
+    validator = Validator(template)
+    
+    # Run the rule's validate method
+    for match in rule.validate(validator, None, properties, {}):
+        matches.append(match)
+
+# Print the results
+print("\nValidation Results:")
+for match in matches:
+    print(f"{match.rule.id} {match.message}")
