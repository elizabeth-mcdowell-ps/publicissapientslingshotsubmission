+#!/usr/bin/env python3
+
+# This script demonstrates the current behavior of the chat functionality
+# where there's no way to set the temperature parameter.
+
+import sys
+import os
+from pathlib import Path
+
+# Add the src directory to the Python path
+sys.path.insert(0, str(Path(__file__).parent / "src"))
+
+from instructlab.model.chat import chat
+from instructlab.configuration import _chat
+
+# Print the current chat configuration options
+print("Current chat configuration options:")
+for field_name, field in _chat.model_fields.items():
+    print(f"  {field_name}: {field.description}")
+
+# Note that there's no temperature option in the configuration
+print("\nNote: There's no temperature option in the configuration")
+
+# In the chat.py file, temperature is only set to 0 when greedy_mode is True
+print("\nIn the chat.py file, temperature is only set to 0 when greedy_mode is True")
+print("There's no way to set a custom temperature value")
