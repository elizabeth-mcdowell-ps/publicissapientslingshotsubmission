+#!/usr/bin/env python3
+"""
+Script to reproduce the issue with balance check directives against non-leaf accounts
+when the leafonly plugin is enabled.
+"""
+
+from beancount import loader
+from beancount.parser import printer
+
+# Create a test file with a balance directive against a non-leaf account
+TEST_INPUT = """
+plugin "beancount.plugins.leafonly"
+
+2019-05-01 open Income:US:Hooli
+2019-05-01 open Income:US:Hooli:Salary
+2019-05-01 open Income:US:Hooli:AnnualBonus
+2019-05-01 open Income:US:Hooli:GroupTermLife
+2019-05-01 open Equity:Retained-Earnings
+
+2019-05-03 * "Hooli 2019 YTD Payroll"
+  Income:US:Hooli:AnnualBonus              -2,000.00 USD
+  Income:US:Hooli:GroupTermLife               -24.64 USD
+  Income:US:Hooli:Salary                   -9,126.89 USD
+  Equity:Retained-Earnings                 11,151.53 USD
+
+; reconcile against YTD/Gross
+2019-05-24 balance Income:US:Hooli       -11,151.53 USD
+"""
+
+def main():
+    # Load the test file
+    entries, errors, options_map = loader.load_string(TEST_INPUT)
+    
+    # Print any errors
+    if errors:
+        print("Errors found:")
+        for error in errors:
+            print(f"  {error}")
+    else:
+        print("No errors found.")
+        
+    # Print the entries
+    print("\nEntries:")
+    printer.print_entries(entries)
+
+if __name__ == "__main__":
+    main()
