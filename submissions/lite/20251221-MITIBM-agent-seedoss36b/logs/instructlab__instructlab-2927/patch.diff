diff --git a/src/instructlab/model/serve_backend.py b/src/instructlab/model/serve_backend.py
index f9a1eaf1..d4b8ca4c 100644
--- a/src/instructlab/model/serve_backend.py
+++ b/src/instructlab/model/serve_backend.py
@@ -100,6 +100,37 @@ def serve_backend(
         if ctx.args:
             vllm_args.extend(ctx.args)
 
+        # Check if tensor-parallel-size is valid for the available GPUs
+        import torch
+        available_gpus = torch.cuda.device_count()
+        tensor_parallel_size = None
+        
+        # Extract tensor-parallel-size from vllm_args
+        for i, arg in enumerate(vllm_args):
+            if arg == "--tensor-parallel-size" and i + 1 < len(vllm_args):
+                try:
+                    tensor_parallel_size = int(vllm_args[i + 1])
+                except ValueError:
+                    pass
+            elif arg.startswith("--tensor-parallel-size="):
+                try:
+                    tensor_parallel_size = int(arg.split("=")[1])
+                except (ValueError, IndexError):
+                    pass
+        
+        if tensor_parallel_size is not None:
+            if tensor_parallel_size <= 0:
+                raise ValueError(
+                    f"Invalid tensor-parallel-size configuration: The configured tensor-parallel-size ({tensor_parallel_size}) "
+                    f"must be a positive integer."
+                )
+            elif tensor_parallel_size > available_gpus:
+                raise ValueError(
+                    f"Invalid tensor-parallel-size configuration: The configured tensor-parallel-size ({tensor_parallel_size}) "
+                    f"is greater than the number of available GPUs ({available_gpus}). "
+                    f"Please update your configuration to use a tensor-parallel-size of {max(1, available_gpus)} or less."
+                )
+
         backend_instance = vllm.Server(
             api_base=ctx.obj.config.serve.api_base(),
             model_family=model_family,
