+# Helper function to replace relativedelta for adding months
+def add_months(dt, months):
+    """Add months to a datetime or date object."""
+    if months == 0:
+        return dt
+    
+    # Get the year and month components
+    year = dt.year
+    month = dt.month
+    
+    # Calculate the new month and adjust the year if needed
+    new_month = ((month - 1) + months) % 12 + 1
+    new_year = year + ((month - 1) + months) // 12
+    
+    # Handle the day (ensure it's valid for the new month)
+    max_day = monthrange(new_year, new_month)[1]
+    new_day = min(dt.day, max_day)
+    
+    # Create the new date or datetime
+    if isinstance(dt, datetime):
+        return dt.replace(year=new_year, month=new_month, day=new_day)
+    else:
+        return dt.replace(year=new_year, month=new_month, day=new_day)
+
+# Timezone utility functions to replace dateutil.tz
+def tzutc():
+    """Return the UTC timezone."""
+    return zoneinfo.ZoneInfo("UTC")
+
+def tzlocal():
+    """Return the local timezone."""
+    # Get the system's local timezone
+    if sys.platform == "win32":
+        # On Windows, use the timezone name from time.tzname
+        import time
+        return zoneinfo.ZoneInfo(time.tzname[0])
+    else:
+        # On Unix-like systems, try to get from /etc/localtime
+        return zoneinfo.ZoneInfo("localtime")
+
+def gettz(name):
+    """Get timezone by name."""
+    if not name:
+        return None
+    try:
+        return zoneinfo.ZoneInfo(name)
+    except zoneinfo.ZoneInfoNotFoundError:
+        return None
+
 
