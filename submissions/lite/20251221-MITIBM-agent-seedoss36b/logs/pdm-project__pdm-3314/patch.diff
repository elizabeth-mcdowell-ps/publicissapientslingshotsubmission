+#!/usr/bin/env python3
+from pdm.cli.utils import save_version_specifiers
+from pdm.models.requirements import Requirement
+from pdm.models.candidates import Candidate
+import sys
+
+# Create a mock project with config
+from pdm.project import Project
+from pdm.project.config import Config
+import tempfile
+import os
+from pathlib import Path
+
+# Create a temporary directory for the project
+temp_dir = tempfile.mkdtemp()
+os.chdir(temp_dir)
+
+# Create a mock project
+class MockProject:
+    def __init__(self, config_dict):
+        self.config = config_dict
+
+# Create a test requirement
+req = Requirement.from_req_dict("test-package", {})
+
+# Create a mock candidate with version 1.2.3
+from pdm.models.requirements import parse_requirement
+parsed_req = parse_requirement("test-package==1.2.3")
+candidate = Candidate(parsed_req, "")
+candidate.version = "1.2.3"
+
+# Create a resolved dictionary
+resolved = {"test-package": [candidate]}
+
+# Test with compatible save strategy and default compatibility level (minor)
+print("Before: ", req.specifier)
+project = MockProject({"strategy.save_compatibility": "minor"})
+save_version_specifiers([req], resolved, "compatible", project)
+print("After compatible (minor): ", req.specifier)
+
+# Reset the requirement
+req = Requirement.from_req_dict("test-package", {})
+
+# Test with compatible save strategy and patch compatibility level
+project = MockProject({"strategy.save_compatibility": "patch"})
+save_version_specifiers([req], resolved, "compatible", project)
+print("After compatible (patch): ", req.specifier)
+
+# Reset the requirement
+req = Requirement.from_req_dict("test-package", {})
+
+# Test with exact save strategy
+save_version_specifiers([req], resolved, "exact", project)
+print("After exact: ", req.specifier)
+
+# Clean up
+import shutil
+shutil.rmtree(temp_dir)
