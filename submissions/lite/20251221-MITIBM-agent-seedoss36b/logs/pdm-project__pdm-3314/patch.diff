@@ -0,0 +1,64 @@
+#!/usr/bin/env python3
+import os
+import tempfile
+import shutil
+import subprocess
+from pathlib import Path
+
+# Create a temporary project directory
+temp_dir = tempfile.mkdtemp()
+os.chdir(temp_dir)
+
+# Initialize a PDM project
+subprocess.run(["pdm", "init", "-n"], check=True)
+
+# Create a pyproject.toml file with dependencies
+pyproject_content = """
+[project]
+name = "test-project"
+version = "0.1.0"
+description = ""
+authors = [
+    {name = "Test", email = "test@example.com"},
+]
+dependencies = [
+    "requests~=2.28.0",
+]
+requires-python = ">=3.8"
+
+[build-system]
+requires = ["pdm-backend"]
+build-backend = "pdm.backend"
+"""
+
+with open("pyproject.toml", "w") as f:
+    f.write(pyproject_content)
+
+# Test with default compatibility level (minor)
+print("Testing with default compatibility level (minor):")
+subprocess.run(["pdm", "update", "--unconstrained", "--save-compatible", "--dry-run"], check=True)
+
+# Read the pyproject.toml file to see if it was updated
+with open("pyproject.toml", "r") as f:
+    print("pyproject.toml after update with default compatibility level:")
+    print(f.read())
+
+# Now set the compatibility level to patch
+subprocess.run(["pdm", "config", "strategy.save_compatibility", "patch"], check=True)
+
+# Create a new pyproject.toml file with dependencies
+with open("pyproject.toml", "w") as f:
+    f.write(pyproject_content)
+
+# Test with patch compatibility level
+print("\nTesting with patch compatibility level:")
+subprocess.run(["pdm", "update", "--unconstrained", "--save-compatible", "--dry-run"], check=True)
+
+# Read the pyproject.toml file to see if it was updated
+with open("pyproject.toml", "r") as f:
+    print("pyproject.toml after update with patch compatibility level:")
+    print(f.read())
+
+# Clean up
+os.chdir("/")
+shutil.rmtree(temp_dir)
