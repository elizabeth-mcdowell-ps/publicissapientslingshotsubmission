+from IPython.testing.globalipapp import get_ipython
+from IPython.core.interactiveshell import InteractiveShell
+import sys
+import os
+
+# Initialize IPython
+ip = get_ipython()
+if ip is None:
+    ip = InteractiveShell.instance()
+
+# Test 1: Empty output
+print("Test 1: Empty output")
+ip.run_cell_magic('script', 'bash', """
+# This script produces no output
+exit 0
+""")
+
+# Test 2: Large output without newlines
+print("\nTest 2: Large output without newlines")
+ip.run_cell_magic('script', 'bash', """
+# Generate a large string without newlines
+echo -n "Large output: "
+for i in {1..50}; do
+    echo -n "$i "
+done
+echo "Done!"
+""")
+
+# Test 3: Binary data
+print("\nTest 3: Binary data")
+ip.run_cell_magic('script', 'bash', """
+# Generate some binary data
+head -c 100 /dev/urandom | od -t x1
+""")
+
+# Test 4: Rapid updates
+print("\nTest 4: Rapid updates")
+ip.run_cell_magic('script', 'bash', """
+# Rapidly update the same line
+echo -n "Rapid updates: "
+for i in {1..20}; do
+    echo -n "$i "
+    sleep 0.1
+done
+echo "Done!"
+""")
