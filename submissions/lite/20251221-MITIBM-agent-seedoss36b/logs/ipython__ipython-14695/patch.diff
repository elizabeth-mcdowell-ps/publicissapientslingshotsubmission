+import sys
+import time
+
+# Test 1: Regular Python output without newlines
+print("Regular Python output:", end="", flush=True)
+for i in range(5):
+    print(f" {i}", end="", flush=True)
+    time.sleep(0.5)
+print()  # Final newline
+
+# Test 2: Simulating a shebang cell with a script that updates the same line
+print("\nSimulating shebang cell output:")
+sys.stdout.write("Shebang cell output:")
+sys.stdout.flush()
+for i in range(5):
+    sys.stdout.write(f" {i}")
+    sys.stdout.flush()
+    time.sleep(0.5)
+sys.stdout.write("\n")
+sys.stdout.flush()
+
+# Test 3: Shebang cell with newlines
+print("\nSimulating shebang cell with newlines:")
+for i in range(5):
+    sys.stdout.write(f"Line {i}\n")
+    sys.stdout.flush()
