+from IPython.testing.globalipapp import get_ipython
+from IPython.core.interactiveshell import InteractiveShell
+import sys
+import os
+
+# Create a temporary script that updates a line without newlines
+with open('/tmp/test_script.sh', 'w') as f:
+    f.write("""#!/bin/bash
+echo -n "Progress: "
+for i in {0..5}; do
+    echo -n "$i "
+    sleep 1
+done
+echo "Done!"
+""")
+
+os.chmod('/tmp/test_script.sh', 0o755)
+
+# Initialize IPython
+ip = get_ipython()
+if ip is None:
+    ip = InteractiveShell.instance()
+
+# Run the script using %%script magic
+print("Running script with %%script bash...")
+ip.run_cell_magic('script', 'bash', """
+echo -n "Progress: "
+for i in {0..5}; do
+    echo -n "$i "
+    sleep 1
+done
+echo "Done!"
+""")
