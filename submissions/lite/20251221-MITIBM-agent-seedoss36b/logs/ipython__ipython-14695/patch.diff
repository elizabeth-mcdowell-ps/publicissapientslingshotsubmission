@@ -0,0 +1,45 @@
+import sys
+import time
+import subprocess
+import os
+
+# Create a test script that outputs without newlines
+with open('/tmp/test_no_newlines.sh', 'w') as f:
+    f.write("""#!/bin/bash
+echo -n "Progress: "
+for i in {0..5}; do
+    echo -n "$i "
+    sleep 1
+done
+echo "Done!"
+""")
+
+os.chmod('/tmp/test_no_newlines.sh', 0o755)
+
+# Run the script directly
+print("Running script directly:")
+process = subprocess.Popen(['/tmp/test_no_newlines.sh'], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
+
+# Read output character by character to simulate real-time display
+while True:
+    char = process.stdout.read(1)
+    if not char and process.poll() is not None:
+        break
+    sys.stdout.write(char)
+    sys.stdout.flush()
+
+print("\nScript completed with return code:", process.returncode)
+
+# Now test with IPython's script magic
+print("\nTo test in IPython, run the following commands:")
+print("```python")
+print("import IPython")
+print("ip = IPython.get_ipython()")
+print("%%bash")
+print("echo -n \"Progress: \"")
+print("for i in {0..5}; do")
+print("    echo -n \"$i \"")
+print("    sleep 1")
+print("done")
+print("echo \"Done!\"")
+print("```")
