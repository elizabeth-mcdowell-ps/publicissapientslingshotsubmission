+def register_hook(func):
+    """Decorator to mark a function as a hook to be registered in settings.
+
+    This decorator is used in .py settings files to register a function
+    as a hook that will be called after the settings are loaded.
+
+    The function must accept a settings object and return a dictionary
+    with settings to be merged.
+
