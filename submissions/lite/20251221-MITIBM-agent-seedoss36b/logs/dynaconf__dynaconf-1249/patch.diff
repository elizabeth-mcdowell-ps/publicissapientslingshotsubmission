diff --git a/test_hooks_edge_cases.py b/test_hooks_edge_cases.py
new file mode 100644
index 0000000..d0d5472
--- /dev/null
+++ b/test_hooks_edge_cases.py
@@ -0,0 +1,101 @@
+from dynaconf import Dynaconf
+import os
+
+# Test 1: Multiple hooks in the same file
+with open('test1_defaults.py', 'w') as f:
+    f.write("""
+DATA = {
+    "items": [1, 2, 3],
+    "config": {
+        "enabled": False,
+        "debug": True
+    }
+}
+""")
+
+with open('test1_config.py', 'w') as f:
+    f.write("""
+from dynaconf.hooking import register_hook
+
+FOO = 1
+BAR = 2
+
+@register_hook
+def hook1(settings) -> dict:
+    data = {}
+    if (d := settings.get("DATA")) is not None:
+        d["items"].append(4)
+        data["DATA"] = d
+    return data
+
+@register_hook
+def hook2(settings) -> dict:
+    data = {}
+    if (d := settings.get("DATA")) is not None:
+        d["config"]["enabled"] = True
+        data["DATA"] = d
+    return data
+""")
+
+# Test 2: Hook that returns None
+with open('test2_defaults.py', 'w') as f:
+    f.write("""
+COUNTER = 0
+""")
+
+with open('test2_config.py', 'w') as f:
+    f.write("""
+from dynaconf.hooking import register_hook
+
+@register_hook
+def hook_no_return(settings):
+    # This hook doesn't return anything
+    # It should not cause errors
+    settings.COUNTER += 1
+""")
+
+# Test 3: Hook that accesses settings that don't exist yet
+with open('test3_defaults.py', 'w') as f:
+    f.write("""
+BASE_VALUE = 10
+""")
+
+with open('test3_config.py', 'w') as f:
+    f.write("""
+from dynaconf.hooking import register_hook
+
+@register_hook
+def hook_with_new_settings(settings) -> dict:
+    # Create settings that don't exist yet
+    return {
+        "COMPUTED_VALUE": settings.BASE_VALUE * 2,
+        "NEW_SETTING": "This is a new setting"
+    }
+""")
+
+# Run the tests
+print("=== Test 1: Multiple hooks in the same file ===")
+settings1 = Dynaconf(settings_files=["test1_defaults.py", "test1_config.py"])
+print(f"DATA.items: {settings1.DATA.items}")
+print(f"DATA.config.enabled: {settings1.DATA.config.enabled}")
+print(f"Both hooks executed: {4 in settings1.DATA.items and settings1.DATA.config.enabled}")
+
+print("\n=== Test 2: Hook that returns None ===")
+settings2 = Dynaconf(settings_files=["test2_defaults.py", "test2_config.py"])
+print(f"COUNTER: {settings2.COUNTER}")
+print(f"Hook executed: {settings2.COUNTER > 0}")
+
+print("\n=== Test 3: Hook that accesses settings that don't exist yet ===")
+settings3 = Dynaconf(settings_files=["test3_defaults.py", "test3_config.py"])
+print(f"BASE_VALUE: {settings3.BASE_VALUE}")
+print(f"COMPUTED_VALUE: {settings3.COMPUTED_VALUE}")
+print(f"NEW_SETTING: {settings3.NEW_SETTING}")
+print(f"Hook executed: {settings3.COMPUTED_VALUE == 20 and settings3.NEW_SETTING == 'This is a new setting'}")
+
+# Clean up
+os.remove('test1_defaults.py')
+os.remove('test1_config.py')
+os.remove('test2_defaults.py')
+os.remove('test2_config.py')
+os.remove('test3_defaults.py')
+os.remove('test3_config.py')
