new file mode 100644
index 0000000..5ea8b3f
--- /dev/null
+++ b/reproduce_issue.py
@@ -0,0 +1,61 @@
+from dynaconf import Dynaconf
+
+# Create a settings file with a hook
+with open('defaults.py', 'w') as f:
+    f.write("""
+LOGGING = {
+   "loggers": {
+        "xpto": {
+            "handlers": {
+                "something": False
+             }
+         },
+         "other": {
+            "handlers": {
+                "something": False
+             },
+            "propagate": False
+         }
+    }
+}
+""")
+
+# Create a settings file that needs to modify the LOGGING
+with open('config.py', 'w') as f:
+    f.write("""
+# Now we can use the register_hook decorator
+from dynaconf.hooking import register_hook
+
+FOO = 1
+BAR = 2
+
+@register_hook
+def set_logging_handlers(settings) -> dict:
+    data = {}
+    if (logging := settings.get("LOGGING")) is not None:
+        for name in logging["loggers"].keys():
+            if not logging["loggers"][name].get("propagate"):
+                handler = logging["loggers"][name].get("handlers", {})
+                if "something" in handler:
+                   logging["loggers"][name]["handlers"]["something"] = True
+        data["LOGGING"] = logging
+    return data
+""")
+
+# Initialize settings
+settings = Dynaconf(
+    settings_files=["defaults.py", "config.py"]
+)
+
+# Print the current state of LOGGING
+print("Current LOGGING configuration:")
+print(settings.LOGGING)
+
+# Check if the hook worked
+other_handler_value = settings.LOGGING["loggers"]["other"]["handlers"]["something"]
+print(f"\nIs other logger's 'something' handler set to True? {other_handler_value}")
+
+# Clean up
+import os
+os.remove('defaults.py')
+os.remove('config.py')
