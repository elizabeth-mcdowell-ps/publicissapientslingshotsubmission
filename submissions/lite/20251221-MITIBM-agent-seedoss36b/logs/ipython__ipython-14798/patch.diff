+class CellMagicAssign(TokenTransformBase):
+    """Transformer for assignments from cell magics (a = %%foo)"""
+    @classmethod
+    def find(cls, tokens_by_line):
+        """Find the first cell magic assignment (a = %%foo) in the cell.
+        """
+        for line in tokens_by_line:
+            assign_ix = _find_assign_op(line)
+            if (assign_ix is not None) \
+                    and (len(line) >= assign_ix + 2) \
+                    and (line[assign_ix+1].string == '%') \
+                    and (len(line) >= assign_ix + 3) \
+                    and (line[assign_ix+2].string == '%') \
+                    and (line[assign_ix+3].type == tokenize.NAME):
+                return cls(line[assign_ix+1].start)
+
+    def transform(self, lines: List[str]):
+        """Transform a cell magic assignment found by the ``find()`` classmethod.
+        """
+        start_line, start_col = self.start_line, self.start_col
+        lhs = lines[start_line][:start_col]
+        end_line = find_end_of_continued_line(lines, start_line)
+        rhs = assemble_continued_line(lines, (start_line, start_col), end_line)
+        
+        # Extract the cell magic name and first line arguments
+        assert rhs.startswith('%%'), rhs
+        magic_name, _, first_line = rhs[2:].partition(' ')
+        
+        # Get the body of the cell
+        body = ''.join(lines[end_line+1:])
+        
+        # Create the transformed line
+        lines_before = lines[:start_line]
+        call = "get_ipython().run_cell_magic({!r}, {!r}, {!r})".format(magic_name, first_line, body)
+        new_line = lhs + call + '\n'
+        
+        # Return the transformed lines
+        return lines_before + [new_line]
+
