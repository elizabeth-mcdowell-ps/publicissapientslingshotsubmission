+import fastf1
+
+# Parameters
+year = 2024
+grand_prix = 4  # Japanese Grand Prix
+session = 1     # Practice 1
+
+# Load session data
+session = fastf1.get_session(year, grand_prix, session)
+session.load()
+
+# Print all drivers in the results
+print("Drivers in the session results:")
+for driver_num, driver_data in session.results.iterrows():
+    print(f"Driver: {driver_data['FullName']} ({driver_num})")
+
+# Check specifically for Daniel Ricciardo
+ricciardo_present = '3' in session.results.index
+print(f"\nIs Daniel Ricciardo (3) present in results? {ricciardo_present}")
+
+if ricciardo_present:
+    print(f"Daniel Ricciardo's data: {session.results.loc['3'].to_dict()}")
