+    @soft_exceptions("filter non-participating drivers",
+                     "Failed to filter non-participating drivers!",
+                     _logger)
+    def _filter_non_participating_drivers(self):
+        """Filter out drivers who didn't participate in the session.
+        
+        This is used to remove drivers who are listed in the API data but didn't
+        actually participate in the session.
+        """
+        if not hasattr(self, '_laps') or self._laps is None or self._laps.empty:
+            return  # no lap data available
+            
+        if not hasattr(self, '_results') or self._results is None or self._results.empty:
+            return  # no results data available
+            
+        # Get the list of drivers who have lap data
+        participating_drivers = set(self._laps['DriverNumber'].unique())
+        
+        # Get the list of drivers in the results
+        all_drivers = set(self._results.index)
+        
+        # Find drivers who are in the results but have no lap data
+        non_participating_drivers = all_drivers - participating_drivers
+        
+        if non_participating_drivers:
+            # Remove non-participating drivers from the results
+            self._results = self._results.drop(index=list(non_participating_drivers))
+            _logger.info(f"Removed non-participating drivers from results: {non_participating_drivers}")
 
