+import arviz as az
+import numpy as np
+import pandas as pd
+import matplotlib.pyplot as plt
+from datetime import datetime
+
+# Create sample y data
+y_data = np.random.normal(0, 1, (2, 100, 5))
+
+# Test case 1: Mixed numeric and string values
+print("Test case 1: Mixed numeric and string values")
+x_mixed = np.array([1, 2, "3", 4, 5])
+try:
+    az.plot_hdi(x=x_mixed, y=y_data)
+except Exception as e:
+    print(f"Error: {type(e).__name__}: {e}")
+
+# Test case 2: Pandas categorical type
+print("\nTest case 2: Pandas categorical type")
+x_cat = pd.Categorical(['A', 'B', 'C', 'D', 'E'])
+try:
+    az.plot_hdi(x=x_cat, y=y_data)
+except Exception as e:
+    print(f"Error: {type(e).__name__}: {e}")
+
+# Test case 3: Datetime objects
+print("\nTest case 3: Datetime objects")
+x_dates = np.array([datetime(2023, 1, i) for i in range(1, 6)])
+try:
+    az.plot_hdi(x=x_dates, y=y_data)
+except Exception as e:
+    print(f"Error: {type(e).__name__}: {e}")
+
+# Test case 4: Numeric values (should work)
+print("\nTest case 4: Numeric values (should work)")
+x_numeric = np.array([1, 2, 3, 4, 5])
+try:
+    az.plot_hdi(x=x_numeric, y=y_data)
+    print("Success: Plot created with numeric values")
+except Exception as e:
+    print(f"Error: {type(e).__name__}: {e}")
