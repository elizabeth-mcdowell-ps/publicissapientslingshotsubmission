@@ -0,0 +1,114 @@
+import concurrent.futures
+import time
+import threading
+from haystack.core.pipeline import Pipeline
+from haystack.testing.sample_components import Double, Sum
+from haystack.tracing.tracer import Span, Tracer
+import contextlib
+from typing import Any, Dict, Iterator, Optional
+
+# Create a custom tracer to demonstrate the fix
+class VerificationTracer(Tracer):
+    """A tracer that verifies parent-child relationships between spans."""
+    
+    def __init__(self):
+        self.spans_by_thread = {}
+        self.span_parents = {}
+        self.lock = threading.Lock()
+        
+    @contextlib.contextmanager
+    def trace(self, operation_name: str, tags: Optional[Dict[str, Any]] = None, parent_span: Optional[Span] = None) -> Iterator[Span]:
+        """Create a new span and yield it."""
+        thread_id = threading.get_ident()
+        
+        # Create a simple span
+        span = VerificationSpan(operation_name, tags or {})
+        span_id = id(span)
+        
+        # Store the parent relationship
+        if parent_span is not None:
+            parent_id = id(parent_span)
+            with self.lock:
+                self.span_parents[span_id] = parent_id
+                print(f"[Thread {thread_id}] Span {span_id} ({operation_name}) has parent {parent_id} ({parent_span.operation_name})")
+        else:
+            print(f"[Thread {thread_id}] Span {span_id} ({operation_name}) has no parent")
+        
+        # Store the current span for this thread
+        with self.lock:
+            self.spans_by_thread[thread_id] = span
+        
+        try:
+            yield span
+        finally:
+            with self.lock:
+                if thread_id in self.spans_by_thread:
+                    del self.spans_by_thread[thread_id]
+    
+    def current_span(self) -> Optional[Span]:
+        """Return the current span for this thread."""
+        thread_id = threading.get_ident()
+        with self.lock:
+            return self.spans_by_thread.get(thread_id)
+
+class VerificationSpan(Span):
+    """A simple span implementation."""
+    
+    def __init__(self, operation_name: str, tags: Dict[str, Any]):
+        self.operation_name = operation_name
+        self.tags = tags
+    
+    def set_tag(self, key: str, value: Any) -> None:
+        """Set a tag on the span."""
+        self.tags[key] = value
+
+def run_pipeline(pipeline_id, value):
+    """Run a pipeline with the given ID and value."""
+    print(f"Starting pipeline {pipeline_id} with value {value}")
+    
+    # Create a simple pipeline
+    pipeline = Pipeline()
+    pipeline.add_component("double", Double())
+    pipeline.add_component("sum", Sum())
+    pipeline.connect("double.output", "sum.a")
+    
+    # Run the pipeline
+    result = pipeline.run({"double": {"value": value}, "sum": {"b": 5}})
+    
+    print(f"Pipeline {pipeline_id} result: {result}")
+    return result
+
+if __name__ == "__main__":
+    # Enable our verification tracer
+    from haystack.tracing.tracer import enable_tracing
+    tracer = VerificationTracer()
+    enable_tracing(tracer)
+    
+    # Run pipelines concurrently to verify the fix
+    with concurrent.futures.ThreadPoolExecutor(max_workers=3) as executor:
+        futures = []
+        for i in range(3):
+            futures.append(executor.submit(run_pipeline, i, i * 10))
+            # Small delay to make logs more readable
+            time.sleep(0.1)
+        
+        # Wait for all pipelines to complete
+        for future in concurrent.futures.as_completed(futures):
+            try:
+                future.result()
+            except Exception as e:
+                print(f"Pipeline execution failed: {e}")
+    
+    # Verify that all component spans have the pipeline span as parent
+    component_spans = [span_id for span_id, parent_id in tracer.span_parents.items() 
+                      if any(tracer.span_parents.get(parent_id) is None for parent_id in tracer.span_parents.values())]
+    
+    print("\nVerification Results:")
+    print(f"Total parent-child relationships: {len(tracer.span_parents)}")
+    
+    # Check if all component spans have a parent
+    orphaned_spans = [span_id for span_id in tracer.span_parents.keys() if span_id not in tracer.span_parents.values()]
+    if orphaned_spans:
+        print(f"Warning: Found {len(orphaned_spans)} spans without children")
+    else:
+        print("All spans have proper parent-child relationships!")
