+#!/usr/bin/env python3
+from fontTools.ttLib import TTFont
+from fontTools.feaLib.builder import Builder
+from fontTools.feaLib.parser import Parser
+from fontTools.feaLib.ast import FeatureFile
+import sys
+import tempfile
+import os
+import io
+
+# Create a simple feature file with the example from the PR description
+fea_content = """
+feature locl {
+    script latn;
+    language CAT;
+    sub l' periodcentered' l by ldot;
+    sub L' periodcentered' L by Ldot;
+} locl;
+"""
+
+# Parse the feature file
+parser = Parser(io.StringIO(fea_content), {})
+feature_file = parser.parse()
+
+# Create a minimal font
+font = TTFont()
+font.setGlyphOrder(["l", "L", "periodcentered", "ldot", "Ldot"])
+
+# Add debug print to the Builder.add_ligature_subst method
+original_add_ligature_subst = Builder.add_ligature_subst
+
+def debug_add_ligature_subst(self, location, prefix, glyphs, suffix, replacement, forceChain):
+    print(f"Debug: add_ligature_subst called with glyphs={glyphs}, replacement={replacement}")
+    print(f"Debug: prefix={prefix}, suffix={suffix}, forceChain={forceChain}")
+    print(f"Debug: current feature={self.cur_feature_name_}")
+    print(f"Debug: lookupflag={self.lookupflag_}, markFilterSet={self.lookupflag_markFilterSet_}")
+    result = original_add_ligature_subst(self, location, prefix, glyphs, suffix, replacement, forceChain)
+    print(f"Debug: lookups count after adding: {len(self.lookups_)}")
+    return result
+
+Builder.add_ligature_subst = debug_add_ligature_subst
+
+# Build the features
+builder = Builder(font, feature_file)
+builder.build()
+
+# Print the lookups to see if they're separate or combined
+print("Examining lookups in the built font:")
+for lookup_index, lookup in enumerate(font["GSUB"].table.LookupList.Lookup):
+    print(f"Lookup {lookup_index}:")
+    for subtable_index, subtable in enumerate(lookup.SubTable):
+        if hasattr(subtable, "ligatures"):
+            print(f"  Subtable {subtable_index} (Ligature substitution):")
+            for first_glyph, ligatures in subtable.ligatures.items():
+                for ligature in ligatures:
+                    components = [first_glyph] + list(ligature.Component)
+                    print(f"    {' '.join(components)} -> {ligature.LigGlyph}")
+        else:
+            print(f"  Subtable {subtable_index} (Other type)")
+
+print("\nThe issue is that the two ligature rules are placed in separate lookups when they could be in the same lookup.")
