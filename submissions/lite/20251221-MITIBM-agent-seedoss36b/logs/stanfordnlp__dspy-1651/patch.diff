+import dspy
+import ujson
+import os
+from dspy.functional import TypedPredictor
+from dspy.signatures.signature import Signature
+
+# Define a more complex signature for entity extraction
+class ComplexEntityExtractorSignature(Signature):
+    """Extract entities from the given text."""
+    text: str = dspy.InputField(desc="Text to extract entities from")
+    context: str = dspy.InputField(desc="Additional context for entity extraction")
+    entities: list[str] = dspy.OutputField(desc="List of entities extracted from the text")
+    entity_types: list[str] = dspy.OutputField(desc="Types of the extracted entities")
+    confidence: list[float] = dspy.OutputField(desc="Confidence scores for each entity")
+
+# Define a complex entity extractor class
+class ComplexEntityExtractor(dspy.Module):
+    def __init__(self):
+        super().__init__()
+        self.predictor = TypedPredictor(ComplexEntityExtractorSignature)
+        
+    def forward(self, text, context=""):
+        return self.predictor(text=text, context=context)
+    
+    def dump_state(self, save_verbose=False):
+        state = {}
+        state["predictor"] = self.predictor.dump_state(save_verbose)
+        return state
+    
+    def load_state(self, state, use_legacy_loading=False):
+        self.predictor.load_state(state["predictor"], use_legacy_loading=use_legacy_loading)
+        
+    def save(self, path):
+        with open(path, "w") as f:
+            f.write(ujson.dumps(self.dump_state(), indent=2))
+            
+    def load(self, path, use_legacy_loading=False):
+        with open(path) as f:
+            self.load_state(ujson.loads(f.read()), use_legacy_loading=use_legacy_loading)
+
+# Create a mock optimized model file
+def create_mock_optimized_model():
+    # Create a modified signature with different instructions
+    optimized_signature = ComplexEntityExtractorSignature.with_instructions(
+        "Extract all named entities from the provided text with their types and confidence scores. " +
+        "Include people, organizations, locations, and dates. Use the context for disambiguation."
+    )
+    
+    # Create the entity extractor
+    entity_extractor = ComplexEntityExtractor()
+    
+    # Modify the signature in the predictor to simulate optimization
+    entity_extractor.predictor.signature = optimized_signature
+    
+    # Save the "optimized" model
+    entity_extractor.save("complex_optimized.json")
+    
+    return optimized_signature
+
+# Test loading the optimized model
+def test_loading():
+    print("Creating and saving optimized model...")
+    optimized_signature = create_mock_optimized_model()
+    print(f"Original optimized signature instructions: {optimized_signature.instructions}")
+    
+    print("\nLoading the optimized model...")
+    entity_extractor = ComplexEntityExtractor()
+    entity_extractor.load("complex_optimized.json")
+    
+    print(f"Loaded signature instructions: {entity_extractor.predictor.signature.instructions}")
+    
+    if entity_extractor.predictor.signature.instructions == optimized_signature.instructions:
+        print("\nSUCCESS: The optimized signature was correctly loaded!")
+    else:
+        print("\nFAILURE: The original signature was used instead of the optimized one!")
+
+if __name__ == "__main__":
+    # Set up a dummy LM for testing
+    dspy.settings.configure(lm=dspy.utils.dummies.DummyLM([{
+        "entities": ["John Smith", "Microsoft", "Seattle"],
+        "entity_types": ["PERSON", "ORG", "LOC"],
+        "confidence": ["0.95", "0.92", "0.88"]  # Use strings instead of floats
+    }]))
+    
+    test_loading()
