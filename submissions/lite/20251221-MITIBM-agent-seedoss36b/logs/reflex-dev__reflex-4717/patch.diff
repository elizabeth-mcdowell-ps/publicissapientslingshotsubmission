@@ -0,0 +1,64 @@
+"""Script to reproduce the issues mentioned in the PR description."""
+
+import reflex as rx
+from reflex.event import EventChain, LiteralEventChainVar
+from reflex.vars import VarData
+
+def test_literal_event_chain_var_hooks():
+    """Test that LiteralEventChainVar includes appropriate hooks for addEvents."""
+    # Create a VarData with a hook for addEvents
+    var_data = VarData(
+        imports={"some_module": {"addEvents"}},
+        hooks={"addEvents": "useAddEvents()"}
+    )
+    
+    # Create an EventChain
+    event_chain = EventChain(events=[], args_spec=lambda: None)
+    
+    # Create a LiteralEventChainVar with the var_data
+    literal_event_chain_var = LiteralEventChainVar.create(event_chain, _var_data=var_data)
+    
+    # Check if the var_data is included in the LiteralEventChainVar
+    print("LiteralEventChainVar hooks test:")
+    print(f"Var data: {literal_event_chain_var._get_var_data()}")
+    print(f"Has addEvents hook: {'addEvents' in literal_event_chain_var._get_var_data().hooks}")
+    print()
+
+def test_event_chain_create_kwargs():
+    """Test that EventChain.create accepts arbitrary kwargs."""
+    # Create an EventChain with arbitrary kwargs
+    event_chain = EventChain.create(
+        value=[],
+        args_spec=lambda: None,
+        invocation=rx.Var.create("customAddEvents")
+    )
+    
+    # Check if the kwargs are passed to the EventChain constructor
+    print("EventChain.create kwargs test:")
+    print(f"Event chain: {event_chain}")
+    print(f"Invocation: {event_chain.invocation}")
+    print()
+
+def test_var_create_var_data():
+    """Test that rx.Var.create doesn't throw away _var_data for non-str values."""
+    # Create a VarData
+    var_data = VarData(
+        imports={"some_module": {"someFunction"}},
+        hooks={"someFunction": "useSomeFunction()"}
+    )
+    
+    # Create a Var with the var_data for different types
+    str_var = rx.Var.create("string value", _var_data=var_data)
+    int_var = rx.Var.create(42, _var_data=var_data)
+    dict_var = rx.Var.create({"key": "value"}, _var_data=var_data)
+    
+    # Check if the var_data is included in the Vars
+    print("rx.Var.create _var_data test:")
+    print(f"String var data: {str_var._get_var_data()}")
+    print(f"Int var data: {int_var._get_var_data()}")
+    print(f"Dict var data: {dict_var._get_var_data()}")
+
+if __name__ == "__main__":
+    test_literal_event_chain_var_hooks()
+    test_event_chain_create_kwargs()
+    test_var_create_var_data()
