+"""Simple test script to check the issues without importing the full reflex package."""
+
+import sys
+import os
+
+# Add the testbed directory to the path so we can import modules directly
+sys.path.append('/testbed')
+
+# Import only the specific modules we need
+from reflex.vars.base import Var, VarData
+from reflex.event import EventChain, LiteralEventChainVar
+
+def test_literal_event_chain_var():
+    """Test if LiteralEventChainVar includes var_data with hooks for addEvents."""
+    print("Testing LiteralEventChainVar...")
+    
+    # Create a VarData with a hook for addEvents
+    var_data = VarData(
+        imports={"some_module": {"addEvents"}},
+        hooks={"addEvents": "useAddEvents()"}
+    )
+    
+    # Create a simple EventChain
+    event_chain = EventChain(events=[], args_spec=lambda: None)
+    
+    # Create a LiteralEventChainVar with the var_data
+    literal_event_chain_var = LiteralEventChainVar.create(event_chain, _var_data=var_data)
+    
+    # Check if the var_data is included in the LiteralEventChainVar
+    print(f"Var data hooks: {literal_event_chain_var._get_var_data().hooks}")
+    
+    # The issue is that 'addEvents' hook should be in the var_data
+    if 'addEvents' in literal_event_chain_var._get_var_data().hooks:
+        print("✅ addEvents hook is present in LiteralEventChainVar")
+    else:
+        print("❌ addEvents hook is missing in LiteralEventChainVar")
+
+def test_event_chain_create():
+    """Test if EventChain.create accepts arbitrary kwargs."""
+    print("\nTesting EventChain.create...")
+    
+    # Create a custom invocation var
+    invocation_var = Var(_js_expr="customAddEvents")
+    
+    # Create an EventChain with the invocation kwarg
+    event_chain = EventChain.create(
+        value=[],
+        args_spec=lambda: None,
+        invocation=invocation_var
+    )
+    
+    # Check if the invocation was passed to the EventChain constructor
+    print(f"Event chain invocation: {event_chain.invocation}")
+    
+    if event_chain.invocation == invocation_var:
+        print("✅ EventChain.create properly passes kwargs to constructor")
+    else:
+        print("❌ EventChain.create doesn't pass kwargs to constructor")
+
+def test_var_create_var_data():
+    """Test if Var.create preserves _var_data for non-str values."""
+    print("\nTesting Var.create with _var_data...")
+    
+    # Create a VarData
+    var_data = VarData(
+        imports={"some_module": {"someFunction"}},
+        hooks={"someFunction": "useSomeFunction()"}
+    )
+    
+    # Create Vars with different types
+    str_var = Var.create("string value", _var_data=var_data)
+    int_var = Var.create(42, _var_data=var_data)
+    dict_var = Var.create({"key": "value"}, _var_data=var_data)
+    
+    # Check if the var_data is preserved
+    print(f"String var hooks: {str_var._get_var_data().hooks}")
+    print(f"Int var hooks: {int_var._get_var_data().hooks}")
+    print(f"Dict var hooks: {dict_var._get_var_data().hooks}")
+    
+    if 'someFunction' in str_var._get_var_data().hooks and \
+       'someFunction' in int_var._get_var_data().hooks and \
+       'someFunction' in dict_var._get_var_data().hooks:
+        print("✅ Var.create preserves _var_data for all types")
+    else:
+        print("❌ Var.create doesn't preserve _var_data for some types")
+
+if __name__ == "__main__":
+    test_literal_event_chain_var()
+    test_event_chain_create()
+    test_var_create_var_data()
