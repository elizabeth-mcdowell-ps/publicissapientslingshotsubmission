+    if card_div:
+        print("Found card div")
+        
+        # Find the song rows
+        song_rows = card_div.find_all("div", class_="box-przeboje")
+        if song_rows:
+            print(f"Found {len(song_rows)} song rows")
+            
+            # Print the first song row
+            song_row = song_rows[0]
