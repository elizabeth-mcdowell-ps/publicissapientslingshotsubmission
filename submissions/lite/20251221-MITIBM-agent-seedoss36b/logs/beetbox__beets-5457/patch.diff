+#!/usr/bin/env python3
+import requests
+from bs4 import BeautifulSoup
+import re
+
+# Constants
+BASE_URL = "http://www.tekstowo.pl"
+SEARCH_URL = BASE_URL + "/wyszukaj.html?search-title=%s&search-artist=%s"
+
+# Helper functions
+def fetch_url(url):
+    try:
+        headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}
+        response = requests.get(url, headers=headers, timeout=10)
+        return response.text if response.status_code == 200 else None
+    except Exception as e:
+        print(f"Error fetching URL: {e}")
+        return None
+
+def parse_search_results(html):
+    soup = BeautifulSoup(html, "html.parser")
+    
+    content_div = soup.find("div", class_="content")
+    if not content_div:
+        print("No content div found")
+        return None
+    
+    card_div = content_div.find("div", class_="card")
+    if not card_div:
+        print("No card div found")
+        return None
+    
+    song_rows = card_div.find_all("div", class_="box-przeboje")
+    if not song_rows:
+        print("No song rows found")
+        return None
+    
+    song_row = song_rows[0]
+    if not song_row:
+        print("No song row found")
+        return None
+    
+    link = song_row.find("a")
+    if not link:
+        print("No link found")
+        return None
+    
+    return BASE_URL + link.get("href")
+
+def extract_lyrics(html):
+    soup = BeautifulSoup(html, "html.parser")
+    
+    lyrics_div = soup.select("div.song-text > div.inner-text")
+    if not lyrics_div:
+        print("No lyrics div found")
+        return None
+    
+    return lyrics_div[0].get_text()
+
+# Test with a Kendrick Lamar song
+artist = "Kendrick Lamar"
+title = "Wesley's Theory"
+
+# Build the URL
+url = SEARCH_URL % (title.title(), artist.title())
+print(f"Search URL: {url}")
+
+# Fetch the search results
+html = fetch_url(url)
+if not html:
+    print("Failed to fetch search results")
+    exit(1)
+
+# Parse the search results
+song_url = parse_search_results(html)
+if not song_url:
+    print("Failed to parse search results")
+    exit(1)
+
+print(f"Song URL: {song_url}")
+
+# Fetch the song page
+song_html = fetch_url(song_url)
+if not song_html:
+    print("Failed to fetch song page")
+    exit(1)
+
+# Extract the lyrics
+lyrics = extract_lyrics(song_html)
+if not lyrics:
+    print("Failed to extract lyrics")
+    exit(1)
+
+print("Lyrics found!")
+print(lyrics[:100] + "..." if len(lyrics) > 100 else lyrics)
