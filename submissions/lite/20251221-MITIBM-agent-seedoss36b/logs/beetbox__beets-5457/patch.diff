+#!/usr/bin/env python3
+import requests
+import re
+from bs4 import BeautifulSoup
+
+# Simulate the Tekstowo backend's behavior
+BASE_URL = "http://www.tekstowo.pl"
+SEARCH_URL = BASE_URL + "/wyszukaj.html?search-title=%s&search-artist=%s"
+ADVANCED_SEARCH_URL = BASE_URL + "/wyszukiwanie-zaawansowane,?q=%s+%s"
+
+def fetch_url(url):
+    try:
+        headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}
+        response = requests.get(url, headers=headers, timeout=10)
+        return response.text if response.status_code == 200 else None
+    except Exception as e:
+        print(f"Error fetching URL: {e}")
+        return None
+
+def parse_search_results_old_method(html):
+    soup = BeautifulSoup(html, "html.parser")
+    
+    content_div = soup.find("div", class_="content")
+    if not content_div:
+        print("No content div found")
+        return None
+    
+    card_div = content_div.find("div", class_="card")
+    if not card_div:
+        print("No card div found")
+        return None
+    
+    song_rows = card_div.find_all("div", class_="box-przeboje")
+    if not song_rows:
+        print("No song rows found")
+        return None
+    
+    song_row = song_rows[0]
+    if not song_row:
+        print("No song row found")
+        return None
+    
+    link = song_row.find("a")
+    if not link:
+        print("No link found")
+        return None
+    
+    return BASE_URL + link.get("href")
+
+def test_old_search_method():
+    artist = "Kendrick Lamar"
+    title = "Wesley's Theory"
+    
+    # Build the URL
+    url = SEARCH_URL % (title.title(), artist.title())
+    print(f"Testing old search URL: {url}")
+    
+    # Fetch the search results
+    html = fetch_url(url)
+    if not html:
+        print("Failed to fetch search results")
+        return
+    
+    # Parse the search results
+    song_url = parse_search_results_old_method(html)
+    if not song_url:
+        print("Failed to parse search results")
+        return
+    
+    print(f"Song URL found: {song_url}")
+
+def test_new_search_method():
+    artist = "Kendrick Lamar"
+    title = "Wesley's Theory"
+    
+    # Build the URL for advanced search
+    query = f"{artist} {title}".replace(" ", "+")
+    url = ADVANCED_SEARCH_URL % (artist.replace(" ", "+"), title.replace(" ", "+"))
+    print(f"Testing new search URL: {url}")
+    
+    # Fetch the search results
+    html = fetch_url(url)
+    if not html:
+        print("Failed to fetch search results")
+        return
+    
+    # Print the first 200 characters of the HTML to see what we're dealing with
+    print(f"HTML snippet: {html[:200]}...")
+    
+    # Check if there's a Google search container
+    if "google" in html.lower():
+        print("Google search container detected")
+
+# Run the tests
+print("Testing old search method:")
+test_old_search_method()
+print("\nTesting new search method:")
+test_new_search_method()
