+#!/usr/bin/env python3
+import sys
+import os
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, '/testbed')
+
+# Create a simple mock for the beets module
+class MockConfig:
+    def __init__(self, config_dict):
+        self.config_dict = config_dict
+    
+    def __getitem__(self, key):
+        return self.config_dict.get(key, {})
+    
+    def as_str(self):
+        return str(self.config_dict)
+    
+    def get(self, type_func):
+        return self.config_dict
+
+class MockView:
+    def __init__(self, value):
+        self.value = value
+    
+    def as_str(self):
+        return self.value
+    
+    def get(self, type_func):
+        return type_func(self.value)
+
+# Create a logger
+class DummyLog:
+    def debug(self, msg):
+        print(f"DEBUG: {msg}")
+    def info(self, msg):
+        print(f"INFO: {msg}")
+    def warning(self, msg):
+        print(f"WARNING: {msg}")
+    def error(self, msg):
+        print(f"ERROR: {msg}")
+
+# Import the Tekstowo class
+from beetsplug.lyrics import Tekstowo
+
+# Create a configuration
+config = {"dist_thresh": MockView(0.7)}
+
+# Create a logger
+log = DummyLog()
+
+# Create a Tekstowo backend instance
+tekstowo = Tekstowo(config, log)
+
+# Try to fetch lyrics for a Kendrick Lamar song
+artist = "Kendrick Lamar"
+title = "Wesley's Theory"
+
+print(f"Fetching lyrics for {artist} - {title}")
+lyrics = tekstowo.fetch(artist, title)
+
+if lyrics:
+    print("Lyrics found!")
+    print(lyrics[:200] + "..." if len(lyrics) > 200 else lyrics)
+else:
+    print("No lyrics found.")
