+
+# Create a temporary directory for our test
+temp_dir = tempfile.mkdtemp()
+os.chdir(temp_dir)
+
+# Create a default profile
+os.makedirs(os.path.expanduser("~/.conan2/profiles"), exist_ok=True)
+with open(os.path.expanduser("~/.conan2/profiles/default"), "w") as f:
+    f.write("""
+[settings]
+arch=x86_64
+build_type=Release
+compiler=gcc
+compiler.version=9
+os=Linux
+""")
+
+# Create packages
+os.makedirs("pkg1", exist_ok=True)
+with open("pkg1/conanfile.py", "w") as f:
+    f.write("""
+from conan import ConanFile
+
+class Pkg1Recipe(ConanFile):
+    name = "pkg1"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+    
+    def build(self):
+        self.output.info(f"Building pkg1 with build_type={self.settings.build_type}")
+""")
+
+os.makedirs("pkg2", exist_ok=True)
+with open("pkg2/conanfile.py", "w") as f:
+    f.write("""
+from conan import ConanFile
+
+class Pkg2Recipe(ConanFile):
+    name = "pkg2"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+    requires = ["pkg1/1.0"]
+    
+    def build(self):
+        self.output.info(f"Building pkg2 with build_type={self.settings.build_type}")
+""")
+
+os.makedirs("app", exist_ok=True)
+with open("app/conanfile.py", "w") as f:
+    f.write("""
+from conan import ConanFile
+
+class AppRecipe(ConanFile):
+    name = "app"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+    requires = ["pkg2/1.0"]
+    
+    def build(self):
+        self.output.info(f"Building app with build_type={self.settings.build_type}")
+""")
+
+# Create profiles
+os.makedirs("profiles", exist_ok=True)
+with open("profiles/debug", "w") as f:
+    f.write("""
+[settings]
+arch=x86_64
+build_type=Debug
+compiler=gcc
+compiler.version=9
+os=Linux
+""")
+
+with open("profiles/release", "w") as f:
+    f.write("""
+[settings]
+arch=x86_64
+build_type=Release
+compiler=gcc
+compiler.version=9
+os=Linux
+""")
+
+# Export the packages
+print("\nExporting packages...")
+os.system("conan export pkg1")
+os.system("conan export pkg2")
+
+# Generate build orders for both profiles
+print("\nGenerating build orders...")
+os.system("conan graph build-order app --profile=profiles/debug --build=missing --format=json --order-by=recipe > debug_build_order.json")
+os.system("conan graph build-order app --profile=profiles/release --build=missing --format=json --order-by=recipe > release_build_order.json")
+
+# Check if profile information is included in the build orders
+print("\nChecking debug build order for profile information...")
+with open("debug_build_order.json", "r") as f:
+    debug_data = json.load(f)
+    
+    # Check for profile information in debug build order
+    debug_has_profile = False
+    if "order" in debug_data:
+        for level in debug_data["order"]:
+            for node in level:
+                for pkg_level in node.get("packages", []):
+                    for pkg in pkg_level:
+                        if "profile" in pkg and pkg["profile"] is not None:
+                            debug_has_profile = True
+                            print(f"Debug build order has profile information: {pkg['profile']}")
+                            break
+                        elif "info" in pkg and "settings" in pkg["info"]:
+                            debug_has_profile = True
+                            print(f"Debug build order has settings in info: {pkg['info']['settings']}")
+                            break
+
+# Merge the build orders
+print("\nMerging build orders...")
+os.system("conan graph build-order-merge --file=debug_build_order.json --file=release_build_order.json --format=json > merged_build_order.json")
+
+# Check if profile information is preserved in the merged build order
+print("\nChecking merged build order for profile information...")
+with open("merged_build_order.json", "r") as f:
+    merged_data = json.load(f)
+    
+    # Check for profile information in merged build order
+    merged_has_profile = False
+    if "order" in merged_data:
+        for level in merged_data["order"]:
+            for node in level:
+                for pkg_level in node.get("packages", []):
+                    for pkg in pkg_level:
+                        if "profile" in pkg and pkg["profile"] is not None:
+                            merged_has_profile = True
+                            print(f"Package {node['ref']} from {pkg['filenames']} has profile: {pkg['profile']}")
+                            break
+                        elif "info" in pkg and "settings" in pkg["info"]:
+                            merged_has_profile = True
+                            print(f"Package {node['ref']} from {pkg['filenames']} has settings in info: {pkg['info']['settings']}")
+                            break
+
+if debug_has_profile and merged_has_profile:
+    print("\nSUCCESS: Profile information is now included in build orders and preserved in merged build orders!")
+else:
+    print("\nFAILURE: Profile information is not properly handled.")
+
+# Clean up
+shutil.rmtree(temp_dir)
