+#!/usr/bin/env python3
+
+import os
+import json
+import tempfile
+import shutil
+
+# Create a temporary directory for our test
+temp_dir = tempfile.mkdtemp()
+os.chdir(temp_dir)
+
+# Create a default profile
+os.makedirs(os.path.expanduser("~/.conan2/profiles"), exist_ok=True)
+with open(os.path.expanduser("~/.conan2/profiles/default"), "w") as f:
+    f.write("""
+[settings]
+arch=x86_64
+build_type=Release
+compiler=gcc
+compiler.version=9
+os=Linux
+""")
+
+# Create a simple conanfile
+with open("conanfile.py", "w") as f:
+    f.write("""
+from conan import ConanFile
+
+class TestConan(ConanFile):
+    name = "test"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+
+    def build(self):
+        self.output.info(f"Building with build_type={self.settings.build_type}")
+""")
+
+# Create two profiles: Debug and Release
+os.makedirs("profiles", exist_ok=True)
+with open("profiles/debug", "w") as f:
+    f.write("""
+[settings]
+arch=x86_64
+build_type=Debug
+compiler=gcc
+compiler.version=9
+os=Linux
+""")
+
+with open("profiles/release", "w") as f:
+    f.write("""
+[settings]
+arch=x86_64
+build_type=Release
+compiler=gcc
+compiler.version=9
+os=Linux
+""")
+
+# Export the package
+os.system("conan export .")
+
+# Generate build orders for both profiles
+print("\nGenerating build orders...")
+os.system("conan graph build-order . --profile=profiles/debug --build=missing --format=json --order-by=recipe > debug_build_order.json")
+os.system("conan graph build-order . --profile=profiles/release --build=missing --format=json --order-by=recipe > release_build_order.json")
+
+# Check if profile information is included in the build orders
+print("\nChecking debug build order for profile information...")
+with open("debug_build_order.json", "r") as f:
+    debug_data = json.load(f)
+    debug_json = json.dumps(debug_data, indent=2)
+    print(debug_json[:1000])  # Print first 1000 chars to avoid too much output
+
+# Merge the build orders
+print("\nMerging build orders...")
+os.system("conan graph build-order-merge --file=debug_build_order.json --file=release_build_order.json --format=json > merged_build_order.json")
+
+# Check if profile information is preserved in the merged build order
+print("\nChecking merged build order for profile information...")
+with open("merged_build_order.json", "r") as f:
+    merged_data = json.load(f)
+    merged_json = json.dumps(merged_data, indent=2)
+    print(merged_json[:1000])  # Print first 1000 chars to avoid too much output
+
+# Check if we can extract profile information from the merged build order
+print("\nExtracting profile information from merged build order...")
+profile_info_found = False
+
+if "order" in merged_data:
+    for level in merged_data["order"]:
+        for node in level:
+            for pkg_level in node.get("packages", []):
+                for pkg in pkg_level:
+                    if "profile" in pkg and pkg["profile"] is not None:
+                        profile_info_found = True
+                        print(f"Found profile information for package from {pkg['filenames']}:")
+                        print(f"  Build type: {pkg['profile']['settings'].get('build_type')}")
+                    elif "info" in pkg and "settings" in pkg["info"]:
+                        profile_info_found = True
+                        print(f"Found profile information in info field for package from {pkg['filenames']}:")
+                        print(f"  Build type: {pkg['info']['settings'].get('build_type')}")
+
+if profile_info_found:
+    print("\nSUCCESS: Profile information can be extracted from the merged build order!")
+else:
+    print("\nFAILURE: Profile information cannot be extracted from the merged build order.")
+
+# Clean up
+shutil.rmtree(temp_dir)
