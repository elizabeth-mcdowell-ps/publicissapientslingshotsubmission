+#!/usr/bin/env python3
+import asyncio
+import sh
+
+async def main():
+    print("Testing sh async functionality")
+    
+    # Workaround mentioned in PR
+    print("\n--- Using workaround ---")
+    cmd = sh.echo("Hello World", _bg=True)
+    await cmd
+    print(f"Type of cmd: {type(cmd)}")
+    print(f"cmd.stdout: {cmd.stdout}")
+    
+    # With _return_cmd=True (but doesn't affect await)
+    print("\n--- Using _return_cmd=True ---")
+    cmd2 = sh.echo("Hello World", _bg=True, _return_cmd=True)
+    result2 = await cmd2
+    print(f"Type of cmd2: {type(cmd2)}")
+    print(f"Type of result2: {type(result2)}")
+    print(f"result2: {result2}")
+
+if __name__ == "__main__":
+    asyncio.run(main())
