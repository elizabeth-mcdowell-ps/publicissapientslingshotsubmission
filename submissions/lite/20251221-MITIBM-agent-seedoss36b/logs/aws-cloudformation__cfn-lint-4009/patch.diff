+#!/usr/bin/env python
+
+import sys
+import os
+import json
+import traceback
+from cfnlint.template.transforms._language_extensions import _ForEachValue, _ForEachCollection, _TypeError, _ValueError
+
+# Test the ForEachValue.create method with Fn::If
+try:
+    # Create a test collection with Fn::If
+    test_collection = {"Fn::If": ["HasAdditionalCertificates", {"Ref": "AdditionalCertificateArns"}, []]}
+    
+    # Try to create a ForEachValue from it
+    value = _ForEachValue.create(test_collection)
+    print("Success! ForEachValue.create accepted Fn::If")
+except Exception as e:
+    print(f"Error: {type(e).__name__}: {str(e)}")
+    traceback.print_exc()
+    print("This confirms the issue in the PR description - Fn::If is not supported in ForEachValue.create")
