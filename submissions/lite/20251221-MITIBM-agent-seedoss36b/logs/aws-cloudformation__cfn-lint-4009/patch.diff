+#!/usr/bin/env python
+
+import sys
+import os
+import json
+from cfnlint.decode.cfn_yaml import load
+from cfnlint.template.template import Template
+
+# Load the template
+with open('/testbed/template.yml', 'r') as f:
+    template_content = f.read()
+
+# Parse the template using cfnlint's YAML loader
+template_dict, _ = load(template_content)
+
+# Create a Template object
+template_obj = Template(template_dict, ['us-east-1'])
+
+# Try to transform the template
+try:
+    transformed_template = template_obj.transform_pre()
+    print("Template transformation successful!")
+    print("Transformed template:")
+    print(json.dumps(transformed_template, indent=2))
+except Exception as e:
+    print(f"Error transforming template: {str(e)}")
+    import traceback
+    traceback.print_exc()
+    sys.exit(1)
