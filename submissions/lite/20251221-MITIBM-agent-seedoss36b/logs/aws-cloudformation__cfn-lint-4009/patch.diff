@@ -0,0 +1,67 @@
+#!/usr/bin/env python
+
+import sys
+import os
+from cfnlint.template.transforms._language_extensions import _ForEachCollection, _ForEachValue
+
+# Create a mock cfn object
+class MockCfn:
+    def __init__(self):
+        self.regions = ['us-east-1']
+        self.template = {
+            'Parameters': {
+                'AdditionalCertificateArns': {
+                    'Type': 'CommaDelimitedList',
+                    'Default': ''
+                }
+            },
+            'Conditions': {
+                'HasAdditionalCertificates': {
+                    'Fn::Not': [
+                        {'Fn::Equals': [
+                            {'Fn::Join': [',', {'Ref': 'AdditionalCertificateArns'}]},
+                            ''
+                        ]}
+                    ]
+                }
+            }
+        }
+
+mock_cfn = MockCfn()
+
+# Test with a direct collection
+direct_collection = ["item1", "item2", "item3"]
+direct_foreach_collection = _ForEachCollection(direct_collection)
+print("Direct collection test:")
+for item in direct_foreach_collection.values(mock_cfn, {}, {}):
+    print(f"  - {item}")
+
+# Test with Fn::If in the collection (true case)
+if_collection = {"Fn::If": ["HasAdditionalCertificates", {"Ref": "AdditionalCertificateArns"}, []]}
+if_foreach_collection = _ForEachCollection(if_collection)
+print("\nFn::If collection test (true case):")
+try:
+    # This should not raise an exception now
+    for item in if_foreach_collection.values(mock_cfn, {}, {}):
+        print(f"  - {item}")
+    print("Success! Fn::If is now supported in ForEach Collection")
+except Exception as e:
+    print(f"Error: {type(e).__name__}: {str(e)}")
+    import traceback
+    traceback.print_exc()
+
+# Test with Fn::If in the collection (false case - empty list)
+# Modify the mock to make the condition evaluate to false
+mock_cfn.template['Parameters']['AdditionalCertificateArns']['Default'] = 'arn1,arn2'
+if_collection_false = {"Fn::If": ["HasAdditionalCertificates", {"Ref": "AdditionalCertificateArns"}, []]}
+if_foreach_collection_false = _ForEachCollection(if_collection_false)
+print("\nFn::If collection test (false case - empty list):")
+try:
+    # This should not raise an exception now
+    for item in if_foreach_collection_false.values(mock_cfn, {}, {}):
+        print(f"  - {item}")
+    print("Success! Fn::If with empty list is now supported in ForEach Collection")
+except Exception as e:
+    print(f"Error: {type(e).__name__}: {str(e)}")
+    import traceback
+    traceback.print_exc()
