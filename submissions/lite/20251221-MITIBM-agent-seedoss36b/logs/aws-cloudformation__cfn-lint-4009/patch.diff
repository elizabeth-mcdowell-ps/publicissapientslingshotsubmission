+#!/usr/bin/env python
+
+import sys
+import os
+import json
+import argparse
+from cfnlint.core import get_rules, run_checks
+from cfnlint.config import ConfigMixIn
+
+# Template from PR description
+template_content = """
+AWSTemplateFormatVersion: '2010-09-09'
+Description: This template adds additional certificates to an Application Load Balancer (ALB) HTTPS Listener
+
+################################################################################
+Transform: 'AWS::LanguageExtensions'
+
+################################################################################
+Parameters:
+
+  LoadBalancerHTTPSListener:
+    Description: The HTTPS Listener of the ALB
+    Type: String
+
+  AdditionalCertificateArns:
+    Description: The ARN of the additional ACM Certificates in the same region
+    Type: CommaDelimitedList
+    Default: ''
+
+################################################################################
+Conditions:
+
+  HasAdditionalCertificates: !Not [!Equals [!Join [',', !Ref AdditionalCertificateArns], '']]
+
+################################################################################
+Resources:
+
+  'Fn::ForEach::AdditionalCertificateLoop':
+    - AdditionalCertificateArn
+    - !If
+      - HasAdditionalCertificates
+      - !Ref AdditionalCertificateArns
+      - []
+    - 'Certificate&{AdditionalCertificateArn}':
+        Type: AWS::ElasticLoadBalancingV2::ListenerCertificate
+        Properties:
+          ListenerArn: !Ref LoadBalancerHTTPSListener
+          Certificates:
+            - CertificateArn: !Ref CertificateArn
+"""
+
+# Write template to a file
+with open('/testbed/template.yml', 'w') as f:
+    f.write(template_content)
+
+# Create args for cfn-lint
+parser = argparse.ArgumentParser()
+args = parser.parse_args([])
+args.template = ['/testbed/template.yml']
+args.format = 'json'
+args.regions = ['us-east-1']
+args.append_rules = []
+args.ignore_checks = []
+args.include_checks = []
+args.configure_rules = {}
+args.include_experimental = False
+args.mandatory_checks = []
+args.custom_rules = None
+args.ignore_bad_template = False
+args.debug = False
+args.update_specs = False
+args.override_specs = None
+args.registry_schemas = []
+args.info_rules = []
+args.warn_rules = []
+args.error_rules = []
+
+# Initialize rules and run checks
+rules = get_rules(
+    args.append_rules, 
+    args.ignore_checks, 
+    args.include_checks, 
+    args.configure_rules, 
+    args.include_experimental, 
+    args.mandatory_checks, 
+    args.custom_rules
+)
+matches = run_checks(args.template, rules, args)
+
+# Print the results
+print(json.dumps(matches, indent=2))
