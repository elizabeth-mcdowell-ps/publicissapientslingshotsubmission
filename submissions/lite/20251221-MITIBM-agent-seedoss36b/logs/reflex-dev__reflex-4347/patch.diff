diff --git a/verify_fix.py b/verify_fix.py
new file mode 100644
index 00000000..0a2f89fb
--- /dev/null
+++ b/verify_fix.py
@@ -0,0 +1,39 @@
+"""Test script to verify the fix for ComponentState initialization."""
+
+import sys
+import os
+
+# Add the current directory to the Python path
+sys.path.insert(0, os.path.abspath('.'))
+
+# Import the ComponentState class
+from reflex.state import ComponentState
+
+# Define a test ComponentState subclass
+class DummyComponent(ComponentState):
+    some_var: int = 0
+
+    def do_something(self):
+        self.some_var += 1
+
+
+def test_direct_component_init():
+    # Directly initialize the ComponentState
+    state_inst = DummyComponent()
+    
+    # Check initial value
+    print(f"Initial value: {state_inst.some_var}")
+    assert state_inst.some_var == 0
+    
+    # Call a method that modifies state
+    state_inst.do_something()
+    
+    # Check that the state was updated
+    print(f"After do_something: {state_inst.some_var}")
+    assert state_inst.some_var == 1
+    
+    print("Test passed!")
+
+
+if __name__ == "__main__":
+    test_direct_component_init()
