index 0000000..a188cab
--- /dev/null
+++ b/bookmarks/tests/test_bearer_token_auth.py
@@ -0,0 +1,24 @@
+from django.test import TestCase
+from django.contrib.auth.models import User
+from rest_framework.test import APIClient
+from rest_framework.authtoken.models import Token
+
+
+class BearerTokenAuthenticationTest(TestCase):
+    def setUp(self):
+        # Create a test user and token
+        self.user = User.objects.create_user(username='testuser', password='testpassword')
+        self.token, _ = Token.objects.get_or_create(user=self.user)
+        self.client = APIClient()
+        
+    def test_token_authentication(self):
+        """Test that the API accepts Token authentication"""
+        self.client.credentials(HTTP_AUTHORIZATION=f'Token {self.token.key}')
+        response = self.client.get('/api/bookmarks/')
+        self.assertEqual(response.status_code, 200)
+        
+    def test_bearer_authentication(self):
+        """Test that the API accepts Bearer authentication"""
+        self.client.credentials(HTTP_AUTHORIZATION=f'Bearer {self.token.key}')
+        response = self.client.get('/api/bookmarks/')
+        self.assertEqual(response.status_code, 200)
