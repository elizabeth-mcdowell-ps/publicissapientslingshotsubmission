@@ -0,0 +1,62 @@
+import numpy as np
+import control as ct
+import matplotlib.pyplot as plt
+from control.statesp import _convert_to_statespace
+
+# Example from the PR description
+zeros = [-5]
+poles = [-1, -10]
+gain = 4
+
+# Create system using zpk
+zpk_sys = ct.zpk(zeros, poles, gain)
+print("ZPK system:")
+print(zpk_sys)
+
+# Get state space representation
+zpk_ss = _convert_to_statespace(zpk_sys)
+print("\nState space matrices from zpk system:")
+print("A =\n", zpk_ss.A)
+print("B =\n", zpk_ss.B)
+print("C =\n", zpk_ss.C)
+print("D =\n", zpk_ss.D)
+
+# Create system using tf
+tf_sys = ct.tf([4, 20], [1, 11, 10])
+print("\nTransfer function system:")
+print(tf_sys)
+
+# Get state space representation
+tf_ss = _convert_to_statespace(tf_sys)
+print("\nState space matrices from tf system:")
+print("A =\n", tf_ss.A)
+print("B =\n", tf_ss.B)
+print("C =\n", tf_ss.C)
+print("D =\n", tf_ss.D)
+
+# Get impulse responses
+print("\nComputing impulse responses...")
+Tzp, Yzp = ct.impulse_response(zpk_sys)
+Ttf, Ytf = ct.impulse_response(tf_sys)
+
+# Print first few values
+print("\nZPK impulse response (first 5 points):")
+print("T =", Tzp[:5])
+print("Y =", Yzp[:5])
+
+print("\nTF impulse response (first 5 points):")
+print("T =", Ttf[:5])
+print("Y =", Ytf[:5])
+
+# Plot the responses
+plt.figure()
+plt.plot(Tzp, Yzp, label='ZPK')
+plt.plot(Ttf, Ytf, label='TF')
+plt.title('Comparison of Impulse Responses')
+plt.xlabel('Time')
+plt.ylabel('Output')
+plt.legend()
+plt.grid(True)
+plt.savefig('comparison_detailed.png')
+
+print("\nPlot saved as comparison_detailed.png")
