@@ -0,0 +1,68 @@
+import numpy as np
+import control as ct
+from control.statesp import _convert_to_statespace
+import scipy.signal as sig
+
+# Example from the PR description
+zeros = [-5]
+poles = [-1, -10]
+gain = 4
+
+# Create systems using different methods
+zpk_sys = ct.zpk(zeros, poles, gain)
+tf_sys = ct.tf([4, 20], [1, 11, 10])
+
+# Convert to state space
+zpk_ss = _convert_to_statespace(zpk_sys)
+tf_ss = _convert_to_statespace(tf_sys)
+
+print("ZPK system state space matrices:")
+print("A =\n", zpk_ss.A)
+print("B =\n", zpk_ss.B)
+print("C =\n", zpk_ss.C)
+print("D =\n", zpk_ss.D)
+
+print("\nTF system state space matrices:")
+print("A =\n", tf_ss.A)
+print("B =\n", tf_ss.B)
+print("C =\n", tf_ss.C)
+print("D =\n", tf_ss.D)
+
+# Try direct conversion using scipy
+num, den = sig.zpk2tf(zeros, poles, gain)
+A_scipy, B_scipy, C_scipy, D_scipy = sig.tf2ss(num, den)
+
+print("\nSciPy direct conversion:")
+print("A =\n", A_scipy)
+print("B =\n", B_scipy)
+print("C =\n", C_scipy)
+print("D =\n", D_scipy)
+
+# Create a state space system directly
+direct_ss = ct.ss(A_scipy, B_scipy, C_scipy, D_scipy)
+
+# Get impulse responses
+print("\nComputing impulse responses...")
+Tzp, Yzp = ct.impulse_response(zpk_sys)
+Ttf, Ytf = ct.impulse_response(tf_sys)
+Tss, Yss = ct.impulse_response(direct_ss)
+
+# Print first few values
+print("\nZPK impulse response (first 5 points):")
+print("T =", Tzp[:5])
+print("Y =", Yzp[:5])
+
+print("\nTF impulse response (first 5 points):")
+print("T =", Ttf[:5])
+print("Y =", Ytf[:5])
+
+print("\nDirect SS impulse response (first 5 points):")
+print("T =", Tss[:5])
+print("Y =", Yss[:5])
+
+# Check the B matrix used for initial condition in impulse_response
+print("\nInitial condition for ZPK system:")
+print("X0 =", zpk_ss.B[:, 0])
+
+print("\nInitial condition for TF system:")
+print("X0 =", tf_ss.B[:, 0])
