+++ b/reproduce_issue.py
@@ -0,0 +1,53 @@
+import control as ct
+import control.matlab as ml
+import matplotlib.pyplot as plt
+import numpy as np
+
+# Declare stable system as zpk
+Gzp = ct.zpk([-5], [-1, -10], gain=4)
+print("ZPK system:")
+print(Gzp)
+
+# Declare same system as tf
+Gtf = ct.tf([4, 20], [1, 11, 10])
+print("\nTransfer function system:")
+print(Gtf)
+
+# Check if both systems have the same transfer function
+print("\nDifference between systems:")
+print(Gzp - Gtf)
+
+# Get impulse responses
+print("\nComputing impulse responses...")
+Tzp, Yzp = ct.impulse_response(Gzp)
+Ttf, Ytf = ct.impulse_response(Gtf)
+
+# Plot the responses
+plt.figure(1)
+plt.plot(Tzp, Yzp, label='ZPK')
+plt.title('Impulse Response of ZPK System')
+plt.xlabel('Time')
+plt.ylabel('Output')
+plt.grid(True)
+plt.savefig('zpk_impulse.png')
+
+plt.figure(2)
+plt.plot(Ttf, Ytf, label='TF')
+plt.title('Impulse Response of TF System')
+plt.xlabel('Time')
+plt.ylabel('Output')
+plt.grid(True)
+plt.savefig('tf_impulse.png')
+
+# Compare the responses
+plt.figure(3)
+plt.plot(Tzp, Yzp, label='ZPK')
+plt.plot(Ttf, Ytf, label='TF')
+plt.title('Comparison of Impulse Responses')
+plt.xlabel('Time')
+plt.ylabel('Output')
+plt.legend()
+plt.grid(True)
+plt.savefig('comparison.png')
+
+print("\nPlots saved as zpk_impulse.png, tf_impulse.png, and comparison.png")
