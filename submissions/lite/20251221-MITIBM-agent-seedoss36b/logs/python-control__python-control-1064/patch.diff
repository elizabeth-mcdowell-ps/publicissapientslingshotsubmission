+import numpy as np
+from scipy.signal import zpk2tf, tf2ss
+import control as ct
+
+# Example from the PR description
+zeros = [-5]
+poles = [-1, -10]
+gain = 4
+
+# Convert using scipy's zpk2tf
+num, den = zpk2tf(zeros, poles, gain)
+print("scipy.signal.zpk2tf result:")
+print("num =", num)
+print("den =", den)
+
+# Convert to state space using scipy's tf2ss
+A, B, C, D = tf2ss(num, den)
+print("\nState space representation:")
+print("A =\n", A)
+print("B =\n", B)
+print("C =\n", C)
+print("D =\n", D)
+
+# Create state space system using control
+ss_sys = ct.ss(A, B, C, D)
+print("\nState space system:")
+print(ss_sys)
+
+# Get impulse response of state space system
+T, Y = ct.impulse_response(ss_sys)
+print("\nImpulse response of state space system (first 5 points):")
+print("T =", T[:5])
+print("Y =", Y[:5])
+
+# Compare with direct tf system
+tf_sys = ct.tf(num, den)
+T_tf, Y_tf = ct.impulse_response(tf_sys)
+print("\nImpulse response of transfer function system (first 5 points):")
+print("T =", T_tf[:5])
+print("Y =", Y_tf[:5])
