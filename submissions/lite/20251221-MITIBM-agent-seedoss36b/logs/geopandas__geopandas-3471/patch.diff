+        # Generate random points in the bounding box
+        x_random = generator.uniform(xmin, xmax, size=batch_size)
+        y_random = generator.uniform(ymin, ymax, size=batch_size)
+        
+        # Create points and filter those inside the polygon
+        batch = points_from_xy(x=x_random, y=y_random)
         valid_samples = batch[batch.sindex.query(geom, predicate="contains")]
+        
+        # Add valid points to our collection
         candidates.extend(valid_samples)
+    
+    # If we have more points than needed, randomly select exactly 'size' points
+    if len(candidates) > size:
+        indices = generator.choice(len(candidates), size=size, replace=False)
+        candidates = [candidates[i] for i in indices]
+    
