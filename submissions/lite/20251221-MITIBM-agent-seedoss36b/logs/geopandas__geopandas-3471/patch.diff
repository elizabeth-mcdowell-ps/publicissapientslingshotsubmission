 def _uniform_polygon(geom, size, generator):
     """
-    Sample uniformly from within a polygon using batched sampling.
+    Sample uniformly from within a polygon using a more robust approach.
+    
+    This implementation uses the fact that a uniform distribution within a polygon
+    can be achieved by:
+    1. Generating random points in the polygon's bounding box
+    2. Keeping only points that are inside the polygon
+    3. Repeating until we have enough points
+    
+    To avoid bias, we ensure that we generate exactly the requested number of points
+    and don't truncate a larger collection.
     """
     xmin, ymin, xmax, ymax = geom.bounds
     candidates = []
+    
+    # Generate points in batches for efficiency
+    batch_size = max(size, 1000)  # Use at least 1000 points per batch for efficiency
+    
     while len(candidates) < size:
-        batch = points_from_xy(
