+import geopandas
+import shapely.geometry as sg
+import numpy as np
+import matplotlib.pyplot as plt
+
+POINTS = 2**10
+
+circle = sg.Point(0, 0).buffer(1)
+
+centers = []
+for i in range(200):
+    pts = geopandas.GeoSeries([circle]).sample_points(POINTS).explode()
+    centers.append((np.mean(pts.x), np.mean(pts.y)))
+
+centers = np.array(centers)
+
+# Plot the results
+plt.figure(figsize=(10, 8))
+plt.scatter(centers[:, 0], centers[:, 1], alpha=0.5)
+plt.axhline(y=0, color='r', linestyle='-', alpha=0.3)
+plt.axvline(x=0, color='r', linestyle='-', alpha=0.3)
+plt.title(f'Distribution of mean points after fix (n={POINTS})')
+plt.xlabel('X')
+plt.ylabel('Y')
+plt.grid(True, alpha=0.3)
+plt.savefig('after_fix.png')
+plt.close()
+
+# Print some statistics
+print(f"Mean X: {np.mean(centers[:, 0])}")
+print(f"Mean Y: {np.mean(centers[:, 1])}")
+print(f"Std X: {np.std(centers[:, 0])}")
+print(f"Std Y: {np.std(centers[:, 1])}")
+
+# Test with different point counts to check for multimodality
+for power in range(10, 16):
+    points = 2**power
+    centers = []
+    for i in range(50):  # Reduced to 50 for speed
+        pts = geopandas.GeoSeries([circle]).sample_points(points).explode()
+        centers.append((np.mean(pts.x), np.mean(pts.y)))
+    
+    centers = np.array(centers)
+    
+    plt.figure(figsize=(8, 6))
+    plt.scatter(centers[:, 0], centers[:, 1], alpha=0.5)
+    plt.axhline(y=0, color='r', linestyle='-', alpha=0.3)
+    plt.axvline(x=0, color='r', linestyle='-', alpha=0.3)
+    plt.title(f'Distribution with n={points} points')
+    plt.xlabel('X')
+    plt.ylabel('Y')
+    plt.grid(True, alpha=0.3)
+    plt.savefig(f'after_fix_{points}.png')
+    plt.close()
+    
+    print(f"\nFor {points} points:")
+    print(f"Mean X: {np.mean(centers[:, 0])}")
+    print(f"Mean Y: {np.mean(centers[:, 1])}")
+    print(f"Std X: {np.std(centers[:, 0])}")
+    print(f"Std Y: {np.std(centers[:, 1])}")
