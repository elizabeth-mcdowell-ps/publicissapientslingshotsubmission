@@ -0,0 +1,47 @@
+import geopandas
+import shapely.geometry as sg
+import numpy as np
+
+# Test case 1: Empty geometry
+empty = sg.Polygon()
+result = geopandas.GeoSeries([empty]).sample_points(10)
+print("Empty geometry test:", result[0].is_empty)
+
+# Test case 2: Very small geometry
+tiny = sg.Point(0, 0).buffer(1e-10)
+result = geopandas.GeoSeries([tiny]).sample_points(10)
+print("Tiny geometry test:", len(result.explode()) > 0)
+
+# Test case 3: Complex polygon (star shape)
+angles = np.linspace(0, 2*np.pi, 10, endpoint=False)
+outer_points = [(np.cos(a), np.sin(a)) for a in angles]
+inner_points = [(0.5*np.cos(a+np.pi/10), 0.5*np.sin(a+np.pi/10)) for a in angles]
+star_points = []
+for i in range(10):
+    star_points.append(outer_points[i])
+    star_points.append(inner_points[i])
+star = sg.Polygon(star_points)
+
+result = geopandas.GeoSeries([star]).sample_points(100)
+points = result.explode()
+print("Complex polygon test:", len(points) == 100)
+
+# Test case 4: Non-convex polygon (C shape)
+exterior = [(0, 0), (1, 0), (1, 3), (0, 3), (0, 0)]
+interior = [(0.2, 0.2), (0.2, 2.8), (0.8, 2.8), (0.8, 0.2), (0.2, 0.2)]
+c_shape = sg.Polygon(exterior, [interior])
+
+result = geopandas.GeoSeries([c_shape]).sample_points(100)
+points = result.explode()
+print("Non-convex polygon test:", len(points) == 100)
+
+# Test case 5: Multiple polygons
+multi = sg.MultiPolygon([sg.Point(0, 0).buffer(1), sg.Point(3, 3).buffer(0.5)])
+result = geopandas.GeoSeries([multi]).sample_points(100)
+points = result.explode()
+print("MultiPolygon test:", len(points) == 100)
+
+# Test case 6: Point geometry (should return empty)
+point = sg.Point(0, 0)
+result = geopandas.GeoSeries([point]).sample_points(10)
+print("Point geometry test:", result[0].is_empty)
