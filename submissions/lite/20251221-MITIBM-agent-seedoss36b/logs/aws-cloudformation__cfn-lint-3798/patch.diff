@@ -0,0 +1,45 @@
+#!/usr/bin/env python
+
+import json
+import os
+import sys
+from cfnlint.api import lint
+
+# Create a CloudFormation template with a nested FindInMap that's too deep
+template_content = {
+    "AWSTemplateFormatVersion": "2010-09-09",
+    "Mappings": {
+        "MyCustomMap": {
+            "Level1": {
+                "Level2": {
+                    "Key": "value"
+                }
+            }
+        }
+    },
+    "Resources": {
+        "MyResource": {
+            "Type": "AWS::S3::Bucket",
+            "Properties": {
+                "BucketName": {
+                    "Fn::FindInMap": ["MyCustomMap", "Level1", "Level2", "Key"]
+                }
+            }
+        }
+    }
+}
+
+# Write the template to a file
+template_path = '/testbed/test_template.json'
+with open(template_path, 'w') as f:
+    json.dump(template_content, f, indent=2)
+
+# Run cfn-lint on the template
+matches = lint(template_path)
+
+# Print the results
+for match in matches:
+    print(f"{match.rule.id} {match.message}")
+
+# Clean up
+os.remove(template_path)
