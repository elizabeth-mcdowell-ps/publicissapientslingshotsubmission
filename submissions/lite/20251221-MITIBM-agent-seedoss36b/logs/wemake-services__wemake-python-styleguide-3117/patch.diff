@@ -0,0 +1,46 @@
+import ast
+import sys
+sys.path.append('/testbed')
+
+from wemake_python_styleguide.violations.refactoring import FalsyConstantCompareViolation
+from wemake_python_styleguide.visitors.ast.compares import WrongConstantCompareVisitor
+from wemake_python_styleguide.options.config import Configuration
+
+# Test code with both assert and if statements using empty list comparisons
+code = """
+def test_function():
+    task_json = {'args': []}
+    
+    # This should NOT trigger a violation (in assert)
+    assert task_json['args'] == []
+    
+    # This should trigger a violation (in if)
+    if task_json['args'] == []:
+        pass
+        
+    # This should NOT trigger a violation (in assert with message)
+    assert task_json['args'] == [], "Empty args list"
+    
+    # This should NOT trigger a violation (in assert with complex expression)
+    assert len(task_json['args']) == 0 or task_json['args'] == []
+"""
+
+# Parse the code into an AST
+tree = ast.parse(code)
+
+# Create a visitor with default options
+options = Configuration()
+visitor = WrongConstantCompareVisitor(options, tree=tree)
+
+# Run the visitor to find violations
+visitor.run()
+
+# Print any violations found
+print("Violations found:", len(visitor.violations))
+for violation in visitor.violations:
+    if isinstance(violation, FalsyConstantCompareViolation):
+        print(f"Found violation: {violation.error_template}")
+
+# Expected output:
+# Violations found: 1
+# Found violation: Found compare with falsy constant
