+import ast
+
+# Example code with an assert statement comparing with an empty list
+code = """
+def test_function():
+    task_json = {'args': []}
+    assert task_json['args'] == []
+    
+    # This should still trigger the violation
+    if task_json['args'] == []:
+        pass
+"""
+
+# Parse the code into an AST
+tree = ast.parse(code)
+
+# Let's check the AST structure to understand the parent-child relationships
+print("AST Structure:")
+for node in ast.walk(tree):
+    if isinstance(node, ast.Assert):
+        print(f"Assert at line {node.lineno}")
+        if isinstance(node.test, ast.Compare):
+            print(f"  Compare node: {ast.dump(node.test)[:50]}...")
+            for i, comparator in enumerate(node.test.comparators):
+                print(f"  Comparator {i}: {ast.dump(comparator)}")
+                
+                # Check if we can find the Assert node as a parent
+                parent_found = False
+                for potential_parent in ast.walk(tree):
+                    if isinstance(potential_parent, ast.Assert) and comparator in ast.walk(potential_parent):
+                        parent_found = True
+                        break
+                print(f"    Assert parent found: {parent_found}")
+                
+    elif isinstance(node, ast.If):
+        print(f"If at line {node.lineno}")
+        if isinstance(node.test, ast.Compare):
+            print(f"  Compare node: {ast.dump(node.test)[:50]}...")
+            for i, comparator in enumerate(node.test.comparators):
+                print(f"  Comparator {i}: {ast.dump(comparator)}")
+                
+                # Check if we can find the If node as a parent
+                parent_found = False
+                for potential_parent in ast.walk(tree):
+                    if isinstance(potential_parent, ast.If) and comparator in ast.walk(potential_parent):
+                        parent_found = True
+                        break
+                print(f"    If parent found: {parent_found}")
