+#!/usr/bin/env python3
+"""
+Script to test edge cases for the SVG fill-opacity fix.
+"""
+
+import tempfile
+from weasyprint import HTML
+
+# Test case 1: Multiple SVG elements with different fill-opacity values
+svg_case1 = """
+<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
+    <rect width="100" height="100" x="10" y="10" fill="red" fill-opacity="0.2" />
+    <rect width="100" height="100" x="120" y="10" fill="green" fill-opacity="0.5" />
+    <rect width="100" height="100" x="230" y="10" fill="blue" fill-opacity="0.8" />
+</svg>
+"""
+
+# Test case 2: SVG elements with both fill-opacity and stroke-opacity
+svg_case2 = """
+<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
+    <rect width="100" height="100" x="10" y="10" fill="red" fill-opacity="0.5" 
+          stroke="blue" stroke-width="5" stroke-opacity="0.7" />
+    <circle cx="200" cy="60" r="50" fill="green" fill-opacity="0.3" 
+            stroke="purple" stroke-width="5" stroke-opacity="0.6" />
+</svg>
+"""
+
+# Test case 3: SVG elements with fill-opacity and general opacity
+svg_case3 = """
+<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
+    <rect width="100" height="100" x="10" y="10" fill="red" fill-opacity="0.5" opacity="0.7" />
+    <circle cx="200" cy="60" r="50" fill="green" fill-opacity="0.8" opacity="0.4" />
+</svg>
+"""
+
+# Test case 4: Nested SVG elements with fill-opacity
+svg_case4 = """
+<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
+    <g opacity="0.8">
+        <rect width="100" height="100" x="10" y="10" fill="red" fill-opacity="0.5" />
+        <circle cx="200" cy="60" r="50" fill="green" fill-opacity="0.7" />
+    </g>
+</svg>
+"""
+
+# Create HTML with all test cases
+html_content = f"""
+<!DOCTYPE html>
+<html>
+<head>
+    <title>SVG Fill Opacity Edge Cases</title>
+    <style>
+        h2 {{ margin-top: 30px; }}
+    </style>
+</head>
+<body>
+    <h1>SVG Fill Opacity Edge Cases</h1>
+    
+    <h2>Case 1: Multiple elements with different fill-opacity values</h2>
+    {svg_case1}
+    
+    <h2>Case 2: Elements with both fill-opacity and stroke-opacity</h2>
+    {svg_case2}
+    
+    <h2>Case 3: Elements with fill-opacity and general opacity</h2>
+    {svg_case3}
+    
+    <h2>Case 4: Nested elements with fill-opacity</h2>
+    {svg_case4}
+</body>
+</html>
+"""
+
+# Create a temporary HTML file
+with tempfile.NamedTemporaryFile(suffix='.html', delete=False) as f:
+    f.write(html_content.encode('utf-8'))
+    html_path = f.name
+
+# Create a temporary PDF file
+pdf_path = html_path.replace('.html', '.pdf')
+
+# Convert HTML to PDF
+HTML(html_path).write_pdf(pdf_path)
+
+print(f"Generated edge cases PDF at: {pdf_path}")
+print("Please check the PDF to verify that all edge cases are handled correctly.")
