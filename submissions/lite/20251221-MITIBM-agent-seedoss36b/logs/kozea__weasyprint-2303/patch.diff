+#!/usr/bin/env python3
+"""
+Script to reproduce the SVG fill-opacity issue described in the PR.
+"""
+
+import os
+import tempfile
+from weasyprint import HTML
+
+# SVG content from the PR description
+svg_content = """
+<svg width="300" height="130" xmlns="http://www.w3.org/2000/svg">
+    <rect width="200" height="100" x="10" y="10" rx="20" ry="20" fill="#000" fill-opacity=".098"
+        fill-rule="evenodd" />
+    <circle cx="50" cy="50" r="50" fill="#1c87c9" fill-opacity=".098"
+        fill-rule="evenodd" />
+</svg>
+"""
+
+# SVG with reversed order
+svg_content_reversed = """
+<svg width="300" height="130" xmlns="http://www.w3.org/2000/svg">
+    <circle cx="50" cy="50" r="50" fill="#1c87c9" fill-opacity=".098"
+        fill-rule="evenodd" />
+    <rect width="200" height="100" x="10" y="10" rx="20" ry="20" fill="#000" fill-opacity=".098"
+        fill-rule="evenodd" />
+</svg>
+"""
+
+# Create HTML with the SVG content
+html_content = f"""
+<!DOCTYPE html>
+<html>
+<head>
+    <title>SVG Fill Opacity Test</title>
+</head>
+<body>
+    <h1>Original Order</h1>
+    {svg_content}
+    
+    <h1>Reversed Order</h1>
+    {svg_content_reversed}
+</body>
+</html>
+"""
+
+# Create a temporary HTML file
+with tempfile.NamedTemporaryFile(suffix='.html', delete=False) as f:
+    f.write(html_content.encode('utf-8'))
+    html_path = f.name
+
+# Create a temporary PDF file
+pdf_path = html_path.replace('.html', '.pdf')
+
+# Convert HTML to PDF
+HTML(html_path).write_pdf(pdf_path)
+
+print(f"Generated PDF at: {pdf_path}")
+print("Please check the PDF to see if both the rect and circle have proper fill-opacity.")
+print("According to the PR description, in v63 only one of them will have the correct fill-opacity.")
