+import os
+import sys
+from conan.tools.build.cross_building import cross_building
+
+# Let's just test the cross_building function directly
+def test_cross_building():
+    # Simulate Linux x86_64 -> x86 cross-compilation
+    build_os = "Linux"
+    build_arch = "x86_64"
+    host_os = "Linux"
+    host_arch = "x86"
+    
+    # Test with skip_x64_x86=True (current behavior)
+    is_cross_with_skip = check_cross_building(build_os, build_arch, host_os, host_arch, skip_x64_x86=True)
+    print(f"Is cross-building with skip_x64_x86=True: {is_cross_with_skip}")
+    
+    # Test without skip_x64_x86 (expected behavior)
+    is_cross_without_skip = check_cross_building(build_os, build_arch, host_os, host_arch, skip_x64_x86=False)
+    print(f"Is cross-building with skip_x64_x86=False: {is_cross_without_skip}")
+    
+    print("\nThis confirms that with the current implementation, x64->x86 cross-compilation")
+    print("is not considered cross-building when skip_x64_x86=True is used.")
+    print("This is why the Meson toolchain doesn't generate a cross-compilation file.")
+
+def check_cross_building(build_os, build_arch, host_os, host_arch, skip_x64_x86=False):
+    """Simplified version of cross_building function for testing"""
+    if skip_x64_x86 and host_os is not None and (build_os == host_os) and \
+            host_arch is not None and ((build_arch == "x86_64") and (host_arch == "x86") or
+                                       (build_arch == "sparcv9") and (host_arch == "sparc") or
+                                       (build_arch == "ppc64") and (host_arch == "ppc32")):
+        return False
+
+    if host_os is not None and (build_os != host_os):
+        return True
+    if host_arch is not None and (build_arch != host_arch):
+        return True
+
+    return False
+
+if __name__ == "__main__":
+    test_cross_building()
