+import os
+import sys
+from conan.tools.build.cross_building import cross_building
+
+class MockConanFile:
+    def __init__(self, build_os, build_arch, host_os, host_arch):
+        self.settings_build = MockSettings(build_os, build_arch)
+        self.settings = MockSettings(host_os, host_arch)
+        self.conf = MockConf()
+        self.conf_build = self.conf
+        
+    def get_safe(self, name):
+        if name == "os":
+            return self.settings.get_safe("os")
+        elif name == "arch":
+            return self.settings.get_safe("arch")
+        return None
+
+class MockSettings:
+    def __init__(self, os, arch):
+        self._os = os
+        self._arch = arch
+    
+    def get_safe(self, name):
+        if name == "os":
+            return self._os
+        elif name == "arch":
+            return self._arch
+        return None
+        
+    def possible_values(self):
+        return {}
+
+class MockConf:
+    def get(self, key, check_type=None):
+        return None
+
+def simulate_meson_toolchain():
+    # Simulate the Linux x86_64 -> x86 scenario from the PR description
+    build_os = "Linux"
+    build_arch = "x86_64"
+    host_os = "Linux"
+    host_arch = "x86"
+    
+    conanfile = MockConanFile(build_os, build_arch, host_os, host_arch)
+    
+    print("Simulating MesonToolchain behavior for Linux x86_64 -> x86 cross-compilation:\n")
+    
+    # Before the fix (skip_x64_x86=True)
+    is_cross_before = cross_building(conanfile, skip_x64_x86=True)
+    print(f"Before fix (skip_x64_x86=True):")
+    print(f"  Is cross-building: {is_cross_before}")
+    print(f"  Would generate cross-compilation file: {is_cross_before}")
+    print()
+    
+    # After the fix (skip_x64_x86=False)
+    is_cross_after = cross_building(conanfile, skip_x64_x86=False)
+    print(f"After fix (skip_x64_x86=False):")
+    print(f"  Is cross-building: {is_cross_after}")
+    print(f"  Would generate cross-compilation file: {is_cross_after}")
+    print()
+    
+    print("Conclusion:")
+    if is_cross_before != is_cross_after:
+        print("  The fix correctly changes the behavior for x64->x86 cross-compilation.")
+        print("  With the fix, MesonToolchain will now generate a cross-compilation file")
+        print("  for Linux x86_64 -> x86, which should resolve the linking issue.")
+    else:
+        print("  The fix does not change the behavior for this scenario.")
+
+if __name__ == "__main__":
+    simulate_meson_toolchain()
