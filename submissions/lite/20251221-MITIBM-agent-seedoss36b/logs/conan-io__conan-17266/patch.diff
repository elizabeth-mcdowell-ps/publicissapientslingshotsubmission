+import os
+import sys
+from conan.tools.build.cross_building import cross_building
+
+class MockConanFile:
+    def __init__(self, build_os, build_arch, host_os, host_arch):
+        self.settings_build = MockSettings(build_os, build_arch)
+        self.settings = MockSettings(host_os, host_arch)
+        self.conf = MockConf()
+        self.conf_build = self.conf
+        
+    def get_safe(self, name):
+        if name == "os":
+            return self.settings.get_safe("os")
+        elif name == "arch":
+            return self.settings.get_safe("arch")
+        return None
+
+class MockSettings:
+    def __init__(self, os, arch):
+        self._os = os
+        self._arch = arch
+    
+    def get_safe(self, name):
+        if name == "os":
+            return self._os
+        elif name == "arch":
+            return self._arch
+        return None
+        
+    def possible_values(self):
+        return {}
+
+class MockConf:
+    def get(self, key, check_type=None):
+        return None
+
+def test_cross_building_scenarios():
+    # Test different cross-building scenarios
+    scenarios = [
+        # build_os, build_arch, host_os, host_arch, description
+        ("Linux", "x86_64", "Linux", "x86", "Linux x64->x86"),
+        ("Linux", "x86_64", "Linux", "x86_64", "Linux x64->x64 (same arch)"),
+        ("Linux", "x86_64", "Windows", "x86_64", "Linux->Windows (different OS)"),
+        ("Linux", "x86_64", "Windows", "x86", "Linux->Windows (different OS and arch)"),
+        ("macOS", "x86_64", "iOS", "arm64", "macOS->iOS (different OS and arch)"),
+    ]
+    
+    print("Testing cross-building scenarios with the fixed implementation:\n")
+    
+    for build_os, build_arch, host_os, host_arch, desc in scenarios:
+        conanfile = MockConanFile(build_os, build_arch, host_os, host_arch)
+        
+        # Test with skip_x64_x86=False (our fix)
+        is_cross = cross_building(conanfile, skip_x64_x86=False)
+        
+        print(f"Scenario: {desc}")
+        print(f"  Build: {build_os}/{build_arch}, Host: {host_os}/{host_arch}")
+        print(f"  Is cross-building: {is_cross}")
+        print()
+
+if __name__ == "__main__":
+    test_cross_building_scenarios()
