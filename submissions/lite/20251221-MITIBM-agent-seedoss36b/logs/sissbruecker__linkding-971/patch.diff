+import logging
+from mozilla_django_oidc.auth import OIDCAuthenticationBackend
+from django.conf import settings
+
+LOGGER = logging.getLogger(__name__)
+
+
+class CustomOIDCAuthenticationBackend(OIDCAuthenticationBackend):
+    """Custom OIDC authentication backend that can use either email or username field."""
+
+    def describe_user_by_claims(self, claims):
+        """Describe the user based on claims."""
+        if settings.OIDC_USE_USERNAME_FIELD:
+            username = claims.get("preferred_username") or claims.get("username")
+            return f"username {username}"
+        else:
+            email = claims.get("email")
+            return f"email {email}"
+
+    def filter_users_by_claims(self, claims):
+        """Return all users matching the specified email or username."""
+        if settings.OIDC_USE_USERNAME_FIELD:
+            username = claims.get("preferred_username") or claims.get("username")
+            if not username:
+                return self.UserModel.objects.none()
+            return self.UserModel.objects.filter(username__iexact=username)
+        else:
+            # Default behavior - filter by email
+            email = claims.get("email")
+            if not email:
+                return self.UserModel.objects.none()
+            return self.UserModel.objects.filter(email__iexact=email)
+
+    def verify_claims(self, claims):
+        """Verify the provided claims to decide if authentication should be allowed."""
+        if settings.OIDC_USE_USERNAME_FIELD:
+            username = claims.get("preferred_username") or claims.get("username")
+            return username is not None
+        else:
+            # Default behavior - verify email
+            scopes = self.get_settings("OIDC_RP_SCOPES", "openid email")
+            if "email" in scopes.split():
+                return "email" in claims
+
+        return True
+
+    def create_user(self, claims):
+        """Return object for a newly created user account."""
+        if settings.OIDC_USE_USERNAME_FIELD:
+            username = claims.get("preferred_username") or claims.get("username")
+            email = claims.get("email", "")
+            return self.UserModel.objects.create_user(username, email=email)
+        else:
+            # Default behavior - create user with email
+            email = claims.get("email")
+            username = self.get_username(claims)
+            return self.UserModel.objects.create_user(username, email=email)
