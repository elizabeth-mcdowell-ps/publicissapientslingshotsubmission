@@ -0,0 +1,83 @@
+from unittest.mock import patch, MagicMock
+from django.test import TestCase, override_settings
+from django.contrib.auth import get_user_model
+from bookmarks.auth import CustomOIDCAuthenticationBackend
+
+User = get_user_model()
+
+
+class MockOIDCBackend(CustomOIDCAuthenticationBackend):
+    """Mock OIDC backend that doesn't require OIDC settings."""
+    def __init__(self):
+        self.UserModel = get_user_model()
+    
+    def get_settings(self, attr, *args):
+        """Mock get_settings to avoid ImproperlyConfigured errors."""
+        return args[0] if args else ""
+
+
+class CustomOIDCBackendTest(TestCase):
+    def setUp(self):
+        self.backend = MockOIDCBackend()
+        self.user = User.objects.create_user(
+            username="testuser", email="test@example.com", password="password"
+        )
+        self.user_by_username = User.objects.create_user(
+            username="oidcuser", email="oidc@example.com", password="password"
+        )
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=False)
+    def test_filter_users_by_email(self):
+        claims = {"email": "test@example.com"}
+        users = self.backend.filter_users_by_claims(claims)
+        self.assertEqual(users.count(), 1)
+        self.assertEqual(users.first(), self.user)
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=True)
+    def test_filter_users_by_username(self):
+        claims = {"preferred_username": "oidcuser"}
+        users = self.backend.filter_users_by_claims(claims)
+        self.assertEqual(users.count(), 1)
+        self.assertEqual(users.first(), self.user_by_username)
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=True)
+    def test_filter_users_by_username_fallback(self):
+        claims = {"username": "oidcuser"}
+        users = self.backend.filter_users_by_claims(claims)
+        self.assertEqual(users.count(), 1)
+        self.assertEqual(users.first(), self.user_by_username)
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=False)
+    def test_create_user_with_email(self):
+        claims = {"email": "new@example.com"}
+        user = self.backend.create_user(claims)
+        self.assertEqual(user.email, "new@example.com")
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=True)
+    def test_create_user_with_username(self):
+        claims = {"preferred_username": "newuser", "email": "newuser@example.com"}
+        user = self.backend.create_user(claims)
+        self.assertEqual(user.username, "newuser")
+        self.assertEqual(user.email, "newuser@example.com")
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=True)
+    def test_create_user_with_username_fallback(self):
+        claims = {"username": "newuser2", "email": "newuser2@example.com"}
+        user = self.backend.create_user(claims)
+        self.assertEqual(user.username, "newuser2")
+        self.assertEqual(user.email, "newuser2@example.com")
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=False)
+    def test_verify_claims_with_email(self):
+        claims = {"email": "test@example.com"}
+        self.assertTrue(self.backend.verify_claims(claims))
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=True)
+    def test_verify_claims_with_username(self):
+        claims = {"preferred_username": "testuser"}
+        self.assertTrue(self.backend.verify_claims(claims))
+
+    @override_settings(OIDC_USE_USERNAME_FIELD=True)
+    def test_verify_claims_with_username_fallback(self):
+        claims = {"username": "testuser"}
+        self.assertTrue(self.backend.verify_claims(claims))
