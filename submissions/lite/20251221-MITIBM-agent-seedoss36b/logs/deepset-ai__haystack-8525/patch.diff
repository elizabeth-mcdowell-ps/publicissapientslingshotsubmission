+    def _split_csv_by_row(self, text: str) -> List[str]:
+        """
+        Splits a CSV document by rows.
+        
+        If include_header is True, each unit will contain the header row followed by a data row.
+        If include_header is False, each unit will contain only a data row.
+        
+        :param text: The CSV content as a string.
+        :return: A list of CSV row strings.
+        """
+        try:
+            # Try to detect the CSV dialect
+            dialect = csv.Sniffer().sniff(text[:1024])  # Use the first 1024 chars to detect dialect
+            has_header = csv.Sniffer().has_header(text[:1024])
+            csv_reader = csv.reader(io.StringIO(text), dialect)
+            rows = list(csv_reader)
+        except Exception as e:
+            # If dialect detection fails, fall back to default CSV reader
+            logger.warning(
+                "CSV dialect detection failed, using default CSV reader. Error: {error}", error=str(e)
+            )
+            csv_reader = csv.reader(io.StringIO(text))
+            rows = list(csv_reader)
+            has_header = len(rows) > 0  # Assume first row is header if there are rows
+        
+        if not rows:
+            logger.warning("Empty CSV content or parsing failed. Returning empty list.")
+            return []
+            
+        # If only one row and we think it's a header, return the original text
+        if len(rows) == 1 and has_header:
+            logger.warning("CSV contains only a header row. Returning original text.")
+            return [text]
+            
+        # Determine header and data rows
+        header = rows[0] if has_header else []
+        data_rows = rows[1:] if has_header else rows
+        
+        if not data_rows:
+            logger.warning("No data rows found in CSV. Returning original text.")
+            return [text]
+            
+        if self.include_header and has_header:
+            # Create units with header + each data row
+            units = []
+            # Use dialect.delimiter if available, otherwise default to comma
+            delimiter = getattr(dialect, 'delimiter', ',') if 'dialect' in locals() else ','
+            header_str = delimiter.join(header)
+            for row in data_rows:
+                row_str = delimiter.join(row)
+                units.append(f"{header_str}\n{row_str}")
+            return units
+        else:
+            # Return each data row as a separate unit
+            # Use dialect.delimiter if available, otherwise default to comma
+            delimiter = getattr(dialect, 'delimiter', ',') if 'dialect' in locals() else ','
+            return [delimiter.join(row) for row in data_rows]
 
