+def _process_complex_type_with_images(value: Any, annotation: Any) -> Union[List[dict], None]:
+    """
+    Process complex types (like List, Dict, Tuple) that might contain images.
+    Returns a list of content blocks if images are found, None otherwise.
+    
+    Args:
+        value: The value to process
+        annotation: The type annotation for the value
+    
+    Returns:
+        A list of content blocks if images are found, None otherwise
+    """
+    try:
+        import PIL
+    except ImportError:
+        # If PIL is not available, we can't process images anyway
+        return None
+        
+    # Helper function to process a single image
+    def process_image(img):
+        if isinstance(img, Image):
+            return {"type": "image_url", "image_url": img.model_dump()}
+        elif isinstance(img, dict) and "url" in img:
+            return {"type": "image_url", "image_url": {"url": img["url"]}}
+        elif isinstance(img, str):
+            encoded = encode_image(img)
+            return {"type": "image_url", "image_url": {"url": encoded}}
+        elif isinstance(img, PIL.Image.Image):
+            encoded = encode_image(img)
+            return {"type": "image_url", "image_url": {"url": encoded}}
+        return None
+    
+    # Helper function to recursively process complex types
+    def process_complex_value(val, type_annotation):
+        # Base case: if it's an image, process it directly
+        if isinstance(val, Image) or type_annotation == Image:
+            return process_image(val)
+        
+        # Get origin and args for the type annotation
+        origin = get_origin(type_annotation)
+        args = get_args(type_annotation)
+        
+        # Handle list types
+        if origin is list or isinstance(val, list):
+            result = []
+            result.append({"type": "text", "text": "["})
+            
+            # Process each item in the list
+            for i, item in enumerate(val):
+                # Determine the item's type annotation
+                item_type = args[0] if args else None
+                
+                # Process the item
+                if i > 0:
+                    result.append({"type": "text", "text": ", "})
+                
+                # Recursively process the item
+                item_result = process_complex_value(item, item_type)
+                if isinstance(item_result, list):
+                    # If it's a list of blocks, add them all
+                    result.extend(item_result)
+                elif isinstance(item_result, dict) and item_result.get("type") == "image_url":
+                    # If it's an image block, add it
+                    result.append(item_result)
+                else:
+                    # Otherwise, add a text representation
+                    result.append({"type": "text", "text": str(item)})
+            
+            result.append({"type": "text", "text": "]"})
+            return result
+        
+        # Handle dictionary types
+        elif origin is dict or isinstance(val, dict):
+            result = []
+            result.append({"type": "text", "text": "{"})
+            
+            # Process each key-value pair in the dictionary
+            for i, (key, item) in enumerate(val.items()):
+                # Determine the value's type annotation
+                value_type = args[1] if len(args) > 1 else None
+                
+                if i > 0:
+                    result.append({"type": "text", "text": ", "})
+                
+                # Add the key
+                result.append({"type": "text", "text": f'"{key}": '})
+                
+                # Recursively process the value
+                item_result = process_complex_value(item, value_type)
+                if isinstance(item_result, list):
+                    # If it's a list of blocks, add them all
+                    result.extend(item_result)
+                elif isinstance(item_result, dict) and item_result.get("type") == "image_url":
+                    # If it's an image block, add it
+                    result.append(item_result)
+                else:
+                    # Otherwise, add a text representation
+                    result.append({"type": "text", "text": str(item)})
+            
+            result.append({"type": "text", "text": "}"})
+            return result
+        
+        # Handle tuple types
+        elif origin is tuple or isinstance(val, tuple):
+            result = []
+            result.append({"type": "text", "text": "("})
+            
+            # Process each item in the tuple
+            for i, item in enumerate(val):
+                # Determine the item's type annotation
+                item_type = args[i] if i < len(args) else None
+                
+                if i > 0:
+                    result.append({"type": "text", "text": ", "})
+                
+                # Recursively process the item
+                item_result = process_complex_value(item, item_type)
+                if isinstance(item_result, list):
+                    # If it's a list of blocks, add them all
+                    result.extend(item_result)
+                elif isinstance(item_result, dict) and item_result.get("type") == "image_url":
+                    # If it's an image block, add it
+                    result.append(item_result)
+                else:
+                    # Otherwise, add a text representation
+                    result.append({"type": "text", "text": str(item)})
+            
+            result.append({"type": "text", "text": ")"})
+            return result
+        
+        # For other types, return None to indicate no special processing
+        return None
+    
+    # Start the recursive processing
+    result = process_complex_value(value, annotation)
+    
+    # Only return the result if it contains at least one image
+    if result and any(block.get("type") == "image_url" for block in result if isinstance(block, dict)):
+        return result
+    
+    return None
+
