+def test_coverage_nrel_with_snow_depth():
+    """Test that snow coverage is set to zero when ground snow depth is zero."""
+    surface_tilt = 5  # Low tilt angle
+    dt = pd.date_range(start="2019-1-1 10:00:00", end="2019-1-2 10:00:00",
+                       freq='1h')
+    poa_irradiance = pd.Series(100, index=dt)  # Low irradiance
+    temp_air = pd.Series(-5, index=dt)         # Cold temperature
+    
+    # Snowfall data - significant snowfall at the beginning
+    snowfall = np.zeros(len(dt))
+    snowfall[0:5] = [5.0, 3.0, 2.0, 1.0, 0.5]  # Heavy snowfall in the first 5 hours
+    snowfall_series = pd.Series(snowfall, index=dt)
+    
+    # Ground snow depth - starts with snow, then melts to zero
+    snow_depth = np.zeros(len(dt))
+    snow_depth[0:12] = 15.0  # 15cm of snow on ground for first 12 hours
+    snow_depth[12:] = 0.0    # No snow on ground after that
+    snow_depth_series = pd.Series(snow_depth, index=dt)
+    
+    # Calculate snow coverage with snow depth parameter
+    coverage = snow.coverage_nrel(
+        snowfall_series, poa_irradiance, temp_air, surface_tilt,
+        snow_depth=snow_depth_series)
+    
+    # Check that snow coverage is zero when ground snow depth is zero
+    assert all(coverage[snow_depth_series == 0] == 0)
