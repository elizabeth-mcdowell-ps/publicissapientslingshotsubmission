+# This should trigger the error described in the PR
+if __name__ == "__main__":
+    # Set environment variable for maximum verbosity
+    os.environ["CONAN_VERBOSE_TRACEBACK"] = "1"
+    os.environ["CONAN_LOGGING_LEVEL"] = "50"  # CRITICAL=50, ERROR=40, WARNING=30, INFO=20, DEBUG=10
