@@ -0,0 +1,97 @@
+import io
+import falcon
+from falcon import testing
+from falcon.media.multipart import MultipartFormHandler
+
+# Create a simple app with a route that accepts multipart form data
+class Resource:
+    def on_post(self, req, resp):
+        form = req.get_media()
+        result = []
+        for part in form:
+            if part.name:
+                result.append({"name": part.name, "value": part.text})
+        resp.media = result
+
+app = falcon.App()
+app.add_route('/upload', Resource())
+app.req_options.media_handlers[falcon.MEDIA_MULTIPART] = MultipartFormHandler()
+
+# Create a test client
+client = testing.TestClient(app)
+
+# Test cases
+test_cases = [
+    {
+        "name": "Standard form with CRLF after closing boundary",
+        "body": (
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="field1"\r\n\r\n'
+            b'value1\r\n'
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="field2"\r\n\r\n'
+            b'value2\r\n'
+            b'--boundary--\r\n'  # Note the CRLF after the closing boundary
+        )
+    },
+    {
+        "name": "Form without CRLF after closing boundary (like Undici client)",
+        "body": (
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="field1"\r\n\r\n'
+            b'value1\r\n'
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="field2"\r\n\r\n'
+            b'value2\r\n'
+            b'--boundary--'  # No CRLF after the closing boundary
+        )
+    },
+    {
+        "name": "Form with multiple fields and files",
+        "body": (
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="field1"\r\n\r\n'
+            b'value1\r\n'
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="field2"\r\n\r\n'
+            b'value2\r\n'
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="file1"; filename="test.txt"\r\n'
+            b'Content-Type: text/plain\r\n\r\n'
+            b'Hello, world!\r\n'
+            b'--boundary--'  # No CRLF after the closing boundary
+        )
+    },
+    {
+        "name": "Empty form with just a boundary",
+        "body": (
+            b'--boundary--'  # No CRLF after the closing boundary
+        )
+    },
+    {
+        "name": "Form with empty fields",
+        "body": (
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="empty1"\r\n\r\n'
+            b'\r\n'
+            b'--boundary\r\n'
+            b'Content-Disposition: form-data; name="empty2"\r\n\r\n'
+            b'\r\n'
+            b'--boundary--'  # No CRLF after the closing boundary
+        )
+    }
+]
+
+# Run the tests
+for test_case in test_cases:
+    print(f"\nTesting: {test_case['name']}")
+    try:
+        resp = client.simulate_post(
+            '/upload',
+            headers={'Content-Type': 'multipart/form-data; boundary=boundary'},
+            body=test_case['body']
+        )
+        print(f"Status: {resp.status}")
+        print(f"Response: {resp.json}")
+    except Exception as e:
+        print(f"Error: {e}")
