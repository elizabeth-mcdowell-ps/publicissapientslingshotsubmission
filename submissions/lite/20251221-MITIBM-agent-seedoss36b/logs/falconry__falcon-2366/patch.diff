@@ -0,0 +1,58 @@
+import io
+import falcon
+from falcon import testing
+from falcon.media.multipart import MultipartFormHandler
+
+# Create a simple app with a route that accepts multipart form data
+class Resource:
+    def on_post(self, req, resp):
+        form = req.get_media()
+        result = []
+        for part in form:
+            if part.name == 'field':
+                result.append(part.text)
+        resp.media = result
+
+app = falcon.App()
+app.add_route('/upload', Resource())
+app.req_options.media_handlers[falcon.MEDIA_MULTIPART] = MultipartFormHandler()
+
+# Create a test client
+client = testing.TestClient(app)
+
+# Standard multipart form with CRLF after the closing boundary
+standard_form = (
+    b'--boundary\r\n'
+    b'Content-Disposition: form-data; name="field"\r\n\r\n'
+    b'value1\r\n'
+    b'--boundary--\r\n'  # Note the CRLF after the closing boundary
+)
+
+# Multipart form without CRLF after the closing boundary (like Undici client)
+undici_form = (
+    b'--boundary\r\n'
+    b'Content-Disposition: form-data; name="field"\r\n\r\n'
+    b'value1\r\n'
+    b'--boundary--'  # No CRLF after the closing boundary
+)
+
+print("Testing standard form with CRLF after closing boundary:")
+resp = client.simulate_post(
+    '/upload',
+    headers={'Content-Type': 'multipart/form-data; boundary=boundary'},
+    body=standard_form
+)
+print(f"Status: {resp.status}")
+print(f"Response: {resp.json}")
+
+print("\nTesting Undici-style form without CRLF after closing boundary:")
+try:
+    resp = client.simulate_post(
+        '/upload',
+        headers={'Content-Type': 'multipart/form-data; boundary=boundary'},
+        body=undici_form
+    )
+    print(f"Status: {resp.status}")
+    print(f"Response: {resp.json}")
+except Exception as e:
+    print(f"Error: {e}")
