diff --git a/test_fix.py b/test_fix.py
new file mode 100644
index 00000000..a349f08a
--- /dev/null
+++ b/test_fix.py
@@ -0,0 +1,108 @@
+import reflex as rx
+
+class TestState(rx.State):
+    value: str = "fast"
+    features: dict[str, dict] = {
+        "fast": {
+            "title": "Fast",
+            "description": "Lightning quick performance",
+            "icon": "zap"
+        },
+        "secure": {
+            "title": "Secure",
+            "description": "Enterprise-grade security",
+            "icon": "lock"
+        },
+        "global": {
+            "title": "Global",
+            "description": "Worldwide availability",
+            "icon": "globe"
+        }
+    }
+    
+    def change_value(self, new_value: str):
+        self.value = new_value
+
+def feature_card(feature: str) -> rx.Component:
+    # Using rx.match to determine icon name
+    icon_name = rx.match(
+        feature,
+        ("fast", "zap"),
+        ("secure", "lock"),
+        ("global", "globe"),
+        "help-circle"  # Default fallback
+    )
+
+    # Using rx.match to determine title
+    title = rx.match(
+        feature,
+        ("fast", "Fast"),
+        ("secure", "Secure"),
+        ("global", "Global"),
+        "Unknown"  # Default fallback
+    )
+
+    return rx.card(
+        rx.vstack(
+            rx.icon(
+                icon_name,
+                size=32,
+            ),
+            rx.heading(title, size="md"),
+            rx.text(TestState.features[feature]["description"]),
+            align="center",
+            spacing="2",
+        ),
+        width="200px",
+        height="200px",
+        border_radius="lg",
+        padding="4",
+    )
+
+def features_section() -> rx.Component:
+    return rx.vstack(
+        rx.heading("Feature Cards with Dynamic Icons", size="lg"),
+        rx.text("Click the buttons to change the selected feature"),
+        rx.hstack(
+            rx.button("Fast", on_click=TestState.change_value("fast")),
+            rx.button("Secure", on_click=TestState.change_value("secure")),
+            rx.button("Global", on_click=TestState.change_value("global")),
+            spacing="4",
+        ),
+        rx.divider(),
+        rx.text("Current selection: ", TestState.value),
+        rx.hstack(
+            feature_card(TestState.value),
+            spacing="6",
+            justify="center",
+            wrap="wrap",
+            width="100%",
+            padding="2em",
+        ),
+        rx.divider(),
+        rx.text("All features:"),
+        rx.hstack(
+            rx.foreach(
+                TestState.features.keys(),
+                lambda feature: feature_card(feature)
+            ),
+            spacing="6",
+            justify="center",
+            wrap="wrap",
+            width="100%",
+            padding="2em",
+        ),
+        spacing="4",
+        width="100%",
+        padding="2em",
+    )
+
+@rx.page(route="/", title="Test Fix")
+def index() -> rx.Component:
+    return rx.vstack(
+        features_section(),
+        spacing="0",
+        width="100%",
+    )
+
+app = rx.App()
