@@ -0,0 +1,57 @@
+import os
+import sys
+import yaml
+from pathlib import Path
+
+# Add the repository root to the Python path
+repo_root = Path(__file__).parent
+
+# Read the YAML file
+yaml_file_path = repo_root / "checkov" / "terraform" / "checks" / "graph_checks" / "azure" / "AzureSubnetConfigWithNSG.yaml"
+with open(yaml_file_path, 'r') as f:
+    yaml_content = yaml.safe_load(f)
+
+# Print the structure of the YAML file
+print("YAML Structure:")
+print(yaml.dump(yaml_content, default_flow_style=False))
+
+# Verify the changes
+print("\nVerification:")
+print(f"Check ID: {yaml_content['metadata']['id']}")
+print(f"Check Name: {yaml_content['metadata']['name']}")
+
+# Check if the top-level condition is 'or'
+if yaml_content['definition'].get('or'):
+    print("✅ Top-level condition is 'or' (correct)")
+else:
+    print("❌ Top-level condition is not 'or' (incorrect)")
+
+# Check if GatewaySubnet is handled
+gateway_subnet_handled = False
+azure_firewall_subnet_handled = False
+
+# Iterate through the OR conditions
+for condition in yaml_content['definition'].get('or', []):
+    if isinstance(condition, dict) and condition.get('and'):
+        # Check if there's an OR condition inside the AND
+        for subcond in condition.get('and', []):
+            if subcond.get('or'):
+                # Check the nested OR conditions
+                for or_cond in subcond.get('or', []):
+                    if or_cond.get('cond_type') == 'attribute' and or_cond.get('attribute') == 'name':
+                        if or_cond.get('value') == 'GatewaySubnet' and or_cond.get('operator') == 'equals_ignore_case':
+                            gateway_subnet_handled = True
+                        if or_cond.get('value') == 'AzureFirewallSubnet' and or_cond.get('operator') == 'equals_ignore_case':
+                            azure_firewall_subnet_handled = True
+
+print(f"GatewaySubnet handled: {'✅ Yes' if gateway_subnet_handled else '❌ No'}")
+print(f"AzureFirewallSubnet handled: {'✅ Yes' if azure_firewall_subnet_handled else '❌ No'}")
+
+# Clean up the temporary files
+temp_dir = repo_root / "temp_test"
+if temp_dir.exists():
+    temp_file = temp_dir / "main.tf"
+    if temp_file.exists():
+        os.remove(temp_file)
+    os.rmdir(temp_dir)
+    print("\nTemporary test files cleaned up.")
