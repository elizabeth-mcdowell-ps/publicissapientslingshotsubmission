+import os
+import sys
+from pathlib import Path
+
+# Add the repository root to the Python path
+repo_root = Path(__file__).parent
+sys.path.append(str(repo_root))
+
+from checkov.terraform.runner import Runner
+from checkov.runner_filter import RunnerFilter
+
+# Create a temporary Terraform file with the problematic resources
+tf_file_content = '''
+resource "azurerm_subnet" "fw-snet" {
+  count                = 1
+  name                 = "AzureFirewallSubnet"
+  resource_group_name  = "test-rg"
+  virtual_network_name = "test-vnet"
+  address_prefixes     = ["10.0.1.0/24"]
+  service_endpoints    = ["Microsoft.Storage"]
+}
+
+resource "azurerm_subnet" "gw_snet" {
+  count                = 1
+  name                 = "GatewaySubnet"
+  resource_group_name  = "test-rg"
+  virtual_network_name = "test-vnet"
+  address_prefixes     = ["10.0.2.0/24"]
+  service_endpoints    = ["Microsoft.Storage"]
+}
+'''
+
+# Create a temporary directory and file
+temp_dir = repo_root / "temp_test"
+os.makedirs(temp_dir, exist_ok=True)
+temp_file = temp_dir / "main.tf"
+
+with open(temp_file, "w") as f:
+    f.write(tf_file_content)
+
+# Run the check
+runner = Runner()
+report = runner.run(
+    root_folder=str(temp_dir),
+    runner_filter=RunnerFilter(checks=["CKV2_AZURE_31"])
+)
+
+# Print the results
+print("\nCheck Results:")
+print(f"Passed checks: {len(report.passed_checks)}")
+print(f"Failed checks: {len(report.failed_checks)}")
+
+for failed in report.failed_checks:
+    print(f"\nFailed: {failed.resource} - {failed.check_id}")
+    print(f"File: {failed.file_path}:{failed.file_line_range}")
+
+# Clean up
+os.remove(temp_file)
+os.rmdir(temp_dir)
