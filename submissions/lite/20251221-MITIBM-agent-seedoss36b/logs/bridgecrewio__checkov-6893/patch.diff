+import os
+import sys
+from pathlib import Path
+
+# Add the repository root to the Python path
+repo_root = Path(__file__).parent
+sys.path.append(str(repo_root))
+
+# Create a temporary Terraform file with the problematic resources
+tf_file_content = '''
+resource "azurerm_resource_group" "test_rg" {
+  name     = "test-rg"
+  location = "East US"
+}
+
+resource "azurerm_virtual_network" "test_vnet" {
+  name                = "test-vnet"
+  address_space       = ["10.0.0.0/16"]
+  location            = azurerm_resource_group.test_rg.location
+  resource_group_name = azurerm_resource_group.test_rg.name
+}
+
+# This should pass the check because it's AzureFirewallSubnet
+resource "azurerm_subnet" "fw-snet" {
+  name                 = "AzureFirewallSubnet"
+  resource_group_name  = azurerm_resource_group.test_rg.name
+  virtual_network_name = azurerm_virtual_network.test_vnet.name
+  address_prefixes     = ["10.0.1.0/24"]
+  service_endpoints    = ["Microsoft.Storage"]
+}
+
+# This should pass the check because it's GatewaySubnet
+resource "azurerm_subnet" "gw_snet" {
+  name                 = "GatewaySubnet"
+  resource_group_name  = azurerm_resource_group.test_rg.name
+  virtual_network_name = azurerm_virtual_network.test_vnet.name
+  address_prefixes     = ["10.0.2.0/24"]
+  service_endpoints    = ["Microsoft.Storage"]
+}
+
+# This should fail the check because it's a regular subnet without NSG
+resource "azurerm_subnet" "regular_subnet" {
+  name                 = "regular-subnet"
+  resource_group_name  = azurerm_resource_group.test_rg.name
+  virtual_network_name = azurerm_virtual_network.test_vnet.name
+  address_prefixes     = ["10.0.3.0/24"]
+  service_endpoints    = ["Microsoft.Storage"]
+}
+
+# This should pass the check because it has an NSG
+resource "azurerm_subnet" "secure_subnet" {
+  name                 = "secure-subnet"
+  resource_group_name  = azurerm_resource_group.test_rg.name
+  virtual_network_name = azurerm_virtual_network.test_vnet.name
+  address_prefixes     = ["10.0.4.0/24"]
+  service_endpoints    = ["Microsoft.Storage"]
+}
+
+resource "azurerm_network_security_group" "test_nsg" {
+  name                = "test-nsg"
+  location            = azurerm_resource_group.test_rg.location
+  resource_group_name = azurerm_resource_group.test_rg.name
+}
+
+resource "azurerm_subnet_network_security_group_association" "test_assoc" {
+  subnet_id                 = azurerm_subnet.secure_subnet.id
+  network_security_group_id = azurerm_network_security_group.test_nsg.id
+}
+'''
+
+# Create a temporary directory and file
+temp_dir = repo_root / "temp_test"
+os.makedirs(temp_dir, exist_ok=True)
+temp_file = temp_dir / "main.tf"
+
+with open(temp_file, "w") as f:
+    f.write(tf_file_content)
+
+print("Created test Terraform file. Please run the following command to test:")
+print(f"cd {repo_root} && python -m checkov.main -d {temp_dir} --check CKV2_AZURE_31")
+print("\nExpected results:")
+print("- azurerm_subnet.fw-snet should PASS (AzureFirewallSubnet)")
+print("- azurerm_subnet.gw_snet should PASS (GatewaySubnet)")
+print("- azurerm_subnet.regular_subnet should FAIL (no NSG)")
+print("- azurerm_subnet.secure_subnet should PASS (has NSG)")
