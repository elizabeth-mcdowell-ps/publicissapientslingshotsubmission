diff --git a/conan/api/subapi/workspace.py b/conan/api/subapi/workspace.py
index 9485e769e..9519be5d6 100644
--- a/conan/api/subapi/workspace.py
+++ b/conan/api/subapi/workspace.py
@@ -81,3 +81,77 @@ class WorkspaceAPI:
 
     def info(self):
         return self._workspace.serialize()
+        
+    def build(self, remotes=None):
+        """Build all editable packages in the workspace in the correct order"""
+        from conan.api.output import ConanOutput
+        
+        output = ConanOutput()
+        
+        if not self._workspace.folder:
+            raise ConanException("No workspace defined, conanws.py file not found")
+            
+        editables = self._workspace.editables()
+        if not editables:
+            output.warning("No editable packages found in workspace")
+            return
+            
+        # Get all references in the workspace
+        references = list(editables.keys())
+        
+        # Create a graph with all the references to determine build order
+        host_profile_path = self._conan_api.profiles.get_default_host()
+        build_profile_path = self._conan_api.profiles.get_default_build()
+        profile_host = self._conan_api.profiles.get_profile([host_profile_path])
+        profile_build = self._conan_api.profiles.get_profile([build_profile_path])
+        
+        # Build the dependency graph
+        output.title("Resolving dependencies")
+        
+        # Use the graph API to load the graph for all references
+        deps_graph = self._conan_api.graph.load_graph_requires(requires=references, 
+                                                             tool_requires=None,
+                                                             profile_host=profile_host, 
+                                                             profile_build=profile_build,
+                                                             lockfile=None, 
+                                                             remotes=remotes, 
+                                                             update=None)
+        
+        # Force build for all editable packages
+        for node in deps_graph.nodes:
+            if node.recipe_reference in editables:
+                output.info(f"Package {node.recipe_reference} will be built")
+        
+        # Install binaries for dependencies
+        output.title("Installing dependencies")
+        self._conan_api.install.install_binaries(deps_graph=deps_graph, remotes=remotes)
+        
+        # Build the editable packages in the correct order
+        output.title("Building editable packages")
+        
+        # Get the build order (dependencies first)
+        build_order = deps_graph.build_order()
+        
+        # Flatten the build order and filter only editable packages
+        packages_to_build = []
+        for level in build_order:
+            for node in level:
+                if node.recipe_reference in editables:
+                    packages_to_build.append(node)
+        
+        # Build each package
+        for node in packages_to_build:
+            ref = node.recipe_reference
+            path = editables[ref]["path"]
+            output.title(f"Building {ref}")
+            
+            # Load the conanfile
+            conanfile_path = os.path.join(path, "conanfile.py")
+            app = ConanApp(self._conan_api)
+            conanfile = app.loader.load_consumer(conanfile_path, ref.name, ref.version, 
+                                               ref.user, ref.channel, None, remotes)
+            
+            # Build the package
+            self._conan_api.local.build(conanfile)
+            
+        output.success("All editable packages in workspace built successfully")
diff --git a/conan/cli/commands/workspace.py b/conan/cli/commands/workspace.py
