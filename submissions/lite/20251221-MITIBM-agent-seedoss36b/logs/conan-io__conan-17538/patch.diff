+import os
+import shutil
+import tempfile
+import subprocess
+
+# Create a temporary directory for our test workspace
+temp_dir = tempfile.mkdtemp(prefix="conan_workspace_test_")
+print(f"Created temporary directory: {temp_dir}")
+
+# Create default profile if it doesn't exist
+if not os.path.exists(os.path.expanduser("~/.conan2/profiles/default")):
+    print("Creating default profile...")
+    subprocess.run(["conan", "profile", "detect"], check=True)
+
+try:
+    # Create workspace structure
+    os.makedirs(os.path.join(temp_dir, "liba"))
+    os.makedirs(os.path.join(temp_dir, "libb"))
+    os.makedirs(os.path.join(temp_dir, "app"))
+
+    # Create conanfile.py for liba
+    with open(os.path.join(temp_dir, "liba", "conanfile.py"), "w") as f:
+        f.write("""from conan import ConanFile
+from conan.tools.files import copy
+import os
+
+class LibAConan(ConanFile):
+    name = "liba"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+    
+    def build(self):
+        self.output.info("Building LibA")
+        with open(os.path.join(self.build_folder, "liba.txt"), "w") as f:
+            f.write("LibA built")
+    
+    def package(self):
+        copy(self, "*.txt", self.build_folder, self.package_folder)
+""")
+
+    # Create conanfile.py for libb
+    with open(os.path.join(temp_dir, "libb", "conanfile.py"), "w") as f:
+        f.write("""from conan import ConanFile
+from conan.tools.files import copy
+import os
+
+class LibBConan(ConanFile):
+    name = "libb"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+    
+    def build(self):
+        self.output.info("Building LibB")
+        with open(os.path.join(self.build_folder, "libb.txt"), "w") as f:
+            f.write("LibB built")
+    
+    def package(self):
+        copy(self, "*.txt", self.build_folder, self.package_folder)
+""")
+
+    # Create conanfile.py for app
+    with open(os.path.join(temp_dir, "app", "conanfile.py"), "w") as f:
+        f.write("""from conan import ConanFile
+from conan.tools.files import copy
+import os
+
+class AppConan(ConanFile):
+    name = "app"
+    version = "1.0"
+    settings = "os", "compiler", "build_type", "arch"
+    requires = "liba/1.0", "libb/1.0"
+    
+    def build(self):
+        self.output.info("Building App")
+        with open(os.path.join(self.build_folder, "app.txt"), "w") as f:
+            f.write("App built")
+    
+    def package(self):
+        copy(self, "*.txt", self.build_folder, self.package_folder)
+""")
+
+    # Create workspace file
+    with open(os.path.join(temp_dir, "conanws.yml"), "w") as f:
+        f.write("""editables:
+  liba/1.0:
+    path: liba
+  libb/1.0:
+    path: libb
+  app/1.0:
+    path: app
+""")
+
+    # Set environment variable to enable workspace feature
+    os.environ["CONAN_WORKSPACE_ENABLE"] = "will_break_next"
+
+    # Change to the workspace directory
+    os.chdir(temp_dir)
+
+    # Test the workspace build command
+    print("\nTesting 'conan workspace build' command:")
+    result = subprocess.run(["conan", "workspace", "build"], 
+                           capture_output=True, text=True)
+    
+    print(f"Return code: {result.returncode}")
+    print(f"Output:\n{result.stdout}")
+    
+    if result.stderr:
+        print(f"Error:\n{result.stderr}")
+
+finally:
+    # Clean up
+    shutil.rmtree(temp_dir)
+    print(f"\nRemoved temporary directory: {temp_dir}")
