@@ -0,0 +1,83 @@
+import os
+import tempfile
+import subprocess
+from pathlib import Path
+import sys
+
+# Add uv to PATH
+os.environ["PATH"] = os.environ["PATH"] + ":/root/.local/bin"
+
+# Create a temporary directory for the test project
+temp_dir = tempfile.mkdtemp(prefix="pdm-test-")
+project_dir = Path(temp_dir)
+
+# Initialize a PDM project
+os.chdir(project_dir)
+subprocess.run(["pdm", "init", "-n"], check=True)
+
+# Create a simple Python package
+src_dir = project_dir / "src" / "example"
+src_dir.mkdir(parents=True)
+with open(src_dir / "__init__.py", "w") as f:
+    f.write("__version__ = '0.1.0'\n")
+
+# Update pyproject.toml to make it a valid package
+# Create a valid pyproject.toml
+with open(project_dir / "pyproject.toml", "w") as f:
+    f.write("""[project]
+name = "example"
+version = "0.1.0"
+description = "Example package"
+authors = [
+    {name = "Test Author", email = "test@example.com"}
+]
+requires-python = ">=3.8"
+
+[build-system]
+requires = ["pdm-backend"]
+build-backend = "pdm.backend"
+
+[tool.pdm]
+distribution = true
+
+[tool.pdm.build]
+includes = ["src"]
+package-dir = "src"
+""")
+
+# Set use_uv to True
+subprocess.run(["pdm", "config", "use_uv", "true"], check=True)
+
+# Test 1: Build with both sdist and wheel
+print("\n=== Test 1: Build with both sdist and wheel ===")
+try:
+    result = subprocess.run(["pdm", "build", "-v"], capture_output=True, text=True, check=False)
+    print("Exit code:", result.returncode)
+    print("Output:", result.stdout)
+    print("Error:", result.stderr)
+except Exception as e:
+    print(f"Exception: {e}")
+
+# Test 2: Build with --no-sdist
+print("\n=== Test 2: Build with --no-sdist ===")
+try:
+    result = subprocess.run(["pdm", "build", "--no-sdist", "-v"], capture_output=True, text=True, check=False)
+    print("Exit code:", result.returncode)
+    print("Output:", result.stdout)
+    print("Error:", result.stderr)
+except Exception as e:
+    print(f"Exception: {e}")
+
+# Test 3: Build with --no-wheel
+print("\n=== Test 3: Build with --no-wheel ===")
+try:
+    result = subprocess.run(["pdm", "build", "--no-wheel", "-v"], capture_output=True, text=True, check=False)
+    print("Exit code:", result.returncode)
+    print("Output:", result.stdout)
+    print("Error:", result.stderr)
+except Exception as e:
+    print(f"Exception: {e}")
+
+# Clean up
+import shutil
+shutil.rmtree(temp_dir)
