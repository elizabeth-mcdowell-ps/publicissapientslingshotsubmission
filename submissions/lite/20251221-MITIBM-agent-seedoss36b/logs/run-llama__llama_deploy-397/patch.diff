+
+# Set up logging
+logging.basicConfig(level=logging.INFO)
+logger = logging.getLogger(__name__)
+
+# Add the testbed directory to the path
+sys.path.append('/testbed')
+
+# Import the necessary modules
+from llama_deploy.message_queues.rabbitmq import RabbitMQMessageQueue, RabbitMQMessageQueueConfig
+from llama_deploy.messages.base import QueueMessage, MessageStats
+
+class SimpleConsumer:
+    def __init__(self, message_type: str):
+        self.message_type = message_type
+        self.id_ = "test-consumer"
+        self.received_messages: List[QueueMessage] = []
+    
+    async def process_message(self, message: QueueMessage) -> None:
+        logger.info(f"Received message: {message}")
+        self.received_messages.append(message)
+
+async def test_with_topic():
+    """Test that messages are properly routed when using a topic."""
+    logger.info("Testing with topic...")
+    
+    # Create a RabbitMQ message queue
+    mq = RabbitMQMessageQueue(RabbitMQMessageQueueConfig())
+    
+    # Create a consumer
+    consumer = SimpleConsumer(message_type="test_message")
+    
+    # Register the consumer with a specific topic
+    logger.info("Registering consumer with topic 'test_topic'")
+    start_consuming_callable = await mq.register_consumer(consumer, topic="test_topic")
+    
+    # Start consuming in the background
+    consumer_task = asyncio.create_task(start_consuming_callable())
+    
+    # Wait a bit for the consumer to start
+    await asyncio.sleep(2)
+    
+    # Create a test message
+    test_message = QueueMessage(
+        type="test_message", 
+        data={"message": "this is a test"},
+        publisher_id="test-publisher",
+        id_="test-id",
+        stats=MessageStats()
+    )
+    
+    # Publish the message with the same topic
+    logger.info(f"Publishing message to topic 'test_topic'")
+    await mq.publish(test_message, topic="test_topic")
+    
+    # Wait for the message to be processed
+    await asyncio.sleep(5)
+    
+    # Check if the message was received
+    if consumer.received_messages:
+        logger.info("SUCCESS: Message was received successfully!")
+    else:
+        logger.error("FAILURE: Message was NOT received!")
+    
+    # Clean up
+    consumer_task.cancel()
+    try:
+        await consumer_task
+    except asyncio.CancelledError:
+        pass
+    
+    # Clean up the queue
+    await mq.cleanup_local(["test_message"])
+    
+    return len(consumer.received_messages) > 0
+
+async def main():
+    success = await test_with_topic()
+    if success:
+        logger.info("Test passed! The fix works correctly.")
+        sys.exit(0)
+    else:
+        logger.error("Test failed! The fix did not work.")
+        sys.exit(1)
+
+if __name__ == "__main__":
+    asyncio.run(main())
