@@ -0,0 +1,243 @@
+import asyncio
+import json
+import logging
+from typing import Any, Dict, List, Optional, Literal, cast
+
+# Configure logging
+logging.basicConfig(level=logging.INFO)
+logger = logging.getLogger(__name__)
+
+# Simplified versions of the necessary classes
+class MessageStats:
+    def __init__(self):
+        self.publish_time = None
+        
+    def timestamp_str(self):
+        return "timestamp"
+
+class QueueMessage:
+    def __init__(
+        self,
+        type: str = "default",
+        action: str = "default",
+        data: Optional[Dict[str, Any]] = None,
+        publisher_id: str = "default",
+        id_: str = "default",
+        stats: Optional[MessageStats] = None,
+    ):
+        self.type = type
+        self.action = action
+        self.data = data or {}
+        self.publisher_id = publisher_id
+        self.id_ = id_
+        self.stats = stats or MessageStats()
+        
+    def model_dump(self):
+        return {
+            "type": self.type,
+            "action": self.action,
+            "data": self.data,
+            "publisher_id": self.publisher_id,
+            "id_": self.id_,
+            "stats": {"publish_time": self.stats.publish_time}
+        }
+        
+    @classmethod
+    def model_validate(cls, data):
+        stats = MessageStats()
+        stats.publish_time = data.get("stats", {}).get("publish_time")
+        return cls(
+            type=data.get("type", "default"),
+            action=data.get("action", "default"),
+            data=data.get("data", {}),
+            publisher_id=data.get("publisher_id", "default"),
+            id_=data.get("id_", "default"),
+            stats=stats
+        )
+
+class BaseMessageQueueConsumer:
+    def __init__(self, message_type: str, id_: str = "consumer"):
+        self.message_type = message_type
+        self.id_ = id_
+        
+    async def process_message(self, message: QueueMessage) -> None:
+        pass
+
+class RabbitMQMessageQueueConfig:
+    def __init__(
+        self,
+        url: str = "amqp://guest:guest@localhost/",
+        exchange_name: str = "llama-deploy",
+    ):
+        self.type = "rabbitmq"
+        self.url = url
+        self.exchange_name = exchange_name
+
+class RabbitMQMessageQueue:
+    def __init__(self, config: Optional[RabbitMQMessageQueueConfig] = None):
+        self._config = config or RabbitMQMessageQueueConfig()
+        
+    async def new_connection(self):
+        from aio_pika import connect
+        return await connect(self._config.url)
+        
+    async def _publish(self, message: QueueMessage, topic: str) -> Any:
+        """Publish message to the queue."""
+        from aio_pika import DeliveryMode, ExchangeType
+        from aio_pika import Message as AioPikaMessage
+
+        message_type_str = message.type
+        connection = await self.new_connection()
+
+        async with connection:
+            channel = await connection.channel()
+            exchange = await channel.declare_exchange(
+                self._config.exchange_name,
+                ExchangeType.DIRECT,
+            )
+            message_body = json.dumps(message.model_dump()).encode("utf-8")
+
+            aio_pika_message = AioPikaMessage(
+                message_body,
+                delivery_mode=DeliveryMode.PERSISTENT,
+            )
+            # Sending the message
+            # Use the topic as the routing key if provided, otherwise fall back to message type
+            routing_key = topic if topic else message_type_str
+            await exchange.publish(aio_pika_message, routing_key=routing_key)
+            logger.info(f"published message {message.id_} to routing key {routing_key}")
+            
+    async def publish(self, message: QueueMessage, topic: str):
+        """Send message to a consumer."""
+        logger.info(
+            f"Publishing message of type '{message.type}' with action '{message.action}' to topic '{topic}'"
+        )
+        
+        message.stats.publish_time = message.stats.timestamp_str()
+        await self._publish(message, topic)
+            
+    async def register_consumer(
+        self, consumer: BaseMessageQueueConsumer, topic: str | None = None
+    ):
+        """Register a new consumer."""
+        from aio_pika import ExchangeType, Queue
+        from aio_pika.abc import AbstractIncomingMessage
+
+        # Use the topic as the routing key if provided, otherwise fall back to message type
+        routing_key = topic if topic else consumer.message_type
+
+        connection = await self.new_connection()
+        async with connection:
+            channel = await connection.channel()
+            exchange = await channel.declare_exchange(
+                self._config.exchange_name,
+                ExchangeType.DIRECT,
+            )
+            queue = await channel.declare_queue(name=consumer.message_type)
+            await queue.bind(exchange, routing_key=routing_key)
+
+        logger.info(
+            f"Registered consumer {consumer.id_}: {consumer.message_type} with routing key {routing_key}",
+        )
+
+        async def start_consuming_callable() -> None:
+            """StartConsumingCallable.
+
+            Consumer of this queue, should call this in order to start consuming.
+            """
+
+            async def on_message(message: AbstractIncomingMessage) -> None:
+                async with message.process():
+                    decoded_message = json.loads(message.body.decode("utf-8"))
+                    queue_message = QueueMessage.model_validate(decoded_message)
+                    await consumer.process_message(queue_message)
+
+            # Use the topic as the routing key if provided, otherwise fall back to message type
+            routing_key = topic if topic else consumer.message_type
+
+            connection = await self.new_connection()
+            async with connection:
+                channel = await connection.channel()
+                exchange = await channel.declare_exchange(
+                    self._config.exchange_name,
+                    ExchangeType.DIRECT,
+                )
+                queue = await channel.declare_queue(name=consumer.message_type)
+                await queue.bind(exchange, routing_key=routing_key)
+                await queue.consume(on_message)
+
+        return start_consuming_callable
+        
+    async def cleanup_local(self, message_types: List[str]) -> None:
+        """Perform any clean up of queues and exchanges."""
+        connection = await self.new_connection()
+        async with connection:
+            channel = await connection.channel()
+            for message_type in message_types:
+                await channel.queue_delete(queue_name=message_type)
+            await channel.exchange_delete(exchange_name=self._config.exchange_name)
+
+class TestConsumer(BaseMessageQueueConsumer):
+    def __init__(self, message_type: str):
+        super().__init__(message_type=message_type, id_="test-consumer")
+        self.received_messages = []
+        
+    async def process_message(self, message: QueueMessage) -> None:
+        logger.info(f"Received message: {message.id_}")
+        self.received_messages.append(message)
+
+async def test_rabbitmq_topic_routing():
+    """Test that messages are properly routed when using a topic."""
+    # Create a RabbitMQ message queue
+    mq = RabbitMQMessageQueue()
+    
+    # Create a consumer
+    consumer = TestConsumer(message_type="test_message")
+    
+    # Register the consumer with a specific topic
+    logger.info("Registering consumer with topic 'test_topic'")
+    start_consuming_callable = await mq.register_consumer(consumer, topic="test_topic")
+    
+    # Start consuming in the background
+    consumer_task = asyncio.create_task(start_consuming_callable())
+    
+    # Wait a bit for the consumer to start
+    await asyncio.sleep(2)
+    
+    # Create a test message
+    test_message = QueueMessage(
+        type="test_message", 
+        data={"message": "this is a test"},
+        publisher_id="test-publisher",
+        id_="test-id",
+    )
+    
+    # Publish the message with the same topic
+    logger.info(f"Publishing message to topic 'test_topic'")
+    await mq.publish(test_message, topic="test_topic")
+    
+    # Wait for the message to be processed
+    await asyncio.sleep(5)
+    
+    # Check if the message was received
+    if consumer.received_messages:
+        logger.info("SUCCESS: Message was received successfully!")
+        result = True
+    else:
+        logger.error("FAILURE: Message was NOT received!")
+        result = False
+    
+    # Clean up
+    consumer_task.cancel()
+    try:
+        await consumer_task
+    except asyncio.CancelledError:
+        pass
+    
+    # Clean up the queue
+    await mq.cleanup_local(["test_message"])
+    
+    return result
+
+if __name__ == "__main__":
+    asyncio.run(test_rabbitmq_topic_routing())
