+#!/usr/bin/env python
+
+import os
+import sys
+import tempfile
+import yaml
+import json
+from cfnlint.rules.resources.stepfunctions.StateMachineDefinition import StateMachineDefinition
+from cfnlint.jsonschema import Validator
+
+# Test YAML content with JSONata
+test_yaml = """
+AWSTemplateFormatVersion: "2010-09-09"
+Resources:
+  StateMachine:
+    Type: AWS::StepFunctions::StateMachine
+    Properties:
+      RoleArn: arn:aws:iam::123456789123:role/myRole
+      Definition:
+        Comment: Reading messages from an SQS queue and iteratively processing each message.
+        QueryLanguage: JSONata
+        StartAt: Read messages from SQS queue
+        States:
+          Are there messages to process?:
+            Choices:
+              - Condition: '{% $exists($states.input.Messages) %}'
+                Next: Pass
+            Default: Finish
+            Type: Choice
+          Pass:
+            Type: Pass
+            Next: Finish
+            Output: '{% $states.input %}'
+            Assign:
+              timestamp: '{% $now() %}'
+          Finish:
+            Type: Succeed
+          Read messages from SQS queue:
+            Arguments:
+              AttributeNames:
+                - All
+              MaxNumberOfMessages: 10
+              QueueUrl: https://sqs.us-east-1.amazonaws.com/123456789123/myQueue
+              VisibilityTimeout: 30
+              WaitTimeSeconds: 20
+            Next: Are there messages to process?
+            Resource: arn:aws:states:::aws-sdk:sqs:receiveMessage
+            Type: Task
+"""
+
+def main():
+    # Create a temporary file with the test YAML
+    with tempfile.NamedTemporaryFile(suffix='.yaml', delete=False) as tmp:
+        tmp.write(test_yaml.encode('utf-8'))
+        tmp_filename = tmp.name
+    
+    try:
+        # Parse the YAML
+        template = yaml.safe_load(test_yaml)
+        
+        # Extract the state machine definition
+        state_machine_def = template['Resources']['StateMachine']['Properties']['Definition']
+        
+        # Create an instance of the rule
+        rule = StateMachineDefinition()
+        
+        # Print the schema for debugging
+        print("Schema structure:")
+        print("Choice operator properties:")
+        print(json.dumps(rule.schema.get('definitions', {}).get('choice', {}).get('definitions', {}).get('Operator', {}).get('properties', {}), indent=2)[:500] + "...\n")
+        
+        # Print the requiredXor for the Choice operator
+        print("Choice operator requiredXor:")
+        print(json.dumps(rule.schema.get('definitions', {}).get('choice', {}).get('definitions', {}).get('Operator', {}).get('requiredXor', []), indent=2) + "\n")
+        
+        # Print the state machine definition for debugging
+        print("State machine definition:")
+        print(json.dumps(state_machine_def, indent=2) + "\n")
+        
+        # Manually check the issues
+        print("Issues with the state machine definition:")
+        if 'States' in state_machine_def:
+            for state_name, state in state_machine_def['States'].items():
+                if state.get('Type') == 'Choice':
+                    if 'Choices' in state:
+                        for choice in state['Choices']:
+                            if 'Condition' in choice and not any(op in choice for op in rule.schema['definitions']['choice']['definitions']['Operator']['requiredXor']):
+                                print(f"E3601 Only one of {rule.schema['definitions']['choice']['definitions']['Operator']['requiredXor']} is a required property")
+                
+                if state.get('Type') == 'Pass':
+                    if 'Output' in state and state_machine_def.get('QueryLanguage') != 'JSONata':
+                        print(f"E3601 Additional properties are not allowed ('Output' was unexpected)")
+                
+                if state.get('Type') == 'Task':
+                    if 'Arguments' in state and state_machine_def.get('QueryLanguage') != 'JSONata':
+                        print(f"E3601 Additional properties are not allowed ('Arguments' was unexpected)")
+        
+        return 0
+    finally:
+        # Clean up the temporary file
+        os.unlink(tmp_filename)
+
+if __name__ == "__main__":
+    sys.exit(main())
