+#!/usr/bin/env python3
+
+import sys
+import os
+import json
+from yt_dlp import YoutubeDL
+
+# Twitter/X m3u8 URL from the PR description
+url = "https://video.twimg.com/ext_tw_video/1785387260893872128/pu/pl/bYr0BsdFEus_r7fy.m3u8"
+
+# Configure YoutubeDL to only list formats
+ydl_opts = {
+    'quiet': True,
+    'no_warnings': True,
+    'skip_download': True,
+}
+
+# Create a YoutubeDL instance
+ydl = YoutubeDL(ydl_opts)
+
+# Get info dict
+info_dict = ydl.extract_info(url, download=False)
+
+# Print formats in a more readable way
+print("Available formats:")
+for f in info_dict.get('formats', []):
+    print(f"Format ID: {f.get('format_id')}, "
+          f"Extension: {f.get('ext')}, "
+          f"Resolution: {f.get('width')}x{f.get('height')}, "
+          f"Codec: {f.get('vcodec')}/{f.get('acodec')}, "
+          f"Bitrate: {f.get('tbr')} kbps, "
+          f"Audio Bitrate: {f.get('abr')} kbps, "
+          f"Audio Channels: {f.get('audio_channels')}")
+
+# Print the format that would be selected by default
+print("\nFormat that would be selected by default:")
+print(f"Format ID: {info_dict.get('format_id')}")
+
+# Examine the raw format data to understand the sorting issue
