+#!/usr/bin/env python3
+
+import sys
+import os
+from yt_dlp import YoutubeDL
+
+# Twitter/X m3u8 URL from the PR description
+url = "https://video.twimg.com/ext_tw_video/1785387260893872128/pu/pl/bYr0BsdFEus_r7fy.m3u8"
+
+# Configure YoutubeDL
+ydl_opts = {
+    'format': 'bestvideo+bestaudio',
+    'quiet': True,
+    'skip_download': True,
+}
+
+# Create a YoutubeDL instance
+ydl = YoutubeDL(ydl_opts)
+
+# Get info about the video
+info = ydl.extract_info(url, download=False)
+
+# Print the selected format
+print("Selected format:")
+print(f"Format ID: {info.get('format_id')}")
+
+# Print all available formats
+print("\nAll available formats:")
+for f in info.get('formats', []):
+    if f.get('vcodec') == 'none':  # Audio-only formats
+        print(f"Audio Format: {f.get('format_id')}, Bitrate: {f.get('abr')} kbps")
+    else:  # Video formats
+        print(f"Video Format: {f.get('format_id')}, Resolution: {f.get('width')}x{f.get('height')}")
+
+# Print a success message
+print("\nTest completed. The highest quality audio stream (128kbps) should be selected.")
