+++ b/falcon/media/text.py
@@ -0,0 +1,118 @@
+from __future__ import annotations
+
+from typing import Optional, Union
+
+from falcon.media.base import BaseHandler
+from falcon.typing import ReadableIO, AsyncReadableIO
+
+
+class TextHandler(BaseHandler):
+    """Handler for plain text media.
+    
+    This handler simply returns the media object as a string (or as bytes if it's
+    already in bytes form). It acts as an identity handler for text content.
+    
+    For serialization:
+    - If the media is None, returns an empty byte string
+    - If the media is already bytes, returns it as-is
+    - Otherwise, converts the media to a string and encodes it as UTF-8
+    
+    For deserialization:
+    - If the body is empty, returns an empty string
+    - If the body is bytes, decodes it as UTF-8 (with fallback to ISO-8859-1)
+    - Otherwise, returns the body as a string
+    """
+
+    def serialize(self, media: object, content_type: str) -> bytes:
+        """Serialize the media object to plain text.
+
+        Args:
+            media (object): The object to serialize.
+            content_type (str): Type of response content.
+
+        Returns:
+            bytes: The UTF-8 encoded value of the media object.
+        """
+        if media is None:
+            return b''
+        
+        if isinstance(media, bytes):
+            return media
+        
+        return str(media).encode('utf-8')
+
+    async def serialize_async(self, media: object, content_type: str) -> bytes:
+        """Serialize the media object to plain text asynchronously.
+
+        Args:
+            media (object): The object to serialize.
+            content_type (str): Type of response content.
+
+        Returns:
+            bytes: The UTF-8 encoded value of the media object.
+        """
+        return self.serialize(media, content_type)
+
+    def deserialize(
+        self,
+        stream: ReadableIO,
+        content_type: Optional[str],
+        content_length: Optional[int],
+    ) -> str:
+        """Deserialize the request body to a string.
+
+        Args:
+            stream (object): Readable file-like object to deserialize.
+            content_type (str): Type of request content.
+            content_length (int): Length of request content.
+
+        Returns:
+            str: The deserialized string.
+        """
+        body = stream.read()
+        
+        if not body:
+            return ''
+            
+        if isinstance(body, bytes):
+            # Try UTF-8 first, but fall back to ISO-8859-1 if that fails
+            try:
+                return body.decode('utf-8')
+            except UnicodeDecodeError:
+                return body.decode('iso-8859-1')
+            
+        return str(body)
+
+    async def deserialize_async(
+        self,
+        stream: AsyncReadableIO,
+        content_type: Optional[str],
+        content_length: Optional[int],
+    ) -> str:
+        """Deserialize the request body to a string asynchronously.
+
+        Args:
+            stream (object): Asynchronous file-like object to deserialize.
+            content_type (str): Type of request content.
+            content_length (int): Length of request content.
+
+        Returns:
+            str: The deserialized string.
+        """
+        body = await stream.read()
+        
+        if not body:
+            return ''
+            
+        if isinstance(body, bytes):
+            # Try UTF-8 first, but fall back to ISO-8859-1 if that fails
+            try:
+                return body.decode('utf-8')
+            except UnicodeDecodeError:
+                return body.decode('iso-8859-1')
+            
+        return str(body)
+
+    # Add sync serialization/deserialization methods for optimization
+    _serialize_sync = serialize
+    _deserialize_sync = deserialize
