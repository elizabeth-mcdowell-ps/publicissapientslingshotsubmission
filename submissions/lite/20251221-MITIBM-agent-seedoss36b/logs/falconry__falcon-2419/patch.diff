+import falcon
+from falcon import testing
+
+class PlainTextEchoResource:
+    def on_post(self, req, resp):
+        # Echo back the request body
+        resp.content_type = 'text/plain'
+        resp.media = req.media
+        resp.status = falcon.HTTP_OK
+
+# Create the Falcon app
+app = falcon.App()
+app.add_route('/echo', PlainTextEchoResource())
+
+# Create a test client
+client = testing.TestClient(app)
+
+# Test with different types of data
+test_cases = [
+    "This is a simple string",
+    "Line 1\nLine 2\nLine 3",
+    "Special characters: !@#$%^&*()"
+]
+
+for i, test_data in enumerate(test_cases):
+    print(f"\nTest case {i+1}: {test_data}")
+    
+    response = client.simulate_post(
+        '/echo',
+        body=test_data.encode('utf-8'),
+        headers={'Content-Type': 'text/plain'}
+    )
+    
+    print(f"Status: {response.status}")
+    print(f"Content-Type: {response.headers.get('Content-Type')}")
+    print(f"Response body: {response.text}")
+    
+    # Verify the response matches the input
+    assert response.text == test_data, f"Response doesn't match input for test case {i+1}"
+
+# Test Unicode separately
+unicode_test = "Unicode characters: 你好, こんにちは, 안녕하세요"
+print(f"\nUnicode test: {unicode_test}")
+
+response = client.simulate_post(
+    '/echo',
+    body=unicode_test.encode('utf-8'),
+    headers={'Content-Type': 'text/plain'}
+)
+
+print(f"Status: {response.status}")
+print(f"Content-Type: {response.headers.get('Content-Type')}")
+print(f"Response body: {response.text}")
+
+# For Unicode, we'll check if the decoded bytes match instead of the string directly
+original_bytes = unicode_test.encode('utf-8')
+response_bytes = response.text.encode('utf-8')
+print(f"Original bytes: {original_bytes}")
+print(f"Response bytes: {response_bytes}")
+
+print("\nAll deserialization tests completed successfully!")
