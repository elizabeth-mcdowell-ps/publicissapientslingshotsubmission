@@ -0,0 +1,37 @@
+import falcon
+from falcon import testing
+
+class PlainTextResource:
+    def __init__(self, media):
+        self.media = media
+        
+    def on_get(self, req, resp):
+        resp.content_type = 'text/plain'
+        resp.media = self.media
+        resp.status = falcon.HTTP_OK
+
+# Create the Falcon app
+app = falcon.App()
+
+# Add routes with different types of data
+app.add_route('/string', PlainTextResource("This is a string"))
+app.add_route('/bytes', PlainTextResource(b"This is bytes data"))
+app.add_route('/number', PlainTextResource(12345))
+app.add_route('/none', PlainTextResource(None))
+app.add_route('/list', PlainTextResource(["item1", "item2", "item3"]))
+app.add_route('/dict', PlainTextResource({"key1": "value1", "key2": "value2"}))
+
+# Create a test client
+client = testing.TestClient(app)
+
+# Test each endpoint
+endpoints = ['/string', '/bytes', '/number', '/none', '/list', '/dict']
+
+for endpoint in endpoints:
+    response = client.simulate_get(endpoint)
+    print(f"\nEndpoint: {endpoint}")
+    print(f"Status: {response.status}")
+    print(f"Content-Type: {response.headers.get('Content-Type')}")
+    print(f"Body: {response.text}")
+
+print("\nAll tests completed successfully!")
