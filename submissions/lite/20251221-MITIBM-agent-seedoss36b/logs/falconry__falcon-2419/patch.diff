+++ b/test_text_handler_direct.py
@@ -0,0 +1,41 @@
+import io
+from falcon.media.text import TextHandler
+
+# Create a TextHandler instance
+handler = TextHandler()
+
+# Test serialization
+test_cases = [
+    "This is a simple string",
+    "Line 1\nLine 2\nLine 3",
+    "Special characters: !@#$%^&*()",
+    "Unicode characters: 你好, こんにちは, 안녕하세요",
+    123,
+    None,
+    ["item1", "item2"],
+    {"key": "value"}
+]
+
+print("Testing serialization:")
+for i, test_data in enumerate(test_cases):
+    print(f"\nTest case {i+1}: {test_data}")
+    result = handler.serialize(test_data, "text/plain")
+    print(f"Serialized result (bytes): {result}")
+    print(f"Decoded result: {result.decode('utf-8')}")
+
+# Test deserialization
+print("\n\nTesting deserialization:")
+test_bytes = [
+    b"This is a simple string",
+    b"Line 1\nLine 2\nLine 3",
+    b"Special characters: !@#$%^&*()",
+    "Unicode characters: 你好, こんにちは, 안녕하세요".encode('utf-8')
+]
+
+for i, test_data in enumerate(test_bytes):
+    print(f"\nTest case {i+1}: {test_data}")
+    stream = io.BytesIO(test_data)
+    result = handler.deserialize(stream, "text/plain", len(test_data))
+    print(f"Deserialized result: {result}")
+
+print("\nAll direct tests completed!")
