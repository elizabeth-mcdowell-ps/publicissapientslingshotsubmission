+def apply_external_patches(conanfile):
+    """
+    Applies external patches to a recipe without modifying the original recipe files.
+    Patches can be specified in a 'conan_patches.yml' or 'conan_patches.json' file in the
+    current directory or in the CONAN_PATCHES environment variable.
+    
+    The format of the patches file or environment variable is:
+    {
+        "recipes": {
+            "recipe_name/version": {
+                "patches": [
+                    {
+                        "patch_file": "/path/to/patch/file.patch",
+                        "base_path": "optional/base/path",
+                        "strip": 0,
+                        "fuzz": false,
+                        "patch_description": "Description of the patch"
+                    },
+                    {
+                        "patch_string": "diff content as a string",
+                        "base_path": "optional/base/path",
+                        "strip": 0,
+                        "fuzz": false,
+                        "patch_description": "Description of the patch"
+                    }
+                ]
+            }
+        }
+    }
+    
+    The recipe_name/version can also be a pattern with wildcards, e.g. "recipe_name/*" or "*/1.0".
+    """
+    recipe_ref = f"{conanfile.name}/{conanfile.version}"
+    conanfile.output.info(f"Checking for external patches for {recipe_ref}")
+    patches_data = {}
+    
+    # Try to load patches from file
+    patches_file = None
+    
+    # Check in current directory and parent directory (for source folder case)
+    possible_locations = [
+        ".",  # Current directory
+        "..",  # Parent directory (for when we're in the source folder)
+        os.path.dirname(os.getcwd())  # Absolute path to parent
+    ]
+    
+    for location in possible_locations:
+        yml_path = os.path.join(location, "conan_patches.yml")
+        json_path = os.path.join(location, "conan_patches.json")
+        
+        if os.path.exists(yml_path):
+            patches_file = yml_path
+            conanfile.output.info(f"Found conan_patches.yml file at {yml_path}")
+            with open(patches_file, 'r') as f:
+                try:
+                    patches_data = yaml.safe_load(f) or {}
+                    conanfile.output.info(f"Loaded patches data from {patches_file}: {patches_data}")
+                    break
+                except yaml.YAMLError as e:
+                    conanfile.output.warning(f"Error parsing {patches_file}: {e}")
+                    patches_data = {}
+        elif os.path.exists(json_path):
+            patches_file = json_path
+            conanfile.output.info(f"Found conan_patches.json file at {json_path}")
+            with open(patches_file, 'r') as f:
+                try:
+                    patches_data = json.load(f) or {}
+                    conanfile.output.info(f"Loaded patches data from {patches_file}: {patches_data}")
+                    break
+                except json.JSONDecodeError as e:
+                    conanfile.output.warning(f"Error parsing {patches_file}: {e}")
+                    patches_data = {}
+    
+    if not patches_file:
+        conanfile.output.info("No conan_patches.yml or conan_patches.json file found in any location")
+    
+    # Try to load patches from environment variable
+    env_patches = os.environ.get("CONAN_PATCHES")
+    if env_patches:
+        conanfile.output.info("Found CONAN_PATCHES environment variable")
+        try:
+            env_data = json.loads(env_patches)
+            conanfile.output.info(f"Loaded patches data from CONAN_PATCHES: {env_data}")
+            # Merge with file data, environment takes precedence
+            if patches_data and env_data:
+                if "recipes" in patches_data and "recipes" in env_data:
+                    for recipe, data in env_data["recipes"].items():
+                        patches_data["recipes"][recipe] = data
+                else:
+                    patches_data = env_data
+            else:
+                patches_data = env_data or patches_data
+        except json.JSONDecodeError as e:
+            conanfile.output.warning(f"Error parsing CONAN_PATCHES environment variable: {e}")
+    
+    if not patches_data or "recipes" not in patches_data:
+        conanfile.output.info("No valid patches data found")
+        return
+    
+    # Find matching recipes (exact match or pattern match)
+    matching_patches = []
+    conanfile.output.info(f"Looking for patches matching {recipe_ref}")
+    for recipe_pattern, data in patches_data["recipes"].items():
+        conanfile.output.info(f"Checking pattern: {recipe_pattern}")
+        # Check for exact match
+        if recipe_pattern == recipe_ref:
+            conanfile.output.info(f"Found exact match for {recipe_ref}")
+            matching_patches.append(data)
+            continue
+        
+        # Check for pattern match
+        if "*" in recipe_pattern:
+            import fnmatch
+            if fnmatch.fnmatch(recipe_ref, recipe_pattern):
+                conanfile.output.info(f"Found pattern match for {recipe_ref} with {recipe_pattern}")
+                matching_patches.append(data)
+    
+    if not matching_patches:
+        conanfile.output.info(f"No matching patches found for {recipe_ref}")
+        return
+    
+    # Apply all matching patches
+    for patch_data in matching_patches:
+        if "patches" not in patch_data:
+            conanfile.output.info("Patch data does not contain 'patches' key")
+            continue
+        
+        conanfile.output.info(f"Found {len(patch_data['patches'])} patches to apply")
+        for patch_entry in patch_data["patches"]:
+            entry = patch_entry.copy()
+            if "patch_file" in entry:
+                patch_file = entry.pop("patch_file")
+                conanfile.output.info(f"Processing patch file: {patch_file}")
+                if not os.path.isabs(patch_file) and patches_file:
+                    # If patch file path is relative, make it relative to the patches file
+                    patch_file = os.path.join(os.path.dirname(os.path.abspath(patches_file)), patch_file)
+                    conanfile.output.info(f"Resolved patch file path: {patch_file}")
+                if not os.path.exists(patch_file):
+                    conanfile.output.warning(f"External patch file does not exist: '{patch_file}'")
+                    continue
+                if "patch_description" not in entry:
+                    entry["patch_description"] = f"External patch: {patch_file}"
+                conanfile.output.info(f"Applying patch from file: {patch_file}")
+                patch(conanfile, patch_file=patch_file, **entry)
+            elif "patch_string" in entry:
+                if "patch_description" not in entry:
+                    entry["patch_description"] = "External patch string"
+                conanfile.output.info("Applying patch from string")
+                patch(conanfile, **entry)
+            else:
+                conanfile.output.warning("External patch entry needs a 'patch_file' or 'patch_string' entry")
