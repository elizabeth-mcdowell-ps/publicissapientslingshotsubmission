+
+# Create a simple recipe
+conanfile_content = """
+import os
+from conan import ConanFile
+from conan.tools.files import save
+
+class TestPkg(ConanFile):
+    name = "testpkg"
+    version = "1.0"
+    
+    def layout(self):
+        self.folders.source = "src"
+        self.folders.build = "build"
+    
+    def source(self):
+        # Create files that we'll patch
+        save(self, "hello.txt", "Hello, World!")
+        save(self, "goodbye.txt", "Goodbye, World!")
+        self.output.info(f"Original hello content: {open('hello.txt').read()}")
+        self.output.info(f"Original goodbye content: {open('goodbye.txt').read()}")
