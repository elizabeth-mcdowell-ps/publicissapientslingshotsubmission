+os.makedirs(patches_dir, exist_ok=True)
+with open(os.path.join(patches_dir, "hello.patch"), "w") as f:
+    f.write(hello_patch_content)
+with open(os.path.join(patches_dir, "goodbye.patch"), "w") as f:
+    f.write(goodbye_patch_content)
+
+# Create the conan_patches.json file for hello.txt
+file_patches_config = {
+    "recipes": {
+        "testpkg/1.0": {
+            "patches": [
+                {
+                    "patch_file": os.path.join(patches_dir, "hello.patch"),
+                    "patch_description": "Test patch for hello.txt (from file)"
+                }
+            ]
+        }
+    }
+}
+
+with open("conan_patches.json", "w") as f:
+    json.dump(file_patches_config, f, indent=2)
+
+# Create the environment variable with patch data for goodbye.txt
