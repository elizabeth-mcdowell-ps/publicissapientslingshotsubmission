+import os
+import json
+import tempfile
+import shutil
+import glob
+from pathlib import Path
+
+# Create a temporary directory for our test
+temp_dir = tempfile.mkdtemp()
+os.chdir(temp_dir)
+
+print(f"Working in temporary directory: {temp_dir}")
+
+# Create a simple recipe
+conanfile_content = """
+from conan import ConanFile
+from conan.tools.files import save
+
+class TestPkg(ConanFile):
+    name = "testpkg"
+    version = "1.0"
+    
+    def layout(self):
+        self.folders.source = "src"
+        self.folders.build = "build"
+    
+    def source(self):
+        # Create a file that we'll patch
+        save(self, "hello.txt", "Hello, World!")
+        self.output.info(f"Original content: {open('hello.txt').read()}")
+"""
+
+# Create a patch file
+patch_content = """diff --git a/hello.txt b/hello.txt
+index af5626b..a4a4462 100644
+--- a/hello.txt
++++ b/hello.txt
+@@ -1 +1 @@
+-Hello, World!
++Hello, Patched World!
+"""
+
+# Create the conanfile.py
+with open("conanfile.py", "w") as f:
+    f.write(conanfile_content)
+
+# Create the patch file
+patches_dir = os.path.join(temp_dir, "patches")
+os.makedirs(patches_dir, exist_ok=True)
+with open(os.path.join(patches_dir, "hello.patch"), "w") as f:
+    f.write(patch_content)
+
+# Create the conan_patches.json file
+patches_config = {
+    "recipes": {
+        "testpkg/1.0": {
+            "patches": [
+                {
+                    "patch_file": os.path.join(patches_dir, "hello.patch"),
+                    "patch_description": "Test patch for hello.txt"
+                }
+            ]
+        }
+    }
+}
+
+with open("conan_patches.json", "w") as f:
+    json.dump(patches_config, f, indent=2)
+
+# Run the conan source command
+print("\nRunning 'conan source .':")
+os.system("conan source .")
+
+# Check if the patch was applied
+hello_file = os.path.join(temp_dir, "src", "hello.txt")
+if os.path.exists(hello_file):
+    with open(hello_file, "r") as f:
+        content = f.read()
+    print(f"\nContent after patching: {content}")
+    if content == "Hello, Patched World!":
+        print("\nSUCCESS: Patch was applied correctly!")
+    else:
+        print("\nFAILURE: Patch was not applied correctly!")
+else:
+    print(f"\nFAILURE: hello.txt file not found at {hello_file}!")
+    print("Files in current directory:")
+    for f in glob.glob("*"):
+        print(f"  {f}")
+    print("Files in src directory:")
+    if os.path.exists("src"):
+        for f in glob.glob("src/*"):
+            print(f"  {f}")
+    else:
+        print("  src directory does not exist")
+
+# Clean up
+shutil.rmtree(temp_dir)
