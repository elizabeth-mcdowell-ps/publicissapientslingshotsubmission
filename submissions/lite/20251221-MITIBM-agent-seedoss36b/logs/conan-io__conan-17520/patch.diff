+index af5626b..a4a4462 100644
+--- a/hello.txt
++++ b/hello.txt
+@@ -1 +1 @@
+-Hello, World!
++Hello, Patched World!
+"""
+
+goodbye_patch_content = """diff --git a/goodbye.txt b/goodbye.txt
+index af5626b..a4a4462 100644
+--- a/goodbye.txt
++++ b/goodbye.txt
+@@ -1 +1 @@
+-Goodbye, World!
++Goodbye, Patched World!
+"""
+
