+#!/usr/bin/env python3
+"""
+Test script to verify the fix for the PDM update issue with a package in multiple groups.
+"""
+import os
+import tempfile
+import shutil
+import subprocess
+import json
+from pathlib import Path
+import tomlkit
+
+# Create a temporary project directory
+temp_dir = tempfile.mkdtemp()
+project_dir = Path(temp_dir)
+
+try:
+    # Initialize project structure
+    os.chdir(project_dir)
+    
+    # Create pyproject.toml with a dependency in multiple groups
+    with open(project_dir / "pyproject.toml", "w") as f:
+        f.write("""
+[project]
+name = "test-project"
+version = "0.1.0"
+description = "Test project for PDM issue"
+requires-python = ">=3.8"
+
+[tool.pdm.dev-dependencies]
+lint = [
+    "ruff==0.9.0",
+    "black==23.3.0",
+]
+
+[tool.pdm.dev-dependencies.test]
+dependencies = [
+    "pytest>=7.0.0",
+    "ruff==0.9.0",  # Duplicate dependency to simulate include-group
+]
+        """)
+    
+    # Initialize PDM project and lock dependencies
+    print("Creating initial lockfile...")
+    subprocess.run(["pdm", "lock"], check=True)
+    
+    # Check the initial lockfile
+    with open(project_dir / "pdm.lock", "r") as f:
+        initial_lock_data = tomlkit.parse(f.read())
+    
+    # Print the groups for ruff
+    ruff_pkg = next((pkg for pkg in initial_lock_data.get("package", []) if pkg.get("name") == "ruff"), None)
+    if ruff_pkg:
+        print(f"\nInitial groups for ruff: {ruff_pkg.get('groups', [])}")
+    
+    # Now run the update command that would trigger the issue
+    print("\nRunning pdm update ruff -G lint --no-sync...")
+    subprocess.run(["pdm", "update", "ruff", "-G", "lint", "--no-sync"], check=True)
+    
+    # Check the updated lockfile
+    with open(project_dir / "pdm.lock", "r") as f:
+        updated_lock_data = tomlkit.parse(f.read())
+    
+    # Print the groups for ruff after update
+    ruff_pkg = next((pkg for pkg in updated_lock_data.get("package", []) if pkg.get("name") == "ruff"), None)
+    if ruff_pkg:
+        print(f"\nGroups for ruff after update: {ruff_pkg.get('groups', [])}")
+    
+    # Check if the issue is fixed
+    if ruff_pkg and set(ruff_pkg.get("groups", [])) == {"lint", "test"}:
+        print("\nThe issue is fixed: pdm update preserves all groups for the updated package")
+    else:
+        print("\nThe issue is still present: pdm update doesn't preserve all groups for the updated package")
+
+finally:
+    # Clean up
+    shutil.rmtree(temp_dir)
