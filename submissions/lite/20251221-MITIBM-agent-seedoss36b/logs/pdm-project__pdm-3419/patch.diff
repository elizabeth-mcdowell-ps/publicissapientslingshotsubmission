+#!/usr/bin/env python3
+"""
+This script demonstrates the issue with PDM update removing group metadata.
+"""
+import os
+import tempfile
+import shutil
+import subprocess
+from pathlib import Path
+import tomlkit
+
+# Create a temporary project directory
+temp_dir = tempfile.mkdtemp()
+project_dir = Path(temp_dir)
+
+try:
+    # Initialize project structure
+    os.chdir(project_dir)
+    
+    # Create a pyproject.toml with a dependency group containing include-group
+    with open(project_dir / "pyproject.toml", "w") as f:
+        f.write("""
+[project]
+name = "test-project"
+version = "0.1.0"
+description = "Test project for PDM issue"
+requires-python = ">=3.8"
+
+[tool.pdm.dev-dependencies]
+lint = [
+    "ruff==0.9.0",
+    "black==23.3.0",
+]
+
+[tool.pdm.dev-dependencies.test]
+includes = ["lint"]
+dependencies = [
+    "pytest>=7.0.0",
+]
+        """)
+    
+    # Create a fake lockfile to simulate the issue
+    lockfile_content = """
+# This file is @generated by PDM.
+# It is not intended for manual editing.
+
+[metadata]
+groups = ["default", "dev", "lint", "test"]
+strategy = ["inherit_metadata"]
+lock_version = "4.5.0"
+
+[[package]]
+name = "black"
+version = "23.3.0"
+summary = "The uncompromising code formatter."
+groups = ["lint", "test"]
+dependencies = [
+    "click>=8.0.0",
+    "mypy-extensions>=0.4.3",
+    "packaging>=22.0",
+    "pathspec>=0.9.0",
+    "platformdirs>=2",
+    "tomli>=1.1.0; python_version < \\"3.11\\"",
+]
+
+[[package]]
+name = "click"
+version = "8.1.7"
+summary = "Composable command line interface toolkit"
+groups = ["lint", "test"]
+
+[[package]]
+name = "colorama"
+version = "0.4.6"
+summary = "Cross-platform colored terminal text."
+groups = ["lint", "test"]
+
+[[package]]
+name = "mypy-extensions"
+version = "1.0.0"
+summary = "Type system extensions for programs checked with the mypy type checker."
+groups = ["lint", "test"]
+
+[[package]]
+name = "packaging"
+version = "23.2"
+summary = "Core utilities for Python packages"
+groups = ["lint", "test"]
+
+[[package]]
+name = "pathspec"
+version = "0.11.2"
+summary = "Utility library for gitignore style pattern matching of file paths."
+groups = ["lint", "test"]
+
+[[package]]
+name = "platformdirs"
+version = "3.11.0"
+summary = "A small Python package for determining appropriate platform-specific dirs, e.g. a \\"user data dir\\"."
+groups = ["lint", "test"]
+
+[[package]]
+name = "pytest"
+version = "7.4.3"
+summary = "pytest: simple powerful testing with Python"
+groups = ["test"]
+dependencies = [
+    "colorama; sys_platform == \\"win32\\"",
+]
+
+[[package]]
+name = "ruff"
+version = "0.9.0"
+summary = "An extremely fast Python linter, written in Rust."
+groups = ["lint", "test"]
+
+[[package]]
+name = "tomli"
+version = "2.0.1"
+summary = "A lil' TOML parser"
+groups = ["lint", "test"]
+"""
+    
+    with open(project_dir / "pdm.lock", "w") as f:
+        f.write(lockfile_content)
+    
+    print("Initial lockfile created")
+    
+    # Parse the initial lockfile
+    with open(project_dir / "pdm.lock", "r") as f:
+        initial_lock_data = tomlkit.parse(f.read())
+    
+    # Print the groups for each package
+    print("\nInitial groups in lockfile:")
+    for pkg in initial_lock_data.get("package", []):
+        name = pkg.get("name")
+        groups = pkg.get("groups", [])
+        print(f"  {name}: {groups}")
+    
+    # Now run the update command that triggers the issue
+    print("\nRunning pdm update ruff -G lint --no-sync...")
+    subprocess.run(["pdm", "update", "ruff", "-G", "lint", "--no-sync"], check=True)
+    
+    # Check the updated lockfile
+    with open(project_dir / "pdm.lock", "r") as f:
+        updated_lock_data = tomlkit.parse(f.read())
+    
+    # Print the groups for each package after update
+    print("\nGroups in lockfile after update:")
+    for pkg in updated_lock_data.get("package", []):
+        name = pkg.get("name")
+        groups = pkg.get("groups", [])
+        print(f"  {name}: {groups}")
+    
+    # Check if the issue is present
+    issue_found = False
+    for pkg in updated_lock_data.get("package", []):
+        name = pkg.get("name")
+        groups = pkg.get("groups", [])
+        
+        if name != "ruff" and "lint" in initial_lock_data.get("package", [])[0].get("groups", []):
+            # Find the same package in the initial lockfile
+            initial_pkg = next((p for p in initial_lock_data.get("package", []) if p.get("name") == name), None)
+            if initial_pkg and "lint" in initial_pkg.get("groups", []) and "lint" not in groups:
+                print(f"\nIssue found: Package '{name}' lost the 'lint' group after update")
+                issue_found = True
+    
+    if issue_found:
+        print("\nThe issue is present: pdm update removes group metadata from packages")
+    else:
+        print("\nThe issue is not present")
+
+finally:
+    # Clean up
+    shutil.rmtree(temp_dir)
