+#!/usr/bin/env python3
+"""
+Test script to verify the fix for the PDM update issue with include-group.
+"""
+import os
+import tempfile
+import shutil
+import subprocess
+import json
+from pathlib import Path
+import tomlkit
+
+# Create a temporary project directory
+temp_dir = tempfile.mkdtemp()
+project_dir = Path(temp_dir)
+
+try:
+    # Initialize project structure
+    os.chdir(project_dir)
+    
+    # Create pyproject.toml with a dependency group containing include-group
+    with open(project_dir / "pyproject.toml", "w") as f:
+        f.write("""
+[project]
+name = "test-project"
+version = "0.1.0"
+description = "Test project for PDM issue"
+requires-python = ">=3.8"
+
+[tool.pdm.dev-dependencies]
+lint = [
+    "ruff==0.9.0",
+    "black==23.3.0",
+]
+
+[tool.pdm.dev-dependencies.test]
+dependencies = [
+    "pytest>=7.0.0",
+    "ruff==0.9.0",  # Duplicate dependency to simulate include-group
+]
+        """)
+    
+    # Initialize PDM project and lock dependencies
+    print("Creating initial lockfile...")
+    subprocess.run(["pdm", "lock"], check=True)
+    
+    # Check the initial lockfile
+    with open(project_dir / "pdm.lock", "r") as f:
+        initial_lock_data = tomlkit.parse(f.read())
+    
+    # Print the groups for each package
+    print("\nInitial groups in lockfile:")
+    for pkg in initial_lock_data.get("package", []):
+        name = pkg.get("name")
+        groups = pkg.get("groups", [])
+        print(f"  {name}: {groups}")
+    
+    # Now run the update command that would trigger the issue
+    print("\nRunning pdm update ruff -G lint --no-sync...")
+    subprocess.run(["pdm", "update", "ruff", "-G", "lint", "--no-sync"], check=True)
+    
+    # Check the updated lockfile
+    with open(project_dir / "pdm.lock", "r") as f:
+        updated_lock_data = tomlkit.parse(f.read())
+    
+    # Print the groups for each package after update
+    print("\nGroups in lockfile after update:")
+    for pkg in updated_lock_data.get("package", []):
+        name = pkg.get("name")
+        groups = pkg.get("groups", [])
+        print(f"  {name}: {groups}")
+    
+    # Check if the issue is fixed
+    issue_found = False
+    for pkg in updated_lock_data.get("package", []):
+        name = pkg.get("name")
+        groups = pkg.get("groups", [])
+        
+        if name != "ruff":
+            # Find the same package in the initial lockfile
+            initial_pkg = next((p for p in initial_lock_data.get("package", []) if p.get("name") == name), None)
+            if initial_pkg and set(initial_pkg.get("groups", [])) != set(groups):
+                print(f"\nIssue found: Package '{name}' has different groups after update")
+                print(f"  Before: {initial_pkg.get('groups', [])}")
+                print(f"  After: {groups}")
+                issue_found = True
+    
+    if issue_found:
+        print("\nThe issue is still present: pdm update changes group metadata for packages")
+    else:
+        print("\nThe issue is fixed: pdm update preserves group metadata for all packages")
+
+finally:
+    # Clean up
+    shutil.rmtree(temp_dir)
