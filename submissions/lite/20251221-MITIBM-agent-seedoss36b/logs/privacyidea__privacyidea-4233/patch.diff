+"""
+This test file tests the enroll_via_multichallenge functionality
+with a focus on the otpauth link in the response.
+"""
+
+import json
+from .base import MyApiTestCase
+from privacyidea.lib.policy import SCOPE, ACTION, set_policy, delete_policy
+from privacyidea.lib.token import init_token, remove_token
+from privacyidea.lib.user import User
+
+
+class EnrollViaMultichallengeOTPAuthTestCase(MyApiTestCase):
+    """
+    Test the enroll_via_multichallenge functionality with otpauth link
+    """
+
+    def test_01_enroll_via_multichallenge_otpauth(self):
+        """
+        Test that the otpauth link is included in the response when
+        enroll_via_multichallenge is triggered.
+        """
+        # Create a user
+        self.setUp_user_realms()
+        user = User("cornelius", self.realm1)
+
+        # Create a policy for enroll_via_multichallenge
+        set_policy(name="enroll_via_multichallenge_test",
+                   scope=SCOPE.AUTH,
+                   action=ACTION.ENROLL_VIA_MULTICHALLENGE + "=hotp",
+                   user="*",
+                   realm="*")
+
+        # Create a token for the user to authenticate with
+        token = init_token({"type": "spass", "pin": "test"}, user=user)
+        serial = token.get_serial()
+
+        # Authenticate with the user to trigger enroll_via_multichallenge
+        with self.app.test_request_context('/validate/check',
+                                          method='POST',
+                                          data={"user": user.login,
+                                                "realm": self.realm1,
+                                                "pass": "test"}):
+            res = self.app.full_dispatch_request()
+            self.assertEqual(res.status_code, 200)
+            result = json.loads(res.data.decode('utf8'))
+            
+            # Check if the response contains the otpauth link
+            self.assertIn("detail", result)
+            self.assertIn("otpauth", result["detail"])
+            self.assertTrue(result["detail"]["otpauth"].startswith("otpauth://"))
+            
+            # Also check if it's in the multi_challenge
+            self.assertIn("multi_challenge", result["detail"])
+            self.assertEqual(len(result["detail"]["multi_challenge"]), 1)
+            self.assertIn("otpauth", result["detail"]["multi_challenge"][0])
+            self.assertTrue(result["detail"]["multi_challenge"][0]["otpauth"].startswith("otpauth://"))
+
+        # Clean up
+        remove_token(serial)
+        
+        # Also remove the HOTP token that was created
+        hotp_tokens = self.find_tokens(tokentype="hotp", user=user)
+        for token in hotp_tokens:
+            remove_token(token.get_serial())
+            
+        delete_policy("enroll_via_multichallenge_test")
+        
+    def find_tokens(self, tokentype=None, user=None):
+        """
+        Helper method to find tokens
+        """
+        from privacyidea.lib.token import get_tokens
+        return get_tokens(tokentype=tokentype, user=user)
