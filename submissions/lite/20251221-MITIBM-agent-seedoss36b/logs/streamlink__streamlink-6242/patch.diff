@@ -0,0 +1,19 @@
+import sys
+import os
+
+# Add the src directory to the Python path
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "src"))
+
+from streamlink.plugins.tv3cat import TV3Cat
+
+def main():
+    url = "https://www.3cat.cat/3cat/directes/tv3/"
+    
+    # Test if the TV3Cat plugin can handle the URL
+    if TV3Cat.can_handle_url(url):
+        print(f"TV3Cat plugin can handle URL: {url}")
+    else:
+        print(f"TV3Cat plugin cannot handle URL: {url}")
+
+if __name__ == "__main__":
+    main()
