+import os
+import textwrap
+from conan.test.utils.tools import TestClient
+
+# Create a test client
+client = TestClient()
+
+# Create a simple package
+pkg_a = textwrap.dedent("""
+from conan import ConanFile
+
+class PkgA(ConanFile):
+    name = "pkga"
+    version = "0.1"
+    
+    def package_info(self):
+        self.cpp_info.libs = ["pkga"]
+""")
+
+# Create a package that uses test_requires
+test_requires_consumer = textwrap.dedent("""
+from conan import ConanFile
+
+class TestRequiresConsumer(ConanFile):
+    name = "test_requires_consumer"
+    version = "0.1"
+    
+    def build_requirements(self):
+        self.test_requires("pkga/0.1")
+        
+    def generate(self):
+        self.output.info("Test requires consumer")
+        # Print information about requirements
+        self.output.info(f"Requirements: {self.dependencies.items()}")
+        for dep in self.dependencies.items():
+            self.output.info(f"Dependency {dep[0]}: visible={dep[1].visible}")
+""")
+
+# Create a package that uses build_requires with force_host_context=True
+build_requires_consumer = textwrap.dedent("""
+from conan import ConanFile
+
+class BuildRequiresConsumer(ConanFile):
+    name = "build_requires_consumer"
+    version = "0.1"
+    
+    def build_requirements(self):
+        self.build_requires("pkga/0.1", force_host_context=True)
+        
+    def generate(self):
+        self.output.info("Build requires consumer with force_host_context=True")
+        # Print information about requirements
+        self.output.info(f"Requirements: {self.dependencies.items()}")
+        for dep in self.dependencies.items():
+            self.output.info(f"Dependency {dep[0]}: visible={dep[1].visible}")
+""")
+
+# Create a package that uses requires with private flag
+private_requires_consumer = textwrap.dedent("""
+from conan import ConanFile
+
+class PrivateRequiresConsumer(ConanFile):
+    name = "private_requires_consumer"
+    version = "0.1"
+    
+    def requirements(self):
+        self.requires("pkgA/0.1", visible=False)
+        
+    def generate(self):
+        self.output.info("Private requires consumer")
+        # Print information about requirements
+        self.output.info(f"Requirements: {self.dependencies.items()}")
+        for dep in self.dependencies.items():
+            self.output.info(f"Dependency {dep[0]}: visible={dep[1].visible}")
+""")
+
+# Save the files
+client.save({"pkgA/conanfile.py": pkg_a,
+             "test_requires_consumer/conanfile.py": test_requires_consumer,
+             "build_requires_consumer/conanfile.py": build_requires_consumer,
+             "private_requires_consumer/conanfile.py": private_requires_consumer})
+
+# Create the packages
+print("Creating pkgA...")
+client.run("create pkgA")
+
+print("\nTesting test_requires...")
+client.run("create test_requires_consumer")
+
+print("\nTesting build_requires with force_host_context=True...")
+client.run("create build_requires_consumer")
+
+print("\nTesting requires with visible=False (private)...")
+client.run("create private_requires_consumer")
+
+# Now create a consumer that depends on all three packages to see transitivity
+transitive_consumer = textwrap.dedent("""
+from conan import ConanFile
+
+class TransitiveConsumer(ConanFile):
+    name = "transitive_consumer"
+    version = "0.1"
+    
+    def requirements(self):
+        self.requires("test_requires_consumer/0.1")
+        self.requires("build_requires_consumer/0.1")
+        self.requires("private_requires_consumer/0.1")
+        
+    def generate(self):
+        self.output.info("Transitive consumer")
+        # Print information about requirements
+        self.output.info(f"Direct requirements: {[str(dep) for dep in self.dependencies.direct_host.items()]}")
+        self.output.info(f"All requirements: {[str(dep) for dep in self.dependencies.host.items()]}")
+""")
+
+client.save({"transitive_consumer/conanfile.py": transitive_consumer})
+print("\nTesting transitivity...")
+client.run("create transitive_consumer")
