+from smolagents.utils import BASE_BUILTIN_MODULES
+from smolagents.local_python_executor import LocalPythonInterpreter
+
+# Create a test script that uses matplotlib and explicitly tries to use dbm
+test_code = """
+import matplotlib.pyplot as plt
+import seaborn as sns
+import pandas as pd
+import numpy as np
+
+# Try to import dbm explicitly to see if that's the issue
+try:
+    import dbm
+    print("Successfully imported dbm")
+except ImportError as e:
+    print(f"Error importing dbm: {e}")
+
+# Try to import other modules that matplotlib might need
+try:
+    import tkinter
+    print("Successfully imported tkinter")
+except ImportError as e:
+    print(f"Error importing tkinter: {e}")
+
+try:
+    import sqlite3
+    print("Successfully imported sqlite3")
+except ImportError as e:
+    print(f"Error importing sqlite3: {e}")
+
+try:
+    import zlib
+    print("Successfully imported zlib")
+except ImportError as e:
+    print(f"Error importing zlib: {e}")
+
+# Create a simple dataframe for testing
+df = pd.DataFrame({
+    'Product_3': ['A', 'B', 'C', 'A', 'B', 'C'],
+    'Stroke_Length': [10, 15, 20, 12, 18, 22],
+    'Cylinder_Function': ['X', 'Y', 'Z', 'X', 'Y', 'Z'],
+    'Closed_Length_mm': [100, 150, 200, 120, 180, 220],
+    'Type_2': ['P', 'Q', 'R', 'P', 'Q', 'R'],
+    'Attributes_Rod_ID': [1, 2, 3, 1.5, 2.5, 3.5],
+    'Attributes_Internal_Bore': [5, 6, 7, 5.5, 6.5, 7.5]
+})
+
+# Try to create a plot
+plt.figure(figsize=(10, 6))
+sns.boxplot(x='Product_3', y='Stroke_Length', data=df)
+plt.title('Test Plot')
+plt.savefig('test_plot.png')  # Save the plot to a file
+print("Plot created successfully!")
+"""
+
+# Print current authorized imports
+print("Current BASE_BUILTIN_MODULES:", BASE_BUILTIN_MODULES)
+
+# Create a LocalPythonInterpreter with matplotlib.pyplot and all potential dependencies
+interpreter = LocalPythonInterpreter(
+    additional_authorized_imports=[
+        "numpy", "pandas", "matplotlib.pyplot", "seaborn", 
+        "dbm", "tkinter", "sqlite3", "zlib", "bz2", "lzma", "gzip"
+    ],
+    tools={},
+    max_print_outputs_length=None
+)
+
+# Execute the code
+result, output, is_final_answer = interpreter(test_code, {})
+print("\nOutput:", output)
+print("\nResult:", result)
