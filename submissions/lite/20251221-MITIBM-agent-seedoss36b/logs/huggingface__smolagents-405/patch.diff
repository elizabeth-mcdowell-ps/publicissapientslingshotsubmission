+from smolagents.agents import CodeAgent
+from smolagents.models import ChatMessage, MessageRole
+
+# Mock HfApiModel for testing
+class MockHfApiModel:
+    def __init__(self, model_name, token=None):
+        self.model_name = model_name
+        self.token = token
+        
+    def __call__(self, messages, stop_sequences=None, **kwargs):
+        # Return a simple matplotlib code snippet
+        return ChatMessage(
+            role=MessageRole.ASSISTANT,
+            content="""
+            I'll create some visualizations for the data.
+            
+            ```python
+            import matplotlib.pyplot as plt
+            import seaborn as sns
+            import pandas as pd
+            import numpy as np
+            
+            # Create a simple dataframe for testing
+            df = pd.DataFrame({
+                'Product_3': ['A', 'B', 'C', 'A', 'B', 'C'],
+                'Stroke_Length': [10, 15, 20, 12, 18, 22],
+                'Cylinder_Function': ['X', 'Y', 'Z', 'X', 'Y', 'Z'],
+                'Closed_Length_mm': [100, 150, 200, 120, 180, 220],
+                'Type_2': ['P', 'Q', 'R', 'P', 'Q', 'R'],
+                'Attributes_Rod_ID': [1, 2, 3, 1.5, 2.5, 3.5],
+                'Attributes_Internal_Bore': [5, 6, 7, 5.5, 6.5, 7.5]
+            })
+            
+            # Create a plot
+            plt.figure(figsize=(10, 6))
+            sns.boxplot(x='Product_3', y='Stroke_Length', data=df)
+            plt.title('Distribution of Stroke_Length by Product_3')
+            plt.savefig('test_plot.png')
+            
+            final_answer("Visualization created successfully!")
+            ```
+            """
+        )
+
+# Create a mock model
+hf_token = "fake_token"
+qwen_model = MockHfApiModel("Qwen/Qwen2.5-Coder-32B-Instruct", token=hf_token)
+
+# Create the CodeAgent with matplotlib.pyplot in additional_authorized_imports
+data_analyst_agent_qwen = CodeAgent(
+    tools=[],
+    model=qwen_model,
+    additional_authorized_imports=["numpy", "pandas", "matplotlib.pyplot", "seaborn"],
+    max_steps=10,
+)
+
+# Run the agent with a data analysis prompt
+data_analyst_prompt = "Create a visualization of the data."
+input_file_path = "fake_input_file.csv"
+
+# Run the agent
+try:
+    result = data_analyst_agent_qwen.run(
+        data_analyst_prompt, 
+        additional_args=dict(source_file_path=input_file_path)
+    )
+    print("Agent ran successfully!")
+    print("Result:", result)
+except Exception as e:
+    print(f"Error running agent: {e}")
