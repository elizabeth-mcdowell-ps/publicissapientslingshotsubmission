+"""
+Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.
+SPDX-License-Identifier: MIT-0
+"""
+
+from __future__ import annotations
+
+import re
+from typing import Any, List
+
+from cfnlint.rules import CloudFormationLintRule, RuleMatch
+
+
+class PolicyConditionOperator(CloudFormationLintRule):
+    """Check IAM Policy Condition Operators"""
+
+    id = "E3511"
+    shortdesc = "Validate IAM Policy Condition Operators"
+    description = (
+        "IAM Policies must use valid condition operators. "
+        "This rule validates that condition operators are properly formatted."
+    )
+    source_url = "https://docs.aws.amazon.com/IAM/latest/UserGuide/reference_policies_elements_condition_operators.html"
+    tags = ["resources", "iam", "policy", "condition"]
+
+    # Regular expressions for valid condition operators
+    _condition_operator_patterns = [
+        r"^ForAllValues:(Not)?IpAddress$",
+        r"^ForAllValues:Arn(Not)?Equals$",
+        r"^ForAllValues:Arn(Not)?Like$",
+        r"^ForAllValues:Date(Not)?Equals$",
+        r"^ForAllValues:Number(Less|Greater)Than(Equals)?$",
+        r"^ForAllValues:Number(Not)?Equals$",
+        r"^ForAllValues:String(Not)?Equals(IgnoreCase)?$",
+        r"^ForAllValues:String(Not)?Like$",
+        r"^ForAnyValues:(Not)?IpAddress$",
+        r"^ForAnyValues:Arn(Not)?Equals$",
+        r"^ForAnyValues:Arn(Not)?Like$",
+        r"^ForAnyValues:Date(Not)?Equals$",
+        r"^ForAnyValues:Number(Less|Greater)Than(Equals)?$",
+        r"^ForAnyValues:Number(Not)?Equals$",
+        r"^ForAnyValues:String(Not)?Equals(IgnoreCase)?$",
+        r"^ForAnyValues:String(Not)?Like$",
+        r"^(Not)?IpAddress(Exists)?$",
+        r"^Arn(Not)?Equals(Exists)?$",
+        r"^Arn(Not)?Like(Exists)?$",
+        r"^Date(Not)?Equals(Exists)?$",
+        r"^Number(Less|Greater)Than(Equals)?(Exists)?$",
+        r"^Number(Not)?Equals(Exists)?$",
+        r"^String(Not)?Equals(IgnoreCase)?(Exists)?$",
+        r"^String(Not)?Like(Exists)?$",
+        r"^BinaryEquals$",
+        r"^Bool$",
+        r"^Null$",
+    ]
+
+    def match(self, cfn):
+        """Check IAM Policy Condition Operators"""
+        matches = []
+
+        iam_types = {
+            'AWS::IAM::ManagedPolicy': 'PolicyDocument',
+            'AWS::IAM::Policy': 'PolicyDocument',
+            'AWS::IAM::Role': 'Policies',
+            'AWS::IAM::User': 'Policies',
+            'AWS::IAM::Group': 'Policies',
+        }
+
+        resources = cfn.get('Resources', {})
+        for resource_name, resource_values in resources.items():
+            resource_type = resource_values.get('Type', '')
+            
+            if resource_type in iam_types:
+                self.check_policy_document(resource_name, resource_values, resource_type, iam_types[resource_type], matches)
+        
+        return matches
+
+    def check_policy_document(self, resource_name, resource_values, resource_type, policy_property, matches):
+        """Check policy document for condition operators"""
+        properties = resource_values.get('Properties', {})
+        
+        if policy_property == 'PolicyDocument':
+            policy_doc = properties.get(policy_property, {})
+            self.check_statements(resource_name, resource_type, policy_doc, matches, [
+                'Resources', resource_name, 'Properties', policy_property
+            ])
+        elif policy_property == 'Policies':
+            policies = properties.get(policy_property, [])
+            for i, policy in enumerate(policies):
+                policy_doc = policy.get('PolicyDocument', {})
+                self.check_statements(resource_name, resource_type, policy_doc, matches, [
+                    'Resources', resource_name, 'Properties', policy_property, i, 'PolicyDocument'
+                ])
+
+    def check_statements(self, resource_name, resource_type, policy_doc, matches, path_parts):
+        """Check statements in policy document"""
+        statements = policy_doc.get('Statement', [])
+        if isinstance(statements, dict):
+            statements = [statements]
+        
+        for i, statement in enumerate(statements):
+            if 'Condition' in statement:
+                condition = statement.get('Condition', {})
+                if isinstance(condition, dict):
+                    for operator_name in condition:
+                        is_valid = False
+                        for pattern in self._condition_operator_patterns:
+                            if re.match(pattern, operator_name):
+                                is_valid = True
+                                break
+                        
+                        if not is_valid:
+                            path = path_parts + ['Statement', i, 'Condition', operator_name]
+                            message = f"IAM Policy Condition operator '{operator_name}' is not valid in {resource_type} {resource_name}"
+                            matches.append(RuleMatch(path, message))
