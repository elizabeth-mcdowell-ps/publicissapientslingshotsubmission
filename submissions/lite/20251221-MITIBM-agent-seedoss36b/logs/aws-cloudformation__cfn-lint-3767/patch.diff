+#!/usr/bin/env python
+
+import sys
+import os
+import json
+from pathlib import Path
+
+# Add the src directory to the Python path
+sys.path.insert(0, str(Path(__file__).parent / 'src'))
+
+from cfnlint.rules.resources.iam.PolicyConditionOperator import PolicyConditionOperator
+import cfnlint.decode.cfn_yaml
+
+def main():
+    """Main function to reproduce the issue"""
+    template_path = Path(__file__).parent / 'demo-template.yaml'
+    
+    # Load the template from the file
+    with open(template_path, 'r') as f:
+        template_str = f.read()
+    
+    # Parse the template
+    template = cfnlint.decode.cfn_yaml.loads(template_str)
+    
+    # Create an instance of the PolicyConditionOperator rule
+    rule = PolicyConditionOperator()
+    
+    # Run the rule against our template
+    matches = rule.match(template)
+    
+    # Print the results
+    print(f"Number of matches: {len(matches)}")
+    for match in matches:
+        print(f"E3511: {match.message}")
+    
+    # Create a valid template for comparison
+    valid_template_str = """---
+AWSTemplateFormatVersion: '2010-09-09'
+Description: Example IAM policy with valid condition operator.
+
+Resources:
+  IAMPolicy:
+    Type: AWS::IAM::ManagedPolicy
+    Properties:
+      Roles:
+        - DemoRole
+      PolicyDocument:
+        Version: '2012-10-17'
+        Statement:
+          - Effect: Allow
+            Action:
+              - servicecatalog:*
+            Resource: '*'
+            Condition:
+                StringEquals:
+                  servicecatalog:accountLevel: self
+"""
+    
+    # Parse the valid template
+    valid_template = cfnlint.decode.cfn_yaml.loads(valid_template_str)
+    
+    # Run the rule against the valid template
+    valid_matches = rule.match(valid_template)
+    print(f"\nValid template - Number of matches: {len(valid_matches)}")
+    for match in valid_matches:
+        print(f"E3511: {match.message}")
+    
+    return 0 if len(matches) > 0 else 1  # We expect to find an error in the invalid template
+
+if __name__ == '__main__':
+    sys.exit(main())
