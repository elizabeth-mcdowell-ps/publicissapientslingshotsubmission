+#!/usr/bin/env python
+import sys
+import os
+
+# Add the src directory to the Python path
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "src"))
+
+from streamlink import Streamlink
+
+def main():
+    session = Streamlink()
+    url = "https://chzzk.naver.com/clips/R9BilMGLOS"
+    
+    print(f"Trying to get streams from: {url}")
+    
+    try:
+        # Set options for more verbose output
+        session.set_option("stream-sorting-excludes", [])
+        
+        streams = session.streams(url)
+        if streams:
+            print(f"Available streams: {streams.keys()}")
+        else:
+            print("No streams found")
+    except Exception as e:
+        import traceback
+        print(f"Error: {e}")
+        traceback.print_exc()
+
+if __name__ == "__main__":
+    main()
