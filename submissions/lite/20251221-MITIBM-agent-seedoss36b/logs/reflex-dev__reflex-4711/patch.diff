+        self._js_expr = _js_expr
+        self._var_type = _var_type
+        self._var_data = _var_data
+
+class ComputedVar(Var):
+    def __init__(
+        self,
+        fget,
+        initial_value=None,
+        cache=True,
+        deps=None,
+        auto_deps=True,
+        interval=None,
+        backend=None,
+        **kwargs
+    ):
+        super().__init__(_js_expr=fget.__name__, _var_type=None)
