+        @functools.wraps(async_fn)
+        def sync_wrapper(state_instance):
+            # Get the current event loop or create a new one
+            try:
+                loop = asyncio.get_event_loop()
+            except RuntimeError:
+                loop = asyncio.new_event_loop()
+                asyncio.set_event_loop(loop)
+            
+            # Check if we have a cached result
+            var_name = async_fn.__name__
+            if hasattr(state_instance, f"_{var_name}_result"):
+                return getattr(state_instance, f"_{var_name}_result")
+            
+            # If no cached result, start a background task to compute it
+            if not hasattr(state_instance, f"_{var_name}_task") or getattr(state_instance, f"_{var_name}_task").done():
+                async def compute_and_store():
+                    try:
+                        result = await async_fn(state_instance)
+                        setattr(state_instance, f"_{var_name}_result", result)
+                        return result
+                    except Exception as e:
+                        print(f"Error in async cached_var {var_name}: {str(e)}")
+                        return None
+                
+                task = asyncio.create_task(compute_and_store())
+                setattr(state_instance, f"_{var_name}_task", task)
+            
+            # Return initial value or None while computing
+            return initial_value if initial_value is not None else None
+        
+        return sync_wrapper
+    
+    # Handle both decorator forms: @cached_var and @cached_var()
+    if fget is not None:
+        sync_fn = create_sync_wrapper(fget)
+        return ComputedVar(sync_fn, cache=cache)
+    
+    def wrapper(async_fn):
+        sync_fn = create_sync_wrapper(async_fn)
