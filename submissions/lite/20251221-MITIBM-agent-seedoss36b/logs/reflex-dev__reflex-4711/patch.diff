+"""Test script for async cached_var functionality in Reflex."""
+
+import asyncio
+import sys
+import os
+import time
+from typing import Optional
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, "/testbed")
+
+# Import from reflex
+from reflex.state import BaseState, cached_var
+
+
+class User:
+    """A simple user class for testing."""
+    
+    def __init__(self, id: str, name: str):
+        self.id = id
+        self.name = name
+    
+    def __str__(self):
+        return f"User(id={self.id}, name={self.name})"
+
+
+async def load_user_by_id(user_id: str) -> User:
+    """Simulate loading a user from a database."""
+    # Simulate network delay
+    print(f"Starting to load user with ID: {user_id}")
+    await asyncio.sleep(1)
+    print(f"Finished loading user with ID: {user_id}")
+    return User(id=user_id, name=f"User {user_id}")
+
+
+class MyState(BaseState):
+    """Test state with async cached_var."""
+    
+    # State variables
+    user_id: str = "123"
+    loading_count: int = 0
+    
+    @cached_var
+    async def user(self) -> Optional[User]:
+        """Load user asynchronously and cache the result."""
+        print(f"Loading user with ID: {self.user_id}")
+        self.loading_count += 1
+        return await load_user_by_id(self.user_id)
+
+
+async def main():
+    """Test the async cached_var functionality."""
+    state = MyState()
+    
+    # First access should trigger the async load and return None initially
+    print("\n=== First access (should return None initially) ===")
+    user = state.user
+    print(f"User: {user}")
+    print(f"Loading count: {state.loading_count}")
+    
+    # Wait for the async task to complete
+    print("\n=== Waiting for async task to complete... ===")
+    await asyncio.sleep(1.5)
+    
+    # Second access should use the cached value
+    print("\n=== Second access (should be cached) ===")
+    user = state.user
+    print(f"User: {user}")
+    print(f"Loading count: {state.loading_count}")
+    
+    # Change the user_id and access again
+    print("\n=== Changing user_id and accessing again ===")
+    state.user_id = "456"
+    
+    # This should invalidate the cache and trigger a new load
+    # We need to manually clear the cache for this test
+    if hasattr(state, "_user_result"):
+        delattr(state, "_user_result")
+    
+    user = state.user
+    print(f"User: {user}")
+    print(f"Loading count: {state.loading_count}")
+    
+    # Wait for the async task to complete
+    print("\n=== Waiting for async task to complete... ===")
