+) -> ComputedVar | Callable[[Callable[[BaseState], Coroutine]], ComputedVar]:
+    """A decorator for creating async computed variables that are cached.
+    
+    This decorator wraps async functions to be used as computed variables.
+    The async function will be executed in a background task and the result
+    will be cached. Until the async function completes, the computed var
+    will return the initial value (None by default).
+    
+    Args:
+        fget: The async getter function.
+        initial_value: The initial value of the computed var.
+        cache: Whether to cache the computed value.
+        deps: Explicit var dependencies to track.
+        auto_deps: Whether var dependencies should be auto-determined.
+        interval: Interval at which the computed var should be updated.
+        backend: Whether the computed var is a backend var.
+        **kwargs: additional attributes to set on the instance
+        
+    Returns:
+        A ComputedVar instance that wraps the async function.
+        
+    Example:
+        ```python
+        class MyState(rx.State):
+            user_id: str
+            
+            @rx.cached_var
+            async def user(self) -> User | None:
+                return await db.load_user_by_id(self.user_id)
+        ```
+    """
+    # Create a synchronous wrapper for the async function
+    def create_sync_wrapper(async_fn):
+        @functools.wraps(async_fn)
+        def sync_wrapper(state_instance):
+            # Get the current event loop or create a new one
+            try:
+                loop = asyncio.get_event_loop()
+            except RuntimeError:
+                loop = asyncio.new_event_loop()
+                asyncio.set_event_loop(loop)
+            
+            # Check if we have a cached result
+            var_name = async_fn.__name__
+            result_attr = f"_{var_name}_result"
+            task_attr = f"_{var_name}_task"
+            
+            # Return cached result if available
+            if hasattr(state_instance, result_attr):
+                return getattr(state_instance, result_attr)
+            
+            # If no cached result, start a background task to compute it if not already running
+            if not hasattr(state_instance, task_attr) or getattr(state_instance, task_attr).done():
+                async def compute_and_store():
+                    try:
+                        result = await async_fn(state_instance)
+                        setattr(state_instance, result_attr, result)
+                        return result
+                    except Exception as e:
+                        console.error(f"Error in async cached_var {var_name}: {str(e)}")
+                        return None
+                
+                task = asyncio.create_task(compute_and_store())
+                setattr(state_instance, task_attr, task)
+            
+            # Return initial value or None while computing
+            if initial_value is not types.Unset():
+                return initial_value
+            return None
+        
+        return sync_wrapper
+    
+    # Handle both decorator forms: @cached_var and @cached_var()
+    if fget is not None:
+        sync_fn = create_sync_wrapper(fget)
