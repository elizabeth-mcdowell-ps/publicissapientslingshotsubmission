+import asyncio
+from llama_deploy.deploy.network_workflow import NetworkWorkflow
+from llama_deploy.control_plane.server import ControlPlaneConfig
+from llama_index.core.workflow import StartEvent
+
+async def main():
+    # Create a mock control plane config
+    control_plane_config = ControlPlaneConfig(url="http://localhost:8000")
+    
+    # Create a network workflow with default timeout (120 seconds)
+    workflow = NetworkWorkflow(
+        control_plane_config=control_plane_config,
+        remote_service_name="test_service"
+    )
+    
+    # Print the default timeout
+    print(f"Default timeout: {workflow.timeout if hasattr(workflow, 'timeout') else 'Not set (using 120s)'}")
+    
+    # Try to run with a custom timeout (this should fail with current implementation)
+    try:
+        # This will use the hardcoded 120s timeout in AsyncLlamaDeployClient
+        event = StartEvent()
+        result = await workflow.run_remote_workflow(event)
+        print("Result:", result)
+    except Exception as e:
+        print(f"Error: {e}")
+    
+    print("\nAfter implementing the fix, we should be able to specify a custom timeout.")
+
+if __name__ == "__main__":
+    asyncio.run(main())
