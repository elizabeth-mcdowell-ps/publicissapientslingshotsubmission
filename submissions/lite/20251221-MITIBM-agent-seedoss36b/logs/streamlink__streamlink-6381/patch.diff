+import sys
+import os
+import logging
+import re
+import json
+from unittest.mock import patch, MagicMock
+from lxml import etree
+
+# Add the src directory to the Python path
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "src"))
+
+from streamlink.plugins.tiktok import TikTok
+from streamlink.session import Streamlink
+from streamlink.plugin.api import validate
+
+# Set up logging
+logging.basicConfig(level=logging.DEBUG)
+logger = logging.getLogger()
+
+# Let's create a simpler test to understand the validation schema
+def test_validation_schema():
+    print("\nTesting validation schema directly:")
+    
+    # Test case with non-empty roomId
+    html = """
+    <html>
+    <head></head>
+    <body>
+        <script type="application/json" id="SIGI_STATE">
+        {
+            "LiveRoom": {
+                "liveRoomUserInfo": {
+                    "user": {
+                        "roomId": "12345678"
+                    }
+                }
+            }
+        }
+        </script>
+    </body>
+    </html>
+    """
+    
+    # Parse HTML
+    parser = etree.HTMLParser()
+    tree = etree.fromstring(html, parser)
+    
+    # Extract SIGI_STATE
+    script_element = tree.xpath(".//script[@type='application/json'][@id='SIGI_STATE'][1]/text()")
+    if script_element:
+        sigi_state = json.loads(script_element[0])
+        print(f"SIGI_STATE: {sigi_state}")
+        
+        # Try to extract roomId using our validation paths
+        try:
+            room_id = sigi_state["LiveRoom"]["liveRoomUserInfo"]["user"]["roomId"]
+            if room_id and room_id != "":
