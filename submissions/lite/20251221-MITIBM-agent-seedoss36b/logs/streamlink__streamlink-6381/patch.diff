+import re
+import json
+import logging
+
+# Set up logging
+logging.basicConfig(level=logging.DEBUG)
+logger = logging.getLogger()
+
+# Test case with non-empty roomId
+html = """
+<html>
+<head></head>
+<body>
+    <script type="application/json" id="SIGI_STATE">
+    {
+        "LiveRoom": {
+            "liveRoomUserInfo": {
+                "user": {
+                    "roomId": "12345678"
+                }
+            }
+        }
+    }
+    </script>
+</body>
+</html>
+"""
+
+# Function to extract room ID
+def extract_room_id(html_text):
+    room_id = None
+    
+    # Try to extract room ID from meta tag
+    meta_match = re.search(r'<meta\s+property="al:android:url"\s+content="[^"]*?room_id=(\d+)[^"]*"', html_text)
+    if meta_match:
+        room_id = meta_match.group(1)
+        print(f"Found room ID in meta tag: {room_id}")
+    else:
+        # Try to extract room ID from SIGI_STATE
+        sigi_match = re.search(r'<script[^>]*id="SIGI_STATE"[^>]*>(.*?)</script>', html_text, re.DOTALL)
+        if sigi_match:
+            try:
+                sigi_data = json.loads(sigi_match.group(1))
+                print(f"Parsed SIGI_STATE: {sigi_data}")
+                
+                # Try original path for roomId
+                try:
+                    room_id = sigi_data["LiveRoom"]["liveRoomUserInfo"]["user"]["roomId"]
+                    if room_id and room_id != "":
+                        print(f"Found room ID in SIGI_STATE LiveRoom: {room_id}")
+                    else:
+                        print("roomId is empty")
+                except (KeyError, TypeError):
+                    print("Failed to extract roomId from original path")
+                
+                # If roomId is empty or not found, try streamId
+                if not room_id:
+                    try:
+                        stream_id = sigi_data["LiveRoom"]["liveRoomUserInfo"]["liveRoom"]["streamId"]
+                        if stream_id and stream_id != "":
+                            room_id = stream_id
+                            print(f"Found stream ID in SIGI_STATE LiveRoom: {room_id}")
+                    except (KeyError, TypeError):
+                        print("Failed to extract streamId")
+                
+                # If still not found, try CurrentRoom
+                if not room_id:
+                    try:
+                        current_room_id = sigi_data["CurrentRoom"]["roomId"]
+                        if current_room_id and current_room_id != "":
+                            room_id = current_room_id
+                            print(f"Found room ID in SIGI_STATE CurrentRoom: {room_id}")
+                    except (KeyError, TypeError):
+                        print("Failed to extract CurrentRoom roomId")
+            except (json.JSONDecodeError, IndexError) as e:
+                print(f"Error parsing SIGI_STATE: {e}")
+    
+    return room_id
+
+# Test the function
+room_id = extract_room_id(html)
+print(f"Final room ID: {room_id}")
+
+# Test with empty roomId but has streamId
+html2 = """
+<html>
+<head></head>
+<body>
+    <script type="application/json" id="SIGI_STATE">
+    {
+        "LiveRoom": {
+            "liveRoomUserInfo": {
+                "user": {
+                    "roomId": ""
+                },
+                "liveRoom": {
+                    "streamId": "87654321"
+                }
+            }
+        }
+    }
+    </script>
+</body>
+</html>
+"""
+
+print("\nTesting with empty roomId but has streamId:")
+room_id = extract_room_id(html2)
+print(f"Final room ID: {room_id}")
+
+# Test with CurrentRoom roomId
+html3 = """
+<html>
+<head></head>
+<body>
+    <script type="application/json" id="SIGI_STATE">
+    {
+        "LiveRoom": {
+            "liveRoomUserInfo": {
+                "user": {
+                    "roomId": ""
+                }
+            }
+        },
+        "CurrentRoom": {
+            "roomId": "98765432"
+        }
+    }
+    </script>
+</body>
+</html>
+"""
+
+print("\nTesting with CurrentRoom roomId:")
+room_id = extract_room_id(html3)
+print(f"Final room ID: {room_id}")
+
+# Test with meta tag room_id
+html4 = """
+<html>
+<head>
+    <meta property="al:android:url" content="tiktok://live?room_id=11223344">
+</head>
+<body>
+    <script type="application/json" id="SIGI_STATE">
+    {
+        "LiveRoom": {
+            "liveRoomUserInfo": {
+                "user": {
+                    "roomId": ""
+                }
+            }
+        }
+    }
+    </script>
+</body>
+</html>
+"""
+
+print("\nTesting with meta tag room_id:")
+room_id = extract_room_id(html4)
+print(f"Final room ID: {room_id}")
