+
+from streamlink.plugins.tiktok import TikTok
+from streamlink.session import Streamlink
+
+# Set up logging
+logging.basicConfig(level=logging.DEBUG)
+logger = logging.getLogger()
+
+# Create a session
+session = Streamlink()
+
+# Create a plugin instance
+url = "https://www.tiktok.com/@username/live"
+
+# Let's examine the TikTok plugin code directly
+print("Analyzing the TikTok plugin issue:")
+print("1. The plugin tries to extract the room ID from two possible sources:")
+print("   - Meta tag with property 'al:android:url'")
+print("   - JSON data in a script tag with ID 'SIGI_STATE'")
+print("2. According to the PR description, the roomId property is now empty")
+print("3. The plugin fails with 'Could not find room ID' when both sources return empty values")
+
+print("\nPossible solutions:")
+print("1. Look for alternative sources of the room ID in the HTML")
+print("2. Check if there are other properties in the SIGI_STATE that could be used")
+print("3. Investigate if there are other API endpoints that could provide the room ID")
+
+# Let's simulate the current behavior with empty roomId
+print("\nSimulating the current behavior with empty roomId:")
+with patch.object(TikTok, '_get_streams') as mock_get_streams:
+    mock_get_streams.side_effect = lambda: (print("Could not find room ID") or None)
+    plugin = TikTok(session, url)
+    streams = plugin.streams()
+    print(f"Result: {streams}")
+
+print("\nThe issue is confirmed: when roomId is empty, the plugin fails to find streams.")
