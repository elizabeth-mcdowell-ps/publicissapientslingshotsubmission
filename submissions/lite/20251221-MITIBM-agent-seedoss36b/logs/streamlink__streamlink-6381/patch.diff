+import sys
+import os
+import re
+import json
+import logging
+from urllib.request import Request, urlopen
+from html.parser import HTMLParser
+
+# Set up logging
+logging.basicConfig(level=logging.INFO)
+logger = logging.getLogger()
+
+class TikTokHTMLParser(HTMLParser):
+    def __init__(self):
+        super().__init__()
+        self.sigi_state = None
+        self.meta_room_id = None
+        self.in_sigi_state = False
+        self.current_data = ""
+        
+    def handle_starttag(self, tag, attrs):
+        attrs_dict = dict(attrs)
+        
+        # Look for meta tag with room_id
+        if tag == "meta" and attrs_dict.get("property") == "al:android:url":
+            content = attrs_dict.get("content", "")
+            room_id_match = re.search(r"room_id=(\d+)", content)
+            if room_id_match:
+                self.meta_room_id = room_id_match.group(1)
+            else:
+                logger.info(f"Meta tag found but no room_id: {content}")
+        
+        # Look for SIGI_STATE script
+        if tag == "script" and attrs_dict.get("id") == "SIGI_STATE":
+            self.in_sigi_state = True
+            self.current_data = ""
+    
+    def handle_data(self, data):
+        if self.in_sigi_state:
+            self.current_data += data
+    
+    def handle_endtag(self, tag):
+        if tag == "script" and self.in_sigi_state:
+            self.in_sigi_state = False
+            try:
+                self.sigi_state = json.loads(self.current_data)
+            except json.JSONDecodeError:
+                logger.error("Failed to parse SIGI_STATE JSON")
+
+def fetch_tiktok_live(username):
+    url = f"https://www.tiktok.com/@{username}/live"
+    
+    # Use a browser-like User-Agent to avoid being blocked
+    headers = {
+        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
+    }
+    
+    try:
+        req = Request(url, headers=headers)
+        with urlopen(req) as response:
+            html = response.read().decode('utf-8')
+            
+        parser = TikTokHTMLParser()
+        parser.feed(html)
+        
+        logger.info(f"Meta tag room_id: {parser.meta_room_id}")
+        
+        if parser.sigi_state:
+            # Check the original path for roomId
+            try:
+                room_id = parser.sigi_state["LiveRoom"]["liveRoomUserInfo"]["user"]["roomId"]
+                logger.info(f"SIGI_STATE roomId: {room_id}")
+            except (KeyError, TypeError):
+                logger.info("SIGI_STATE roomId path not found")
+            
+            # Explore SIGI_STATE for alternative room ID sources
+            logger.info("Exploring SIGI_STATE for alternative room ID sources:")
+            explore_json(parser.sigi_state, "")
+            
+    except Exception as e:
+        logger.error(f"Error fetching TikTok live: {e}")
+
+def explore_json(obj, path, max_depth=5, current_depth=0):
+    """Recursively explore JSON to find potential room ID fields"""
+    if current_depth >= max_depth:
+        return
+    
+    if isinstance(obj, dict):
+        for key, value in obj.items():
+            new_path = f"{path}.{key}" if path else key
+            
+            # Look for fields that might contain room IDs
+            if isinstance(value, (str, int)) and any(id_key in key.lower() for id_key in ["id", "room"]):
+                logger.info(f"Potential ID field: {new_path} = {value}")
+            
+            explore_json(value, new_path, max_depth, current_depth + 1)
+    
+    elif isinstance(obj, list) and len(obj) > 0:
+        # Only explore the first item in lists to avoid too much output
+        explore_json(obj[0], f"{path}[0]", max_depth, current_depth + 1)
+
+if __name__ == "__main__":
+    if len(sys.argv) > 1:
+        username = sys.argv[1]
+    else:
+        username = "tiktok"  # Default username
+    
+    logger.info(f"Investigating TikTok live for @{username}")
+    fetch_tiktok_live(username)
