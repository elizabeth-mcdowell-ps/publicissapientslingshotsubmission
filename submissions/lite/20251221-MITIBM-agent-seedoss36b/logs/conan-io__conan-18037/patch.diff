+#!/usr/bin/env python3
+
+import os
+import json
+from conan.api.model import MultiPackagesList
+from conan.errors import ConanException
+
+# Create a simple graph.json file
+graph_json = {
+    "graph": {
+        "nodes": {
+            "0": {
+                "ref": "hello/1.0",
+                "recipe": "Cache",
+                "context": "host",
+                "remote": "conancenter",
+                "package_id": "abcdef123456",
+                "prev": "0",
+                "prev_timestamp": "2023-01-01T12:00:00Z",
+                "rrev_timestamp": "2023-01-01T12:00:00Z",
+                "binary": "Cache",
+                "binary_remote": "conancenter",
+                "info": {}
+            }
+        }
+    }
+}
+
+# Create a simple package list file
+pkglist_json = {
+    "Local Cache": {
+        "hello/1.0": {
+            "revisions": {
+                "123456": {
+                    "timestamp": "2023-01-01T12:00:00Z",
+                    "packages": {
+                        "abcdef123456": {
+                            "revisions": {
+                                "0": {
+                                    "timestamp": "2023-01-01T12:00:00Z"
+                                }
+                            }
+                        }
+                    }
+                }
+            }
+        }
+    }
+}
+
+# Write the files
+with open("graph.json", "w") as f:
+    json.dump(graph_json, f)
+
+with open("pkglist.json", "w") as f:
+    json.dump(pkglist_json, f)
+
+print("Testing error messages when loading wrong JSON file types...")
+
+# Try to load graph.json as a package list
+try:
+    print("\nTrying to load graph.json as a package list:")
+    multi_pkglist = MultiPackagesList.load("graph.json")
+    print("  Success (this should not happen)")
+except ConanException as e:
+    print(f"  Error: {e}")
+
+# Try to load pkglist.json using the graph loader
+try:
+    print("\nTrying to load pkglist.json as a graph:")
+    multi_pkglist = MultiPackagesList.load_graph("pkglist.json")
+    print("  Success (this should not happen)")
+except ConanException as e:
+    print(f"  Error: {e}")
+
+print("\nTest completed.")
