@@ -0,0 +1,53 @@
+import os
+import sys
+import tempfile
+
+# Add the testbed directory to the Python path
+sys.path.insert(0, '/testbed')
+
+from conan.tools.google import Bazel
+
+# Mock ConanFile class for testing
+class MockConanFile:
+    def __init__(self):
+        self.generators_folder = tempfile.mkdtemp()
+        self.conf = MockConf()
+    
+    def run(self, command):
+        print(f"Running command: {command}")
+        # Simulate the error message
+        if "bazel clean" in command and not "--bazelrc" in command:
+            print("WARNING: Running Bazel server needs to be killed, because the startup options are different.")
+            print("WARNING: Waiting for server process to terminate (waited 5 seconds, waiting at most 60)")
+
+class MockConf:
+    def __init__(self):
+        self._conf = {
+            "tools.google.bazel:bazelrc_path": ["/tmp/test.bazelrc"]
+        }
+    
+    def get(self, key, default=None, check_type=None):
+        if key in self._conf:
+            return self._conf[key]
+        return default
+
+# Create a .bazelrc file with startup options
+with open("/tmp/test.bazelrc", "w") as f:
+    f.write("startup --host_jvm_args=-Djavax.net.ssl.trustStore=/etc/ssl/certs/java/cacerts")
+
+# Create a mock ConanFile
+conanfile = MockConanFile()
+
+# Create a Bazel instance
+bazel = Bazel(conanfile)
+
+# Call the build method with clean=True
+print("Testing build method with fixed implementation:")
+bazel.build(target="//my_folder/mylib:mylib", clean=True)
+
+# Call the test method
+print("\nTesting test method with fixed implementation:")
+bazel.test(target="//my_folder/mylib:mylib_test")
+
+# Clean up
+os.remove("/tmp/test.bazelrc")
