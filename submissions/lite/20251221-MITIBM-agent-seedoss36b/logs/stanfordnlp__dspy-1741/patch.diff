diff --git a/minimal_test.py b/minimal_test.py
new file mode 100644
index 00000000..7360e5ac
--- /dev/null
+++ b/minimal_test.py
@@ -0,0 +1,44 @@
+import os
+import tempfile
+import sys
+sys.path.append('/testbed')
+
+from dspy.primitives.module import BaseModule
+
+# Create a simple subclass of BaseModule for testing
+class TestModule(BaseModule):
+    def __init__(self, value=None):
+        super().__init__()
+        self.value = value
+    
+    def dump_state(self, save_verbose):
+        return {"value": self.value}
+    
+    def load_state(self, state, use_legacy_loading=False):
+        self.value = state["value"]
+
+# Create a temporary file
+temp_file = tempfile.NamedTemporaryFile(delete=False)
+temp_path = temp_file.name
+temp_file.close()
+
+# Create and save a module
+module = TestModule(value="test")
+module.save(temp_path)
+
+# Current behavior (two lines)
+print("Current behavior:")
+module1 = TestModule()
+module1.load(temp_path)
+print(f"Module loaded: {module1.value}")
+
+# Desired behavior (one line, but currently not supported)
+print("\nDesired behavior (will fail):")
+try:
+    module2 = TestModule().load(temp_path, return_self=True)
+    print(f"Module loaded: {module2.value}")
+except TypeError as e:
+    print(f"Error: {e}")
+
+# Clean up
+os.unlink(temp_path)
