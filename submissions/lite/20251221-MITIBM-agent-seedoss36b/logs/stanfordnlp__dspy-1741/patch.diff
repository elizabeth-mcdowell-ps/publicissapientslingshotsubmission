+import os
+import tempfile
+import dspy
+
+# Create a temporary file to save the predictor
+temp_file = tempfile.NamedTemporaryFile(delete=False)
+temp_path = temp_file.name
+temp_file.close()
+
+# Create and save a predictor
+predictor = dspy.Predict("question -> answer")
+predictor.save(temp_path)
+
+# Current behavior (two lines)
+print("Current behavior:")
+predictor1 = dspy.Predict("question -> answer")
+predictor1.load(temp_path)
+print(f"Predictor loaded: {predictor1}")
+
+# Desired behavior (one line, but currently not supported)
+print("\nDesired behavior (will fail):")
+try:
+    predictor2 = dspy.Predict("question -> answer").load(temp_path, return_self=True)
+    print(f"Predictor loaded: {predictor2}")
+except TypeError as e:
+    print(f"Error: {e}")
+
+# Clean up
+os.unlink(temp_path)
