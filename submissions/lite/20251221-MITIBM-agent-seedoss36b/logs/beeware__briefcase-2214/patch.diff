@@ -0,0 +1,60 @@
+#!/usr/bin/env python3
+import sys
+import argparse
+from briefcase.console import Console
+
+def main():
+    console = Console()
+    
+    # Test build command with multiple app names
+    print("Testing build command with multiple app names...")
+    try:
+        # Create a parser and add options
+        parser = argparse.ArgumentParser()
+        parser.add_argument(
+            "-a",
+            "--app",
+            dest="app_names",
+            action="append",
+            help="Name of the app to build (specify multiple times to build multiple apps)",
+        )
+        
+        # Parse arguments
+        args = parser.parse_args(["-a", "app1", "-a", "app2"])
+        
+        # Check if app_names is a list with the correct values
+        if hasattr(args, "app_names") and isinstance(args.app_names, list) and set(args.app_names) == {"app1", "app2"}:
+            print("✅ Build command correctly handles multiple app names")
+            print(f"app_names: {args.app_names}")
+        else:
+            print(f"❌ Build command failed to handle multiple app names: {getattr(args, 'app_names', None)}")
+    except Exception as e:
+        print(f"❌ Error testing build command: {e}")
+    
+    # Test package command with multiple app names
+    print("\nTesting package command with multiple app names...")
+    try:
+        # Create a parser and add options
+        parser = argparse.ArgumentParser()
+        parser.add_argument(
+            "-a",
+            "--app",
+            dest="app_names",
+            action="append",
+            help="Name of the app to package (specify multiple times to package multiple apps)",
+        )
+        
+        # Parse arguments
+        args = parser.parse_args(["-a", "app1", "-a", "app2"])
+        
+        # Check if app_names is a list with the correct values
+        if hasattr(args, "app_names") and isinstance(args.app_names, list) and set(args.app_names) == {"app1", "app2"}:
+            print("✅ Package command correctly handles multiple app names")
+            print(f"app_names: {args.app_names}")
+        else:
+            print(f"❌ Package command failed to handle multiple app names: {getattr(args, 'app_names', None)}")
+    except Exception as e:
+        print(f"❌ Error testing package command: {e}")
+
+if __name__ == "__main__":
+    main()
