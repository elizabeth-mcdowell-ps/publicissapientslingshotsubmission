@@ -0,0 +1,31 @@
+from IPython.core.completer import IPCompleter, CompletionContext
+
+# Create a completer
+completer = IPCompleter()
+
+# Set up a test environment
+completer.namespace = {
+    'math': __import__('math'),
+    'long_variable_name': 56
+}
+
+# Create a context with a dot in the line
+context_with_dot = CompletionContext(
+    full_text="x = math.sin(lo)",
+    cursor_position=13,
+    cursor_line=0,
+    token="lo",
+    limit=None
+)
+
+# Test the python_matcher directly
+result = completer.python_matcher(context_with_dot)
+print("Python matcher result with dot in line:")
+print(f"  Completions: {[c['text'] for c in result['completions']]}")
+print(f"  Suppress: {result['suppress']}")
+
+# Check if 'long_variable_name' is in the completions
+if any('long_variable_name' in c['text'] for c in result['completions']):
+    print("SUCCESS: 'long_variable_name' is in the completions")
+else:
+    print("FAILURE: 'long_variable_name' is NOT in the completions")
