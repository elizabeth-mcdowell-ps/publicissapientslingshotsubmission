+import os
+os.environ["KERAS_BACKEND"] = "tensorflow"
+import keras
+import numpy as np
+
+# Create test data
+x = np.ones((10, 4))
+y = np.ones((10, 1))
+
+# Create a simple model
+input = keras.Input(shape=[4])
+output = keras.layers.Dense(1, activation='relu')(input)
+
+model = keras.Model(inputs=input,
+                    outputs=output)
+
+# Compile with steps_per_execution larger than the training set
+model.compile(
+    loss="mse",
+    optimizer="adam",
+    steps_per_execution=20,  # This is larger than the number of batches (5 with batch_size=2)
+)
+
+# Train the model
+epochs = 2
+history = model.fit(
+    x=x,
+    y=y,
+    batch_size=2,
+    epochs=epochs,
+    verbose=0,
+)
+print(f"History: {history.history}")
