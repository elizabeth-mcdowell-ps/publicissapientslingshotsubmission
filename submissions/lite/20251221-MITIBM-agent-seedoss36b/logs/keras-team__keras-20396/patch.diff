+import os
+os.environ["KERAS_BACKEND"] = "tensorflow"
+import keras
+import tensorflow as tf
+
+# Create test data
+x = tf.random.normal((1000, 10))
+y = tf.random.uniform((1000,), maxval=2, dtype=tf.int32)
+
+# Create a tf.data.Dataset
+dataset = tf.data.Dataset.from_tensor_slices((x, y))
+dataset = dataset.shuffle(1000).batch(32)
+
+# Create a simple model
+model = keras.Sequential([
+    keras.layers.Dense(64, activation='relu', input_shape=(10,)),
+    keras.layers.Dense(1, activation='sigmoid')
+])
+
+# Compile the model with steps_per_execution > 32
+model.compile(optimizer='adam',
+              loss='binary_crossentropy',
+              metrics=['accuracy'])
+
+# Set steps_per_execution to 33 (greater than 32)
+model.compile(steps_per_execution=33)
+
+# Try to fit the model
+try:
+    history = model.fit(dataset, epochs=5)
+    print("Training succeeded!")
+    print(f"History: {history.history}")
+except Exception as e:
+    print(f"Training failed with error: {e}")
