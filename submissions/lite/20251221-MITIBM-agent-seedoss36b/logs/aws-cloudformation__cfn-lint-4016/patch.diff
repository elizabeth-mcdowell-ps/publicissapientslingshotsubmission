+#!/usr/bin/env python
+
+import sys
+import json
+from pathlib import Path
+
+# Add the src directory to the Python path
+sys.path.insert(0, str(Path(__file__).parent / 'src'))
+
+from cfnlint.helpers import load_resource
+from cfnlint.jsonschema import CfnTemplateValidator
+from cfnlint.rules.resources.iam.IdentityPolicy import IdentityPolicy
+
+def test_policy_schema():
+    # Load the policy schema
+    policy_schema = load_resource("cfnlint.data.schemas.other.iam", "policy.json")
+    print("Loaded policy schema")
+    
+    # Create a policy with an invalid Sid (contains spaces)
+    invalid_policy = {
+        "Version": "2012-10-17",
+        "Statement": [
+            {
+                "Sid": "Allow use of KMS key in Operations Production Account",
+                "Effect": "Allow",
+                "Resource": "arn:aws:kms::123123123123:key/*",
+                "Action": [
+                    "kms:Encrypt",
+                    "kms:Decrypt",
+                    "kms:ReEncrypt*",
+                    "kms:GenerateDataKey*",
+                    "kms:DescribeKey"
+                ]
+            }
+        ]
+    }
+    
+    # Create a policy with a valid Sid (alphanumeric only)
+    valid_policy = {
+        "Version": "2012-10-17",
+        "Statement": [
+            {
+                "Sid": "AllowUseOfKMSKeyInOperationsProductionAccount",
+                "Effect": "Allow",
+                "Resource": "arn:aws:kms::123123123123:key/*",
+                "Action": [
+                    "kms:Encrypt",
+                    "kms:Decrypt",
+                    "kms:ReEncrypt*",
+                    "kms:GenerateDataKey*",
+                    "kms:DescribeKey"
+                ]
+            }
+        ]
+    }
+    
+    # Check if the Sid pattern is in the schema
+    sid_schema = policy_schema["definitions"]["Statement"]["properties"]["Sid"]
+    print(f"Sid schema: {json.dumps(sid_schema, indent=2)}")
+    
+    # Create a validator
+    validator = CfnTemplateValidator()
+    
+    # Create the rule
+    rule = IdentityPolicy()
+    
+    # Test invalid policy
+    print("\nTesting invalid policy (Sid with spaces):")
+    errors = list(rule.validate(validator=validator, policy=invalid_policy, schema={}, policy_type=None))
+    if errors:
+        print(f"Found {len(errors)} errors:")
+        for error in errors:
+            print(f"  - {error}")
+    else:
+        print("No errors found - this is a bug!")
+    
+    # Test valid policy
+    print("\nTesting valid policy (alphanumeric Sid):")
+    errors = list(rule.validate(validator=validator, policy=valid_policy, schema={}, policy_type=None))
+    if errors:
+        print(f"Found {len(errors)} errors:")
+        for error in errors:
+            print(f"  - {error}")
+    else:
+        print("No errors found - this is correct!")
+
+if __name__ == "__main__":
+    test_policy_schema()
