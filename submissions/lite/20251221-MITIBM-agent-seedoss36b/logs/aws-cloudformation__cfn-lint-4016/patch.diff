+#!/usr/bin/env python
+
+import sys
+import json
+import re
+from pathlib import Path
+
+# Add the src directory to the Python path
+sys.path.insert(0, str(Path(__file__).parent / 'src'))
+
+from cfnlint.helpers import load_resource
+
+def test_sid_pattern():
+    # Load the policy schema
+    policy_schema = load_resource("cfnlint.data.schemas.other.iam", "policy.json")
+    
+    # Extract the Sid pattern from the schema
+    sid_schema = policy_schema["definitions"]["Statement"]["properties"]["Sid"]
+    sid_pattern = sid_schema.get("pattern", "")
+    
+    print(f"Sid pattern in schema: {sid_pattern}")
+    
+    # Test the pattern against valid and invalid Sids
+    valid_sid = "AllowUseOfKMSKeyInOperationsProductionAccount"
+    invalid_sid = "Allow use of KMS key in Operations Production Account"
+    
+    # Compile the pattern
+    pattern = re.compile(sid_pattern)
+    
+    # Test valid Sid
+    valid_match = pattern.match(valid_sid)
+    print(f"\nValid Sid '{valid_sid}' matches pattern: {valid_match is not None}")
+    
+    # Test invalid Sid
+    invalid_match = pattern.match(invalid_sid)
+    print(f"Invalid Sid '{invalid_sid}' matches pattern: {invalid_match is not None}")
+    
+    # Verify that our pattern works as expected
+    if valid_match and not invalid_match:
+        print("\n✅ Pattern works correctly!")
+    else:
+        print("\n❌ Pattern does not work as expected!")
+
+if __name__ == "__main__":
+    test_sid_pattern()
