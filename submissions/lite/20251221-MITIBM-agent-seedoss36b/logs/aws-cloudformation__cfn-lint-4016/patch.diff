+#!/usr/bin/env python
+
+import sys
+import os
+import json
+from pathlib import Path
+
+# Add the src directory to the Python path
+sys.path.insert(0, str(Path(__file__).parent / 'src'))
+
+from cfnlint import api
+from cfnlint.config import ConfigMixIn
+from cfnlint.template import Template
+from cfnlint.rules import RulesCollection
+from cfnlint.rules.resources.iam.IdentityPolicy import IdentityPolicy
+
+def test_template(sid_value, expected_error=False):
+    # Create a sample CloudFormation template with the given Sid
+    template_dict = {
+        "Resources": {
+            "ManagedPolicyCodeSuiteKmsKey": {
+                "Type": "AWS::IAM::ManagedPolicy",
+                "Properties": {
+                    "PolicyDocument": {
+                        "Version": "2012-10-17",
+                        "Statement": [
+                            {
+                                "Sid": sid_value,
+                                "Effect": "Allow",
+                                "Resource": "arn:aws:kms::123123123123:key/*",
+                                "Action": [
+                                    "kms:Encrypt",
+                                    "kms:Decrypt",
+                                    "kms:ReEncrypt*",
+                                    "kms:GenerateDataKey*",
+                                    "kms:DescribeKey"
+                                ]
+                            }
+                        ]
+                    }
+                }
+            }
+        }
+    }
+
+    # Write the template to a temporary file
+    template_file = '/tmp/test_template.json'
+    with open(template_file, 'w') as f:
+        json.dump(template_dict, f, indent=2)
+
+    # Run cfn-lint on the template
+    print(f"Running cfn-lint on template with Sid: '{sid_value}'")
+    
+    # Use the lower-level API to get more control
+    config = ConfigMixIn()
+    config.template_args = {}
+    
+    template = Template(template_file, config.template_args)
+    
+    # Create a rules collection with just the IdentityPolicy rule
+    rules = RulesCollection()
+    rules.register(IdentityPolicy())
+    
+    # Run the rules
+    matches = []
+    for rule in rules:
+        matches.extend(rule.matchall(template))
+
+    # Check if there are any matches related to the Sid field
+    sid_matches = [m for m in matches if 'Sid' in str(m)]
+    if sid_matches:
+        print(f"Found {len(sid_matches)} issues with Sid field:")
+        for match in sid_matches:
+            print(f"  - {match}")
+        if expected_error:
+            print("✅ Test passed: Error detected as expected")
+        else:
+            print("❌ Test failed: Error detected but none expected")
+    else:
+        if expected_error:
+            print("❌ Test failed: No error detected but one was expected")
+        else:
+            print("✅ Test passed: No error detected as expected")
+
+    # Clean up
+    os.remove(template_file)
+    return sid_matches
+
+# Test with invalid Sid (contains spaces)
+print("\n=== Testing with invalid Sid (contains spaces) ===")
+invalid_matches = test_template("Allow use of KMS key in Operations Production Account", expected_error=True)
+
+# Test with valid Sid (alphanumeric only)
+print("\n=== Testing with valid Sid (alphanumeric only) ===")
+valid_matches = test_template("AllowUseOfKMSKeyInOperationsProductionAccount", expected_error=False)
+
+# Summary
+print("\n=== Summary ===")
+if invalid_matches and not valid_matches:
+    print("✅ Fix successful! Invalid Sid is now detected, valid Sid passes.")
+else:
+    print("❌ Fix incomplete. Please check the implementation.")
