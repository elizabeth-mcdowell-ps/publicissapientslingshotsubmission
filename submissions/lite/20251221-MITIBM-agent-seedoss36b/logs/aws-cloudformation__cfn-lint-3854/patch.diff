+#!/usr/bin/env python
+
+import os
+import sys
+import json
+import subprocess
+
+# Create the template file from the PR description
+template_content = """
+%YAML 1.2
+---
+AWSTemplateFormatVersion: 2010-09-09
+Mappings:
+  BucketMap:
+    BucketGroup1:
+      BucketNames:
+        - Bucket1
+        - Bucket2
+    BucketGroup2:
+      BucketNames:
+        - Bucket3
+Conditions:
+  ShouldCreateBucket1: !Equals
+    - !Ref AWS::AccountId
+    - 123456789012
+  ShouldCreateBucket2: !Equals
+    - !Ref AWS::AccountId
+    - 234567890123
+  ShouldCreateBucket3: !Equals
+    - !Ref AWS::AccountId
+    - 345678901234
+Transform: AWS::LanguageExtensions
+Resources:
+  Fn::ForEach::BucketGroupNames:
+    - BucketGroupName
+    - - BucketGroup1
+      - BucketGroup2
+    - Fn::ForEach::BucketNames:
+        - BucketName
+        - !FindInMap
+          - BucketMap
+          - !Ref BucketGroupName
+          - BucketNames
+        - ${BucketGroupName}${BucketName}:
+            Type: AWS::S3::Bucket
+            Condition: !Sub ShouldCreate${BucketName}
+"""
+
+# Write the template to a file
+with open('template.yaml', 'w') as f:
+    f.write(template_content)
+
+# Run cfn-lint using the command line
+cmd = [
+    "python", "-m", "cfnlint.cli",
+    "--format", "json",
+    "--regions", "us-east-2",
+    "--include-checks", "W",
+    "template.yaml"
+]
+
+try:
+    result = subprocess.run(cmd, capture_output=True, text=True)
+    print(f"Return code: {result.returncode}")
+    
+    if result.stdout:
+        try:
+            matches = json.loads(result.stdout)
+            print(f"Total matches: {len(matches)}")
+            for match in matches:
+                if match.get('Rule', {}).get('Id') == "W8001":
+                    print(f"Found W8001 warning: {match.get('Message')} at {match.get('Location', {}).get('Path')}")
+        except json.JSONDecodeError:
+            print("Failed to parse JSON output")
+            print(f"Output: {result.stdout}")
+    else:
+        print(f"Error: {result.stderr}")
+except Exception as e:
+    print(f"Exception: {e}")
+    
+# Let's also try using the Python API directly
+import cfnlint
+from cfnlint.rules import RulesCollection
+import cfnlint.decode
+import cfnlint.config
+from cfnlint.template import Template
+
+try:
+    # Parse the template
+    template_filename = 'template.yaml'
+    template_obj = cfnlint.decode.decode(template_filename)
+    
+    # Create a template object
+    template = Template(template_filename, template_obj.get('template'), ['us-east-2'])
+    
+    # Get the rules
+    rules = RulesCollection()
+    rules.register(cfnlint.rules.conditions.Used.Used())
+    
+    # Run the rules
+    matches = []
+    for rule in rules:
+        matches.extend(rule.matchall(template))
+    
+    # Print the results
+    print("\nDirect API results:")
+    print(f"Total matches: {len(matches)}")
+    for match in matches:
+        if match.rule.id == "W8001":
+            print(f"Found W8001 warning: {match.message} at {match.path}")
+except Exception as e:
+    print(f"API Exception: {e}")
