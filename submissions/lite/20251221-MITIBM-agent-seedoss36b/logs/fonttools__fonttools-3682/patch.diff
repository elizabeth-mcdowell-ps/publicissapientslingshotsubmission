+#!/usr/bin/env python3
+from fontTools import ttLib
+import sys
+import os
+import tempfile
+
+# This script simulates the example from the PR description
+# We'll use one of our test fonts since we don't have the IBM Plex Sans font
+
+test_fonts = [
+    "/testbed/Tests/cffLib/data/LinLibertine_RBI.otf",  # This is a larger font with more glyphs
+]
+
+for font_path in test_fonts:
+    if not os.path.exists(font_path):
+        continue
+        
+    print(f"Testing with font: {font_path}")
+    
+    # Load the font
+    font = ttLib.TTFont(font_path)
+    
+    # Check if it's a CFF font
+    if "CFF " not in font:
+        print("This is not a CFF font. Skipping test.")
+        continue
+    
+    # Get the original glyph order
+    glyph_order = font.getGlyphOrder()
+    print(f"Original glyph order length: {len(glyph_order)}")
+    
+    # Sort the glyphs alphabetically (as in the PR example)
+    new_glyph_order = sorted(glyph_order)
+    
+    # Reorder glyphs using our fixed function
+    from fontTools.ttLib.reorderGlyphs import reorderGlyphs
+    reorderGlyphs(font, new_glyph_order)
+    
+    # Save the reordered font to a temporary file
+    with tempfile.NamedTemporaryFile(suffix=".otf", delete=False) as tmp:
+        tmp_path = tmp.name
+    
+    font.save(tmp_path)
+    print(f"Saved reordered font to: {tmp_path}")
+    
+    # Try to load the reordered font to see if it's valid
+    try:
+        reloaded_font = ttLib.TTFont(tmp_path)
+        print("Successfully reloaded the reordered font.")
+        
+        # Check if the charset and CharStrings in the reloaded font match the new glyph order
+        reloaded_glyph_order = reloaded_font.getGlyphOrder()
+        reloaded_charset = reloaded_font["CFF "].cff.topDictIndex[0].charset
+        reloaded_charstrings = reloaded_font["CFF "].cff.topDictIndex[0].CharStrings.charStrings
+        
+        # Check if all three are in sync
+        charset_matches_glyphorder = (reloaded_charset == reloaded_glyph_order)
+        charstrings_keys_match_glyphorder = (list(reloaded_charstrings.keys()) == reloaded_glyph_order)
+        
+        print(f"Charset matches glyph order: {charset_matches_glyphorder}")
+        print(f"CharStrings keys match glyph order: {charstrings_keys_match_glyphorder}")
+        
+        # Verify that .notdef is the first glyph
+        print(f"First glyph in new order: {reloaded_glyph_order[0]}")
+        
+        # Clean up
+        os.unlink(tmp_path)
+        
+    except Exception as e:
+        print(f"Error loading the reordered font: {e}")
+        # Clean up
+        os.unlink(tmp_path)
+        sys.exit(1)
+
+print("Test completed successfully!")
