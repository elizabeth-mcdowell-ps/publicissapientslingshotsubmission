+#!/usr/bin/env python3
+from fontTools import ttLib
+import sys
+import os
+import tempfile
+
+def test_reorder_glyphs(font_path):
+    print(f"Testing with font: {font_path}")
+    
+    # Load the font
+    font = ttLib.TTFont(font_path)
+    
+    # Check if it's a CFF font
+    if "CFF " not in font:
+        print("This is not a CFF font. Skipping test.")
+        return False
+    
+    # Get the original glyph order
+    original_glyph_order = font.getGlyphOrder()
+    print(f"Original glyph order length: {len(original_glyph_order)}")
+    
+    # Get the original charset from CFF table
+    cff_table = font["CFF "]
+    original_charset = cff_table.cff.topDictIndex[0].charset
+    print(f"Original charset length: {len(original_charset) if original_charset else 'None'}")
+    
+    # Get the original CharStrings
+    original_charstrings = cff_table.cff.topDictIndex[0].CharStrings.charStrings
+    print(f"Original CharStrings length: {len(original_charstrings)}")
+    
+    # Create a new glyph order (sorted alphabetically)
+    new_glyph_order = sorted(original_glyph_order)
+    
+    # Reorder glyphs
+    from fontTools.ttLib.reorderGlyphs import reorderGlyphs
+    reorderGlyphs(font, new_glyph_order)
+    
+    # Check if the charset and CharStrings were updated
+    new_charset = cff_table.cff.topDictIndex[0].charset
+    print(f"New charset length: {len(new_charset) if new_charset else 'None'}")
+    
+    new_charstrings = cff_table.cff.topDictIndex[0].CharStrings.charStrings
+    print(f"New CharStrings length: {len(new_charstrings)}")
+    
+    # Verify that .notdef is the first glyph
+    print(f"First glyph in new order: {font.getGlyphOrder()[0]}")
+    
+    # Save the reordered font to a temporary file
+    with tempfile.NamedTemporaryFile(suffix=".otf", delete=False) as tmp:
+        tmp_path = tmp.name
+    
+    font.save(tmp_path)
+    print(f"Saved reordered font to: {tmp_path}")
+    
+    # Try to load the reordered font to see if it's valid
+    try:
+        reloaded_font = ttLib.TTFont(tmp_path)
+        print("Successfully reloaded the reordered font.")
+        
+        # Check if the charset and CharStrings in the reloaded font match the new glyph order
+        reloaded_glyph_order = reloaded_font.getGlyphOrder()
+        reloaded_charset = reloaded_font["CFF "].cff.topDictIndex[0].charset
+        reloaded_charstrings = reloaded_font["CFF "].cff.topDictIndex[0].CharStrings.charStrings
+        
+        # Check if all three are in sync
+        charset_matches_glyphorder = (reloaded_charset == reloaded_glyph_order)
+        charstrings_keys_match_glyphorder = (list(reloaded_charstrings.keys()) == reloaded_glyph_order)
+        
+        print(f"Charset matches glyph order: {charset_matches_glyphorder}")
+        print(f"CharStrings keys match glyph order: {charstrings_keys_match_glyphorder}")
+        
+        success = charset_matches_glyphorder and charstrings_keys_match_glyphorder
+        print(f"Test {'PASSED' if success else 'FAILED'}")
+        
+        # Clean up
+        os.unlink(tmp_path)
+        return success
+        
+    except Exception as e:
+        print(f"Error loading the reordered font: {e}")
+        # Clean up
+        os.unlink(tmp_path)
+        return False
+
+# Test with multiple fonts
+test_fonts = [
+    "/testbed/Tests/ttx/data/TestOTF.otf",
+    "/testbed/Tests/cffLib/data/LinLibertine_RBI.otf",
+    "/testbed/Tests/ttLib/data/IBMPlexSans-Bold.subset.otf"
+]
+
+success = True
+for font_path in test_fonts:
+    if os.path.exists(font_path):
+        print("\n" + "="*50)
+        if not test_reorder_glyphs(font_path):
+            success = False
+        print("="*50)
+
+if success:
+    print("\nAll tests passed!")
+    sys.exit(0)
+else:
+    print("\nSome tests failed!")
+    sys.exit(1)
