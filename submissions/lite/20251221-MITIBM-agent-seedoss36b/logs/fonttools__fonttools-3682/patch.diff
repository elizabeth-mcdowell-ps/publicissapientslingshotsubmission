+#!/usr/bin/env python3
+from fontTools import ttLib
+import sys
+import os
+
+# Check if we have a test font
+test_fonts = [
+    "/testbed/Tests/ttx/data/TestOTF.otf",
+    "/testbed/Tests/cffLib/data/LinLibertine_RBI.otf",
+    "/testbed/Tests/ttLib/data/IBMPlexSans-Bold.subset.otf"
+]
+
+test_font = None
+for font_path in test_fonts:
+    if os.path.exists(font_path):
+        test_font = font_path
+        break
+
+if not test_font:
+    print("No test font found. Please provide a path to a CFF font.")
+    sys.exit(1)
+
+print(f"Using test font: {test_font}")
+
+# Load the font
+font = ttLib.TTFont(test_font)
+
+# Check if it's a CFF font
+if "CFF " not in font:
+    print("This is not a CFF font. Please provide a CFF font.")
+    sys.exit(1)
+
+# Get the original glyph order
+original_glyph_order = font.getGlyphOrder()
+print(f"Original glyph order (first 5): {original_glyph_order[:5]}")
+
+# Get the original charset from CFF table
+cff_table = font["CFF "]
+original_charset = cff_table.cff.topDictIndex[0].charset
+print(f"Original charset (first 5): {original_charset[:5] if original_charset else 'None'}")
+
+# Get the original CharStrings
+original_charstrings = cff_table.cff.topDictIndex[0].CharStrings.charStrings
+print(f"Original CharStrings keys (first 5): {list(original_charstrings.keys())[:5]}")
+
+# Create a new glyph order (sorted alphabetically)
+new_glyph_order = sorted(original_glyph_order)
+print(f"New glyph order (first 5): {new_glyph_order[:5]}")
+
+# Reorder glyphs
+from fontTools.ttLib.reorderGlyphs import reorderGlyphs
+reorderGlyphs(font, new_glyph_order)
+
+# Check if the charset and CharStrings were updated
+new_charset = cff_table.cff.topDictIndex[0].charset
+print(f"New charset (first 5): {new_charset[:5] if new_charset else 'None'}")
+
+new_charstrings = cff_table.cff.topDictIndex[0].CharStrings.charStrings
+print(f"New CharStrings keys (first 5): {list(new_charstrings.keys())[:5]}")
+
+# Save the reordered font
+output_font = test_font.replace(".otf", "-reordered.otf")
+font.save(output_font)
+print(f"Saved reordered font to: {output_font}")
+
+# Try to load the reordered font to see if it's valid
+try:
+    reloaded_font = ttLib.TTFont(output_font)
+    print("Successfully reloaded the reordered font.")
+except Exception as e:
+    print(f"Error loading the reordered font: {e}")
