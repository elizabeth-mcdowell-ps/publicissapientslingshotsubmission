+import os
+import tempfile
+import shutil
+from conan.tools.cmake.cmakedeps.cmakedeps import CMakeDeps
+from conans.model.recipe_ref import RecipeReference
+
+# Mock a conanfile with components that are just strings, not libraries
+class MockConanFile:
+    def __init__(self):
+        self.ref = RecipeReference.loads("curl/7.80.0")
+        self.settings = type('obj', (object,), {
+            'build_type': 'Release',
+            'get_safe': lambda x, y=None: None
+        })
+        self.dependencies = type('obj', (object,), {
+            'host': {},
+            'direct_build': {},
+            'test': {}
+        })
+        self._conan_is_consumer = True
+        self.generators_folder = os.path.join(tempfile.gettempdir(), "curl_test")
+        os.makedirs(self.generators_folder, exist_ok=True)
+        self.output = type('obj', (object,), {
+            'info': lambda x, fg=None: print(f"INFO: {x}"),
+            'warning': lambda x: print(f"WARNING: {x}"),
+            'error': lambda x: print(f"ERROR: {x}"),
+            'verbose': lambda x: print(f"VERBOSE: {x}")
+        })
+        
+        # Create cpp_info with components that are just strings
+        self.cpp_info = type('obj', (object,), {
+            'components': {
+                'SSL': type('obj', (object,), {'get_property': lambda x, y=None, check_type=None: None}),
+                'IDN': type('obj', (object,), {'get_property': lambda x, y=None, check_type=None: None}),
+                'SSPI': type('obj', (object,), {'get_property': lambda x, y=None, check_type=None: None})
+            },
+            'get_sorted_components': lambda: {
+                'SSL': type('obj', (object,), {'get_property': lambda x, y=None, check_type=None: None}),
+                'IDN': type('obj', (object,), {'get_property': lambda x, y=None, check_type=None: None}),
+                'SSPI': type('obj', (object,), {'get_property': lambda x, y=None, check_type=None: None})
+            },
+            'get_property': lambda x, y=None, check_type=None: None,
+            'required_components': [],
+            'aggregated_components': lambda: type('obj', (object,), {'get_property': lambda x, y=None, check_type=None: None})
+        })
+        self.recipe_folder = self.generators_folder
+        self.package_folder = self.generators_folder
+        
+    def get_property(self, prop, check_type=None):
+        return None
+
+print("Testing the fix for CMakeDeps with string components...")
+
+# Create a CMakeDeps instance with check_components_exist=True
+conanfile = MockConanFile()
+cmake_deps = CMakeDeps(conanfile)
+cmake_deps.check_components_exist = True
+
+# Set the string components
+cmake_deps.string_components = ["SSL", "IDN", "SSPI"]
+
+try:
+    # Generate the CMake files
+    content = cmake_deps.content
+    
+    print(f"Generated files: {list(content.keys())}")
+    
+    # Check if the string components are handled correctly in the config file
+    config_file = None
+    for filename, file_content in content.items():
+        print(f"Checking file: {filename}")
+        if "Config.cmake" in filename or "-config.cmake" in filename or "Find" in filename and filename.endswith(".cmake"):
+            config_file = file_content
+            print(f"Found config file: {filename}")
+            break
+    
+    if config_file:
+        # Print part of the config file for debugging
+        print("\nConfig file content (partial):")
+        lines = config_file.split('\n')
+        for i, line in enumerate(lines):
+            if "FIND_COMPONENTS" in line or "STRING_COMPONENT" in line or "String feature" in line:
+                start = max(0, i-5)
+                end = min(len(lines), i+5)
+                print("\n".join(lines[start:end]))
+                break
+        
+        # Check if our string component handling code is in the config file
+        if "set(_IS_STRING_COMPONENT FALSE)" in config_file and "String feature" in config_file:
+            print("\nSUCCESS: The fix for string components is working correctly!")
+            print("The config file now handles both target components and string features.")
+        else:
+            print("\nERROR: The fix for string components is not working correctly.")
+            print("The config file does not contain the expected string component handling code.")
+    else:
+        print("\nERROR: Could not find the config file in the generated content.")
+except Exception as e:
+    print(f"\nERROR: An exception occurred: {e}")
+
+# Clean up
+if os.path.exists(conanfile.generators_folder):
+    shutil.rmtree(conanfile.generators_folder)
