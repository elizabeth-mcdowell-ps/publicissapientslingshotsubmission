@@ -0,0 +1,64 @@
+import os
+import tempfile
+import jinja2
+from jinja2 import Template
+
+# Let's directly test our changes by creating a simplified version of the template
+# This simulates the relevant part of the config.py template
+
+# Create a template with our changes
+template_str = """
+{% if check_components_exist %}
+# Check that the specified components in the find_package(Foo COMPONENTS x y z) are there
+# This is the variable filled by CMake with the requested components in find_package
+if({{ file_name }}_FIND_COMPONENTS)
+    foreach(_FIND_COMPONENT {{ '${' + file_name + '_FIND_COMPONENTS}' }})
+        {% if string_components %}
+        # Check if the component is a string feature (not a target)
+        set(_IS_STRING_COMPONENT FALSE)
+        {% for string_comp in string_components %}
+        if("${_FIND_COMPONENT}" STREQUAL "{{ string_comp }}")
+            set(_IS_STRING_COMPONENT TRUE)
+            message(STATUS "Conan: String feature '${_FIND_COMPONENT}' found in package '{{ pkg_name }}'")
+        endif()
+        {% endfor %}
+        
+        if(NOT _IS_STRING_COMPONENT)
+        {% endif %}
+            if(TARGET ${_FIND_COMPONENT})
+                message(STATUS "Conan: Component '${_FIND_COMPONENT}' found in package '{{ pkg_name }}'")
+            else()
+                message(FATAL_ERROR "Conan: Component '${_FIND_COMPONENT}' NOT found in package '{{ pkg_name }}'")
+            endif()
+        {% if string_components %}
+        endif()
+        {% endif %}
+    endforeach()
+endif()
+{% endif %}
+"""
+
+# Create a template instance
+template = Template(template_str, trim_blocks=True, lstrip_blocks=True, undefined=jinja2.StrictUndefined)
+
+# Render the template with our context
+context = {
+    "check_components_exist": True,
+    "string_components": ["SSL", "IDN", "SSPI"],
+    "file_name": "curl",
+    "pkg_name": "curl"
+}
+
+rendered = template.render(context)
+
+# Check if our string component handling code is in the rendered template
+if "set(_IS_STRING_COMPONENT FALSE)" in rendered and "String feature" in rendered:
+    print("\nSUCCESS: The fix for string components is working correctly!")
+    print("The config file now handles both target components and string features.")
+    
+    # Print the rendered template
+    print("\nRendered template:")
+    print(rendered)
+else:
+    print("\nERROR: The fix for string components is not working correctly.")
+    print("The config file does not contain the expected string component handling code.")
