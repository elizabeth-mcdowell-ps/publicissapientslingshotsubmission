+import os
+import tempfile
+from pathlib import Path
+
+from checkov.terraform.runner import Runner
+from checkov.runner_filter import RunnerFilter
+from checkov.terraform.checks.resource.azure.PostgreSQLFlexiServerGeoBackupEnabled import check
+
+# Create a temporary file with a replica configuration
+tf_content = '''
+resource "azurerm_postgresql_flexible_server" "replica" {
+  name                   = "example-psqlflexibleserver-replica"
+  resource_group_name    = "azurerm_resource_group.example.name"
+  location               = "azurerm_resource_group.example.location"
+  version                = "12"
+  delegated_subnet_id    = "azurerm_subnet.example.id"
+  private_dns_zone_id    = "azurerm_private_dns_zone.example.id"
+  administrator_login    = "psqladmin"
+  administrator_password = "H@Sh1CoR3!"
+  zone                   = "1"
+
+  storage_mb = 32768
+  
+  # This makes the server a replica
+  create_mode      = "Replica"
+  source_server_id = "azurerm_postgresql_flexible_server.primary.id"
+
+  sku_name   = "GP_Standard_D4s_v3"
+  depends_on = ["azurerm_private_dns_zone_virtual_network_link.example"]
+}
+'''
+
+# Create a temporary directory and file
+with tempfile.TemporaryDirectory() as temp_dir:
+    tf_file = Path(temp_dir) / "replica.tf"
+    with open(tf_file, 'w') as f:
+        f.write(tf_content)
+    
+    # Run the check
+    runner = Runner()
+    report = runner.run(
+        root_folder=temp_dir,
+        runner_filter=RunnerFilter(checks=[check.id])
+    )
+    
+    # Print results
+    print(f"Check ID: {check.id}")
+    print(f"Check Name: {check.name}")
+    
+    summary = report.get_summary()
+    print(f"Summary: {summary}")
+    
+    # Show failed checks
+    if report.failed_checks:
+        print("\nFailed Checks:")
+        for failed_check in report.failed_checks:
+            print(f"  - {failed_check.resource}: {failed_check.check_id}")
+            print(f"    Reason: {failed_check.check_result['result']}")
+    else:
+        print("\nNo failed checks.")
+    
+    # Show passed checks
+    if report.passed_checks:
+        print("\nPassed Checks:")
+        for passed_check in report.passed_checks:
+            print(f"  - {passed_check.resource}: {passed_check.check_id}")
+    else:
+        print("\nNo passed checks.")
