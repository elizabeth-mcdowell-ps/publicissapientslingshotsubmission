+import os
+import tempfile
+from pathlib import Path
+
+from checkov.terraform.runner import Runner
+from checkov.runner_filter import RunnerFilter
+from checkov.terraform.checks.resource.azure.PostgreSQLFlexiServerGeoBackupEnabled import check
+
+# Test different edge cases
+test_cases = [
+    {
+        "name": "Standard server with geo backup enabled",
+        "content": '''
+resource "azurerm_postgresql_flexible_server" "standard_with_geo" {
+  name                   = "example-psqlflexibleserver"
+  resource_group_name    = "azurerm_resource_group.example.name"
+  location               = "azurerm_resource_group.example.location"
+  version                = "12"
+  storage_mb             = 32768
+  geo_redundant_backup_enabled = true
+  sku_name               = "GP_Standard_D4s_v3"
+}
+''',
+        "expected_result": "PASSED"
+    },
+    {
+        "name": "Standard server without geo backup",
+        "content": '''
+resource "azurerm_postgresql_flexible_server" "standard_without_geo" {
+  name                   = "example-psqlflexibleserver"
+  resource_group_name    = "azurerm_resource_group.example.name"
+  location               = "azurerm_resource_group.example.location"
+  version                = "12"
+  storage_mb             = 32768
+  geo_redundant_backup_enabled = false
+  sku_name               = "GP_Standard_D4s_v3"
+}
+''',
+        "expected_result": "FAILED"
+    },
+    {
+        "name": "Read replica with lowercase 'replica'",
+        "content": '''
+resource "azurerm_postgresql_flexible_server" "replica_lowercase" {
+  name                   = "example-psqlflexibleserver-replica"
+  resource_group_name    = "azurerm_resource_group.example.name"
+  location               = "azurerm_resource_group.example.location"
+  version                = "12"
+  storage_mb             = 32768
+  create_mode            = "replica"
+  source_server_id       = "azurerm_postgresql_flexible_server.primary.id"
+  sku_name               = "GP_Standard_D4s_v3"
+}
+''',
+        "expected_result": "PASSED"
+    },
+    {
+        "name": "Read replica with uppercase 'REPLICA'",
+        "content": '''
+resource "azurerm_postgresql_flexible_server" "replica_uppercase" {
+  name                   = "example-psqlflexibleserver-replica"
+  resource_group_name    = "azurerm_resource_group.example.name"
+  location               = "azurerm_resource_group.example.location"
+  version                = "12"
+  storage_mb             = 32768
+  create_mode            = "REPLICA"
+  source_server_id       = "azurerm_postgresql_flexible_server.primary.id"
+  sku_name               = "GP_Standard_D4s_v3"
+}
+''',
+        "expected_result": "PASSED"
+    },
+    {
+        "name": "Read replica without geo backup explicitly set",
+        "content": '''
+resource "azurerm_postgresql_flexible_server" "replica_no_geo" {
+  name                   = "example-psqlflexibleserver-replica"
+  resource_group_name    = "azurerm_resource_group.example.name"
+  location               = "azurerm_resource_group.example.location"
+  version                = "12"
+  storage_mb             = 32768
+  create_mode            = "Replica"
+  source_server_id       = "azurerm_postgresql_flexible_server.primary.id"
+  sku_name               = "GP_Standard_D4s_v3"
+}
+''',
+        "expected_result": "PASSED"
+    },
+    {
+        "name": "Read replica with geo backup explicitly set to false",
+        "content": '''
+resource "azurerm_postgresql_flexible_server" "replica_with_geo_false" {
+  name                   = "example-psqlflexibleserver-replica"
+  resource_group_name    = "azurerm_resource_group.example.name"
+  location               = "azurerm_resource_group.example.location"
+  version                = "12"
+  storage_mb             = 32768
+  create_mode            = "Replica"
+  source_server_id       = "azurerm_postgresql_flexible_server.primary.id"
+  geo_redundant_backup_enabled = false
+  sku_name               = "GP_Standard_D4s_v3"
+}
+''',
+        "expected_result": "PASSED"
+    }
+]
+
+# Run tests
+print("Testing edge cases for PostgreSQL Flexible Server Geo Backup check:")
+print("-" * 80)
+
+for i, test_case in enumerate(test_cases, 1):
+    print(f"\nTest {i}: {test_case['name']}")
+    
+    # Create a temporary directory and file
+    with tempfile.TemporaryDirectory() as temp_dir:
+        tf_file = Path(temp_dir) / f"test_{i}.tf"
+        with open(tf_file, 'w') as f:
+            f.write(test_case['content'])
+        
+        # Run the check
+        runner = Runner()
+        report = runner.run(
+            root_folder=temp_dir,
+            runner_filter=RunnerFilter(checks=[check.id])
+        )
+        
+        # Get results
+        summary = report.get_summary()
+        result = "PASSED" if report.passed_checks else "FAILED" if report.failed_checks else "SKIPPED"
+        
+        # Print results
+        print(f"  Expected: {test_case['expected_result']}")
+        print(f"  Actual:   {result}")
+        print(f"  {'✅ PASS' if result == test_case['expected_result'] else '❌ FAIL'}")
+
+print("\nEdge case testing complete.")
