+import pypsa
+import pandas as pd
+
+# Create a simple network to test our fix
+n = pypsa.Network()
+n.add("Bus", "bus1", carrier="AC")
+n.add("Generator", "gen_fixed", bus="bus1", p_nom=100, carrier="gas", active=True)
+n.add("Generator", "gen_extendable", bus="bus1", p_nom=0, p_nom_extendable=True, 
+      p_nom_min=0, p_nom_max=200, carrier="wind", marginal_cost=10, active=True)
+n.generators.p_nom_opt = pd.Series({"gen_fixed": 100, "gen_extendable": 150})
+
+# Before fix
+print("Before fix:")
+stats = n.statistics
+expanded_capacity = stats.expanded_capacity(comps='Generator', groupby=False).fillna(0)
+print("Expanded capacity:", expanded_capacity)
+optimal_capacity = stats.optimal_capacity(comps='Generator', groupby=False).fillna(0)
+print("Optimal capacity:", optimal_capacity)
+
+# Apply the fix
+# The issue is in the _filter_active_assets method in abstract.py
+# We need to modify it to include extendable components
+
+# Original method:
+# def _filter_active_assets(self, n: Network, c: str, obj: Any) -> Any:
+#     """
+#     For static values iterate over periods and concat values.
+#     """
+#     if isinstance(obj, pd.DataFrame) or "snapshot" in getattr(obj, "dims", []):
+#         return obj
+#     idx = self._get_component_index(obj, c)
+#     if not self.is_multi_indexed:
+#         mask = n.get_active_assets(c)
+#         idx = mask.index[mask].intersection(idx)
+#         return obj.loc[idx]
+#
+#     per_period = {}
+#     for p in n.investment_periods:
+#         mask = n.get_active_assets(c, p)
+#         idx = mask.index[mask].intersection(idx)
+#         per_period[p] = obj.loc[idx]
+#
+#     return self._concat_periods(per_period, c)
+
+# Let's patch the method
+def patched_filter_active_assets(self, n, c, obj):
+    """
+    For static values iterate over periods and concat values.
+    """
+    if isinstance(obj, pd.DataFrame) or "snapshot" in getattr(obj, "dims", []):
+        return obj
+    
+    idx = self._get_component_index(obj, c)
+    
+    # Check if this is a component with extendable attribute
+    nominal_attr = pypsa.descriptors.nominal_attrs.get(c)
+    if nominal_attr is not None:
+        extendable_attr = f"{nominal_attr}_extendable"
+        if extendable_attr in n.static(c).columns:
+            # Include both active and extendable components
+            if not self.is_multi_indexed:
+                mask = n.get_active_assets(c)
+                idx = mask.index[mask].intersection(idx)
+                
+                # Also include extendable components
+                extendable_mask = n.static(c)[extendable_attr]
+                extendable_idx = extendable_mask.index[extendable_mask]
+                
+                # Combine both sets of indices
+                idx = idx.union(extendable_idx)
+                
+                return obj.loc[idx]
+    
+    # Default behavior for non-extendable components
+    if not self.is_multi_indexed:
+        mask = n.get_active_assets(c)
+        idx = mask.index[mask].intersection(idx)
+        return obj.loc[idx]
+
+    per_period = {}
+    for p in n.investment_periods:
+        mask = n.get_active_assets(c, p)
+        idx = mask.index[mask].intersection(idx)
+        per_period[p] = obj.loc[idx]
+
+    return self._concat_periods(per_period, c)
+
+# Apply the patch
+pypsa.statistics.abstract.AbstractStatisticsAccessor._filter_active_assets = patched_filter_active_assets
+
+# After fix
+print("\nAfter fix:")
+stats = n.statistics
+expanded_capacity = stats.expanded_capacity(comps='Generator', groupby=False).fillna(0)
+print("Expanded capacity:", expanded_capacity)
+optimal_capacity = stats.optimal_capacity(comps='Generator', groupby=False).fillna(0)
+print("Optimal capacity:", optimal_capacity)
