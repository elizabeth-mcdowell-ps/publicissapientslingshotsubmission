+
+# Let's look at the implementation of the optimal_capacity function
+print("\nLet's debug the optimal_capacity function:")
+print("nominal_attrs['Generator']:", pypsa.descriptors.nominal_attrs["Generator"])
+
+# Let's check what's happening in the func method of optimal_capacity
+print("\nChecking what's happening in the func method of optimal_capacity:")
+c = "Generator"
+for index, row in n.static(c).iterrows():
+    print(f"Generator: {index}")
+    print(f"  p_nom_extendable: {row.p_nom_extendable}")
+    print(f"  p_nom: {row.p_nom}")
+    print(f"  p_nom_opt: {row.p_nom_opt}")
+    
+    # This is what's happening in the func method
+    nominal_attr = pypsa.descriptors.nominal_attrs[c]
+    print(f"  nominal_attr: {nominal_attr}")
+    print(f"  {nominal_attr}_opt: {nominal_attr}_opt")
+    
+    # This is the value that should be used
+    col_value = row[f"{nominal_attr}_opt"]
+    print(f"  col_value: {col_value}")
+    
+# Let's look at the source code of the optimal_capacity function
+print("\nLet's examine the source code of the optimal_capacity function:")
+print("From expressions.py line 460-467:")
+print("""
+@pass_empty_series_if_keyerror
