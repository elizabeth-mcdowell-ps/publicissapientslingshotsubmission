+import random
+from sqllineage.core.models import Column, Table
+
+# Current sorting key from runner.py (before our fix)
+def old_sort_key(x):
+    # Current implementation sorts by target column, then source column
+    return (str(x[-1]), str(x[0]))
+
+# New sorting key (our fix)
+def new_sort_key(x):
+    # Proposed implementation sorts by the entire lineage path
+    return "".join([str(i) for i in reversed(x)])
+
+# Create paths with different lengths
+def create_path(length, prefix):
+    path = []
+    for i in range(length):
+        col = Column(f"col_{prefix}_{i}")
+        col.parent = Table(f"table_{prefix}_{i}")
+        path.append(col)
+    return tuple(path)
+
+# Create a mix of paths with different lengths
+paths = []
+for i in range(5):
+    # Create paths with lengths 2, 3, and 4
+    for length in [2, 3, 4]:
+        paths.append(create_path(length, i))
+
+# Test sorting with both keys
+print("Testing sorting with paths of different lengths:")
+
+# Sort with old key
+sorted_old = sorted(paths, key=old_sort_key)
+print("\nSorted with old key:")
+for path in sorted_old:
+    print(f"  Length: {len(path)}, Path: {path}")
+
+# Sort with new key
+sorted_new = sorted(paths, key=new_sort_key)
+print("\nSorted with new key:")
+for path in sorted_new:
+    print(f"  Length: {len(path)}, Path: {path}")
+
+# Check consistency
+print("\nTesting consistency with multiple shuffles:")
+for i in range(3):
+    print(f"\nTest {i+1}:")
+    
+    # Shuffle the paths
+    random.shuffle(paths)
+    
+    # Sort with new key
+    sorted_new = sorted(paths, key=new_sort_key)
+    new_paths_str = [str(path) for path in sorted_new]
+    
+    # Shuffle again
+    random.shuffle(paths)
+    
+    # Sort with new key again
+    sorted_new_again = sorted(paths, key=new_sort_key)
+    new_paths_str_again = [str(path) for path in sorted_new_again]
+    
+    # Check if the new sorting is consistent
+    if new_paths_str == new_paths_str_again:
+        print("New sorting is consistent!")
+    else:
+        print("New sorting is inconsistent! This should not happen.")
