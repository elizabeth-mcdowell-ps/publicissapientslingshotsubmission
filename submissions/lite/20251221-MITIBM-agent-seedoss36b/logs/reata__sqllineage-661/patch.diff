+import random
+from sqllineage.core.models import Column, Table
+from sqllineage.runner import LineageRunner
+from sqllineage.core.metadata_provider import MetaDataProvider
+from sqllineage.utils.entities import ColumnQualifierTuple
+from tests.helpers import assert_column_lineage_equal, generate_metadata_providers, _assert_column_lineage
+
+# Generate metadata providers
+providers = generate_metadata_providers(
+    {
+        "database_a.table_a": ["col_a", "col_b", "col_c"],
+    }
+)
+
+# SQL query from the PR description
+sql = """CREATE TABLE database_b.table_c
+AS (
+  SELECT
+    *,
+    1 AS event_time
+  FROM (
+    SELECT
+      table_b.col_b AS col_a
+    FROM database_b.table_b AS table_b
+    JOIN database_a.table_a AS table_d
+  ) AS base
+)
+"""
+
+# Expected column lineage from the PR description
+expected_lineage = [
+    (
+        ColumnQualifierTuple("col_b", "database_a.table_a"),
+        ColumnQualifierTuple("col_b", "database_b.table_c"),
+    ),
+    (
+        ColumnQualifierTuple("col_c", "database_a.table_a"),
+        ColumnQualifierTuple("col_c", "database_b.table_c"),
+    ),
+    (
+        ColumnQualifierTuple("col_b", "database_b.table_b"),
+        ColumnQualifierTuple("col_a", "database_b.table_c"),
+    ),
+]
+
+# Let's examine the actual lineage in detail
+provider = providers[0]  # Use the first provider for simplicity
+lr = LineageRunner(sql, dialect="athena", metadata_provider=provider)
+lineage_paths = lr.get_column_lineage()
+
+print("Detailed lineage paths:")
+for path in lineage_paths:
+    print(f"Path: {path}")
+    for node in path:
+        print(f"  Node: {node}, Parent: {node.parent}")
+
+# Convert to the format used in the test
+actual_set = {(lineage[0], lineage[-1]) for lineage in lineage_paths}
+print("\nActual lineage set:")
+for src, tgt in actual_set:
+    print(f"  {src} -> {tgt}")
+
+# Convert expected lineage to the format used in the test
+def convert_to_test_format(lineages):
+    result = set()
+    for src, tgt in lineages:
+        src_col = Column(src.column)
+        if src.qualifier is not None:
+            src_col.parent = Table(src.qualifier)
+        tgt_col = Column(tgt.column)
+        tgt_col.parent = Table(tgt.qualifier)
+        result.add((src_col, tgt_col))
+    return result
+
+expected_set = convert_to_test_format(expected_lineage)
+print("\nExpected lineage set:")
+for src, tgt in expected_set:
+    print(f"  {src} -> {tgt}")
+
+# Run multiple times to verify consistency
+print("\nRunning multiple times to verify consistency:")
+for i in range(3):
+    print(f"\nRun {i+1}:")
+    
+    # Get the column lineage directly
+    lr = LineageRunner(sql, dialect="athena", metadata_provider=provider)
+    lineage_paths = lr.get_column_lineage()
+    
+    # Convert to the same format as in the test
+    actual_set = {(lineage[0], lineage[-1]) for lineage in lineage_paths}
+    
+    # Print the actual lineage
+    print("Actual lineage:")
+    for src, tgt in actual_set:
+        print(f"  {src} -> {tgt}")
+    
+    # Check if the ordering is consistent
+    lineage_list = list(actual_set)
+    print("\nOrdered lineage:")
+    for i, (src, tgt) in enumerate(lineage_list):
+        print(f"  {i+1}: {src} -> {tgt}")
