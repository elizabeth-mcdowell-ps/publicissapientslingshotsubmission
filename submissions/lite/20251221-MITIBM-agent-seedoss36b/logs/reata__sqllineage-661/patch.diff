+import random
+from sqllineage.core.models import Column, Table
+
+# Current sorting key from runner.py
+def current_sort_key(x):
+    # Current implementation sorts by target column, then source column
+    return (str(x[-1]), str(x[0]))
+
+# Proposed sorting key
+def proposed_sort_key(x):
+    # Proposed implementation sorts by the entire lineage path
+    return "".join([str(i) for i in reversed(x)])
+
+# Create paths with same first and last elements but different middle elements
+def create_path(middle_name):
+    path = []
+    col_a = Column("col_a")
+    col_a.parent = Table("table_1")
+    path.append(col_a)
+
+    col_m = Column(middle_name)
+    col_m.parent = Table("table_mid")
+    path.append(col_m)
+
+    col_z = Column("col_z")
+    col_z.parent = Table("table_2")
+    path.append(col_z)
+    
+    return tuple(path)
+
+# Create multiple paths with different middle elements
+paths = [
+    create_path(f"col_m{i}") for i in range(10)
+]
+
+print("Original paths:")
+for i, path in enumerate(paths):
+    print(f"  {i}: {path}")
+
+# Shuffle the paths to simulate non-deterministic behavior
+random.shuffle(paths)
+print("\nShuffled paths:")
+for i, path in enumerate(paths):
+    print(f"  {i}: {path}")
+
+# Sort with current key
+sorted_current = sorted(paths, key=current_sort_key)
+print("\nSorted with current key:")
+for i, path in enumerate(sorted_current):
+    print(f"  {i}: {path}")
+
+# Sort with proposed key
+sorted_proposed = sorted(paths, key=proposed_sort_key)
+print("\nSorted with proposed key:")
+for i, path in enumerate(sorted_proposed):
+    print(f"  {i}: {path}")
+
+# Demonstrate that the current key doesn't differentiate between paths with same first and last elements
+print("\nDemonstrating that current key doesn't differentiate:")
+for i in range(len(paths)):
+    for j in range(i+1, len(paths)):
+        if current_sort_key(paths[i]) == current_sort_key(paths[j]):
+            print(f"  Paths {i} and {j} have the same sort key with current implementation:")
+            print(f"    {paths[i]}")
+            print(f"    {paths[j]}")
+            print(f"    Current key: {current_sort_key(paths[i])}")
+            print(f"    Proposed key would differentiate: {proposed_sort_key(paths[i])} vs {proposed_sort_key(paths[j])}")
