+"""Helper functions for grouping nodes based on namespaces.
+
+This module provides utility functions to help plugin developers implement
+node grouping based on namespaces, making it easier to deploy Kedro pipelines
+to various platforms.
+"""
+
+from __future__ import annotations
+
+from collections import defaultdict
+from typing import TYPE_CHECKING, Dict, List, Optional, Set, Union
+
+if TYPE_CHECKING:
+    from kedro.pipeline import Pipeline
+    from kedro.pipeline.node import Node
+
+
+def group_nodes_by_namespace(
+    pipeline: "Pipeline", namespace_filter: Optional[List[str]] = None
+) -> Dict[Optional[str], List["Node"]]:
+    """Group nodes in a pipeline by their namespace.
+
+    This function helps plugin developers implement node grouping based on namespaces,
+    making it easier to deploy Kedro pipelines to various platforms.
+
+    Args:
+        pipeline: The pipeline containing nodes to be grouped.
+        namespace_filter: Optional list of namespaces to filter by. If provided,
+            only nodes with namespaces in this list will be included in the result.
+
+    Returns:
+        A dictionary mapping namespace names to lists of nodes. Nodes without a
+        namespace are grouped under the key `None`.
+
+    Example:
+        ```python
+        from kedro.pipeline import node, pipeline
+        from kedro.pipeline.grouping import group_nodes_by_namespace
+
+        # Create nodes with namespaces
+        node1 = node(func1, "input1", "output1", namespace="data_processing")
+        node2 = node(func2, "input2", "output2", namespace="data_processing")
+        node3 = node(func3, "input3", "output3", namespace="model_training")
+
+        # Create a pipeline
+        my_pipeline = pipeline([node1, node2, node3])
+
+        # Group nodes by namespace
+        grouped_nodes = group_nodes_by_namespace(my_pipeline)
+        # Result: {
+        #   "data_processing": [node1, node2],
+        #   "model_training": [node3]
+        # }
+
+        # Filter by specific namespaces
+        data_processing_nodes = group_nodes_by_namespace(
+            my_pipeline, namespace_filter=["data_processing"]
+        )
+        # Result: {"data_processing": [node1, node2]}
+        ```
+    """
+    grouped_nodes: Dict[Optional[str], List["Node"]] = defaultdict(list)
+
+    for node in pipeline.nodes:
+        if namespace_filter is None or node.namespace in namespace_filter:
+            grouped_nodes[node.namespace].append(node)
+
+    return dict(grouped_nodes)
+
+
+def get_namespaces(pipeline: "Pipeline") -> Set[Optional[str]]:
+    """Get all unique namespaces used in a pipeline.
+
+    Args:
+        pipeline: The pipeline to extract namespaces from.
+
+    Returns:
+        A set of all unique namespace names used in the pipeline.
+        Nodes without a namespace will result in `None` being included in the set.
+
+    Example:
+        ```python
+        from kedro.pipeline import node, pipeline
+        from kedro.pipeline.grouping import get_namespaces
+
+        # Create nodes with namespaces
+        node1 = node(func1, "input1", "output1", namespace="data_processing")
+        node2 = node(func2, "input2", "output2", namespace="model_training")
+        node3 = node(func3, "input3", "output3")  # No namespace
+
+        # Create a pipeline
+        my_pipeline = pipeline([node1, node2, node3])
+
+        # Get all namespaces
+        namespaces = get_namespaces(my_pipeline)
+        # Result: {"data_processing", "model_training", None}
+        ```
+    """
+    return {node.namespace for node in pipeline.nodes}
+
+
+def get_nodes_in_namespace(
+    pipeline: "Pipeline", namespace: Optional[str]
+) -> List["Node"]:
+    """Get all nodes in a pipeline that belong to a specific namespace.
+
+    Args:
+        pipeline: The pipeline to extract nodes from.
+        namespace: The namespace to filter by. Use `None` to get nodes without a namespace.
+
+    Returns:
+        A list of nodes that belong to the specified namespace.
+
+    Example:
+        ```python
+        from kedro.pipeline import node, pipeline
+        from kedro.pipeline.grouping import get_nodes_in_namespace
+
+        # Create nodes with namespaces
+        node1 = node(func1, "input1", "output1", namespace="data_processing")
+        node2 = node(func2, "input2", "output2", namespace="data_processing")
+        node3 = node(func3, "input3", "output3", namespace="model_training")
+        node4 = node(func4, "input4", "output4")  # No namespace
+
+        # Create a pipeline
+        my_pipeline = pipeline([node1, node2, node3, node4])
+
+        # Get nodes in the "data_processing" namespace
+        data_nodes = get_nodes_in_namespace(my_pipeline, "data_processing")
+        # Result: [node1, node2]
+
+        # Get nodes without a namespace
+        no_namespace_nodes = get_nodes_in_namespace(my_pipeline, None)
+        # Result: [node4]
+        ```
+    """
+    return [node for node in pipeline.nodes if node.namespace == namespace]
