+using Blazorise.Bootstrap5;
+using Blazorise.DataGrid;
+using Blazorise.Tests.bUnit;
+using Bunit;
+using Microsoft.Extensions.DependencyInjection;
+using Employee = BasicTestApp.Client.DataGridGroupingComponent.Employee;
+
+try
+{
+    VerifySingleLevelGroupingHasNoNestedGroups();
+    VerifyTwoLevelGroupingCreatesNestedGroups();
+    VerifyRemovingSecondLevelClearsNestedGroups();
+    Console.WriteLine( "All grouping reproduction checks passed." );
+    return 0;
+}
+catch ( Exception ex )
+{
+    Console.Error.WriteLine( ex.Message );
+    return 1;
+}
+
+static void VerifySingleLevelGroupingHasNoNestedGroups()
+{
+    using TestContext context = CreateContext();
+    var (dataGrid, component, departmentColumn, _) = RenderGrid( context );
+
+    dataGrid.Instance.AddGroupColumn( departmentColumn.Instance );
+    component.Render();
+
+    var grouped = dataGrid.Instance.DisplayGroupedData.ToList();
+    Console.WriteLine( "single-level: " + Describe( grouped ) );
+
+    if ( grouped.Count != 2 || grouped.Any( x => x.NestedGroup is not null ) )
+    {
+        throw new InvalidOperationException( "Single-level grouping should create only top-level groups." );
+    }
+}
+
+static void VerifyTwoLevelGroupingCreatesNestedGroups()
+{
+    using TestContext context = CreateContext();
+    var (dataGrid, component, departmentColumn, nameColumn) = RenderGrid( context );
+
+    dataGrid.Instance.AddGroupColumn( departmentColumn.Instance );
+    dataGrid.Instance.AddGroupColumn( nameColumn.Instance );
+    component.Render();
+
+    var grouped = dataGrid.Instance.DisplayGroupedData.ToList();
+    Console.WriteLine( "two-level: " + Describe( grouped ) );
+
+    if ( grouped.Count != 2 || grouped.Any( x => x.NestedGroup is null ) || grouped.SelectMany( x => x.NestedGroup ).Count() != 4 )
+    {
+        throw new InvalidOperationException( "Expected two top-level groups, each with nested Active/Inactive groups." );
+    }
+}
+
+static void VerifyRemovingSecondLevelClearsNestedGroups()
+{
+    using TestContext context = CreateContext();
+    var (dataGrid, component, departmentColumn, nameColumn) = RenderGrid( context );
+
+    dataGrid.Instance.AddGroupColumn( departmentColumn.Instance );
+    dataGrid.Instance.AddGroupColumn( nameColumn.Instance );
+    dataGrid.Instance.RemoveGroupColumn( nameColumn.Instance );
+    component.Render();
+
+    var grouped = dataGrid.Instance.DisplayGroupedData.ToList();
+    Console.WriteLine( "after-removal: " + Describe( grouped ) );
+
+    if ( grouped.Count != 2 || grouped.Any( x => x.NestedGroup is not null ) )
+    {
+        throw new InvalidOperationException( "Removing the second grouped column should clear nested groups." );
+    }
+}
+
+static TestContext CreateContext()
+{
+    TestContext context = new();
+    context.Services.AddBlazoriseTests().AddBootstrap5Providers().AddEmptyIconProvider().AddMemoryCache();
+    context.JSInterop.AddBlazoriseDataGrid();
+    return context;
+}
+
+static (IRenderedComponent<BasicTestApp.Client.DataGridGroupingComponent> DataGridComponent, IRenderedComponent<BasicTestApp.Client.DataGridGroupingComponent> Component, IRenderedComponent<DataGridColumn<Employee>> DepartmentColumn, IRenderedComponent<DataGridColumn<Employee>> NameColumn) RenderGrid( TestContext context )
+{
+    var data = new[]
+    {
+        new Employee { Name = "Active", Department = "Female", City = "A" },
+        new Employee { Name = "Inactive", Department = "Female", City = "B" },
+        new Employee { Name = "Active", Department = "Male", City = "C" },
+        new Employee { Name = "Inactive", Department = "Male", City = "D" },
+    };
+
+    var component = context.RenderComponent<BasicTestApp.Client.DataGridGroupingComponent>( parameters => parameters.Add( x => x.Data, data ) );
+    var dataGrid = component.FindComponent<DataGrid<Employee>>();
+    var columns = dataGrid.FindComponents<DataGridColumn<Employee>>();
+    var departmentColumn = columns.Single( x => x.Instance.Field == nameof( Employee.Department ) );
+    var nameColumn = columns.Single( x => x.Instance.Field == nameof( Employee.Name ) );
+
+    return (dataGrid, component, departmentColumn, nameColumn);
+}
+
+static string Describe( IEnumerable<GroupContext<Employee>> grouped )
+    => string.Join( "; ", grouped.Select( x => $"{x.Key}: nested={x.NestedGroup?.Count() ?? 0}, items={x.Items.Count()}" ) );
