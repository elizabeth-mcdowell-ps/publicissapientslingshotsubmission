+
+    private static string ExtractText(string input)
+    {
+        var start = input.IndexOf('(');
+        while (start >= 0)
+        {
+            var quoteIndex = start + 1;
+            while (quoteIndex < input.Length && char.IsWhiteSpace(input[quoteIndex]))
+            {
+                quoteIndex++;
+            }
+
+            if (quoteIndex < input.Length && (input[quoteIndex] == '\'' || input[quoteIndex] == '"'))
+            {
+                return ReadQuotedText(input, quoteIndex);
+            }
+
+            start = input.IndexOf('(', start + 1);
+        }
+
+        return string.Empty;
+    }
+
+    private static string ReadQuotedText(string input, int quoteIndex)
+    {
+        var quote = input[quoteIndex];
+        var text = new StringBuilder();
+        var isEscaped = false;
+
+        for (var i = quoteIndex + 1; i < input.Length; i++)
+        {
+            var ch = input[i];
+            if (isEscaped)
+            {
+                text.Append(Unescape(ch));
+                isEscaped = false;
+            }
+            else if (ch == '\\')
+            {
+                isEscaped = true;
+            }
+            else if (ch == quote)
+            {
+                return text.ToString();
+            }
+            else
+            {
+                text.Append(ch);
+            }
+        }
+
+        if (isEscaped)
+        {
+            text.Append('\\');
+        }
+
+        return text.ToString();
+    }
+
+    private static char Unescape(char ch)
+    {
+        return ch switch
+        {
+            'n' => '\n',
+            'r' => '\r',
+            't' => '\t',
+            '0' => '\0',
+            _ => ch,
+        };
+    }
