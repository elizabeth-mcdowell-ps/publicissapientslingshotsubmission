diff --git a/src/mod_fswatch.c b/src/mod_fswatch.c
index 114c6d76..ad4a0d52 100644
--- a/src/mod_fswatch.c
+++ b/src/mod_fswatch.c
@@ -28,6 +28,7 @@
 
 typedef struct {
     JSContext *ctx;
+    JSValue obj;
     uv_fs_event_t handle;
     JSValue callback;
     int closed;
@@ -43,15 +44,25 @@ static TJSFsWatch *tjs_fswatch_get(JSValue obj) {
 static void uv__fsevent_close_cb(uv_handle_t *handle) {
     TJSFsWatch *fw = handle->data;
     if (fw) {
+        JSContext *ctx = fw->ctx;
+        JSValue obj = fw->obj;
+
         fw->closed = 1;
+        fw->obj = JS_UNDEFINED;
+
         if (fw->finalized) {
             tjs__free(fw);
+            return;
+        }
+
+        if (!JS_IsUndefined(obj)) {
+            JS_FreeValue(ctx, obj);
         }
     }
 }
 
 static void maybe_close(TJSFsWatch *fw) {
-    if (!uv_is_closing((uv_handle_t *) &fw->handle)) {
+    if (!fw->closed && !uv_is_closing((uv_handle_t *) &fw->handle)) {
         uv_close((uv_handle_t *) &fw->handle, uv__fsevent_close_cb);
     }
 }
@@ -184,6 +195,7 @@ static JSValue tjs_fs_watch(JSContext *ctx, JSValue this_val, int argc, JSValue
         JS_FreeValue(ctx, obj);
         return JS_ThrowOutOfMemory(ctx);
     }
+    fw->obj = JS_UNDEFINED;
 
     int r = uv_fs_event_init(tjs_get_loop(ctx), &fw->handle);
     if (r != 0) {
@@ -204,6 +216,7 @@ static JSValue tjs_fs_watch(JSContext *ctx, JSValue this_val, int argc, JSValue
     JS_FreeCString(ctx, path);
 
     fw->ctx = ctx;
+    fw->obj = JS_DupValue(ctx, obj);
     fw->handle.data = fw;
     fw->callback = JS_DupValue(ctx, argv[1]);
 
