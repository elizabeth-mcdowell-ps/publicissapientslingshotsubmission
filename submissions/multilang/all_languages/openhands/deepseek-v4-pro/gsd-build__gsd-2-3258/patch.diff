@@ -10,6 +10,15 @@ export function getMilestoneStatus(
   milestone: WorkspaceMilestoneTarget,
   active: { milestoneId?: string },
 ): ItemStatus {
+  // Prefer authoritative milestone status from GSD state when available
+  if (milestone.status) {
+    if (milestone.status === "complete") return "done"
+    if (milestone.status === "active") return "in-progress"
+    if (milestone.status === "parked") return "pending"
+    // "pending" → use active check, then slice heuristic
+  }
+
+  // Fallback: slice-based heuristics (for backwards compatibility)
   if (milestone.slices.length > 0 && milestone.slices.every((slice) => slice.done)) {
     return "done"
   }
