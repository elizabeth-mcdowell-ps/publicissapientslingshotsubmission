+++ b/crates/openshell-sandbox/src/sandbox/linux/mod.rs
@@ -7,11 +7,42 @@ mod landlock;
 pub mod netns;
 mod seccomp;
 
+pub use landlock::BuiltRuleset;
+
 use crate::policy::SandboxPolicy;
 use miette::Result;
 
+/// Apply all sandbox restrictions in a single step (convenience wrapper).
+///
+/// Prefer [`build_ruleset`] + [`enforce`] in `pre_exec` hooks so Landlock path
+/// FDs can be opened before dropping privileges.
 pub fn apply(policy: &SandboxPolicy, workdir: Option<&str>) -> Result<()> {
-    landlock::apply(policy, workdir)?;
+    if let Some(ruleset) = build_ruleset(policy, workdir)? {
+        enforce(ruleset, policy)?;
+    } else {
+        seccomp::apply(policy)?;
+    }
+    Ok(())
+}
+
+/// Build a Landlock ruleset (opens path FDs, creates rules).
+///
+/// Must be called while the process still has sufficient privileges (root).
+/// Call [`enforce`] afterward to activate restrictions.
+pub fn build_ruleset(policy: &SandboxPolicy, workdir: Option<&str>) -> Result<Option<BuiltRuleset>> {
+    landlock::build_ruleset(policy, workdir)
+}
+
+/// Enforce a previously built Landlock ruleset and apply seccomp.
+///
+/// Call this after [`build_ruleset`] and after dropping privileges.
+pub fn enforce(ruleset: BuiltRuleset, policy: &SandboxPolicy) -> Result<()> {
+    ruleset.enforce()?;
     seccomp::apply(policy)?;
     Ok(())
 }
+
+/// Apply only seccomp (no Landlock).
+pub fn apply_seccomp_only(policy: &SandboxPolicy) -> Result<()> {
+    seccomp::apply(policy)
+}
