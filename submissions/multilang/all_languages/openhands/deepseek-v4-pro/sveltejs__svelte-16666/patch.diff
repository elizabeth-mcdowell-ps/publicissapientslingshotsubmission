diff --git a/packages/svelte/tests/runtime-runes/samples/async-snippet-await-test/_config.js b/packages/svelte/tests/runtime-runes/samples/async-snippet-await-test/_config.js
new file mode 100644
index 000000000..ce595cbad
--- /dev/null
+++ b/packages/svelte/tests/runtime-runes/samples/async-snippet-await-test/_config.js
@@ -0,0 +1,21 @@
+import { tick } from 'svelte';
+import { test } from '../../test';
+
+export default test({
+  html: `
+    <button>reset</button>
+    <button>hello</button>
+    <p>pending</p>
+  `,
+
+  async test({ assert, target }) {
+    const [reset, hello] = target.querySelectorAll('button');
+
+    hello.click();
+    await tick();
+    assert.htmlEqual(
+      target.innerHTML,
+      `<button>reset</button><button>hello</button><p>hello</p>`
+    );
+  }
+});
\ No newline at end of file
