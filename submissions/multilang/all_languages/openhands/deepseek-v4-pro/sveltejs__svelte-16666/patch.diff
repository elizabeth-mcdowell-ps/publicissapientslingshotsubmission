--- /dev/null
+++ b/packages/svelte/tests/runtime-runes/samples/async-snippet-await-test/main.svelte
@@ -0,0 +1,18 @@
+<script>
+  let deferred = $state(Promise.withResolvers());
+</script>
+
+<button onclick={() => deferred = Promise.withResolvers()}>reset</button>
+<button onclick={() => deferred.resolve('hello')}>hello</button>
+
+<svelte:boundary>
+  {#snippet child()}
+    <p>{await deferred.promise}</p>
+  {/snippet}
+
+  {@render child()}
+
+  {#snippet pending()}
+    <p>pending</p>
+  {/snippet}
+</svelte:boundary>
