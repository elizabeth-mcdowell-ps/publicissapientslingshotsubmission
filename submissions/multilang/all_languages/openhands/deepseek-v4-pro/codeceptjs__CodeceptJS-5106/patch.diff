diff --git a/lib/helper/JSONResponse.js b/lib/helper/JSONResponse.js
index 908d4d0b..a34af583 100644
--- a/lib/helper/JSONResponse.js
+++ b/lib/helper/JSONResponse.js
@@ -73,7 +73,11 @@ class JSONResponse extends Helper {
       throw new Error(`Error setting JSONResponse, helper ${this.options.requestHelper} is not enabled in config, helpers: ${Object.keys(this.helpers)}`)
     }
     // connect to REST helper
+    const existingOnResponse = this.helpers[this.options.requestHelper].config.onResponse
     this.helpers[this.options.requestHelper].config.onResponse = response => {
+      if (existingOnResponse) {
+        existingOnResponse(response)
+      }
       this.response = response
     }
   }
