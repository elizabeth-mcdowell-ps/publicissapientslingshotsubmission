+    /**
+     * Restore a stream from persisted table data.
+     * Called during startup to rehydrate the streams cache.
+     */
+    void restoreStream(String tableName, String streamArn, String viewType, String region) {
+        String key = streamKey(region, tableName);
+        if (streams.containsKey(key)) {
+            return;
+        }
+
+        String label = streamArn.contains("/stream/")
+                ? streamArn.substring(streamArn.lastIndexOf("/stream/") + 8)
+                : "";
+
+        StreamDescription sd = new StreamDescription();
+        sd.setStreamArn(streamArn);
+        sd.setStreamLabel(label);
+        sd.setStreamStatus("ENABLED");
+        sd.setStreamViewType(viewType);
+        sd.setTableName(tableName);
+        sd.setCreationDateTime(Instant.now());
+        sd.setStartingSequenceNumber(String.format("%021d", 1));
+
+        streams.put(key, sd);
+        records.put(streamArn, new ConcurrentLinkedDeque<>());
+        LOG.debugv("Restored stream for table {0} in region {1}: {2}", tableName, region, streamArn);
+    }
