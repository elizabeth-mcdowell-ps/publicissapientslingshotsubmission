+	/**
+	 * Strip only OAuth credentials for a provider, preserving any API key
+	 * credentials. Used to self-heal stale OAuth entries (e.g. Anthropic OAuth
+	 * removed in v2.74.0, #3952). If no credentials remain after stripping,
+	 * the provider entry is removed entirely.
+	 *
+	 * Returns true if any OAuth credentials were removed.
+	 */
+	stripLegacyOAuthCredential(provider: string): boolean {
+		const existing = this.getCredentialsForProvider(provider);
+		const apiKeys = existing.filter((c) => c.type === "api_key");
+		if (apiKeys.length === existing.length) {
+			return false; // No OAuth credentials to strip
+		}
+		if (apiKeys.length === 0) {
+			this.remove(provider);
+		} else {
+			this.data[provider] = apiKeys.length === 1 ? apiKeys[0] : apiKeys;
+			this.persistProviderChange(provider, apiKeys.length === 1 ? apiKeys[0] : apiKeys);
+		}
+		return true;
+	}
+
