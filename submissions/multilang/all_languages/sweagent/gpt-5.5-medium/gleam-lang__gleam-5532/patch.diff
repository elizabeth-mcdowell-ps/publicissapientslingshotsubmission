+fn has_comment_between(extra: &ModuleExtra, start: u32, end: u32) -> bool {
+    let comment_is_between = |comment: &SrcSpan| comment.start >= start && comment.end <= end;
+
+    extra.comments.iter().any(comment_is_between)
+        || extra.doc_comments.iter().any(comment_is_between)
+        || extra.module_comments.iter().any(comment_is_between)
+}
+
+fn start_of_line_before(code: &str, byte_index: u32) -> u32 {
+    let mut index = byte_index as usize;
+    let bytes = code.as_bytes();
+
+    while index > 0 && bytes[index - 1] != b'\n' {
+        index -= 1;
+    }
+
+    index as u32
+}
