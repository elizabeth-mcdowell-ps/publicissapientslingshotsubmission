diff --git a/harper-core/src/linting/weir_rules/FlauntFlout.weir b/harper-core/src/linting/weir_rules/FlauntFlout.weir
new file mode 100644
index 0000000..e22209b
--- /dev/null
+++ b/harper-core/src/linting/weir_rules/FlauntFlout.weir
@@ -0,0 +1,20 @@
+expr floutObjects [law, laws, rule, rules]
+expr floutObjectPhrase [@floutObjects, (DET @floutObjects), (ADJ @floutObjects), (NOUN @floutObjects), (PRON @floutObjects), (DET ADJ @floutObjects), (DET NOUN @floutObjects), (ADJ NOUN @floutObjects), (NOUN NOUN @floutObjects), (PRON NOUN @floutObjects), (PRON PRON @floutObjects), (DET ADJ NOUN @floutObjects)]
+expr main <(flaunt @floutObjectPhrase), flaunt>
+
+let message "Use `flout` when you mean openly ignore a rule or law."
+let description "Flags `flaunt` in contexts where `flout` is meant: `flaunt` means show off, while `flout` means openly ignore rules."
+let kind "WordChoice"
+let becomes "flout"
+let strategy "MatchCase"
+
+test "They flaunt rules whenever possible." "They flout rules whenever possible."
+test "Officials who flaunt the law should resign." "Officials who flout the law should resign."
+test "Do not flaunt the basic rules of grammar." "Do not flout the basic rules of grammar."
+test "Companies flaunt privacy laws at their peril." "Companies flout privacy laws at their peril."
+test "Some users flaunt US bankruptcy laws." "Some users flout US bankruptcy laws."
+allows "They flaunt their achievements whenever possible."
+allows "She likes to flaunt her wealth."
+allows "The ad will flaunt the phone's features."
+allows "They flout rules whenever possible."
+allows "He flaunts the rules."
