diff --git a/src/flb_parser.c b/src/flb_parser.c
index f13243f58..29491dd4d 100644
--- a/src/flb_parser.c
+++ b/src/flb_parser.c
@@ -1199,7 +1199,20 @@ int flb_parser_time_lookup(const char *time_str, size_t tsize,
             time_now = now;
         }
 
-        gmtime_r(&time_now, &tmy);
+        /*
+         * Make timestamps without a complete date default to "today" in
+         * the same timezone that will be used later to convert the parsed
+         * struct tm to epoch time.  When Time_System_Timezone is enabled,
+         * flb_parser_tm2time() uses mktime(), so deriving the default date
+         * in UTC can select yesterday/tomorrow around local midnight for
+         * zones east/west of UTC.
+         */
+        if (parser->time_system_timezone) {
+            localtime_r(&time_now, &tmy);
+        }
+        else {
+            gmtime_r(&time_now, &tmy);
+        }
 
         /* Make the timestamp default to today */
         tm->tm.tm_mon = tmy.tm_mon;
