@@ -56,6 +56,105 @@ upsert_provider() {
   fi
 }
 
+provider_credential_handoff_mode() {
+  local help
+  help="$(openshell provider create --help 2>&1 || true)"
+  if grep -q -- "--credential-env" <<< "$help"; then
+    printf '%s\n' env
+  elif grep -q -- "--credential-stdin" <<< "$help"; then
+    printf '%s\n' stdin
+  elif grep -q -- "--credential-file" <<< "$help"; then
+    printf '%s\n' file
+  else
+    # Prefer the env-based interface on recent OpenShell releases. If this CLI
+    # is too old to support it, the provider command will fail closed rather
+    # than exposing the secret on argv.
+    printf '%s\n' env
+  fi
+}
+
+openshell_provider_with_credential_env() {
+  local action="$1"
+  local name="$2"
+  local type="$3"
+  local credential_env="$4"
+  local config="$5"
+  local mode temp_dir credential_file rc
+  mode="$(provider_credential_handoff_mode)"
+
+  if [[ -z "$credential_env" || "$credential_env" == *$'\n'* || "$credential_env" == *$'\r'* || "$credential_env" == *'='* ]]; then
+    fail "Invalid provider credential environment variable name"
+  fi
+  if [[ -z "${!credential_env:-}" ]]; then
+    fail "$credential_env not set"
+  fi
+  if [[ "${!credential_env}" == *$'\n'* || "${!credential_env}" == *$'\r'* ]]; then
+    fail "$credential_env must not contain newlines"
+  fi
+
+  case "$mode" in
+    stdin)
+      if [ "$action" = "create" ]; then
+        printf '%s=%s\n' "$credential_env" "${!credential_env}" | \
+          openshell provider create --name "$name" --type "$type" \
+            --credential-stdin --config "$config"
+      else
+        printf '%s=%s\n' "$credential_env" "${!credential_env}" | \
+          openshell provider update "$name" --credential-stdin --config "$config"
+      fi
+      ;;
+    file)
+      temp_dir="$(mktemp -d)"
+      chmod 700 "$temp_dir"
+      credential_file="$temp_dir/credential.env"
+      printf '%s=%s\n' "$credential_env" "${!credential_env}" > "$credential_file"
+      chmod 600 "$credential_file"
+      set +e
+      if [ "$action" = "create" ]; then
+        openshell provider create --name "$name" --type "$type" \
+          --credential-file "$credential_file" --config "$config"
+      else
+        openshell provider update "$name" --credential-file "$credential_file" --config "$config"
+      fi
+      rc=$?
+      set -e
+      rm -rf "$temp_dir"
+      return "$rc"
+      ;;
+    *)
+      if [ "$action" = "create" ]; then
+        openshell provider create --name "$name" --type "$type" \
+          --credential-env "$credential_env" --config "$config"
+      else
+        openshell provider update "$name" --credential-env "$credential_env" --config "$config"
+      fi
+      ;;
+  esac
+}
+
+upsert_provider_with_credential_env() {
+  local name="$1"
+  local type="$2"
+  local credential_env="$3"
+  local config="$4"
+  local output rc
+
+  set +e
+  output="$(openshell_provider_with_credential_env create "$name" "$type" "$credential_env" "$config" 2>&1)"
+  rc=$?
+  set -e
+
+  if [ "$rc" -ne 0 ] && grep -q "AlreadyExists" <<< "$output"; then
+    openshell_provider_with_credential_env update "$name" "$type" "$credential_env" "$config" > /dev/null
+    info "Updated $name provider"
+  elif [ "$rc" -ne 0 ]; then
+    printf '%s\n' "$output" >&2
+    fail "Failed to create $name provider"
+  else
+    info "Created $name provider"
+  fi
+}
+
