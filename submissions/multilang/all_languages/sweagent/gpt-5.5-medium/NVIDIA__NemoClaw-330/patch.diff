+++ b/nemoclaw-blueprint/orchestrator/runner.py
@@ -20,6 +20,7 @@ import os
 import shutil
 import subprocess
 import sys
+import tempfile
 import uuid
 from datetime import UTC, datetime
 from pathlib import Path
@@ -67,6 +68,67 @@ def run_cmd(
     )
 
 
+def provider_credential_handoff_mode() -> str:
+    help_result = subprocess.run(
+        ["openshell", "provider", "create", "--help"],
+        check=False,
+        capture_output=True,
+        text=True,
+    )
+    help_text = f"{help_result.stdout or ''}{help_result.stderr or ''}"
+    if "--credential-env" in help_text:
+        return "env"
+    if "--credential-stdin" in help_text:
+        return "stdin"
+    if "--credential-file" in help_text:
+        return "file"
+    # Prefer recent OpenShell's env-var interface. Older CLIs fail closed rather
+    # than receiving a secret on argv.
+    return "env"
+
+
+def run_provider_create_with_credential(
+    args: list[str], credential_name: str, credential_value: str
+) -> subprocess.CompletedProcess[str]:
+    if not credential_name or any(ch in credential_name for ch in "=\r\n"):
+        raise ValueError("invalid provider credential environment variable name")
+    if "\n" in credential_value or "\r" in credential_value:
+        raise ValueError(f"{credential_name} must not contain newlines")
+
+    env = {**os.environ, credential_name: credential_value}
+    mode = provider_credential_handoff_mode()
+    if mode == "stdin":
+        return subprocess.run(
+            [*args, "--credential-stdin"],
+            check=False,
+            capture_output=True,
+            text=True,
+            input=f"{credential_name}={credential_value}\n",
+            env=env,
+        )
+    if mode == "file":
+        with tempfile.TemporaryDirectory(prefix="nemoclaw-credential-") as temp_dir:
+            os.chmod(temp_dir, 0o700)
+            credential_file = Path(temp_dir) / "credential.env"
+            credential_file.write_text(f"{credential_name}={credential_value}\n")
+            credential_file.chmod(0o600)
+            return subprocess.run(
+                [*args, "--credential-file", str(credential_file)],
+                check=False,
+                capture_output=True,
+                text=True,
+                env=env,
+            )
+    return subprocess.run(
+        [*args, "--credential-env", credential_name],
+        check=False,
+        capture_output=True,
+        text=True,
+        env=env,
+    )
+
+
+
 def openshell_available() -> bool:
     """Check if openshell CLI is available."""
     return shutil.which("openshell") is not None
@@ -209,12 +271,13 @@ def action_apply(
         "--type",
