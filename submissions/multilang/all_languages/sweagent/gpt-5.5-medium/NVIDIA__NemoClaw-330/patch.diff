@@ -284,6 +284,93 @@ function waitForSandboxReady(sandboxName, attempts = 10, delaySeconds = 2) {
   return false;
 }
 
+function getProviderCredentialHandoffMode() {
+  const result = spawnSync("openshell", ["provider", "create", "--help"], {
+    cwd: ROOT,
+    env: process.env,
+    stdio: ["ignore", "pipe", "pipe"],
+    encoding: "utf-8",
+  });
+  const help = `${result.stdout || ""}${result.stderr || ""}`;
+  if (help.includes("--credential-env")) return "env";
+  if (help.includes("--credential-stdin")) return "stdin";
+  if (help.includes("--credential-file")) return "file";
+
+  // Prefer the env-based interface added by recent OpenShell releases.  If the
+  // installed CLI is old enough that help text is unavailable, fail closed in
+  // the provider command rather than putting the secret back on argv.
+  return "env";
+}
+
+function runProviderCommandWithCredential(action, name, type, credentialEnv, credentialValue, config) {
+  if (!credentialEnv || /[\r\n=]/.test(credentialEnv)) {
+    throw new Error("Invalid provider credential environment variable name");
+  }
+  if (typeof credentialValue !== "string" || credentialValue.length === 0) {
+    throw new Error(`Missing value for ${credentialEnv}`);
+  }
+  if (/[\r\n]/.test(credentialValue)) {
+    throw new Error(`${credentialEnv} must not contain newlines`);
+  }
+
+  const args = action === "create"
+    ? ["provider", "create", "--name", name, "--type", type]
+    : ["provider", "update", name];
+  const env = { ...process.env, [credentialEnv]: credentialValue };
+  const mode = getProviderCredentialHandoffMode();
+  let input;
+  let tempDir;
+
+  try {
+    if (mode === "stdin") {
+      args.push("--credential-stdin");
+      input = `${credentialEnv}=${credentialValue}\n`;
+    } else if (mode === "file") {
+      tempDir = fs.mkdtempSync(path.join(os.tmpdir(), "nemoclaw-credential-"));
+      fs.chmodSync(tempDir, 0o700);
+      const credentialFile = path.join(tempDir, "credential.env");
+      fs.writeFileSync(credentialFile, `${credentialEnv}=${credentialValue}\n`, { mode: 0o600 });
+      args.push("--credential-file", credentialFile);
+    } else {
+      args.push("--credential-env", credentialEnv);
+    }
+    args.push("--config", config);
+
+    return spawnSync("openshell", args, {
+      cwd: ROOT,
+      env,
+      input,
+      stdio: input ? ["pipe", "pipe", "pipe"] : ["ignore", "pipe", "pipe"],
+      encoding: "utf-8",
+    });
+  } finally {
+    if (tempDir) {
+      fs.rmSync(tempDir, { recursive: true, force: true });
+    }
+  }
+}
+
+function upsertProviderWithCredentialEnv(name, type, credentialEnv, credentialValue, config) {
+  const createResult = runProviderCommandWithCredential(
+    "create",
+    name,
+    type,
+    credentialEnv,
+    credentialValue,
+    config
+  );
+  if (createResult.status === 0) return createResult;
+  return runProviderCommandWithCredential(
+    "update",
+    name,
+    type,
+    credentialEnv,
+    credentialValue,
+    config
+  );
+}
+
+
