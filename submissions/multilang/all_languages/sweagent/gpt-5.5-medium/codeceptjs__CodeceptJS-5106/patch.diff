diff --git a/lib/helper/JSONResponse.js b/lib/helper/JSONResponse.js
index 908d4d0b..838733bf 100644
--- a/lib/helper/JSONResponse.js
+++ b/lib/helper/JSONResponse.js
@@ -72,9 +72,24 @@ class JSONResponse extends Helper {
     if (!this.helpers[this.options.requestHelper]) {
       throw new Error(`Error setting JSONResponse, helper ${this.options.requestHelper} is not enabled in config, helpers: ${Object.keys(this.helpers)}`)
     }
-    // connect to REST helper
-    this.helpers[this.options.requestHelper].config.onResponse = response => {
-      this.response = response
+    // connect to request helper without overriding a user-defined onResponse hook
+    const requestHelper = this.helpers[this.options.requestHelper]
+    const onResponse = requestHelper.config.onResponse
+    const jsonResponseHelper = this
+
+    requestHelper.config.onResponse = function (response) {
+      const setResponse = () => {
+        jsonResponseHelper.response = response
+      }
+
+      if (typeof onResponse === 'function') {
+        const result = onResponse.call(this, response)
+        if (result && typeof result.then === 'function') {
+          return result.then(setResponse)
+        }
+      }
+
+      setResponse()
     }
   }
 
diff --git a/lib/helper/REST.js b/lib/helper/REST.js
