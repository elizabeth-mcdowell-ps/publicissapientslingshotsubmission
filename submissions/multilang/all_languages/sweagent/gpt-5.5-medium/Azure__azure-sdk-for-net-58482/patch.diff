+        private static string BuildSharedResourceModelName(InputModelType model, IReadOnlyList<ProvisioningResourceProvider> resources)
+        {
+            var unavailableNames = new HashSet<string>(
+                resources.Select(r => r.ResourceMetadata?.ResourceName.ToIdentifierName())
+                    .Concat(ProvisioningGenerator.Instance.InputLibrary.InputNamespace.Models
+                        .Where(m => !ReferenceEquals(m, model))
+                        .Select(m => m.Name.ToIdentifierName()))
+                    .Where(n => n is not null)!,
+                StringComparer.Ordinal);
+
+            var name = model.Name.ToIdentifierName() + "Model";
+            while (unavailableNames.Contains(name))
+            {
+                name += "Model";
+            }
+            return name;
