+    private static string ParseText(string input)
+    {
+        var tupleStart = input.IndexOf('(');
+        if (tupleStart < 0)
+        {
+            return string.Empty;
+        }
+
+        var quoteIndex = -1;
+        for (var i = tupleStart + 1; i < input.Length; i++)
+        {
+            if (input[i] is '\'' or '"')
+            {
+                quoteIndex = i;
+                break;
+            }
+        }
+
+        if (quoteIndex < 0)
+        {
+            return string.Empty;
+        }
+
+        var quote = input[quoteIndex];
+        var sb = new StringBuilder();
+        var escaped = false;
+
+        for (var i = quoteIndex + 1; i < input.Length; i++)
+        {
+            var c = input[i];
+
+            if (escaped)
+            {
+                sb.Append(c switch
+                {
+                    '\\' => '\\',
+                    '\'' => '\'',
+                    '"' => '"',
+                    'n' => '\n',
+                    'r' => '\r',
+                    't' => '\t',
+                    _ => '\\' + c.ToString(),
+                });
+                escaped = false;
+                continue;
+            }
+
+            if (c == '\\')
+            {
+                escaped = true;
+                continue;
+            }
+
+            if (c == quote)
+            {
+                break;
+            }
+
+            sb.Append(c);
+        }
+
+        if (escaped)
+        {
+            sb.Append('\\');
+        }
+
+        return sb.ToString();
+    }
+}
