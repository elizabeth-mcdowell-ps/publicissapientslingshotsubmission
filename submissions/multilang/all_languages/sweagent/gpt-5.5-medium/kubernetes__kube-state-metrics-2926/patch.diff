 )
 
 var (
@@ -85,6 +86,46 @@ type Options struct {
 	AuthFilter           bool  `yaml:"auth_filter"`
 }
 
+// UnmarshalYAML decodes Options from YAML. It preserves compatibility with the
+// original custom resource state config file option name used by the options
+// config file.
+func (o *Options) UnmarshalYAML(value *yaml.Node) error {
+	customResourceConfigFileSet := yamlMapHasKey(value, "custom_resource_config_file")
+	customResourceStateConfigFileSet := yamlMapHasKey(value, "custom_resource_state_config_file")
+
+	type plain Options
+	var config struct {
+		*plain `yaml:",inline"`
+
+		CustomResourceConfigFile string `yaml:"custom_resource_config_file"`
+	}
+	config.plain = (*plain)(o)
+
+	if err := value.Decode(&config); err != nil {
+		return err
+	}
+
+	if customResourceConfigFileSet && !customResourceStateConfigFileSet {
+		o.CustomResourceConfigFile = config.CustomResourceConfigFile
+	}
+
+	return nil
+}
+
+func yamlMapHasKey(value *yaml.Node, key string) bool {
+	if value.Kind != yaml.MappingNode {
+		return false
+	}
+
+	for i := 0; i+1 < len(value.Content); i += 2 {
+		if value.Content[i].Value == key {
+			return true
+		}
+	}
+
+	return false
+}
+
