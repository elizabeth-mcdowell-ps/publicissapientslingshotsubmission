@@ -0,0 +1,54 @@
+package io.github.hectorvent.floci.services.sqs;
+
+import jakarta.ws.rs.HttpMethod;
+import jakarta.ws.rs.container.ContainerRequestContext;
+import jakarta.ws.rs.container.ContainerRequestFilter;
+import jakarta.ws.rs.container.PreMatching;
+import jakarta.ws.rs.core.UriBuilder;
+import jakarta.ws.rs.ext.Provider;
+
+import java.net.URI;
+import java.util.Locale;
+
+/**
+ * Routes SQS JSON 1.0 calls sent to queue URL paths (/{accountId}/{queueName})
+ * through the generic JSON dispatcher instead of the S3 path-style controller.
+ */
+@Provider
+@PreMatching
+public class SqsJsonPathRoutingFilter implements ContainerRequestFilter {
+
+    public static final String ORIGINAL_QUEUE_PATH_HEADER = "X-Floci-SQS-Queue-Path";
+
+    @Override
+    public void filter(ContainerRequestContext requestContext) {
+        if (!HttpMethod.POST.equals(requestContext.getMethod())) {
+            return;
+        }
+
+        String target = requestContext.getHeaderString("X-Amz-Target");
+        if (target == null || !target.startsWith("AmazonSQS.")) {
+            return;
+        }
+
+        String contentType = requestContext.getHeaderString("Content-Type");
+        if (contentType == null || !contentType.toLowerCase(Locale.ROOT).startsWith("application/x-amz-json-1.0")) {
+            return;
+        }
+
+        URI requestUri = requestContext.getUriInfo().getRequestUri();
+        String rawPath = requestUri.getRawPath();
+        if (rawPath == null || rawPath.isEmpty() || "/".equals(rawPath)) {
+            return;
+        }
+
+        String normalizedPath = rawPath.startsWith("/") ? rawPath.substring(1) : rawPath;
+        requestContext.getHeaders().putSingle(ORIGINAL_QUEUE_PATH_HEADER, normalizedPath);
+
+        URI rootUri = UriBuilder.fromUri(requestUri)
+                .replacePath(requestContext.getUriInfo().getBaseUri().getRawPath())
+                .replaceQuery(null)
+                .build();
+        requestContext.setRequestUri(rootUri);
+    }
+}
