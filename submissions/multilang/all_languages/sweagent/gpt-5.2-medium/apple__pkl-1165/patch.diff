diff --git a/pkl-core/src/main/java/org/pkl/core/util/yaml/snake/YamlUtils.java b/pkl-core/src/main/java/org/pkl/core/util/yaml/snake/YamlUtils.java
index d481d539..e9547f41 100644
--- a/pkl-core/src/main/java/org/pkl/core/util/yaml/snake/YamlUtils.java
+++ b/pkl-core/src/main/java/org/pkl/core/util/yaml/snake/YamlUtils.java
@@ -50,8 +50,24 @@ public final class YamlUtils {
    * resolver to determine whether the string needs to be quoted.
    */
   public static ScalarEvent stringScalar(String value, ScalarResolver resolver) {
-    var scalarStyle = value.contains("\n") ? ScalarStyle.LITERAL : ScalarStyle.PLAIN;
     var inferredTag = resolver.resolve(value, true);
+
+    // Ensure correct round-tripping for strings containing backslashes. YAML double-quoted
+    // scalars treat backslash as an escape character, so a single backslash before a
+    // non-escape character (e.g. "\\d") must be emitted as "\\\\d".
+    // SnakeYAML-Engine only performs this escaping when using DOUBLE_QUOTED style, but
+    // may still decide to quote values when using PLAIN style. To avoid emitting invalid
+    // escape sequences, force DOUBLE_QUOTED whenever the value contains a backslash.
+
+    ScalarStyle scalarStyle;
+    if (value.contains("\n")) {
+      scalarStyle = ScalarStyle.LITERAL;
+    } else if (value.contains("\\")) {
+      scalarStyle = ScalarStyle.DOUBLE_QUOTED;
+    } else {
+      scalarStyle = ScalarStyle.PLAIN;
+    }
+
     var tuple = new ImplicitTuple(Tag.STR.equals(inferredTag), true);
     return new ScalarEvent(Optional.empty(), STRING_TAG, tuple, value, scalarStyle);
   }
diff --git a/repro.py b/repro.py
new file mode 100644
index 00000000..45dc70b7
--- /dev/null
+++ b/repro.py
@@ -0,0 +1,14 @@
+import subprocess, textwrap, tempfile, pathlib
+pkl = pathlib.Path('pkl-cli/build/executable/jpkl')
+with tempfile.TemporaryDirectory() as td:
+    p = pathlib.Path(td)/'test.pkl'
+    p.write_text(textwrap.dedent(r'''
+        foo = "\t\\d"
+
+        output {
+          renderer = new YamlRenderer {}
+        }
+    '''))
+    out = subprocess.check_output(['bash', str(pkl), 'eval', str(p)], text=True)
+    print(out)
+    assert out.strip() == 'foo: "\\t\\\\d"'
