diff --git a/frontend/src/ts/config-metadata.ts b/frontend/src/ts/config-metadata.ts
index adb2c586f..bdb446b54 100644
--- a/frontend/src/ts/config-metadata.ts
+++ b/frontend/src/ts/config-metadata.ts
@@ -148,7 +148,29 @@ export const configMetadata: ConfigMetadataObject = {
       }
       return {};
     },
-    afterSet: ({ currentConfig }) => {
+    // When applying config from localStorage/DB, we may be applying a *partial*
+    // config (e.g. DB doesn't store keys that equal defaults). In that case,
+    // applying just `mode` would trigger overrideConfig and inadvertently reset
+    // `numbers`/`punctuation` back to false, even if the user previously enabled
+    // them and they were persisted locally.
+    //
+    // Only force-disable numbers/punctuation when the user explicitly changes
+    // mode (i.e. not during silent/nosave config application).
+    afterSet: ({ nosave, currentConfig }) => {
+      if (!nosave) {
+        if (
+          (currentConfig.mode === "custom" ||
+            currentConfig.mode === "quote" ||
+            currentConfig.mode === "zen") &&
+          (currentConfig.numbers || currentConfig.punctuation)
+        ) {
+          // Use nosave=true to avoid a double write; genericSet will already
+          // persist the mode change.
+          UpdateConfig.setNumbers(false, true);
+          UpdateConfig.setPunctuation(false, true);
+        }
+      }
+
       if (currentConfig.mode === "zen" && currentConfig.paceCaret !== "off") {
         Notifications.add(`Pace caret will not work with zen mode.`, 0);
       }
