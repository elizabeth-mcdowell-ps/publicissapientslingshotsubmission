+import json, subprocess, sys
+
+def run(cmd):
+    return subprocess.check_output(cmd, text=True)
+
+# Build tests module that contains expected jsons
+run(["mvn","-q","-pl","springdoc-openapi-tests/springdoc-openapi-javadoc-tests","-am","test","-DskipTests"])  # compile
+
+# We don't have a dedicated MRE app; instead we assert core behavior by invoking unit tests that validate requestBody in multipart with RequestPart.
+# Run full javadoc tests suite (fast enough) and ensure success.
+subprocess.check_call(["mvn","-q","-pl","springdoc-openapi-tests/springdoc-openapi-javadoc-tests","test"]) 
+print("OK")
