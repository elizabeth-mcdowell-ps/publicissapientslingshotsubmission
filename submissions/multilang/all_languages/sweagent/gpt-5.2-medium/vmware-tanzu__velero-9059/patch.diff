+
+// RegisterBackupStorageLocationLastStatus records the last status of the backup storage location.
+// A value of 1 is valid, 0 is invalid.
+func (m *ServerMetrics) RegisterBackupStorageLocationLastStatus(bsl string, lastStatus int64) {
+	if g, ok := m.metrics[veleroBackupStorageLocationLastStatus].(*prometheus.GaugeVec); ok {
+		g.WithLabelValues(bsl).Set(float64(lastStatus))
+	}
+}
