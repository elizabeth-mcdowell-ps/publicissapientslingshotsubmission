diff --git a/reproduce.sh b/reproduce.sh
new file mode 100755
index 0000000000..002e01db5a
--- /dev/null
+++ b/reproduce.sh
@@ -0,0 +1,17 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+FILE=src/Uno.UI/UI/Xaml/Controls/ContentDialog/ContentDialog.Visuals.cs
+
+# Ensure Uno uses XamlRoot.Size for sizing the popup overlay (smoke layer), not TrueVisibleBounds.Size
+if grep -n "XamlRoot\.VisualTree\.TrueVisibleBounds\.Size" "$FILE"; then
+  echo "FAIL: Still uses TrueVisibleBounds.Size in SizeAndPositionContentInPopup" >&2
+  exit 1
+fi
+
+if ! grep -n "var xamlRootSize = XamlRoot\.Size;" "$FILE" >/dev/null; then
+  echo "FAIL: Expected XamlRoot.Size assignment not found" >&2
+  exit 1
+fi
+
+echo "PASS: ContentDialog sizing uses XamlRoot.Size (overlay should cover full window on resize/maximize)."
diff --git a/reproduce_contentdialog_overlay.csx b/reproduce_contentdialog_overlay.csx
new file mode 100644
index 0000000000..67f70003c6
--- /dev/null
+++ b/reproduce_contentdialog_overlay.csx
@@ -0,0 +1 @@
+#r "nuget: Uno.WinUI, 5.5.0" 
diff --git a/src/Uno.UI/UI/Xaml/Controls/ContentDialog/ContentDialog.Visuals.cs b/src/Uno.UI/UI/Xaml/Controls/ContentDialog/ContentDialog.Visuals.cs
index acf80eccf7..325ef35806 100644
--- a/src/Uno.UI/UI/Xaml/Controls/ContentDialog/ContentDialog.Visuals.cs
+++ b/src/Uno.UI/UI/Xaml/Controls/ContentDialog/ContentDialog.Visuals.cs
@@ -226,7 +226,10 @@ namespace Microsoft.UI.Xaml.Controls
 #if !HAS_UNO
 			var xamlRootSize = XamlRoot.Size;
 #else
-			var xamlRootSize = XamlRoot.VisualTree.TrueVisibleBounds.Size;
+			// TrueVisibleBounds can be offset when the window is restored/maximized (or when visible bounds don't start at 0,0).
+			// For the popup child itself we want to always size to the *full* XamlRoot (size only), while the popup panel
+			// (ContentDialogPopupPanel) will take care of positioning the dialog within the visible bounds.
+			var xamlRootSize = XamlRoot.Size;
 #endif
 
 			var flowDirection = FlowDirection;
