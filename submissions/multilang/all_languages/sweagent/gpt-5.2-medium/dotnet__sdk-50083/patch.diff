diff --git a/reproduce.sh b/reproduce.sh
new file mode 100755
index 0000000000..056dfb1382
--- /dev/null
+++ b/reproduce.sh
@@ -0,0 +1,9 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+grep -R "GenerateEmbeddedValidatableTypeAttribute" -n src/RazorSdk/Targets || true
+
+test -f src/RazorSdk/Targets/EmbeddedAttribute.cs && echo "EmbeddedAttribute.cs exists" || echo "EmbeddedAttribute.cs missing"
+test -f src/RazorSdk/Targets/ValidatableTypeAttribute.cs && echo "ValidatableTypeAttribute.cs exists" || echo "ValidatableTypeAttribute.cs missing"
+
+grep -R "Microsoft.Extensions.Validation.Embedded" -n src/RazorSdk/Targets || true
diff --git a/src/RazorSdk/Targets/EmbeddedAttribute.cs b/src/RazorSdk/Targets/EmbeddedAttribute.cs
new file mode 100644
index 0000000000..b94d172560
--- /dev/null
+++ b/src/RazorSdk/Targets/EmbeddedAttribute.cs
@@ -0,0 +1,8 @@
+// <auto-generated/>
+namespace Microsoft.CodeAnalysis
+{
+    [global::System.AttributeUsage(global::System.AttributeTargets.All, AllowMultiple = true, Inherited = false)]
+    internal sealed class EmbeddedAttribute : global::System.Attribute
+    {
+    }
+}
