diff --git a/repro.py b/repro.py
new file mode 100644
index 000000000..06b71b400
--- /dev/null
+++ b/repro.py
@@ -0,0 +1,51 @@
+import subprocess, os, re, textwrap, sys, time
+
+def run(cmd, **kw):
+    print('RUN:', ' '.join(cmd))
+    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, **kw).stdout
+
+# build
+out = run(['bash','-lc','cd /testbed && make -j2'])
+print(out)
+
+# run server in background
+server = subprocess.Popen(['bash','-lc','cd /testbed && ./bin/s2nd localhost 8443 --ciphers test_all_rsa_kex'], stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
+# wait for listening line
+sig_line = None
+start=time.time()
+while time.time()-start < 5:
+    line = server.stdout.readline()
+    if not line:
+        break
+    print('s2nd:', line.rstrip())
+    if 'Listening on' in line:
+        break
+
+client_out = run(['bash','-lc','cd /testbed && echo | ./bin/s2nc localhost 8443 --ciphers test_all_rsa_kex'], timeout=10)
+print('s2nc output:\n', client_out)
+
+# read a bit more server output then terminate
+start=time.time()
+server_lines=[]
+while time.time()-start < 3:
+    line = server.stdout.readline()
+    if not line:
+        break
+    server_lines.append(line)
+    print('s2nd:', line.rstrip())
+
+server.terminate()
+try:
+    server.wait(timeout=2)
+except subprocess.TimeoutExpired:
+    server.kill()
+
+server_out=''.join(server_lines)
+print('captured s2nd tail:\n', server_out)
+
+# extract negotiated signature
+m = re.search(r"Server signature negotiated: (.*)", server_out)
+if m:
+    print('NEGOTIATED SIG:', m.group(1).strip())
+else:
+    print('No negotiated sig line found')
diff --git a/repro.sh b/repro.sh
new file mode 100755
index 000000000..e0a89e198
--- /dev/null
+++ b/repro.sh
@@ -0,0 +1,27 @@
+#!/usr/bin/env bash
+set -euo pipefail
+cd /testbed
+make -j2
+
+# start server
+./bin/s2nd localhost 8443 --ciphers test_all_rsa_kex > /tmp/s2nd.out 2>&1 &
+S2ND_PID=$!
+trap "kill $S2ND_PID 2>/dev/null || true" EXIT
+
+# wait for listening
+for i in {1..50}; do
+  if grep -q "Listening on" /tmp/s2nd.out; then break; fi
+  sleep 0.1
+done
+
+# run client
+(echo | ./bin/s2nc localhost 8443 --ciphers test_all_rsa_kex) > /tmp/s2nc.out 2>&1 || true
+
+# wait for connected
+sleep 0.2
+kill $S2ND_PID 2>/dev/null || true
+sleep 0.2
+
+echo "---s2nd---"; grep "Server signature negotiated" -n /tmp/s2nd.out || true
+echo "---s2nc---"; grep "Server signature negotiated" -n /tmp/s2nc.out || true
+
