new file mode 100644
index 000000000..609f312ba
--- /dev/null
+++ b/repro/Program.cs
@@ -0,0 +1,24 @@
+using System.Text.Json;
+using System.Text.Json.Nodes;
+
+var serializerOptions = new JsonSerializerOptions();
+
+var original = JsonValue.Create(1)!;
+Console.WriteLine("Original type: " + original.GetType());
+
+var bytes = JsonSerializer.SerializeToUtf8Bytes<JsonNode>(original, serializerOptions);
+
+var deserializedAsNode = JsonSerializer.Deserialize<JsonNode>(bytes, serializerOptions)!;
+Console.WriteLine("Deserialized as JsonNode type: " + deserializedAsNode.GetType());
+
+var deserializedAsValue = JsonSerializer.Deserialize<JsonValue>(bytes, serializerOptions)!;
+Console.WriteLine("Deserialized as JsonValue type: " + deserializedAsValue.GetType());
+
+try
+{
+    Console.WriteLine("GetValue<int> => " + deserializedAsValue.GetValue<int>());
+}
+catch (Exception ex)
+{
+    Console.WriteLine("GetValue failed: " + ex);
+}
