index 000000000..6c6106bf0
--- /dev/null
+++ b/repro_jsonnode_cast/Program.cs
@@ -0,0 +1,21 @@
+using System.Text.Json.Nodes;
+
+JsonNode input = JsonValue.Create(1)!;
+Console.WriteLine("Input type: " + input.GetType());
+
+var asValue = (JsonValue)input;
+Console.WriteLine("As JsonValue type: " + asValue.GetType());
+
+// simulate code which expects JsonValuePrimitive<int>
+var primType = Type.GetType("System.Text.Json.Nodes.JsonValuePrimitive`1[System.Int32], System.Text.Json", throwOnError: false);
+Console.WriteLine("JsonValuePrimitive<int>: " + primType);
+
+try
+{
+    var casted = Convert.ChangeType(asValue, primType!);
+    Console.WriteLine("Converted: " + casted);
+}
+catch (Exception ex)
+{
+    Console.WriteLine(ex.GetType().FullName + ": " + ex.Message);
+}
