+using System.Buffers;
+using System.Text.Json.Nodes;
+using Microsoft.Extensions.DependencyInjection;
+using Orleans.Serialization;
+
+var services = new ServiceCollection();
+services.AddSerializer();
+services.AddJsonSerializer(isSupported: _ => true);
+var sp = services.BuildServiceProvider();
+var serializer = sp.GetRequiredService<Serializer>();
+
+JsonNode? original = JsonValue.Create(1);
+Console.WriteLine("Original runtime type: " + original!.GetType());
+
+var writer = new ArrayBufferWriter<byte>();
+serializer.Serialize(original, writer);
+var payload = writer.WrittenSpan.ToArray();
+
+var deserialized = serializer.Deserialize<JsonNode>(payload);
+Console.WriteLine("Deserialized runtime type: " + deserialized!.GetType());
+
+try
+{
+    // mimic app code expecting primitive<int>
+    var asValue = (JsonValue)deserialized;
+    Console.WriteLine("As JsonValue runtime type: " + asValue.GetType());
+    var value = asValue.GetValue<int>();
+    Console.WriteLine("GetValue<int> => " + value);
+}
+catch (Exception ex)
+{
+    Console.WriteLine("Exception: " + ex);
+}
