diff --git a/crates/ide-completion/src/render.rs b/crates/ide-completion/src/render.rs
index 3d7a4067c2..85fcb1ed61 100644
--- a/crates/ide-completion/src/render.rs
+++ b/crates/ide-completion/src/render.rs
@@ -621,6 +621,14 @@ fn compute_ref_match(
     ctx: &CompletionContext<'_>,
     completion_ty: &hir::Type<'_>,
 ) -> Option<CompletionItemRefMode> {
+    // If the expected type is already a reference, don't suggest inserting an extra `&`/`&mut`.
+    //
+    // This avoids confusing completions in contexts like deref-assign (`*x = $0`) where the
+    // expected type can be `&mut T` and we would otherwise offer `&mut <expr>`.
+    if ctx.expected_type.as_ref().is_some_and(|ty| ty.is_reference()) {
+        return None;
+    }
+
     let expected_type = ctx.expected_type.as_ref()?;
     let expected_without_ref = expected_type.remove_ref();
     let completion_without_ref = completion_ty.remove_ref();
