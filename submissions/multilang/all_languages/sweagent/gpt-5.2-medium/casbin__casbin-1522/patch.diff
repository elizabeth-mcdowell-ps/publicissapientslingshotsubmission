diff --git a/examples/lbac_model.conf b/examples/lbac_model.conf
new file mode 100644
index 0000000..c084c38
--- /dev/null
+++ b/examples/lbac_model.conf
@@ -0,0 +1,14 @@
+[request_definition]
+r = sub, sub_level, obj, obj_level, act
+
+[policy_definition]
+p = sub, obj, act
+
+[policy_effect]
+e = some(where (p.eft == allow))
+
+[matchers]
+# LBAC: allow if subject and object levels are comparable in the lattice
+# Here we model a simple numeric lattice: a can access b if a dominates b (>=)
+# and can write if b dominates a (<=)
+m = (r.act == "read" && r.sub_level >= r.obj_level) || (r.act == "write" && r.sub_level <= r.obj_level)
