+import name.abuchen.portfolio.datatransfer.pdf.*;
+import name.abuchen.portfolio.model.*;
+import name.abuchen.portfolio.datatransfer.*;
+import java.nio.file.*;
+import java.util.*;
+
+public class repro {
+  public static void main(String[] args) throws Exception {
+    Client client = new Client();
+    FinTechGroupBankPDFExtractor ex = new FinTechGroupBankPDFExtractor(client);
+    String txt = Files.readString(Path.of("name.abuchen.portfolio.tests/src/name/abuchen/portfolio/datatransfer/pdf/fintechgroupbank/FinTechKontoauszug06.txt"));
+    txt = txt.replace("```\n", "").replace("```", "");
+    List<Extractor.InputFile> files = PDFInputFile.createTestCase("FinTechKontoauszug06.txt", txt);
+    List<Exception> errors = new ArrayList<>();
+    var items = ex.extract(files, errors);
+    System.out.println("errors="+errors.size());
+    System.out.println("items=" + items.size());
+    long removals = items.stream().filter(i -> i.getSubject() instanceof AccountTransaction at && at.getType()==AccountTransaction.Type.REMOVAL).count();
+    long deposits = items.stream().filter(i -> i.getSubject() instanceof AccountTransaction at && at.getType()==AccountTransaction.Type.DEPOSIT).count();
+    System.out.println("deposits=" + deposits + " removals=" + removals);
+    items.stream().filter(i -> i.getSubject() instanceof AccountTransaction).limit(10).forEach(i->{
+      AccountTransaction at=(AccountTransaction)i.getSubject();
+      System.out.println(at.getDateTime()+" "+at.getType()+" note='"+at.getNote()+"' amount="+at.getAmount()+" "+at.getCurrencyCode());
+    });
+  }
+}
