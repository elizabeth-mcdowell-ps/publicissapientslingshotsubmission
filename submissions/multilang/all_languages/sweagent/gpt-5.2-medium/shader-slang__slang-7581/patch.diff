@@ -1073,6 +1073,27 @@ static void _maybeDiagnoseMissingVulkanLayoutModifier(
     ParameterBindingContext* context,
     DeclRef<VarDeclBase> const& varDecl)
 {
+    // This diagnostic is intended to help users authoring shaders for Vulkan/GLSL
+    // targets.
+    //
+    // When compiling for Metal (e.g. `-target metallib`), users may still use HLSL
+    // `register(...)` syntax for resource binding, and they may also supply
+    // `[[vk::binding(...)]]` attributes to keep the same source compatible with
+    // Vulkan.
+    //
+    // In that case, warning about missing Vulkan bindings is confusing/noisy
+    // (and can even look spurious when `[[vk::binding]]` is present but does not
+    // contribute to Metal binding).
+    //
+    // Therefore, only emit this warning when compiling for a Vulkan-capable
+    // target.
+    //
+    // Note: We don't have a shared `isVulkanTarget()` helper here, so we instead
+    // treat the broader set of Khronos targets (GLSL/SPIR-V/Vulkan) as the ones
+    // where Vulkan layout warnings are relevant.
+    if (!isKhronosTarget(context->getTargetRequest()))
+        return;
+
     // Don't warn if the declaration is a vk::push_constant or shaderRecordEXT
     if (varDecl.getDecl()->hasModifier<PushConstantAttribute>() ||
         varDecl.getDecl()->hasModifier<ShaderRecordAttribute>())
