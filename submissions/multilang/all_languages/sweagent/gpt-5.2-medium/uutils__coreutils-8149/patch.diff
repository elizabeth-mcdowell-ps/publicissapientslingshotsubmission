diff --git a/src/uu/cp/src/cp.rs b/src/uu/cp/src/cp.rs
index e3f03a40d..0f8639e6b 100644
--- a/src/uu/cp/src/cp.rs
+++ b/src/uu/cp/src/cp.rs
@@ -2548,7 +2548,15 @@ fn copy_file(
     #[cfg(unix)]
     let source_is_stream = source_is_fifo
         || source_metadata.file_type().is_char_device()
-        || source_metadata.file_type().is_block_device();
+        || source_metadata.file_type().is_block_device()
+        // Treat /dev/stdin and friends as streams too. They are often symlinks
+        // to pipes or /proc/self/fd/* and must be copied via read/write rather
+        // than std::fs::copy (which can leave old bytes in the destination when
+        // the new content is shorter).
+        || source.starts_with("/dev/fd/")
+        || source == Path::new("/dev/stdin")
+        || source == Path::new("/dev/stdout")
+        || source == Path::new("/dev/stderr");
     #[cfg(not(unix))]
     let source_is_stream = false;
 
diff --git a/src/uu/cp/src/platform/linux.rs b/src/uu/cp/src/platform/linux.rs
