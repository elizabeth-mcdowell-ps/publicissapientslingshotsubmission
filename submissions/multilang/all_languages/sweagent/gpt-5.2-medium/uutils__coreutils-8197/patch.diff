+#[cfg(unix)]
+static FORWARD_PID: AtomicI32 = AtomicI32::new(0);
+
+/// Start a background thread that forwards common terminating signals to the
+/// spawned child (or its process group).
+///
+/// This matches GNU `timeout` behavior: if `timeout` is killed (e.g. SIGTERM),
+/// it should also terminate its child so it doesn't get re-parented to init.
+#[cfg(unix)]
+fn install_signal_forwarders(child_pid: libc::pid_t, foreground: bool) {
+    // When not in foreground mode, the child is expected to be in our process group,
+    // so forwarding to the group will kill it and any descendants.
+    let target: i32 = if foreground {
+        child_pid as i32
+    } else {
+        -(child_pid as i32)
+    };
+    FORWARD_PID.store(target, Ordering::Relaxed);
+
+    // Best-effort setup; if we can't register signals we just won't forward.
+    let signals = match Signals::new([SIGTERM, SIGINT, SIGHUP, SIGQUIT]) {
+        Ok(s) => s,
+        Err(_) => return,
+    };
+
+    // Leak `signals` so the iterator can live for the remainder of the process.
+    // This is acceptable for `timeout`, which is short-lived.
+    let signals: &'static mut Signals = Box::leak(Box::new(signals));
+
+    std::thread::spawn(move || {
+        for sig in signals.forever() {
+            let pid = FORWARD_PID.load(Ordering::Relaxed);
+            if pid != 0 {
+                unsafe {
+                    libc::kill(pid, sig);
+                    // Also try signaling the process group in case the child moved
+                    // into a different group (best-effort).
+                    if pid > 0 {
+                        libc::kill(-pid, sig);
+                    }
+                }
+            }
+            // Restore default handling and re-raise so `timeout` terminates normally.
+            unsafe {
+                libc::signal(sig, libc::SIG_DFL);
+                libc::raise(sig);
+            }
+        }
+    });
+}
