+import json, subprocess, textwrap, os, sys, tempfile, pathlib
+repo='/testbed'
+node_script = r'''
+import { compile } from './packages/svelte/src/compiler/index.js';
+
+const source = `<script>
+class MyStore {
+arrayOfComplexObjects = $state([{ value: "value" }])
+updateObject = (x) => {
+this.arrayOfComplexObjects = this.arrayOfComplexObjects.map(_ => ({ value:x }))
+}
+}
+const myStore = new MyStore();
+</script>
+
+{#each myStore.arrayOfComplexObjects as obj}
+<div>{obj.value}</div>
+<input bind:value={() => obj.value, (x) => myStore.updateObject(x)} />
+{/each}`;
+
+const { js } = compile(source, { generate: 'client', filename: 'App.svelte' });
+console.log(js.code);
+'''
+# write temp mjs in repo so relative imports work
+path = pathlib.Path(repo)/'tmp_repro.mjs'
+path.write_text(node_script)
+res = subprocess.run(['node', str(path)], cwd=repo, capture_output=True, text=True)
+print(res.stderr)
+print(res.stdout[:2000])
