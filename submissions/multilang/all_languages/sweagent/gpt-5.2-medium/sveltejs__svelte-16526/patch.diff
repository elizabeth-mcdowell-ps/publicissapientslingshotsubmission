diff --git a/repro_duplicate_class_field.py b/repro_duplicate_class_field.py
new file mode 100644
index 000000000..879bde36d
--- /dev/null
+++ b/repro_duplicate_class_field.py
@@ -0,0 +1,41 @@
+import subprocess, textwrap, os, sys, tempfile
+
+repo = '/testbed'
+node = 'node'
+
+code = """
+<script lang=\"ts\">
+class Hello {
+  hello() {}
+  static hello() {} // should be allowed
+}
+</script>
+"""
+
+with tempfile.TemporaryDirectory() as d:
+    svelte_file = os.path.join(d, 'Component.svelte')
+    with open(svelte_file, 'w', encoding='utf-8') as f:
+        f.write(textwrap.dedent(code).lstrip())
+
+    script = f"""
+const fs = require('fs');
+const svelte = require('{repo}/packages/svelte/compiler');
+const source = fs.readFileSync('{svelte_file}', 'utf8');
+try {{
+  svelte.compile(source, {{ filename: 'Component.svelte', dev: true, generate: 'client', runes: true }});
+  console.log('OK');
+}} catch (e) {{
+  console.error('ERROR');
+  console.error(e.code || '');
+  console.error(e.message || String(e));
+  process.exit(1);
+}}
+"""
+    js_file = os.path.join(d, 'run.js')
+    with open(js_file, 'w', encoding='utf-8') as f:
+        f.write(script)
+
+    p = subprocess.run([node, js_file], capture_output=True, text=True)
+    sys.stdout.write(p.stdout)
+    sys.stderr.write(p.stderr)
+    sys.exit(p.returncode)
