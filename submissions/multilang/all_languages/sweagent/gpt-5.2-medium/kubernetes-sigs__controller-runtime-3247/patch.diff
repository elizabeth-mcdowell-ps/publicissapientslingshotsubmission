+import subprocess, os, sys
+
+def run(cmd):
+    print(' '.join(cmd))
+    p = subprocess.run(cmd, cwd='/testbed', stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
+    print(p.stdout)
+    return p.returncode
+
+# run only manager package tests (includes envtest/integration ones)
+code = run(['bash','-lc','go test ./pkg/manager -run Test -count=1'])
+sys.exit(code)
