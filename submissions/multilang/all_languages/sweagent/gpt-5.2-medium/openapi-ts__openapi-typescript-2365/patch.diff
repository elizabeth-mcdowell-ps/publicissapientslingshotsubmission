+import type { OpenAPIV3 } from "openapi-types";
 import { type OperationMetadata, OperationMetadataStorage } from "../metadata/operation.js";
+import { OperationParameterMetadataStorage } from "../metadata/operation-parameter.js";
 
 export type ApiOperationOptions = OperationMetadata;
 
@@ -10,6 +12,20 @@ export type ApiOperationOptions = OperationMetadata;
  */
 export function ApiOperation(options: ApiOperationOptions): MethodDecorator {
   return (target, propertyKey) => {
+    // Store the operation metadata itself
     OperationMetadataStorage.defineMetadata(target, options, propertyKey);
+
+    // Also persist any inline parameters so they are picked up by the generator.
+    // This mirrors how @ApiParam/@ApiQuery/etc. contribute to OperationParameterMetadataStorage.
+    const inlineParameters = options.parameters;
+    if (Array.isArray(inlineParameters) && inlineParameters.length > 0) {
+      // mergeMetadata expects the *full* metadata value shape for this storage (an array).
+      OperationParameterMetadataStorage.mergeMetadata(
+        target,
+        inlineParameters as unknown as OpenAPIV3.ParameterObject[],
+        propertyKey,
+        true,
+      );
+    }
   };
 }
