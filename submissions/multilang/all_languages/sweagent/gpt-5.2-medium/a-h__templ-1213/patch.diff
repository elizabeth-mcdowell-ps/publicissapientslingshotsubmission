+import subprocess, textwrap, os, json, sys, tempfile, pathlib
+
+def run(cmd, cwd='/testbed'):
+    print('>',' '.join(cmd))
+    p=subprocess.run(cmd, cwd=cwd, text=True, capture_output=True)
+    print(p.stdout)
+    print(p.stderr, file=sys.stderr)
+    return p.returncode
+
+# Create a small Go program that uses templ.RenderAttributes with non-string values.
+go = r'''
+package main
+
+import (
+  "context"
+  "bytes"
+  "fmt"
+  "github.com/a-h/templ"
+)
+
+func main() {
+  var b bytes.Buffer
+  attrs := templ.Attributes{"type": "text", "value": 42}
+  _ = templ.RenderAttributes(context.Background(), &b, attrs)
+  fmt.Print(b.String())
+}
+'''
+path='/testbed/_repro_go/main.go'
+os.makedirs('/testbed/_repro_go', exist_ok=True)
+open(path,'w').write(go)
+code = run(['go','run','./_repro_go'])
+print('exit', code)
