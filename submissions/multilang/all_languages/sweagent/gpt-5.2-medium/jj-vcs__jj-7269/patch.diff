     Ok(repo)
 }
 
-// Set repository level `trunk()` alias to the default branch for "origin".
+// Set repository level `trunk()` alias to the default branch.
+//
+// Prefer "upstream" remote if it exists (common when the GitHub CLI renames
+// the original remote to "upstream" when creating a fork).
 pub fn maybe_set_repository_level_trunk_alias(
     ui: &Ui,
     workspace_command: &WorkspaceCommandHelper,
 ) -> Result<(), CommandError> {
     let git_repo = git::get_git_repo(workspace_command.repo().store())?;
-    if let Some(reference) = git_repo
-        .try_find_reference("refs/remotes/origin/HEAD")
-        .map_err(internal_error)?
-    {
-        if let Some(reference_name) = reference.target().try_name() {
-            if let Some((GitRefKind::Bookmark, symbol)) = str::from_utf8(reference_name.as_bstr())
-                .ok()
-                .and_then(|name| parse_git_ref(name.as_ref()))
-            {
-                // TODO: Can we assume the symbolic target points to the same remote?
-                let symbol = symbol.name.to_remote_symbol("origin".as_ref());
-                write_repository_level_trunk_alias(ui, workspace_command.repo_path(), symbol)?;
-            }
-        };
-    };
+
+    // Determine which remote to use.
+    // If both exist, choose upstream.
+    for remote in ["upstream", "origin"] {
+        let head_ref = format!("refs/remotes/{remote}/HEAD");
+        if let Some(reference) = git_repo
+            .try_find_reference(head_ref)
+            .map_err(internal_error)?
+        {
+            if let Some(reference_name) = reference.target().try_name() {
+                if let Some((GitRefKind::Bookmark, symbol)) =
+                    str::from_utf8(reference_name.as_bstr())
+                        .ok()
+                        .and_then(|name| parse_git_ref(name.as_ref()))
+                {
+                    // TODO: Can we assume the symbolic target points to the same remote?
+                    let symbol = symbol.name.to_remote_symbol(remote.as_ref());
+                    write_repository_level_trunk_alias(ui, workspace_command.repo_path(), symbol)?;
+                    break;
+                }
+            };
+        }
+    }
 
     Ok(())
 }
diff --git a/repro.py b/repro.py
new file mode 100644
index 000000000..0ae83a792
--- /dev/null
+++ b/repro.py
@@ -0,0 +1,38 @@
+import os, subprocess, tempfile, sys, pathlib
+
+def run(cmd, cwd=None, check=True):
+    res = subprocess.run(cmd, cwd=cwd, text=True, capture_output=True)
+    print('+', ' '.join(map(str, cmd)))
+    if res.stdout:
+        print(res.stdout)
+    if res.stderr:
+        print(res.stderr, file=sys.stderr)
+    if check:
+        res.check_returncode()
+    return res
+
+def main():
+    jj = '/testbed/target/debug/jj'
+    with tempfile.TemporaryDirectory() as td:
+        td = pathlib.Path(td)
+        repo = td/'repo'
+        repo.mkdir()
+        run(['git','init','-q'], cwd=repo)
+        (repo/'file.txt').write_text('hello\n')
+        run(['git','add','file.txt'], cwd=repo)
+        run(['git','-c','user.name=a','-c','user.email=a@a','commit','-qm','init'], cwd=repo)
+
+        upstream_bare = td/'upstream.git'
+        run(['git','init','--bare','-q', upstream_bare])
+        run(['git','remote','add','upstream', upstream_bare], cwd=repo)
+        run(['git','push','-q','upstream','master'], cwd=repo)
+        run(['git','symbolic-ref','HEAD','refs/heads/master'], cwd=upstream_bare)
+        run(['git','fetch','-q','upstream'], cwd=repo)
+
+        out = run([jj,'git','init','--colocate'], cwd=repo)
+        # show which trunk() line was printed (if any)
+        trunk_lines = [l for l in out.stdout.splitlines() if 'trunk()' in l]
+        print('TRUNK_LINES:', trunk_lines)
+
+if __name__ == '__main__':
+    main()
