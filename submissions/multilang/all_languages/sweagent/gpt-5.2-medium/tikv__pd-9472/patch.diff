+import re, pathlib, sys
+root = pathlib.Path('/testbed')
+code = (root/'pkg/mcs/resourcemanager/server/grpc_service.go').read_text()
+# Expect AcquireTokenBuckets to read keyspace id from TokenBucketsRequest (top-level), not from each TokenBucketRequest.
+# If it uses req.GetKeyspaceId() inside loop, that's the bug described.
+if re.search(r"for _, req := range request\.Requests[\s\S]*?GetKeyspaceId\(\)", code):
+    print('BUG: AcquireTokenBuckets reads keyspace id from inner TokenBucketRequest')
+    sys.exit(1)
+print('OK: AcquireTokenBuckets does not read keyspace id from inner request')
