+import re, pathlib
+root = pathlib.Path('javaparser-core/src/main/java')
+patterns = []
+for p in root.rglob('*.java'):
+    txt = p.read_text(encoding='utf-8', errors='ignore')
+    if 'setValue' in txt and '==' in txt:
+        if 'if (value == this.value)' in txt:
+            patterns.append(str(p))
+print('Files with identity comparison in setValue:', *patterns, sep='\n- ')
+# show problematic snippet from LiteralStringValueExpr
+p = pathlib.Path('javaparser-core/src/main/java/com/github/javaparser/ast/expr/LiteralStringValueExpr.java')
+text = p.read_text(encoding='utf-8')
+for line in text.splitlines():
+    if 'if (value == this.value)' in line:
+        print('Found in LiteralStringValueExpr:', line.strip())
