+#!/usr/bin/env bash
+set -euo pipefail
+./gradlew -q :compileJava
+./gradlew -q :wiremock-common:compileJava
+JOPTS=$(ls ~/.gradle/caches/modules-2/files-2.1/net.sf.jopt-simple/jopt-simple/*/jopt-simple-*.jar 2>/dev/null | head -n1 || true)
+if [ -z "$JOPTS" ]; then
+  JOPTS=$(ls ~/.gradle/caches/modules-2/files-2.1/*/jopt-simple/*/jopt-simple-*.jar 2>/dev/null | head -n1 || true)
+fi
+cat > /tmp/ReproTimeout.java <<'JAVA'
+import com.github.tomakehurst.wiremock.standalone.CommandLineOptions;
+
+public class ReproTimeout {
+  public static void main(String[] args) {
+    CommandLineOptions options = new CommandLineOptions("--timeout", "45000");
+    System.out.println(options.timeout());
+  }
+}
+JAVA
+CP="build/classes/java/main:wiremock-common/build/classes/java/main:${JOPTS}"
+javac -cp "$CP" /tmp/ReproTimeout.java
+java -cp "$CP:/tmp" ReproTimeout
