+import json
+from pathlib import Path
+import subprocess, textwrap, os, sys
+
+def compile_svelte(source: str):
+    # use repo's svelte compiler via node
+    node_script = r"""
+const svelte = require('./packages/svelte/compiler');
+const fs = require('fs');
+const src = fs.readFileSync(0, 'utf8');
+const out = svelte.compile(src, { generate: 'client', dev: false });
+process.stdout.write(JSON.stringify(out.js.code));
+""";
+    p = subprocess.run(
+        ['node', '-e', node_script],
+        input=source.encode(),
+        cwd='/testbed',
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        check=False,
+    )
+    if p.returncode != 0:
+        raise RuntimeError(p.stderr.decode())
+    return json.loads(p.stdout.decode())
+
+src = textwrap.dedent('''
+<script>
+  let x = $state(0);
+</script>
+
+{#each { length: 1 } as _, index}
+  <button type="button" onclick={() => console.log(index)}>A</button>
+  <button
+    type="button"
+    data-index={index}
+    onclick={(e) => {
+      const index = Number(e.currentTarget.dataset.index);
+      console.log(index);
+    }}>B</button>
+  <button
+    type="button"
+    data-index={index}
+    onclick={(e) => {
+      const index = Number(e.currentTarget.dataset.index);
+      x += index + 1;
+    }}>C</button>
+{/each}
+''')
+
+js = compile_svelte(src)
+print(js)
+print('\n--- contains "const i"?', 'const i =' in js)
+print('--- contains "const index" inside hoisted handler?', 'const index = Number(e.currentTarget.dataset.index)' in js)
