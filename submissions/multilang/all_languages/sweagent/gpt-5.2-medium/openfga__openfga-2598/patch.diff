diff --git a/repro.py b/repro.py
new file mode 100644
index 00000000..e774be8a
--- /dev/null
+++ b/repro.py
@@ -0,0 +1,42 @@
+import subprocess, textwrap, os, sys
+
+# Run a tiny Go program that registers two DBStatsCollectors with same namespace.
+# This mirrors current postgres.configureDB behavior.
+go = r'''
+package main
+
+import (
+  "database/sql"
+  _ "github.com/jackc/pgx/v5/stdlib"
+  "github.com/prometheus/client_golang/prometheus"
+  "github.com/prometheus/client_golang/prometheus/collectors"
+)
+
+func main() {
+  // we don't need a live DB; collector creation doesn't connect.
+  db1, _ := sql.Open("pgx", "postgres://example")
+  db2, _ := sql.Open("pgx", "postgres://example")
+
+  c1 := collectors.NewDBStatsCollector(db1, "openfga")
+  if err := prometheus.Register(c1); err != nil {
+    panic(err)
+  }
+  c2 := collectors.NewDBStatsCollector(db2, "openfga")
+  if err := prometheus.Register(c2); err != nil {
+    panic(err)
+  }
+}
+'''
+
+open('/testbed/_repro.go','w').write(go)
+
+# Use `go run` from repo module context.
+cmd = ['bash','-lc','cd /testbed && go run _repro.go']
+print('Running:', ' '.join(cmd))
+res = subprocess.run(cmd, capture_output=True, text=True)
+print('returncode', res.returncode)
+print('stdout:', res.stdout)
+print('stderr:', res.stderr)
+if res.returncode == 0:
+  print('Unexpected: no error')
+  sys.exit(1)
