+/// On a broken pipe (EPIPE), `cat` should exit silently.
+///
+/// This matches historical/coreutils behavior and avoids spurious error output
+/// in pipelines where downstream closes early (e.g. `cat /dev/zero | head`).
+fn is_broken_pipe(e: &io::Error) -> bool {
+    e.kind() == ErrorKind::BrokenPipe
+        || matches!(e.raw_os_error(), Some(code) if code == uucore::libc::EPIPE)
+}
