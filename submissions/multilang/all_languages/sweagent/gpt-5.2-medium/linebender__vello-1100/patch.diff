diff --git a/sparse_strips/vello_common/src/coarse.rs b/sparse_strips/vello_common/src/coarse.rs
index ced1a4c7..f954cd35 100644
--- a/sparse_strips/vello_common/src/coarse.rs
+++ b/sparse_strips/vello_common/src/coarse.rs
@@ -930,7 +930,10 @@ impl WideTile {
             self.cmds.push(Cmd::PopBuf);
         }
 
-        self.n_bufs -= 1;
+        // It is possible to call `pop_buf` after pushing a clip buffer that ended up
+        // being optimized away (for example when a clip path affects no tiles).
+        // In that case `n_bufs` may already be 0; avoid underflow.
+        self.n_bufs = self.n_bufs.saturating_sub(1);
     }
 
     /// Apply an opacity to the whole buffer.
diff --git a/sparse_strips/vello_cpu/src/fine/mod.rs b/sparse_strips/vello_cpu/src/fine/mod.rs
