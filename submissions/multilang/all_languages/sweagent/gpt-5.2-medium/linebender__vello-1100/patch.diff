@@ -584,8 +584,13 @@ impl<S: Simd, T: FineKernel<S>> Fine<S, T> {
     }
 
     fn blend(&mut self, blend_mode: BlendMode) {
-        let (source_buffer, rest) = self.blend_buf.split_last_mut().unwrap();
-        let target_buffer = rest.last_mut().unwrap();
+        // If the buffer stack is unexpectedly empty/unbalanced, avoid panicking.
+        let Some((source_buffer, rest)) = self.blend_buf.split_last_mut() else {
+            return;
+        };
+        let Some(target_buffer) = rest.last_mut() else {
+            return;
+        };
 
         T::blend(
             self.simd,
@@ -599,13 +604,24 @@ impl<S: Simd, T: FineKernel<S>> Fine<S, T> {
     }
 
     fn clip(&mut self, x: usize, width: usize, alphas: Option<&[u8]>) {
-        let (source_buffer, rest) = self.blend_buf.split_last_mut().unwrap();
-        let target_buffer = rest.last_mut().unwrap();
+        // If the buffer stack is unexpectedly empty/unbalanced, avoid panicking.
+        let Some((source_buffer, rest)) = self.blend_buf.split_last_mut() else {
+            return;
+        };
+        let Some(target_buffer) = rest.last_mut() else {
+            return;
+        };
+
+        // Guard against out-of-bounds when we get an empty or inconsistent clip span.
+        let start = x.saturating_mul(TILE_HEIGHT_COMPONENTS);
+        let len = width.saturating_mul(TILE_HEIGHT_COMPONENTS);
+        if len == 0 || start >= source_buffer.len() || start >= target_buffer.len() {
+            return;
+        }
+        let end = (start + len).min(source_buffer.len()).min(target_buffer.len());
 
-        let source_buffer =
-            &mut source_buffer[x * TILE_HEIGHT_COMPONENTS..][..TILE_HEIGHT_COMPONENTS * width];
-        let target_buffer =
-            &mut target_buffer[x * TILE_HEIGHT_COMPONENTS..][..TILE_HEIGHT_COMPONENTS * width];
+        let source_buffer = &mut source_buffer[start..end];
+        let target_buffer = &mut target_buffer[start..end];
 
         T::alpha_composite_buffer(self.simd, target_buffer, source_buffer, alphas);
     }
