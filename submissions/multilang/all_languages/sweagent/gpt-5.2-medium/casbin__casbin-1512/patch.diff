diff --git a/examples/blp_model.conf b/examples/blp_model.conf
new file mode 100644
index 0000000..8dd7d00
--- /dev/null
+++ b/examples/blp_model.conf
@@ -0,0 +1,21 @@
+[request_definition]
+r = sub, obj, act
+
+[policy_definition]
+p = sub, obj, act
+
+[policy_effect]
+e = some(where (p.eft == allow))
+
+[matchers]
+# Bell–LaPadula (BLP):
+# - "no read up"   : subject level >= object level
+# - "no write down": subject level <= object level
+#
+# We model security levels as numeric values and store the subject level in p.sub
+# and the object level in p.obj.
+#
+# Policy semantics:
+# - p.act == "read"  means: subject level p.sub can read objects with level <= p.obj
+# - p.act == "write" means: subject level p.sub can write objects with level >= p.obj
+m = r.sub == p.sub && r.act == p.act && ((r.act == "read" && r.obj <= p.obj) || (r.act == "write" && r.obj >= p.obj))
diff --git a/examples/blp_policy.csv b/examples/blp_policy.csv
