@@ -244,7 +244,13 @@ public class ServiceUtils {
                 .withName(name)
                 .withProtocol(protocol)
                 .withPort(port)
-                .withNewTargetPort(targetPort)
+                // Use named targetPort (when possible) rather than an explicit number.
+                // This is considered a Kubernetes best practice and makes the Service more resilient
+                // to container port changes as long as the port name stays the same.
+                //
+                // The Fabric8 builder exposes only the "withNewTargetPort(...)" methods for setting
+                // the IntOrString value. Passing a String results in a named targetPort.
+                .withNewTargetPort(name != null && !name.isEmpty() ? name : String.valueOf(targetPort))
                 .withNodePort(nodePort)
                 .build();
     }
