+import io.fabric8.kubernetes.api.model.ServicePort;
+import io.strimzi.operator.cluster.model.ServiceUtils;
+
+public class reproduce_named_ports {
+    public static void main(String[] args) {
+        ServicePort sp = ServiceUtils.createServicePort("tcp-ctrlplane", 9090, 9090, "TCP");
+        System.out.println("targetPort=" + sp.getTargetPort());
+    }
+}
