@@ -0,0 +1,27 @@
+using Terminal.Gui;
+using Terminal.Gui.Views;
+using Terminal.Gui.ViewBase;
+
+// Create a simple test
+var selector = new OptionSelector
+{
+    Orientation = Orientation.Horizontal,
+};
+
+// Labels set after construction
+selector.Labels = ["IMDb (Recommended)", "TMDb"];
+selector.Values = [0, 1];
+
+Console.WriteLine($"Selector Width: {selector.Width}");
+Console.WriteLine($"Selector Frame.Width: {selector.Frame.Width}");
+
+// Layout the selector
+selector.Layout();
+
+Console.WriteLine($"After Layout - Selector Width: {selector.Width}");
+Console.WriteLine($"After Layout - Selector Frame.Width: {selector.Frame.Width}");
+
+foreach (var cb in selector.SubViews.OfType<CheckBox>())
+{
+    Console.WriteLine($"CheckBox '{cb.Title}': Frame={cb.Frame}, Width={cb.Width}");
+}
