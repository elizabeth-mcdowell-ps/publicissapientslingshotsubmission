new file mode 100644
index 00000000..22f3c69c
--- /dev/null
+++ b/src/SamplesApp/Settings.XamlStyler
@@ -0,0 +1,28 @@
+<?xml version="1.0" encoding="utf-8"?>
+<XamlStylerConfiguration>
+  <!-- Attribute formatting -->
+  <AttributeIndentation>Mixed</AttributeIndentation>
+  <AttributeOrderingRuleGroups>
+    <AttributeOrderingRuleGroup Name="Default">
+      <AttributeOrderingRule Name="x:Class" />
+      <AttributeOrderingRule Name="x:Name" />
+      <AttributeOrderingRule Name="xmlns:*" />
+      <AttributeOrderingRule Name="xmlns" />
+      <AttributeOrderingRule Name="mc:Ignorable" />
+      <AttributeOrderingRule Name="d:*" />
+      <AttributeOrderingRule Name="*" />
+    </AttributeOrderingRuleGroup>
+  </AttributeOrderingRuleGroups>
+  <AttributesToFormatOnSave>None</AttributesToFormatOnSave>
+  <CommentSpaces>1</CommentSpaces>
+  <EnableAttributeReordering>True</EnableAttributeReordering>
+  <IndentSize>4</IndentSize>
+  <IndentWithTabs>True</IndentWithTabs>
+  <KeepFirstAttributeOnSameLine>True</KeepFirstAttributeOnSameLine>
+  <MaxAttributeCharactersPerLine>0</MaxAttributeCharactersPerLine>
+  <MaxAttributesPerLine>0</MaxAttributesPerLine>
+  <PutEndingBracketOnNewLine>False</PutEndingBracketOnNewLine>
+  <RemoveExtraSpaces>True</RemoveExtraSpaces>
+  <ReorderVSM>True</ReorderVSM>
+  <Tolerance>4</Tolerance>
+</XamlStylerConfiguration>
