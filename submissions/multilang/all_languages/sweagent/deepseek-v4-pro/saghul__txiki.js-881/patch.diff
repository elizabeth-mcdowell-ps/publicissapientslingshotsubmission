diff --git a/src/mod_fswatch.c b/src/mod_fswatch.c
index 114c6d76..383dbaec 100644
--- a/src/mod_fswatch.c
+++ b/src/mod_fswatch.c
@@ -30,6 +30,7 @@ typedef struct {
     JSContext *ctx;
     uv_fs_event_t handle;
     JSValue callback;
+    JSValue this_val;
     int closed;
     int finalized;
 } TJSFsWatch;
@@ -60,6 +61,8 @@ static void tjs_fswatch_finalizer(JSRuntime *rt, JSValue val) {
     TJSFsWatch *fw = tjs_fswatch_get(val);
     if (fw) {
         JS_FreeValueRT(rt, fw->callback);
+        JS_FreeValueRT(rt, fw->this_val);
+        fw->this_val = JS_UNDEFINED;
         fw->finalized = 1;
         if (fw->closed) {
             tjs__free(fw);
@@ -73,6 +76,7 @@ static void tjs_fswatch_mark(JSRuntime *rt, JSValue val, JS_MarkFunc *mark_func)
     TJSFsWatch *fw = tjs_fswatch_get(val);
     if (fw) {
         JS_MarkValue(rt, fw->callback, mark_func);
+        JS_MarkValue(rt, fw->this_val, mark_func);
     }
 }
 
@@ -87,6 +91,11 @@ static JSValue tjs_fswatch_close(JSContext *ctx, JSValue this_val, int argc, JSV
     if (!fw) {
         return JS_EXCEPTION;
     }
+    if (!JS_IsUndefined(fw->this_val)) {
+        JSValue val = fw->this_val;
+        fw->this_val = JS_UNDEFINED;
+        JS_FreeValue(ctx, val);
+    }
     maybe_close(fw);
     return JS_UNDEFINED;
 }
@@ -206,6 +215,7 @@ static JSValue tjs_fs_watch(JSContext *ctx, JSValue this_val, int argc, JSValue
     fw->ctx = ctx;
     fw->handle.data = fw;
     fw->callback = JS_DupValue(ctx, argv[1]);
+    fw->this_val = JS_DupValue(ctx, obj);
 
     JS_SetOpaque(obj, fw);
     return obj;
