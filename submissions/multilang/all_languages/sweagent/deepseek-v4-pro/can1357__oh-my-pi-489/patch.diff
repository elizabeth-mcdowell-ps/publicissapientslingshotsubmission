+                if (!diff.includes("\n")) return;
+                const lastNewlineIndex = diff.lastIndexOf("\n");
+                if (lastNewlineIndex < 0) return;
+                const diffForCheck = diff.endsWith("\n") ? diff : diff.slice(0, lastNewlineIndex + 1);
