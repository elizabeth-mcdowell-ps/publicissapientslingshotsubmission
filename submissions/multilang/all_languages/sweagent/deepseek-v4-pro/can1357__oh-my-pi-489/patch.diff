+
+        async #promptAgentWithIdleRetry(messages: AgentMessage[], options?: { toolChoice?: ToolChoice }): Promise<void> {
+                const deadline = Date.now() + 30_000;
+                for (;;) {
+                        try {
+                                await this.agent.prompt(messages, options);
+                                return;
+                        } catch (err) {
