+                                                toolCallId: toolCall.id,
+                                                path,
+                                                error: `Failed to find expected lines in ${path}:\n${missing}`,
+                                        });
+                                        this.agent.abort();
+                                }
+                                return;
+                        }
+                        if (assistantEvent.type === "toolcall_delta") return;
+                        void this.#checkRemovedLinesAsync(toolCall.id, path, resolvedPath, removedLines);
+                        return;
+                }
