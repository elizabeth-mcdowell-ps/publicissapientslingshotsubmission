diff --git a/test/assets/output/preset-wind4-important-string.css b/test/assets/output/preset-wind4-important-string.css
new file mode 100644
index 000000000..e21acee90
--- /dev/null
+++ b/test/assets/output/preset-wind4-important-string.css
@@ -0,0 +1,16 @@
+/* layer: properties */
+@property --un-text-opacity{syntax:"<percentage>";inherits:false;initial-value:100%;}
+@property --un-bg-opacity{syntax:"<percentage>";inherits:false;initial-value:100%;}
+/* layer: default */
+#app :is(.text-red){color:color-mix(in srgb, var(--colors-red-DEFAULT) var(--un-text-opacity), transparent) /* oklch(70.4% 0.191 22.216) */;}
+#app :is(.text-opacity-50){--un-text-opacity:50%;}
+#app :is(.after\:m-4)::after{margin:calc(var(--spacing) * 4);}
+#app :is(.dark .dark\:bg-blue){background-color:color-mix(in srgb, var(--colors-blue-DEFAULT) var(--un-bg-opacity), transparent) /* oklch(70.7% 0.165 254.624) */;}
+#app :is(.selection\:bg-yellow) *::selection,
+#app :is(.selection\:bg-yellow)::selection{background-color:color-mix(in srgb, var(--colors-yellow-DEFAULT) var(--un-bg-opacity), transparent) /* oklch(85.2% 0.199 91.936) */;}
+@supports (color: color-mix(in lab, red, red)){
+#app :is(.text-red){color:color-mix(in oklab, var(--colors-red-DEFAULT) var(--un-text-opacity), transparent) /* oklch(70.4% 0.191 22.216) */;}
+#app :is(.dark .dark\:bg-blue){background-color:color-mix(in oklab, var(--colors-blue-DEFAULT) var(--un-bg-opacity), transparent) /* oklch(70.7% 0.165 254.624) */;}
+#app :is(.selection\:bg-yellow) *::selection{background-color:color-mix(in oklab, var(--colors-yellow-DEFAULT) var(--un-bg-opacity), transparent) /* oklch(85.2% 0.199 91.936) */;}
+#app :is(.selection\:bg-yellow)::selection{background-color:color-mix(in oklab, var(--colors-yellow-DEFAULT) var(--un-bg-opacity), transparent) /* oklch(85.2% 0.199 91.936) */;}
+}
