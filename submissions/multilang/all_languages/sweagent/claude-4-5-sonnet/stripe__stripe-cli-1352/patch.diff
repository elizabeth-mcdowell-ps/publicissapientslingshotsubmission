+func (s *persistentVolumeSyncer) ModifyController(ctx *synccontext.RegisterContext, builder *builder.Builder) (*builder.Builder, error) {
+	// Create a custom event handler to ensure we properly handle PVC deletion events
+	pvcHandler := &handler.Funcs{
+		CreateFunc: func(_ context.Context, e event.TypedCreateEvent[client.Object], q workqueue.TypedRateLimitingInterface[ctrl.Request]) {
+			requests := mapPVCs(nil, e.Object)
+			for _, req := range requests {
+				q.Add(req)
+			}
+		},
+		UpdateFunc: func(_ context.Context, e event.TypedUpdateEvent[client.Object], q workqueue.TypedRateLimitingInterface[ctrl.Request]) {
+			// Try to get volume name from new object first, then old object
+			var volumeName string
+			if newPVC, ok := e.ObjectNew.(*corev1.PersistentVolumeClaim); ok && newPVC.Spec.VolumeName != "" {
+				volumeName = newPVC.Spec.VolumeName
+			} else if oldPVC, ok := e.ObjectOld.(*corev1.PersistentVolumeClaim); ok && oldPVC.Spec.VolumeName != "" {
+				volumeName = oldPVC.Spec.VolumeName
+			}
+			
+			if volumeName != "" {
+				q.Add(reconcile.Request{
+					NamespacedName: types.NamespacedName{
+						Name: volumeName,
+					},
+				})
+			}
+		},
+		DeleteFunc: func(_ context.Context, e event.TypedDeleteEvent[client.Object], q workqueue.TypedRateLimitingInterface[ctrl.Request]) {
+			// On delete, always try to reconcile the PV if we have a volume name
+			requests := mapPVCs(nil, e.Object)
+			for _, req := range requests {
+				q.Add(req)
+			}
+		},
+	}
+	
+	return builder.Watches(&corev1.PersistentVolumeClaim{}, pvcHandler), nil
