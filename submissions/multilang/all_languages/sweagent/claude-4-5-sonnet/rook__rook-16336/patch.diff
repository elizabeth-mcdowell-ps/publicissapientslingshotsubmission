+package main
+
+import (
+"fmt"
+)
+
+// Simulate the current logic
+func currentLogic(totalKeys int) int {
+// This is what the code currently does
+currentKeyCount := totalKeys
+priorKeyCount := currentKeyCount // Bug: this includes the active key
+return priorKeyCount
+}
+
+// Simulate the fixed logic
+func fixedLogic(totalKeys int) int {
+// This is what the code should do
+currentKeyCount := totalKeys
+// Prior keys = total keys - 1 (the active key)
+priorKeyCount := currentKeyCount - 1
+if priorKeyCount < 0 {
+priorKeyCount = 0
+}
+return priorKeyCount
+}
+
+func main() {
+testCases := []struct {
+scenario  string
+totalKeys int
+}{
+{"Fresh deployment (4 keys: rbd-node.1, rbd-prov.1, cephfs-node.1, cephfs-prov.1)", 1},
+{"After first rotation (2 keys per component: .1 and .2)", 2},
+{"After second rotation (3 keys: .1, .2, .3)", 3},
+{"With keepPriorKeyCountMax=1 (2 keys: .3 and .4, others deleted)", 2},
+}
+
+fmt.Println("Demonstrating the PriorKeyCount calculation issue:")
+fmt.Println("=" * 60)
+fmt.Println()
+
+for _, tc := range testCases {
+current := currentLogic(tc.totalKeys)
+fixed := fixedLogic(tc.totalKeys)
+
+fmt.Printf("Scenario: %s\n", tc.scenario)
+fmt.Printf("  Total keys in Ceph: %d\n", tc.totalKeys)
+fmt.Printf("  Current (buggy) PriorKeyCount: %d\n", current)
+fmt.Printf("  Fixed PriorKeyCount: %d\n", fixed)
+
+if current != fixed {
+fmt.Printf("  ❌ INCORRECT: Shows %d prior keys when there are actually %d\n", current, fixed)
+} else {
+fmt.Printf("  ✓ Correct\n")
+}
+fmt.Println()
+}
+}
