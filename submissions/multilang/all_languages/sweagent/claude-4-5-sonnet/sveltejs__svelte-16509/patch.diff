+#!/usr/bin/env node
+/**
+ * Test script to verify that params are correctly passed to components
+ */
+
+import fs from 'fs';
+import path from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+
+console.log('Verifying params implementation...\n');
+
+let errors = 0;
+
+// Test 1: Check write_types/index.js for PageProps and LayoutProps
+console.log('1. Checking write_types/index.js...');
+const writeTypesPath = path.join(__dirname, 'packages/kit/src/core/sync/write_types/index.js');
+const writeTypesContent = fs.readFileSync(writeTypesPath, 'utf8');
+
+if (writeTypesContent.includes('export type PageProps = { data: PageData; form: ActionData; params: RouteParams }')) {
+  console.log('   ✓ PageProps with server includes params');
+} else {
+  console.log('   ✗ PageProps with server missing params');
+  errors++;
+}
+
+if (writeTypesContent.includes('export type PageProps = { data: PageData; params: RouteParams }')) {
+  console.log('   ✓ PageProps without server includes params');
+} else {
+  console.log('   ✗ PageProps without server missing params');
+  errors++;
+}
+
+if (writeTypesContent.includes('export type LayoutProps = { data: LayoutData; params: LayoutParams; children: import("svelte").Snippet }')) {
+  console.log('   ✓ LayoutProps includes params');
+} else {
+  console.log('   ✗ LayoutProps missing params');
+  errors++;
+}
+
+// Test 2: Check write_root.js for params in component props
+console.log('\n2. Checking write_root.js...');
+const writeRootPath = path.join(__dirname, 'packages/kit/src/core/sync/write_root.js');
+const writeRootContent = fs.readFileSync(writeRootPath, 'utf8');
+
+if (writeRootContent.includes('{params}')) {
+  console.log('   ✓ Components receive {params} prop');
+} else {
+  console.log('   ✗ Components missing {params} prop');
+  errors++;
+}
+
+if (writeRootContent.includes('let { stores, page, constructors, components = [], form, params')) {
+  console.log('   ✓ Root component declares params in Svelte 5 $props');
+} else {
+  console.log('   ✗ Root component missing params in Svelte 5 $props');
+  errors++;
+}
+
+if (writeRootContent.includes('export let params;')) {
+  console.log('   ✓ Root component declares params in Svelte 4');
+} else {
+  console.log('   ✗ Root component missing params in Svelte 4');
+  errors++;
+}
+
+// Test 3: Check client.js for params in navigation result props
+console.log('\n3. Checking client.js...');
+const clientPath = path.join(__dirname, 'packages/kit/src/runtime/client/client.js');
+const clientContent = fs.readFileSync(clientPath, 'utf8');
+
+if (clientContent.includes('props: {\n\t\t\t\t// @ts-ignore Somehow it\'s getting SvelteComponent and SvelteComponentDev mixed up\n\t\t\t\tconstructors: compact(branch).map((branch_node) => branch_node.node.component),\n\t\t\t\tpage: clone_page(page),\n\t\t\t\tparams')) {
+  console.log('   ✓ Navigation result includes params in props');
+} else if (clientContent.includes('params') && clientContent.includes('props: {')) {
+  console.log('   ✓ Navigation result includes params in props (formatting may differ)');
+} else {
+  console.log('   ✗ Navigation result missing params in props');
+  errors++;
+}
+
+// Test 4: Check types.d.ts for params in NavigationFinished type
+console.log('\n4. Checking client types.d.ts...');
+const clientTypesPath = path.join(__dirname, 'packages/kit/src/runtime/client/types.d.ts');
+const clientTypesContent = fs.readFileSync(clientTypesPath, 'utf8');
+
+if (clientTypesContent.includes('params: Record<string, string>;') && 
+    clientTypesContent.includes('export type NavigationFinished')) {
+  console.log('   ✓ NavigationFinished type includes params');
+} else {
+  console.log('   ✗ NavigationFinished type missing params');
+  errors++;
+}
+
+// Test 5: Check server render.js for params in props
+console.log('\n5. Checking server render.js...');
+const renderPath = path.join(__dirname, 'packages/kit/src/runtime/server/page/render.js');
+const renderContent = fs.readFileSync(renderPath, 'utf8');
+
+if (renderContent.includes('params: /** @type {Record<string, any>} */ (event.params)') &&
+    renderContent.includes('form: form_value,')) {
+  console.log('   ✓ Server-side rendering includes params in props');
+} else {
+  console.log('   ✗ Server-side rendering missing params in props');
+  errors++;
+}
+
+// Summary
+console.log('\n' + '='.repeat(50));
+if (errors === 0) {
+  console.log('✓ All checks passed! Implementation looks correct.');
+  process.exit(0);
+} else {
+  console.log(`✗ ${errors} check(s) failed. Please review the implementation.`);
+  process.exit(1);
+}
