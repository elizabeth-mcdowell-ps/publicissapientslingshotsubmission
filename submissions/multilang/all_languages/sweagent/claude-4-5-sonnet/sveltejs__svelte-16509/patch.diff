+// Test script to verify params are passed to components
+import { write_root } from './packages/kit/src/core/sync/write_root.js';
+import { write_all_types } from './packages/kit/src/core/sync/write_types/index.js';
+import create_manifest_data from './packages/kit/src/core/sync/create_manifest_data/index.js';
+import options from './packages/kit/src/core/config/options.js';
+import { fileURLToPath } from 'url';
+import path from 'path';
+import fs from 'fs';
+
+const cwd = fileURLToPath(new URL('./packages/kit/src/core/sync/write_types/test', import.meta.url));
+const dir = 'slugs';
+
+const initial = options({}, 'config');
+initial.kit.files.assets = path.resolve(cwd, 'static');
+initial.kit.files.params = path.resolve(cwd, dir, 'params');
+initial.kit.files.routes = path.resolve(cwd, dir);
+initial.kit.outDir = path.resolve(cwd, path.join(dir, '.svelte-kit'));
+
+const manifest = create_manifest_data({
+  config: initial
+});
+
+// Write types
+write_all_types(initial, manifest);
+
+// Write root
+const output = path.join(initial.kit.outDir, 'generated');
+fs.mkdirSync(output, { recursive: true });
+write_root(manifest, output);
+
+// Check if root.svelte includes params
+const root_content = fs.readFileSync(path.join(output, 'root.svelte'), 'utf8');
+console.log('Checking root.svelte for params...');
+if (root_content.includes('{params}')) {
+  console.log('✓ root.svelte includes {params} prop in components');
+} else {
+  console.log('✗ root.svelte does NOT include {params} prop in components');
+  console.log(root_content.substring(0, 500));
+}
+
+if (root_content.includes('export let params') || root_content.includes('let { stores, page, constructors, components = [], form, params')) {
+  console.log('✓ root.svelte declares params as a prop');
+} else {
+  console.log('✗ root.svelte does NOT declare params as a prop');
+}
+
+// Check if types include params
+const types_path = path.join(initial.kit.outDir, 'types/src/core/sync/write_types/test/slugs/[slug]/$types.d.ts');
+const types_content = fs.readFileSync(types_path, 'utf8');
+console.log('\nChecking $types.d.ts for params...');
+if (types_content.includes('params: RouteParams')) {
+  console.log('✓ PageProps includes params: RouteParams');
+} else {
+  console.log('✗ PageProps does NOT include params: RouteParams');
+}
+
+const layout_types_path = path.join(initial.kit.outDir, 'types/src/core/sync/write_types/test/slugs/$types.d.ts');
+const layout_types_content = fs.readFileSync(layout_types_path, 'utf8');
+if (layout_types_content.includes('params: LayoutParams')) {
+  console.log('✓ LayoutProps includes params: LayoutParams');
+} else {
+  console.log('✗ LayoutProps does NOT include params: LayoutParams');
+}
+
+console.log('\n✓ All checks passed!');
