diff --git a/src/libcrun/cgroup-systemd.c b/src/libcrun/cgroup-systemd.c
index a3d8fc73..e2addb73 100644
--- a/src/libcrun/cgroup-systemd.c
+++ b/src/libcrun/cgroup-systemd.c
@@ -108,7 +108,7 @@ property_missing_p (char **missing_properties, const char *property)
 }
 
 static void
-get_systemd_scope_and_slice (const char *id, const char *cgroup_path, char **scope, char **slice)
+get_systemd_scope_and_slice (const char *id, const char *cgroup_path, char **scope, char **slice, int cgroup_mode)
 {
   char *n;
 
@@ -134,6 +134,22 @@ get_systemd_scope_and_slice (const char *id, const char *cgroup_path, char **sco
       n = strchr (*slice, ':');
       if (n)
         *n = '\0';
+      
+      /* Apply default slice when empty, as per runc systemd docs:
+       * If empty, it defaults to system.slice, except when cgroup v2 is used 
+       * and rootless container is created, in which case it defaults to user.slice.
+       */
+      if ((*slice)[0] == '\0')
+        {
+          const char *default_slice = "system.slice";
+          
+          /* For cgroup v2 (unified mode) with rootless, use user.slice */
+          if (cgroup_mode == CGROUP_MODE_UNIFIED && geteuid () != 0)
+            default_slice = "user.slice";
+          
+          free (*slice);
+          *slice = xstrdup (default_slice);
+        }
     }
 }
 
@@ -1863,7 +1879,7 @@ libcrun_cgroup_enter_systemd (struct libcrun_cgroup_args *args,
   if (UNLIKELY (cgroup_mode < 0))
     return cgroup_mode;
 
-  get_systemd_scope_and_slice (id, cgroup_path, &scope, &slice);
+  get_systemd_scope_and_slice (id, cgroup_path, &scope, &slice, cgroup_mode);
 
   for (;;)
     {
