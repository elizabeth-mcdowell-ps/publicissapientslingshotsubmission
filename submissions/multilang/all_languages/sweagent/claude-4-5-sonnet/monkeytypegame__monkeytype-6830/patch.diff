+echo ""
+echo "Running all tests to verify the fix..."
+echo ""
+
+# Run frontend tests
+echo "1. Running frontend tests..."
+cd /testbed/frontend && npm test --silent 2>&1 | grep -E "(Test Files|Tests)" | tail -2
+if [ $? -eq 0 ]; then
+    echo "   ✅ Frontend tests passed"
+else
+    echo "   ❌ Frontend tests failed"
+    exit 1
+fi
+
+echo ""
+
+# Run backend tests
+echo "2. Running backend tests..."
+cd /testbed/backend && npm test --silent 2>&1 | grep -E "(Test Files|Tests)" | tail -2
+if [ $? -eq 0 ]; then
+    echo "   ✅ Backend tests passed"
+else
+    echo "   ❌ Backend tests failed"
+    exit 1
+fi
+
+echo ""
+
+# Run the specific bug fix test
+echo "3. Running bug fix specific tests..."
+cd /testbed/frontend && npm test -- __tests__/bugs/punctuation-numbers-fix.spec.ts --silent 2>&1 | grep -E "(Test Files|Tests)" | tail -2
+if [ $? -eq 0 ]; then
+    echo "   ✅ Bug fix tests passed"
+else
+    echo "   ❌ Bug fix tests failed"
+    exit 1
+fi
+
+echo ""
+echo "=== All Tests Passed! ==="
+echo ""
+echo "Summary of changes:"
+echo "  - Modified frontend/src/ts/config.ts"
+echo "    Changed saveFullConfigToLocalStorage() to only save non-default values to DB"
+echo ""
+echo "  - Modified frontend/src/ts/controllers/account-controller.ts"
+echo "    Changed config merging logic to prefer local values for fields at defaults"
+echo ""
+echo "  - Added frontend/__tests__/bugs/punctuation-numbers-fix.spec.ts"
+echo "    New test suite to verify the fix"
+echo ""
+echo "The fix ensures that punctuation and numbers settings are preserved"
+echo "when users refresh the page, even before changes are saved to the database."
