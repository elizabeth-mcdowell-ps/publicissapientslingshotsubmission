+#!/usr/bin/env node
+'use strict';
+
+var rangeBy = require( './lib/node_modules/@stdlib/stats/base/range-by' );
+var toAccessorArray = require( './lib/node_modules/@stdlib/array/base/to-accessor-array' );
+
+function accessor( v ) {
+    if ( v === void 0 ) {
+        return;
+    }
+    return v * 2.0;
+}
+
+console.log( 'Testing range-by with regular arrays:' );
+var x = [ 1.0, -2.0, -4.0, 5.0, 0.0, 3.0 ];
+var v = rangeBy( x.length, x, 1, accessor );
+console.log( 'Regular array result:', v );
+console.log( 'Expected: 18.0' );
+console.log( '' );
+
+console.log( 'Testing range-by.ndarray with regular arrays:' );
+v = rangeBy.ndarray( x.length, x, 1, 0, accessor );
+console.log( 'Regular array result:', v );
+console.log( 'Expected: 18.0' );
+console.log( '' );
+
+console.log( 'Testing range-by.ndarray with accessor arrays:' );
+var y = toAccessorArray( x );
+v = rangeBy.ndarray( y.length, y, 1, 0, accessor );
+console.log( 'Accessor array result:', v );
+console.log( 'Expected: 18.0' );
+console.log( '' );
+
+console.log( 'Testing range-by with accessor arrays (via main entry):' );
+v = rangeBy( y.length, y, 1, accessor );
+console.log( 'Accessor array result:', v );
+console.log( 'Expected: 18.0' );
+console.log( '' );
+
+console.log( 'All tests completed!' );
