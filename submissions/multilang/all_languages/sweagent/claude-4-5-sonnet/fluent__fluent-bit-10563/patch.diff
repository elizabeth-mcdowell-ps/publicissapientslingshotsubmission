diff --git a/tests/src/test_cases/widgets/test_image_cache.c b/tests/src/test_cases/widgets/test_image_cache.c
new file mode 100644
index 000000000..05f887847
--- /dev/null
+++ b/tests/src/test_cases/widgets/test_image_cache.c
@@ -0,0 +1,87 @@
+/**
+ * Test to demonstrate the memory leak fix in image widget
+ * This test verifies that when switching images, the old cache entries are properly dropped
+ */
+
+#if LV_BUILD_TEST
+#include "../lvgl.h"
+#include "../../lvgl_private.h"
+
+#include "unity/unity.h"
+
+LV_IMAGE_DECLARE(test_img_lvgl_logo_png);
+LV_IMAGE_DECLARE(test_arc_bg);
+
+void setUp(void)
+{
+    /* Function run before every test */
+}
+
+void tearDown(void)
+{
+    /* Function run after every test */
+    lv_obj_clean(lv_screen_active());
+}
+
+/**
+ * Test that switching images properly drops old cache entries
+ */
+void test_image_cache_drop_on_src_change(void)
+{
+    /* Create an image widget */
+    lv_obj_t * img = lv_image_create(lv_screen_active());
+    
+    /* Set initial source */
+    lv_image_set_src(img, &test_img_lvgl_logo_png);
+    
+    /* Switch to a different source - old cache entry should be dropped */
+    lv_image_set_src(img, &test_arc_bg);
+    
+    /* Switch back - old cache entry should be dropped */
+    lv_image_set_src(img, &test_img_lvgl_logo_png);
+    
+    /* Switch to NULL - cache should be dropped */
+    lv_image_set_src(img, NULL);
+    
+    /* If we get here without crashes, the test passes */
+    TEST_ASSERT_EQUAL(1, 1);
+}
+
+/**
+ * Test that destroying an image widget drops its cache entry
+ */
+void test_image_cache_drop_on_delete(void)
+{
+    /* Create an image widget */
+    lv_obj_t * img = lv_image_create(lv_screen_active());
+    
+    /* Set source */
+    lv_image_set_src(img, &test_img_lvgl_logo_png);
+    
+    /* Delete the widget - cache should be dropped */
+    lv_obj_delete(img);
+    
+    /* If we get here without crashes, the test passes */
+    TEST_ASSERT_EQUAL(1, 1);
+}
+
+/**
+ * Test multiple rapid image switches
+ */
+void test_image_multiple_switches(void)
+{
+    lv_obj_t * img = lv_image_create(lv_screen_active());
+    
+    /* Rapidly switch between images multiple times */
+    for(int i = 0; i < 10; i++) {
+        lv_image_set_src(img, &test_img_lvgl_logo_png);
+        lv_image_set_src(img, &test_arc_bg);
+    }
+    
+    /* Clean up */
+    lv_obj_delete(img);
+    
+    TEST_ASSERT_EQUAL(1, 1);
+}
+
+#endif
