+package main
+
+import (
+"encoding/json"
+"fmt"
+"sync"
+"time"
+
+"github.com/nats-io/nats-server/v2/server"
+"github.com/nats-io/nats.go"
+)
+
+func main() {
+fmt.Println("Testing batch publish isolated reads...")
+
+// Create a simple cluster
+opts := server.Options{
+Host:      "127.0.0.1",
+Port:      4222,
+JetStream: true,
+StoreDir:  "/tmp/test_nats_batch",
+}
+
+s, err := server.NewServer(&opts)
+if err != nil {
+panic(err)
+}
+
+go s.Start()
+if !s.ReadyForConnections(10 * time.Second) {
+panic("Server not ready")
+}
+defer s.Shutdown()
+
+// Connect to server
+nc, err := nats.Connect("nats://127.0.0.1:4222")
+if err != nil {
+panic(err)
+}
+defer nc.Close()
+
+js, err := nc.JetStream()
+if err != nil {
+panic(err)
+}
+
+// Create a stream with batch publish enabled
+_, err = js.AddStream(&nats.StreamConfig{
+Name:              "TEST",
+Subjects:          []string{"test.>"},
+AllowAtomicPublish: true,
+})
+if err != nil {
+panic(err)
+}
+
+// Start a goroutine that continuously reads messages
+var wg sync.WaitGroup
+wg.Add(1)
+messagesObserved := make([]int, 0)
+var mu sync.Mutex
+stopReading := make(chan struct{})
+
+go func() {
+defer wg.Done()
+ticker := time.NewTicker(10 * time.Millisecond)
+defer ticker.Stop()
+
+for {
+select {
+case <-stopReading:
+return
+case <-ticker.C:
+// Try to get stream info which shows last sequence
+info, err := js.StreamInfo("TEST")
+if err == nil && info.State.Msgs > 0 {
+mu.Lock()
+messagesObserved = append(messagesObserved, int(info.State.Msgs))
+mu.Unlock()
+}
+}
+}
+}()
+
+// Publish a batch of 10 messages
+batchId := "test-batch-1"
+for i := 1; i <= 10; i++ {
+m := nats.NewMsg(fmt.Sprintf("test.%d", i))
+m.Data = []byte(fmt.Sprintf("message %d", i))
+m.Header.Set("Nats-Batch-Id", batchId)
+m.Header.Set("Nats-Batch-Sequence", fmt.Sprintf("%d", i))
+if i == 10 {
+m.Header.Set("Nats-Batch-Commit", "10")
+}
+
+resp, err := nc.RequestMsg(m, time.Second)
+if err != nil {
+fmt.Printf("Error publishing message %d: %v\n", i, err)
+continue
+}
+
+var pubAck server.JSPubAckResponse
+if err := json.Unmarshal(resp.Data, &pubAck); err != nil {
+fmt.Printf("Error unmarshaling response %d: %v\n", i, err)
+continue
+}
+
+if pubAck.Error != nil {
+fmt.Printf("PubAck error for message %d: %v\n", i, pubAck.Error)
+}
+
+// Add a small delay to simulate slow publishing
+time.Sleep(50 * time.Millisecond)
+}
+
+// Stop reading
+close(stopReading)
+wg.Wait()
+
+// Analyze results
+fmt.Println("\nMessages observed during batch publish:")
+mu.Lock()
+for i, count := range messagesObserved {
+fmt.Printf("  Observation %d: %d messages\n", i+1, count)
+}
+mu.Unlock()
+
+// Check if we observed intermediate states
+hasIntermediateStates := false
+mu.Lock()
+for _, count := range messagesObserved {
+if count > 0 && count < 10 {
+hasIntermediateStates = true
+break
+}
+}
+mu.Unlock()
+
+if hasIntermediateStates {
+fmt.Println("\n❌ ISSUE: Observed intermediate states during batch publish!")
+fmt.Println("   Readers should only see 0 messages or all 10 messages.")
+} else {
+fmt.Println("\n✓ SUCCESS: No intermediate states observed.")
+}
+}
