diff --git a/quick_verify.js b/quick_verify.js
new file mode 100644
index 00000000..0fe8146f
--- /dev/null
+++ b/quick_verify.js
@@ -0,0 +1,33 @@
+#!/usr/bin/env node
+/**
+ * Quick verification that the fix works
+ */
+
+const REST = require('./lib/helper/REST');
+
+console.log('Quick Verification Test');
+console.log('='.repeat(50));
+
+let onRequestCalled = false;
+let onResponseCalled = false;
+
+const helper = new REST({
+  endpoint: 'https://httpbin.org',
+  onRequest: () => { onRequestCalled = true; },
+  onResponse: () => { onResponseCalled = true; },
+});
+
+helper.sendGetRequest('/get')
+  .then(() => {
+    if (onRequestCalled && onResponseCalled) {
+      console.log('✅ VERIFIED: Both callbacks work!');
+      process.exit(0);
+    } else {
+      console.log('❌ FAILED');
+      process.exit(1);
+    }
+  })
+  .catch((err) => {
+    console.error('❌ Error:', err.message);
+    process.exit(1);
+  });
