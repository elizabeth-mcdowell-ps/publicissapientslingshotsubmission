diff --git a/test_compile.js b/test_compile.js
new file mode 100644
index 000000000..1fab13010
--- /dev/null
+++ b/test_compile.js
@@ -0,0 +1,20 @@
+import { compile } from './packages/svelte/src/compiler/index.js';
+import { readFileSync } from 'fs';
+
+const source = readFileSync('./test_snippet_async_toplevel.svelte', 'utf-8');
+
+try {
+  const result = compile(source, {
+    filename: 'test_snippet_async_toplevel.svelte',
+    runes: true,
+    experimental: {
+      async: true
+    },
+    generate: 'client'
+  });
+  
+  console.log('=== Compiled JavaScript ===');
+  console.log(result.js.code);
+} catch (err) {
+  console.error('Compilation error:', err);
+}
