+use datafusion::prelude::*;
+use datafusion_common::Result;
+
+#[tokio::test]
+async fn test_null_multiply_avg_distinct() -> Result<()> {
+    let ctx = SessionContext::new();
+    
+    // Create table
+    ctx.sql("CREATE TABLE tab1(col0 INTEGER, col1 INTEGER, col2 INTEGER)")
+        .await?
+        .collect()
+        .await?;
+    
+    // Insert data
+    ctx.sql("INSERT INTO tab1 VALUES(51,14,96)")
+        .await?
+        .collect()
+        .await?;
+    ctx.sql("INSERT INTO tab1 VALUES(85,5,59)")
+        .await?
+        .collect()
+        .await?;
+    ctx.sql("INSERT INTO tab1 VALUES(91,47,68)")
+        .await?
+        .collect()
+        .await?;
+    
+    // This query should simplify to NULL before trying to create AVG(DISTINCT)
+    // because NULL * anything = NULL
+    let df = ctx
+        .sql("SELECT + CAST ( NULL AS INTEGER ) * + + AVG ( DISTINCT 4 ) + - SUM ( ALL + col1 ) AS col0 FROM tab1")
+        .await?;
+    
+    println!("Logical plan:");
+    println!("{}", df.logical_plan());
+    
+    println!("\nOptimized logical plan:");
+    println!("{}", df.clone().into_optimized_plan()?);
+    
+    // Execute the query - it should return NULL
+    let result = df.collect().await?;
+    println!("\nResult:");
+    println!("{:?}", result);
+    
+    Ok(())
+}
