 #include "compact_filter.h"
+#include <search/search_encoding.h>
 
 #include <string>
 #include <utility>
@@ -132,4 +133,35 @@ bool SubKeyFilter::Filter([[maybe_unused]] int level, const Slice &key, const Sl
   return IsMetadataExpired(ikey, metadata) || (metadata.Type() == kRedisBitmap && redis::Bitmap::IsEmptySegment(value));
 }
 
+bool SearchFilter::Filter([[maybe_unused]] int level, const Slice &key, [[maybe_unused]] const Slice &value,
+                          [[maybe_unused]] std::string *new_value, [[maybe_unused]] bool *modified) const {
+  auto db = stor_->GetDB();
+  const auto cf_handles = stor_->GetCFHandles();
+  if (!db || cf_handles->size() < 2) return false;
+
+  Slice input(key);
+  uint8_t ns_size = 0;
+  if (!GetFixed8(&input, &ns_size)) return false;
+  input.remove_prefix(ns_size);
+
+  if (input.size() < 1) return false;
+  input.remove_prefix(1);  // skip type
+
+  Slice index_name;
+  if (!GetSizedString(&input, &index_name)) return false;
+
+  std::string metadata_key;
+  PutFixed8(&metadata_key, ns_size);
+  metadata_key.append(key.data() + 1, ns_size);
+  PutFixed8(&metadata_key, (uint8_t)redis::SearchSubkeyType::INDEX_META);
+  PutSizedString(&metadata_key, index_name);
+
+  std::string bytes;
+  rocksdb::Status s = db->Get(rocksdb::ReadOptions(), (*cf_handles)[static_cast<size_t>(ColumnFamilyID::Search)],
+                              metadata_key, &bytes);
+  if (s.IsNotFound()) return true;
+
+  return false;
+}
+
 }  // namespace engine
