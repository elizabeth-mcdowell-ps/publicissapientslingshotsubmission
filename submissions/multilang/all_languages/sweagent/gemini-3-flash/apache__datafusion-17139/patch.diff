new file mode 100644
index 000000000..59408166c
--- /dev/null
+++ b/datafusion/core/examples/reproduce_issue.rs
@@ -0,0 +1,17 @@
+use datafusion::prelude::*;
+use datafusion::error::Result;
+
+#[tokio::main]
+async fn main() -> Result<()> {
+    let ctx = SessionContext::new();
+    ctx.sql("CREATE TABLE tab1(col0 INTEGER, col1 INTEGER, col2 INTEGER)").await?.collect().await?;
+    ctx.sql("INSERT INTO tab1 VALUES(51,14,96)").await?.collect().await?;
+    ctx.sql("INSERT INTO tab1 VALUES(85,5,59)").await?.collect().await?;
+    ctx.sql("INSERT INTO tab1 VALUES(91,47,68)").await?.collect().await?;
+
+    let sql = "SELECT + CAST ( NULL AS INTEGER ) * + + AVG ( DISTINCT 4 ) + - SUM ( ALL + col1 ) AS col0 FROM tab1";
+    let df = ctx.sql(sql).await?;
+    df.show().await?;
+
+    Ok(())
+}
