+    let val = get(count) * 2;
+    // console.log('derived run, count =', get(count), 'double =', val);
+    return val;
+});
+let teardownValues = [];
+
+const rootCleanup = effect(() => {
+    user_effect(() => {
+        let v = double.v;
+        return () => {
+            teardownValues.push(double.v);
+        };
+    });
+});
+
+console.log('--- start ---');
+flushSync();
+console.log('--- change count to 1 ---');
+count.v = 1;
+flushSync();
+console.log('Teardown values:', teardownValues);
+if (teardownValues[0] === 2) {
+    console.log('REPRODUCED: Teardown saw the NEW values');
+} else if (teardownValues[0] === 0) {
+    console.log('SUCCESS: Teardown saw the OLD values');
+} else {
+    console.log('Unexpected teardown values:', teardownValues);
+}
