diff --git a/source/slang/slang-check-expr.cpp b/source/slang/slang-check-expr.cpp
index 6fed59621..3dd13b8be 100644
--- a/source/slang/slang-check-expr.cpp
+++ b/source/slang/slang-check-expr.cpp
@@ -968,6 +968,41 @@ bool SemanticsVisitor::isDeclVisibleFromScope(DeclRef<Decl> declRef, Scope* scop
     auto visibility = getDeclVisibility(declRef.getDecl());
     if (visibility == DeclVisibility::Public)
         return true;
+
+    // Special case for EnumCaseDecl of an UnscopedEnum.
+    // Their visibility should be the same as the EnumDecl.
+    if (auto letDecl = as<LetDecl>(declRef.getDecl()))
+    {
+        if (letDecl->initExpr)
+        {
+            if (auto varExpr = as<VarExpr>(letDecl->initExpr))
+            {
+                if (auto enumCase = as<EnumCaseDecl>(varExpr->declRef.getDecl()))
+                {
+                    if (auto enumDecl = as<EnumDecl>(enumCase->parentDecl))
+                    {
+                        if (enumDecl->hasModifier<UnscopedEnumAttribute>())
+                        {
+                            if (isDeclVisibleFromScope(DeclRef<Decl>(enumDecl), scope))
+                                return true;
+                        }
+                    }
+                }
+            }
+        }
+    }
+    else if (auto enumCase = as<EnumCaseDecl>(declRef.getDecl()))
+    {
+        if (auto enumDecl = as<EnumDecl>(enumCase->parentDecl))
+        {
+            if (enumDecl->hasModifier<UnscopedEnumAttribute>())
+            {
+                if (isDeclVisibleFromScope(DeclRef<Decl>(enumDecl), scope))
+                    return true;
+            }
+        }
+    }
+
     if (visibility == DeclVisibility::Internal)
     {
         // Check that the decl is in the same module as the scope.
@@ -992,7 +1027,6 @@ bool SemanticsVisitor::isDeclVisibleFromScope(DeclRef<Decl> declRef, Scope* scop
             if (s->containerDecl == parentContainer)
                 return true;
         }
-        return false;
     }
     return false;
 }
