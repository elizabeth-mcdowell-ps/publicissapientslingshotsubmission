--- /dev/null
+++ b/lbac_test.go
@@ -0,0 +1,29 @@
+package casbin
+
+import (
+"testing"
+)
+
+func testEnforceLBAC(t *testing.T, e *Enforcer, sub string, subLevel float64, subCategories []string, obj string, objLevel float64, objCategories []string, act string, res bool) {
+t.Helper()
+if myRes, err := e.Enforce(sub, subLevel, subCategories, obj, objLevel, objCategories, act); err != nil {
+force Error: %s", err)
+} else if myRes != res {
+%v, %v, %s, %v, %v, %s: %t, supposed to be %t", sub, subLevel, subCategories, obj, objLevel, objCategories, act, myRes, res)
+}
+}
+
+func TestLBACModel(t *testing.T) {
+e, _ := NewEnforcer("examples/lbac_model.conf")
+
+// Same level, same categories
+testEnforceLBAC(t, e, "alice", 3, []string{"HR", "Finance"}, "data1", 3, []string{"HR", "Finance"}, "read", true)
+// Higher level, same categories
+testEnforceLBAC(t, e, "alice", 4, []string{"HR", "Finance"}, "data1", 3, []string{"HR", "Finance"}, "read", true)
+// Lower level, same categories
+testEnforceLBAC(t, e, "alice", 2, []string{"HR", "Finance"}, "data1", 3, []string{"HR", "Finance"}, "read", false)
+// Same level, more categories
+testEnforceLBAC(t, e, "alice", 3, []string{"HR", "Finance", "IT"}, "data1", 3, []string{"HR", "Finance"}, "read", true)
+// Same level, fewer categories
+testEnforceLBAC(t, e, "alice", 3, []string{"HR"}, "data1", 3, []string{"HR", "Finance"}, "read", false)
+}
