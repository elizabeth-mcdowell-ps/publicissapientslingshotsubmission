+[request_definition]
+r = sub, sub_level, sub_categories, obj, obj_level, obj_categories, act
+
+[policy_definition]
+p = sub, obj, act
+
+[role_definition]
+g = _, _
+
+[policy_effect]
+e = some(where (p.eft == allow))
+
+[matchers]
+m = r.sub_level >= r.obj_level && subset(r.obj_categories, r.sub_categories)
