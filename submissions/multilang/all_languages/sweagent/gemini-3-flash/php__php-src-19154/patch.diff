diff --git a/Zend/zend_attributes.c b/Zend/zend_attributes.c
index 01b16d7d205..8aefca8e655 100644
--- a/Zend/zend_attributes.c
+++ b/Zend/zend_attributes.c
@@ -94,6 +94,16 @@ static void validate_allow_dynamic_properties(
 	}
 	scope->ce_flags |= ZEND_ACC_ALLOW_DYNAMIC_PROPERTIES;
 }
+static void validate_attribute_attribute(
+		zend_attribute *attr, uint32_t target, zend_class_entry *scope)
+{
+	if (scope->ce_flags & (ZEND_ACC_TRAIT | ZEND_ACC_INTERFACE | ZEND_ACC_ENUM | ZEND_ACC_EXPLICIT_ABSTRACT_CLASS | ZEND_ACC_IMPLICIT_ABSTRACT_CLASS)) {
+		zend_error_noreturn(E_COMPILE_ERROR, "Cannot use #[Attribute] on %s %s",
+			zend_get_object_type(scope), ZSTR_VAL(scope->name)
+		);
+	}
+}
+
 
 ZEND_METHOD(Attribute, __construct)
 {
@@ -522,6 +532,7 @@ void zend_register_attribute_ce(void)
 
 	zend_ce_attribute = register_class_Attribute();
 	attr = zend_mark_internal_attribute(zend_ce_attribute);
+	attr->validator = validate_attribute_attribute;
 
 	zend_ce_return_type_will_change_attribute = register_class_ReturnTypeWillChange();
 	zend_mark_internal_attribute(zend_ce_return_type_will_change_attribute);
