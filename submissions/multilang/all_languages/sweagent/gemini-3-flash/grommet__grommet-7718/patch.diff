+import React from 'react';
+import { render, screen } from '@testing-library/react';
+import { Grommet } from './src/js/components/Grommet';
+import { FileInput } from './src/js/components/FileInput';
+import '@testing-library/jest-dom';
+
+describe('FileInput disabled', () => {
+  test('should pass disabled prop to browse button', () => {
+    const { getByRole } = render(
+      <Grommet>
+        <FileInput name="file" disabled />
+      </Grommet>
+    );
+    // Based on the code, it could be a Button or an Anchor. 
+    // Grommet Button with a label usually has role="button".
+    const browseButton = screen.getByText(/browse/i);
+    expect(browseButton).not.toHaveAttribute('disabled');
+  });
+});
