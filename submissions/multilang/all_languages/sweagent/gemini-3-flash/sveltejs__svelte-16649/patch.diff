@@ -0,0 +1,15 @@
+import { flushSync } from 'svelte';
+
+export default {
+async test({ assert, target, window }) {
+const input = target.querySelector('#input');
+const value = target.querySelector('#value');
+
+input.value = 'new value';
+input.dispatchEvent(new window.InputEvent('input'));
+// flushSync(); // We want to see if it updates correctly after flush or even without it if possible
+
+assert.equal(value.textContent.trim(), 'new value', 'Value in div should be updated');
+assert.equal(input.value, 'new value', 'Value in input should be updated');
+}
+};
diff --git a/packages/svelte/tests/runtime-runes/samples/binding-delayed-array-update/main.svelte b/packages/svelte/tests/runtime-runes/samples/binding-delayed-array-update/main.svelte
