+#nullable enable
+using System.Text.Json.Nodes;
+using Microsoft.Extensions.DependencyInjection;
+using Orleans.Serialization.TestKit;
+using Orleans.Serialization.Codecs;
+using Xunit;
+using Xunit.Abstractions;
+
+namespace Orleans.Serialization.UnitTests
+{
+    [Trait("Category", "BVT")]
+    public class ReproductionTests : FieldCodecTester<JsonNode?, IFieldCodec<JsonNode?>>
+    {
+        public ReproductionTests(ITestOutputHelper output) : base(output)
+        {
+        }
+
+        protected override void Configure(ISerializerBuilder builder)
+        {
+            builder.AddJsonSerializer(isSupported: type => typeof(JsonNode).IsAssignableFrom(type));
+        }
+
+        protected override JsonNode? CreateValue() => JsonValue.Create(1);
+
+        protected override JsonNode?[] TestValues => new JsonNode?[]
+        {
+            null,
+            JsonValue.Create(1),
+            JsonValue.Create("hello"),
+            new JsonObject { ["foo"] = "bar" }
+        };
+
+        [Fact]
+        public void CanSerializeJsonValue()
+        {
+            var original = JsonValue.Create(1);
+            var result = RoundTripThroughUntypedSerializer(original, out _);
+            Assert.Equal(original.ToJsonString(), ((JsonNode)result!).ToJsonString());
+        }
+    }
+}
