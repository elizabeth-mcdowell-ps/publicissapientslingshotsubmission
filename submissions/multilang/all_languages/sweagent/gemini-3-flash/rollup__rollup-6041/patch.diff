@@ -0,0 +1,100 @@
+
+import path from 'node:path';
+import { rollup } from './dist/rollup.js';
+
+async function run() {
+    const bundle = await rollup({
+        input: 'main.js',
+        external: ['@emotion/unitless'],
+        plugins: [{
+            name: 'test-plugin',
+            resolveId(id) {
+                if (id === 'main.js' || id === './unitless') return id;
+                return null;
+            },
+            load(id) {
+                if (id === 'main.js') {
+                    return `
+import unitless from '@emotion/unitless';
+import unitlessLocal from './unitless';
+
+export default function addUnitIfNeeded(name, value) {
+  if (value == null || typeof value === 'boolean' || value === '') {
+    return '';
+  }
+
+  if (typeof value === 'number' && value !== 0 && !(name in unitlessLocal) && !name.startsWith('--')) {
+    return \`\${value}px\`;
+  }
+
+  return String(value).trim();
+}
+`;
+                }
+                if (id === './unitless') {
+                    return `
+let unitlessKeys = {
+  animationIterationCount: 1,
+  aspectRatio: 1,
+  borderImageOutset: 1,
+  borderImageSlice: 1,
+  borderImageWidth: 1,
+  boxFlex: 1,
+  boxFlexGroup: 1,
+  boxOrdinalGroup: 1,
+  columnCount: 1,
+  columns: 1,
+  flex: 1,
+  flexGrow: 1,
+  flexPositive: 1,
+  flexShrink: 1,
+  flexNegative: 1,
+  flexOrder: 1,
+  gridRow: 1,
+  gridRowEnd: 1,
+  gridRowSpan: 1,
+  gridRowStart: 1,
+  gridColumn: 1,
+  gridColumnEnd: 1,
+  gridColumnSpan: 1,
+  gridColumnStart: 1,
+  msGridRow: 1,
+  msGridRowSpan: 1,
+  msGridColumn: 1,
+  msGridColumnSpan: 1,
+  fontWeight: 1,
+  lineHeight: 1,
+  opacity: 1,
+  order: 1,
+  orphans: 1,
+  scale: 1,
+  tabSize: 1,
+  widows: 1,
+  zIndex: 1,
+  zoom: 1,
+  WebkitLineClamp: 1,
+
+  // SVG-related properties
+  fillOpacity: 1,
+  floodOpacity: 1,
+  stopOpacity: 1,
+  strokeDasharray: 1,
+  strokeDashoffset: 1,
+  strokeMiterlimit: 1,
+  strokeOpacity: 1,
+  strokeWidth: 1
+}
+
+export default unitlessKeys;
+`;
+                }
+                return null;
+            }
+        }]
+    });
+
+    const { output } = await bundle.generate({ format: 'es' });
+    console.log(output[0].code);
+}
+
+run();
