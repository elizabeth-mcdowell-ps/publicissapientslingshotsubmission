@@ -0,0 +1,45 @@
+#!/usr/bin/env python3
+import os
+import subprocess
+
+# Create the test files as described in the PR
+test_a_content = """
+[UnscopedEnum]
+public enum TestEnum
+{
+    CASE_A,
+    CASE_B
+};
+"""
+
+test_b_content = """
+import test_a;
+
+[numthreads(1, 1, 1)]
+void computeMain(int3 dispatchThreadID: SV_DispatchThreadID)
+{
+    TestEnum e = CASE_A;
+}
+"""
+
+# Write the test files
+with open('/testbed/test_a.slang', 'w') as f:
+    f.write(test_a_content)
+
+with open('/testbed/test_b.slang', 'w') as f:
+    f.write(test_b_content)
+
+# Try to compile as described in the PR description
+print("Attempting to compile the test case...")
+result = subprocess.run(['/testbed/build/Release/bin/slangc', '-target', 'spirv', 'test_b.slang', '-o', 'test.spv'], 
+                       capture_output=True, text=True, cwd='/testbed')
+
+print("Return code:", result.returncode)
+print("\nSTDOUT:")
+print(result.stdout)
+print("\nSTDERR:")
+print(result.stderr)
+
+# Clean up
+os.remove('/testbed/test_a.slang')
+os.remove('/testbed/test_b.slang')
\ No newline at end of file
