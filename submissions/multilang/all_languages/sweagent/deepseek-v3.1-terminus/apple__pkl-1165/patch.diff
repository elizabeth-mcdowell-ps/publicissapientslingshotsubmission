diff --git a/test_escape.py b/test_escape.py
new file mode 100644
index 00000000..6b28ca84
--- /dev/null
+++ b/test_escape.py
@@ -0,0 +1,30 @@
+#!/usr/bin/env python3
+"""Analyze the YAML escaping issue"""
+
+# The issue is:
+# Pkl string: "\\t\\\\d" (which contains tab character + backslash + 'd')
+# Should render as YAML: "\\t\\\\\\\\d" 
+# But currently renders as: "\\t\\\\d"
+
+print("Understanding the escaping:")
+print("=" * 50)
+
+# In Pkl source
+pkl_source = 'foo = "\\t\\\\d"'
+print(f"Pkl source code: {pkl_source}")
+
+# The resulting string in Java would be:
+# "\\t" represents tab character (\t)
+# "\\\\" represents a single backslash (due to Pkl string escaping rules)
+java_string = "\t\\d"
+print(f"\nJava string representation:")
+print(f"Length: {len(java_string)}")
+for i, c in enumerate(java_string):
+    char_code = ord(c)
+    print(f"  [{i}]: '{c}' (ord: {char_code}, hex: {hex(char_code)})")
+
+print(f"\nWhen rendered as YAML with DOUBLE_QUOTED style:")
+print("  Should be: \"\\\\t\\\\\\\\d\"")
+print("  Currently: \"\\\\t\\\\d\"")
+print("\nThe issue is that backslashes need to be escaped in double-quoted YAML strings.")
+print("Each backslash becomes two backslashes in the YAML output.")
