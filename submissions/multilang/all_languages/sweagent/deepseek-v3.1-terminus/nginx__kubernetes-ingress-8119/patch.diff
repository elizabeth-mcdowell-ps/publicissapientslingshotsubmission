+#!/usr/bin/env python3
+"""
+Simple verification of the JWKS security fix
+"""
+
+def main():
+    template_file = "/testbed/internal/configs/version2/nginx-plus.virtualserver.tmpl"
+    
+    with open(template_file, 'r') as f:
+        content = f.read()
+    
+    print("=== JWKS Security Fix Verification ===\n")
+    
+    # Check if the template contains the JWKS location block
+    if "_jwks_uri_server_" not in content:
+        print("❌ ERROR: No JWKS location blocks found!")
+        return False
+    
+    print("✅ Found JWKS location blocks")
+    
+    # Find the exact location block content
+    lines = content.split('\n')
+    
+    # Find all lines containing the JWKS location pattern
+    jwks_lines = []
+    for i, line in enumerate(lines):
+        if "_jwks_uri_server_" in line:
+            jwks_lines.append((i+1, line.strip()))
+    
+    print(f"\nFound {len(jwks_lines)} JWKS references:")
+    for line_num, line in jwks_lines:
+        print(f"  Line {line_num}: {line}")
+    
+    # Find the location block starting from a JWKS location line
+    security_directives_found = []
+    
+    for line_num, line in jwks_lines:
+        if "location" in line:
+            print(f"\n📍 Analyzing location block starting at line {line_num}:")
+            
+            # Extract the block by finding the matching brace
+            brace_count = 0
+            block_content = []
+            
+            for i in range(line_num-1, min(line_num+30, len(lines))):
+                current_line = lines[i]
+                block_content.append(current_line)
+                
+                brace_count += current_line.count('{')
+                brace_count -= current_line.count('}')
+                
+                if brace_count == 0:
+                    break
+            
+            block_text = ''.join(block_content)
+            
+            # Check for required security directives
+            print("  Checking security directives:")
+            
+            checks = [
+                ('proxy_pass_request_headers off', 'Prevents header leakage', False),
+                ('proxy_pass_request_body off', 'Prevents body leakage', False),
+                ('internal', 'Internal access only', False),
+                ('proxy_method GET', 'Forced GET method', False)
+            ]
+            
+            for directive, description, found in checks:
+                if directive in block_text:
+                    print(f"    ✅ {directive:<35} - {description}")
+                    security_directives_found.append(directive)
+                    checks = [(d, desc, True) if d == directive else (d, desc, f) for d, desc, f in checks]
+                else:
+                    print(f"    ❌ {directive:<35} - {description}")
+    
+    # Final verdict
+    print("\n=== SECURITY ASSESSMENT ===")
+    
+    critical_directives = ['proxy_pass_request_headers off', 'proxy_pass_request_body off']
+    all_critical_present = all(directive in security_directives_found for directive in critical_directives)
+    
+    if all_critical_present:
+        print("✅ CRITICAL SECURITY FIX APPLIED SUCCESSFULLY")
+        print("\nThe fix addresses the security vulnerability by:")
+        print("• Preventing client headers from being forwarded to the IdP")
+        print("• Preventing client request body from being forwarded to the IdP") 
+        print("• Ensuring JWKS fetches are clean, unauthenticated requests")
+        print("• Preventing credential leakage to identity providers")
+        return True
+    else:
+        print("❌ SECURITY VULNERABILITY STILL EXISTS")
+        missing = [d for d in critical_directives if d not in security_directives_found]
+        print(f"Missing critical directives: {missing}")
+        return False
+
+if __name__ == "__main__":
+    success = main()
+    exit(0 if success else 1)
