+    if not all_found:
+        print("ERROR: Security directives are missing!")
+        return False
+    
+    print("\n✓ All security directives are present and correctly positioned")
+    
+    # Verify the order
+    print("\nVerifying directive order...")
+    
+    # Get the exact lines in order
+    block_lines = lines[jwks_block_start:jwks_block_start + 10]
+    
+    # Look for key directives and their order
+    directives_order = []
+    for line in block_lines:
+        line_clean = line.strip()
+        if 'proxy_method' in line_clean:
+            directives_order.append('proxy_method')
+        elif 'proxy_pass_request_headers off' in line_clean:
+            directives_order.append('proxy_pass_request_headers')
+        elif 'proxy_pass_request_body off' in line_clean:
+            directives_order.append('proxy_pass_request_body')
+        elif 'proxy_set_header Content-Length' in line_clean:
+            directives_order.append('proxy_set_header')
+    
+    expected_order = ['proxy_method', 'proxy_pass_request_headers', 'proxy_pass_request_body', 'proxy_set_header']
+    
+    if directives_order == expected_order:
+        print("✓ Directive order is correct")
+        print(f"  Order: {' -> '.join(directives_order)}")
+    else:
+        print(f"✗ Directive order is incorrect")
+        print(f"  Got: {' -> '.join(directives_order)}")
+        print(f"  Expected: {' -> '.join(expected_order)}")
+        return False
+    
+    print("\n✅ All security requirements have been met!")
+    print("\nThe fix ensures that:")
+    print("- Headers from the original request are NOT passed to the IdP")
+    print("- Body content from the original request is NOT passed to the IdP")
+    print("- This prevents credential leakage when fetching JWKS from identity providers")
+    
+    return True
+
+if __name__ == "__main__":
+    success = test_jwks_configuration()
+    exit(0 if success else 1)
