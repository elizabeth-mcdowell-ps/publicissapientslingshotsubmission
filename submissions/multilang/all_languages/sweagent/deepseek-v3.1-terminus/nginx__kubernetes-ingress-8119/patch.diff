+        return False
+    
+    print(f"✓ Found JWKS location block starting at line {jwks_block_start + 1}")
+    
+    # Check the next lines for the required directives
+    required_directives = [
+        ('proxy_pass_request_headers off', False),
+        ('proxy_pass_request_body off', False)
+    ]
+    
+    # Look in the next 20 lines for our directives
+    for i in range(jwks_block_start, min(jwks_block_start + 20, len(lines))):
+        line = lines[i].strip()
+        
+        for j, (directive, found) in enumerate(required_directives):
+            if directive in line:
+                required_directives[j] = (directive, True)
+                print(f"✓ Found directive: {directive} at line {i+1}")
+    
+    # Check if all directives were found
+    all_found = True
+    for directive, found in required_directives:
+        if not found:
+            print(f"✗ Missing directive: {directive}")
+            all_found = False
