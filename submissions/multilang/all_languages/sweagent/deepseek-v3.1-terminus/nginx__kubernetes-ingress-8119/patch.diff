+    
+    with open(template_file, 'r') as f:
+        lines = f.readlines()
+    
+    print("Test: Checking JWKS location block security directives...")
+    
+    # Find the JWKS location block
+    jwks_block_start = None
+    for i, line in enumerate(lines):
+        if "location = /_jwks_uri_server_" in line:
+            jwks_block_start = i
+            break
+    
+    if jwks_block_start is None:
