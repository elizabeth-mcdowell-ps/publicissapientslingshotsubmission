+)
+
+func main() {
+    // Mock the pagewriter
+    writer := &pagewriter.WriterFuncs{}
+    
+    // Test case 1: Basic rewrite (like the app upstream)
+    fmt.Println("Test 1: Basic rewrite (^/(.*)$ -> /$1)")
+    testRewrite(`^/(.*)$`, "/$1", "/path/to/resource", writer)
+    
+    // Test case 2: Complex rewrite (like the api upstream)
+    fmt.Println("\nTest 2: Complex rewrite (^/api(/stripe/webhook|/graphql|/downloads)(.*)$ -> /api$1$2)")
+    testRewrite(`^/api(/stripe/webhook|/graphql|/downloads)(.*)$`, "/api$1$2", "/api/graphql/query", writer)
+    testRewrite(`^/api(/stripe/webhook|/graphql|/downloads)(.*)$`, "/api$1$2", "/api/stripe/webhook/event", writer)
+    
+    // Test case 3: Path prefix matching (without rewrite)
+    fmt.Println("\nTest 3: Path prefix matching (without rewrite)")
+    testPathPrefix("/api/", "/api/graphql")
+    testPathPrefix("/api/", "/api/stripe/webhook")
+}
+
+func testRewrite(regexStr, target, inputPath string, writer pagewriter.Writer) {
+    regex := regexp.MustCompile(regexStr)
+    
+    req := httptest.NewRequest("GET", "http://example.com" + inputPath, nil)
+    rw := httptest.NewRecorder()
+    
+    var gotRequestURI string
+    var gotRequestURLPath string
+    
+    handler := upstream.NewRewritePath(regex, target, writer)(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+        gotRequestURI = r.RequestURI
+        gotRequestURLPath = r.URL.Path
+    }))
+    
+    handler.ServeHTTP(rw, req)
+    
+    expectedPath := regex.ReplaceAllString(inputPath, target)
+    fmt.Printf("Input: %s -> Expected: %s, Got URI: %s, Got Path: %s\n", 
+        inputPath, expectedPath, gotRequestURI, gotRequestURLPath)
+}
+
+func testPathPrefix(prefix, inputPath string) {
+    fmt.Printf("Path prefix '%s' matches '%s': %v\n", prefix, inputPath, strings.HasPrefix(inputPath, prefix))
+}
