+package main
+
+import (
+"fmt"
+"net/http"
+"net/http/httptest"
+"regexp"
+
+"github.com/oauth2-proxy/oauth2-proxy/v7/pkg/app/pagewriter"
+"github.com/oauth2-proxy/oauth2-proxy/v7/pkg/upstream"
+)
+
+func main() {
+fmt.Println("Testing the regression in rewrite functionality...")
+
+// Create a mock page writer
+writer := &pagewriter.WriterFuncs{}
+
+// Test case 1: Simple rewrite that should work
+fmt.Println("\nTest 1: Simple rewrite (^/(.*)$ -> /$1)")
+testRewrite(`^/(.*)$`, "/$1", "/css/style.css", writer)
+
+// Test case 2: Simple rewrite targeting '/' 
+fmt.Println("\nTest 2: Simple rewrite targeting root (^/(.*)$ -> /$1)")
+testRewrite(`^/(.*)$`, "/$1", "/", writer)
+
+// Test case 3: Complex regex rewrite like in the PR
+fmt.Println("\nTest 3: Complex regex rewrite (^/api(/stripe/webhook|/graphql|/downloads)(.*)$ -> /api$1$2)")
+testRewrite(`^/api(/stripe/webhook|/graphql|/downloads)(.*)$`, "/api$1$2", "/api/graphql/query", writer)
+
+// Test case 4: Another complex case
+testRewrite(`^/api(/stripe/webhook|/graphql|/downloads)(.*)$`, "/api$1$2", "/api/stripe/webhook/hook", writer)
+
+fmt.Println("\nTesting request URI handling...")
+testRequestURIHandling()
+}
+
+func testRewrite(regexStr, target, inputPath string, writer pagewriter.Writer) {
+regex := regexp.MustCompile(regexStr)
+
+req := httptest.NewRequest("GET", "http://example.com" + inputPath, nil)
+req.RequestURI = inputPath // Set the RequestURI as it would be in real requests
+rw := httptest.NewRecorder()
+
+var gotRequestURI string
+var gotRequestURLPath string
+
+// Use newRewritePath to create the middleware
+rewriteMiddleware := upstream.NewRewritePath(regex, target, writer)
+handler := rewriteMiddleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+gotRequestURI = r.RequestURI
+gotRequestURLPath = r.URL.Path
+}))
+
+handler.ServeHTTP(rw, req)
+
+expectedPath := regex.ReplaceAllString(inputPath, target)
+fmt.Printf("Input: %s -> Expected: %s, Got URI: %s, Got Path: %s", 
+inputPath, expectedPath, gotRequestURI, gotRequestURLPath)
+
+if gotRequestURLPath != expectedPath {
+fmt.Printf("  ERROR: Path mismatch!")
+}
+fmt.Println()
+}
+
+func testRequestURIHandling() {
+// Test how RequestURI is parsed
+fmt.Println("\nTesting URL parsing...")
+
+req := httptest.NewRequest("GET", "http://example.com/api/graphql/query", nil)
+fmt.Printf("Original RequestURI: %s\n", req.RequestURI)
+fmt.Printf("Original URL.Path: %s\n", req.URL.Path)
+
+// Simulate what happens in rewritePath function
+reqURL, err := req.URL.Parse(req.RequestURI)
+if err != nil {
+fmt.Printf("Error parsing RequestURI: %v\n", err)
+} else {
+fmt.Printf("Parsed URL.Path: %s\n", reqURL.Path)
+}
+}
