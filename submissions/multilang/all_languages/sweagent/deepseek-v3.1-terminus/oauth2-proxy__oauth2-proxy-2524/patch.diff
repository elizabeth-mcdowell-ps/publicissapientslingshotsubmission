+#!/usr/bin/env python3
+"""
+Script to reproduce the upstream rewrite issue described in the PR.
+This simulates the upstream configuration and tests the rewrite functionality.
+"""
+
+import subprocess
+import sys
+import os
+
+def test_upstream_rewrite():
+    """
+    Test the upstream rewrite functionality by creating a simple Go test program
+    """
+    
+    # Create a test Go program that reproduces the issue
+    test_program = """
+package main
+
+import (
+    "fmt"
+    "net/http"
+    "net/http/httptest"
+    "regexp"
+    "strings"
+    
+    "github.com/oauth2-proxy/oauth2-proxy/v7/pkg/upstream"
+)
+
+func main() {
+    fmt.Println("Testing upstream rewrite functionality...")
+    
+    // Test the rewritePath function directly
+    testRewritePath(`^/(.*)$`, "/$1", "/path/to/resource")
+    testRewritePath(`^/api(/stripe/webhook|/graphql|/downloads)(.*)$`, "/api$1$2", "/api/graphql/query")
+    testRewritePath(`^/api(/stripe/webhook|/graphql|/downloads)(.*)$`, "/api$1$2", "/api/stripe/webhook/event")
+}
+
+func testRewritePath(regexStr, target, inputPath string) {
+    regex := regexp.MustCompile(regexStr)
+    
+    req := httptest.NewRequest("GET", "http://example.com" + inputPath, nil)
+    rw := httptest.NewRecorder()
+    
+    var gotRequestURI string
+    var gotRequestURLPath string
+    
+    // Use the rewritePath handler directly
+    handler := upstream.RewritePath(regex, target, nil, http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+        gotRequestURI = r.RequestURI
+        gotRequestURLPath = r.URL.Path
+    }))
+    
+    handler.ServeHTTP(rw, req)
+    
+    expectedPath := regex.ReplaceAllString(inputPath, target)
+    fmt.Printf("Input: %s -> Expected: %s, Got URI: %s, Got Path: %s\\n", 
+        inputPath, expectedPath, gotRequestURI, gotRequestURLPath)
+    
+    if gotRequestURLPath != expectedPath {
+        fmt.Printf("ERROR: Path mismatch! Expected: %s, Got: %s\\n", expectedPath, gotRequestURLPath)
+    }
+}
+"""
+    
+    # Write the test program
+    with open('/testbed/reproduce_main.go', 'w') as f:
+        f.write(test_program)
+    
+    # Try to run it
+    print("Testing upstream rewrite functionality...")
+    result = subprocess.run(['go', 'run', '/testbed/reproduce_main.go'], 
+                          cwd='/testbed', 
+                          capture_output=True, 
+                          text=True)
+    
+    print("STDOUT:")
+    print(result.stdout)
+    print("STDERR:")
+    print(result.stderr)
+    print("Return code:", result.returncode)
+
+if __name__ == "__main__":
+    test_upstream_rewrite()
