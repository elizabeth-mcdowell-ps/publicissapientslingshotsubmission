+#!/usr/bin/env python3
+"""
+Script to analyze the current metrics structure and BSL controller
+"""
+
+import os
+import re
+
+def analyze_metrics_file():
+    """Analyze the metrics.go file to understand current structure"""
+    metrics_file = "/testbed/pkg/metrics/metrics.go"
+    
+    print("=== Analyzing metrics.go ===")
+    with open(metrics_file, 'r') as f:
+        content = f.read()
+        
+    # Find all metric constants
+    metric_constants = re.findall(r'(\w+)\s*=\s*"[^"]+"', content)
+    print(f"Existing metric constants: {metric_constants}")
+    
+    # Find backupLastStatus related code
+    backup_last_status_patterns = [
+        r'backupLastStatus\s*=\s*"[^"]+"',
+        r'backupLastStatus:\s*prometheus\.NewGaugeVec',
+        r'func.*RegisterBackupLastStatus'
+    ]
+    
+    for pattern in backup_last_status_patterns:
+        matches = re.findall(pattern, content)
+        if matches:
+            print(f"Found backupLastStatus pattern: {matches}")
+
+def analyze_bsl_controller():
+    """Analyze the BSL controller to understand where to add metrics"""
+    controller_file = "/testbed/pkg/controller/backup_storage_location_controller.go"
+    
+    print("\n=== Analyzing BSL Controller ===")
+    with open(controller_file, 'r') as f:
+        lines = f.readlines()
+    
+    # Look for key sections where we might add metrics
+    reconciler_start = -1
+    reconcile_method_start = -1
+    
+    for i, line in enumerate(lines):
+        if "func (r *backupStorageLocationReconciler) Reconcile" in line:
+            reconcile_method_start = i
+        elif "BackupStorageLocationPhaseAvailable" in line:
+            print(f"Found BSL phase constants around line {i}")
+        elif "location.Status.Phase =" in line:
+            print(f"Found phase setting at line {i}: {line.strip()}")
+    
+    if reconcile_method_start >= 0:
+        # Show the reconcile method
+        print(f"\nReconcile method starts at line {reconcile_method_start + 1}")
+        for i in range(reconcile_method_start, min(len(lines), reconcile_method_start + 50)):
+            if "return ctrl.Result{}" in lines[i]:
+                print(f"  {i+1}: {lines[i].rstrip()}")
+                break
+
+if __name__ == "__main__":
+    analyze_metrics_file()
+    analyze_bsl_controller()
