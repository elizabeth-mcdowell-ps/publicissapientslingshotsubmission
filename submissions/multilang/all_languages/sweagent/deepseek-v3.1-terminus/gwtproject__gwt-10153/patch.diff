+    private static void addBinaryTypes(
+        Collection<CompiledClass> compiledClasses, Map<String, CompiledClass> internalTypes) {
+    for (CompiledClass cc : compiledClasses) {
+      internalTypes.put(cc.getInternalName(), cc);
+    }
