-
-    std::promise<void> promise;
-    auto future = promise.get_future();
-    worker = std::make_unique<asio::io_context::work>(io_context);
-    thd = std::thread([this, &promise] {
-      promise.set_value();
-      io_context.run();
-    });
-    future.wait();
-  }
-  ~SSLClientTester() {
