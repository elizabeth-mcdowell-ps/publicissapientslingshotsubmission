-  bool operator==(const array2D& o) const {
-    return x == o.x && y == o.y &&
-           memcmp(p, o.p, 1ull * x * y * sizeof(float)) == 0 &&
-           values == o.values && values2 == o.values2;
-  }
-  array2D() : x(0), y(0), p(nullptr) {}
-  ~array2D() { free(p); }
