+// Debug script to check the TypedArray constructor properties
+var TypedArray = Object.getPrototypeOf(Uint8Array);
+
+console.log("TypedArray:", TypedArray);
+console.log("TypedArray.name:", TypedArray.name);
+console.log("TypedArray.length:", TypedArray.length);
+console.log("TypedArray.prototype:", TypedArray.prototype);
+console.log("typeof TypedArray:", typeof TypedArray);
+
+// Check if it has the constructor bit
+console.log("TypedArray.toString():", TypedArray.toString());
+
+// Try to call it as constructor
+try {
+    var test = new TypedArray();
+    console.log("SUCCESS: TypedArray can be instantiated");
+} catch (e) {
+    console.log("ERROR on instantiation:", e.message);
+}
+
+// Check if it's an instance of Function
+console.log("TypedArray instanceof Function:", TypedArray instanceof Function);
+
+// Check its constructor
+console.log("TypedArray.constructor:", TypedArray.constructor);
+
+// Check various properties
+var props = Object.getOwnPropertyNames(TypedArray);
+console.log("TypedArray own properties:", props);
+
+var protoProps = Object.getOwnPropertyNames(TypedArray.prototype);
+console.log("TypedArray.prototype own properties:", protoProps.slice(0, 10));
