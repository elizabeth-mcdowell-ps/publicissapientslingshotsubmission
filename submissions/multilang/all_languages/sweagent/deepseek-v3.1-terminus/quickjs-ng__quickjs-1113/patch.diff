diff --git a/reproduce_issue.js b/reproduce_issue.js
new file mode 100644
index 0000000..11b0c09
--- /dev/null
+++ b/reproduce_issue.js
@@ -0,0 +1,21 @@
+// Test case to reproduce the TypedArray extension issue
+console.log("Testing TypedArray extension...");
+
+try {
+    var TypedArray = Object.getPrototypeOf(Uint8Array);
+    console.log("TypedArray prototype retrieved:", TypedArray);
+    console.log("TypedArray.prototype:", TypedArray.prototype);
+    console.log("TypedArray constructor:", TypedArray.constructor);
+    
+    // This should work but currently throws "TypeError: parent class must be constructor"
+    var MyClass = class extends TypedArray {};
+    console.log("SUCCESS: MyClass created successfully:", MyClass);
+    
+    // Test instantiation
+    var instance = new MyClass(10);
+    console.log("SUCCESS: Instance created:", instance);
+    console.log("Instance length:", instance.length);
+    
+} catch (error) {
+    console.log("ERROR:", error.message);
+}
