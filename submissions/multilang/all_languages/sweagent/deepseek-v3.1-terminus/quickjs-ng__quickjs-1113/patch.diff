diff --git a/test_typedarray.js b/test_typedarray.js
new file mode 100644
index 0000000..39cc4fa
--- /dev/null
+++ b/test_typedarray.js
@@ -0,0 +1,49 @@
+// Test to verify the TypedArray extension issue
+console.log("Testing TypedArray extension...");
+
+// Get the TypedArray constructor
+var TypedArray = Object.getPrototypeOf(Uint8Array);
+console.log("TypedArray:", TypedArray);
+console.log("TypedArray.name:", TypedArray.name);
+
+// Test if it's a constructor
+console.log("typeof TypedArray:", typeof TypedArray);
+console.log("TypedArray instanceof Function:", TypedArray instanceof Function);
+
+// Try to extend it
+try {
+    var MyClass = class extends TypedArray {};
+    console.log("SUCCESS: MyClass created:", MyClass);
+    
+    // Try to instantiate it
+    try {
+        var instance = new MyClass(10);
+        console.log("SUCCESS: Instance created:", instance);
+        console.log("Instance length:", instance.length);
+    } catch (e) {
+        console.log("ERROR on instantiation:", e.message);
+    }
+} catch (e) {
+    console.log("ERROR on extension:", e.message);
+}
+
+// Test with other constructors for comparison
+console.log("\n=== Comparison with other constructors ===");
+
+// Function constructor
+console.log("Function is constructor:", typeof Function === 'function');
+try {
+    var MyFuncClass = class extends Function {};
+    console.log("SUCCESS: Extended Function");
+} catch (e) {
+    console.log("ERROR extending Function:", e.message);
+}
+
+// Array constructor  
+console.log("Array is constructor:", typeof Array === 'function');
+try {
+    var MyArrayClass = class extends Array {};
+    console.log("SUCCESS: Extended Array");
+} catch (e) {
+    console.log("ERROR extending Array:", e.message);
+}
\ No newline at end of file
