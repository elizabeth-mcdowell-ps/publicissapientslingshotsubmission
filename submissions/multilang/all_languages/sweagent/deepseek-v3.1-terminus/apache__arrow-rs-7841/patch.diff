index 000000000..37a3916cb
--- /dev/null
+++ b/arrow-cast/tests/test_decimal32_64.rs
@@ -0,0 +1,74 @@
+use arrow_array::{cast::AsArray, Array, Decimal32Array, Decimal64Array, Int32Array, Float64Array};
+use arrow_cast::cast;
+use arrow_schema::DataType;
+
+#[test]
+fn test_decimal32_decimal64_casting() {
+    // Test 1: Create Decimal32Array
+    let decimals_32 = vec![Some(12345), None, Some(67890)];
+    let array_32 = Decimal32Array::from(decimals_32.clone())
+        .with_precision_and_scale(5, 2).unwrap();
+    
+    // Test 2: Create Decimal64Array  
+    let decimals_64 = vec![Some(1234567890), None, Some(9876543210)];
+    let array_64 = Decimal64Array::from(decimals_64.clone())
+        .with_precision_and_scale(10, 2).unwrap();
+    
+    // Test 3: Cast Decimal32 to Decimal64
+    let casted_64 = cast(&array_32, &DataType::Decimal64(8, 2)).unwrap();
+    let casted_64_array = casted_64.as_primitive::<arrow_array::types::Decimal64Type>();
+    assert_eq!(casted_64_array.value_as_string(0), "123.45");
+    assert!(casted_64_array.is_null(1));
+    assert_eq!(casted_64_array.value_as_string(2), "678.90");
+    
+    // Test 4: Cast Decimal64 to Decimal32 (within precision)
+    let small_decimals_64 = vec![Some(123_i64), None, Some(456_i64)];
+    let small_array_64 = Decimal64Array::from(small_decimals_64)
+        .with_precision_and_scale(3, 0).unwrap();
+    let casted_32 = cast(&small_array_64, &DataType::Decimal32(3, 0)).unwrap();
+    let casted_32_array = casted_32.as_primitive::<arrow_array::types::Decimal32Type>();
+    assert_eq!(casted_32_array.value_as_string(0), "123");
+    
+    // Test 5: Cast from numeric to Decimal32
+    let int_array = Int32Array::from(vec![123, 456, 789]);
+    let dec_from_int = cast(&int_array, &DataType::Decimal32(5, 0)).unwrap();
+    let dec_array = dec_from_int.as_primitive::<arrow_array::types::Decimal32Type>();
+    assert_eq!(dec_array.value_as_string(0), "123");
+    
+    // Test 6: Cast from Decimal32 to numeric
+    let dec_to_int = cast(&array_32, &DataType::Int32).unwrap();
+    let int_result = dec_to_int.as_primitive::<arrow_array::types::Int32Type>();
+    assert_eq!(int_result.value(0), 123);
+    
+    // Test 7: Cast Decimal32 to Float64
+    let dec_to_float = cast(&array_32, &DataType::Float64).unwrap();
+    let float_result = dec_to_float.as_primitive::<arrow_array::types::Float64Type>();
+    assert!((float_result.value(0) - 123.45).abs() < 0.01);
+    
+    // Test 8: Cast Float64 to Decimal32
+    let float_array = Float64Array::from(vec![123.45, 678.90]);
+    let float_to_dec = cast(&float_array, &DataType::Decimal32(5, 2)).unwrap();
+    let dec_result = float_to_dec.as_primitive::<arrow_array::types::Decimal32Type>();
+    assert_eq!(dec_result.value_as_string(0), "123.45");
+}
+
+#[test]
+fn test_decimal32_decimal64_conversions() {
+    // Test conversions between different decimal types
+    let values_32 = vec![Some(123456_i32), None, Some(789012_i32)];
+    let values_64 = vec![Some(123456_i64), None, Some(789012_i64)];
+    
+    // Decimal32 -> Decimal64
+    let array_32 = Decimal32Array::from(values_32)
+        .with_precision_and_scale(6, 2).unwrap();
+    let array_64 = cast(&array_32, &DataType::Decimal64(8, 2)).unwrap();
+    let array_64_typed = array_64.as_primitive::<arrow_array::types::Decimal64Type>();
+    assert_eq!(array_64_typed.value_as_string(0), "1234.56");
+    
+    // Decimal64 -> Decimal32
+    let array_64_src = Decimal64Array::from(values_64)
+        .with_precision_and_scale(6, 2).unwrap();
+    let array_32_dest = cast(&array_64_src, &DataType::Decimal32(6, 2)).unwrap();
+    let array_32_typed = array_32_dest.as_primitive::<arrow_array::types::Decimal32Type>();
+    assert_eq!(array_32_typed.value_as_string(0), "1234.56");
+}
