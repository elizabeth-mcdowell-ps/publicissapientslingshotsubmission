+    presets: [
+      presetWind4({
+        important: '#__nuxt'
+      })
+    ]
+  });
+
+  // Generate CSS for text-red-500 with more detailed output
+  const { css, matched } = await uno.generate('text-red-500');
+  
+  console.log('Generated CSS:');
+  console.log(css);
+  
+  console.log('\n=== Analyzing CSS ===');
+  
+  // Split by layers
+  const layers = css.split('\n\n').filter(layer => layer.trim());
+  
+  layers.forEach((layer, index) => {
+    console.log(`\n--- Layer ${index + 1} ---`);
+    const lines = layer.split('\n');
+    lines.forEach((line, lineIndex) => {
+      if (line.includes('--un-text-opacity') || line.includes('@property')) {
+        console.log(`Line ${lineIndex + 1}: ${line}`);
+      }
+    });
+  });
+  
+  // Extract the @property rule
+  const propertyRule = css.match(/@property\s+--un-text-opacity[^}]*}/);
+  if (propertyRule) {
+    console.log('\n💡 Found @property rule:');
+    console.log(propertyRule[0]);
+    
+    // Check if it's inside #__nuxt
+    if (propertyRule[0].includes('#__nuxt')) {
+      console.log('❌ @property rule is INSIDE #__nuxt selector - this is the BUG!');
+    } else {
+      console.log('✅ @property rule is NOT inside #__nuxt selector');
+    }
+  } else {
+    console.log('\n❌ No @property rule found for --un-text-opacity');
+  }
+  
+  // Check where the property definition is
+  const hasPropertyDef = css.includes('--un-text-opacity:100%;');
+  console.log(`\n💡 Does CSS contain --un-text-opacity:100%? ${hasPropertyDef ? '✅ YES' : '❌ NO'}`);
+  
+  // Check where the color rule is
+  const colorRule = css.match(/#__nuxt[^{]*{[^}]*color-mix[^}]*}/g);
+  if (colorRule) {
+    console.log('\n💡 Found color-mix rule:');
+    colorRule.forEach(rule => console.log(rule));
+  }
+}
+
+main().catch(console.error);
