+public class TestUrlFunctions {
+    public static void main(String[] args) {
+        System.out.println("Testing URL encoding and decoding functions");
+        
+        // Test URL encoding with URLEncoder
+        String testUrl = "https://example.com/search?q=java url encode";
+        try {
+            String encoded = java.net.URLEncoder.encode(testUrl, "UTF-8");
+            System.out.println("Encoded (UTF-8): " + encoded);
+            
+            // Test URL decoding
+            String decoded = java.net.URLDecoder.decode(encoded, "UTF-8");
+            System.out.println("Decoded (UTF-8): " + decoded);
+            
+            // Test different charsets
+            encoded = java.net.URLEncoder.encode(testUrl, "ISO-8859-1");
+            System.out.println("Encoded (ISO-8859-1): " + encoded);
+            
+            decoded = java.net.URLDecoder.decode(encoded, "ISO-8859-1");
+            System.out.println("Decoded (ISO-8859-1): " + decoded);
+            
+            System.out.println("Basic URL encode/decode functionality verified");
+            
+        } catch (Exception e) {
+            e.printStackTrace();
+        }
+    }
+}
