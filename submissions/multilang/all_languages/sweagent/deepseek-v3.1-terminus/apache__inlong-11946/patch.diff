+package org.apache.inlong.sort.function;
+
+import org.apache.flink.table.functions.ScalarFunction;
+
+import java.net.URLDecoder;
+import java.nio.charset.Charset;
+import java.nio.charset.StandardCharsets;
+
+/**
+ * UrlDecodeFunction class. It is a custom function, used to URL decode the value in the string
+ * with optional character set specification.
+ */
+public class UrlDecodeFunction extends ScalarFunction {
+
+    private static final long serialVersionUID = -7185622027483662397L;
+
+    /**
+     * eval method for URL decoding with default UTF-8 charset
+     *
+     * @param field the field to be URL decoded
+     * @return URL decoded value
+     */
+    public String eval(String field) {
+        return eval(field, "UTF-8");
+    }
+
+    /**
+     * eval method for URL decoding with specified charset
+     *
+     * @param field the field to be URL decoded
+     * @param charset the character set to use for decoding
+     * @return URL decoded value
+     */
+    public String eval(String field, String charset) {
+        if (field == null) {
+            return null;
+        }
+        
+        try {
+            Charset decodingCharset = StandardCharsets.UTF_8;
+            if (charset != null && !charset.trim().isEmpty()) {
+                decodingCharset = Charset.forName(charset.trim());
+            }
+            return URLDecoder.decode(field, decodingCharset.toString());
+        } catch (Exception e) {
+            return null;
+        }
+    }
+}
