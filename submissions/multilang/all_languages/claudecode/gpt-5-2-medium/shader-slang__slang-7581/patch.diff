@@ -1073,6 +1073,17 @@ static void _maybeDiagnoseMissingVulkanLayoutModifier(
     ParameterBindingContext* context,
     DeclRef<VarDeclBase> const& varDecl)
 {
+    // Only diagnose about missing Vulkan-specific layout when Vulkan/SPIR-V
+    // code generation is actually relevant for this compilation.
+    //
+    // When targeting Metal (e.g., `-target metallib`) we still accept HLSL
+    // `register(...)` bindings for compatibility, but Vulkan bindings are
+    // not required and warning about them is spurious.
+    if (!isKhronosTarget(context->getTargetRequest()) && !isWGPUTarget(context->getTargetRequest()))
+    {
+        return;
+    }
+
     // Don't warn if the declaration is a vk::push_constant or shaderRecordEXT
     if (varDecl.getDecl()->hasModifier<PushConstantAttribute>() ||
         varDecl.getDecl()->hasModifier<ShaderRecordAttribute>())
