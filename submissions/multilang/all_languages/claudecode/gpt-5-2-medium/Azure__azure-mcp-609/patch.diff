+    public async Task<List<string>> ListDataLakePaths(
+        string accountName,
+        string fileSystem,
+        string subscriptionId,
+        string? path = null,
+        bool recursive = false,
+        string? tenant = null,
+        RetryPolicyOptions? retryPolicy = null)
+    {
+        ValidateRequiredParameters(accountName, fileSystem, subscriptionId);
+
+        var serviceClient = await CreateDataLakeServiceClient(accountName, tenant, retryPolicy);
+        var fileSystemClient = serviceClient.GetFileSystemClient(fileSystem);
+
+        var results = new List<string>();
+
+        try
+        {
+            await foreach (PathItem item in fileSystemClient.GetPathsAsync(path: path, recursive: recursive))
+            {
+                if (!string.IsNullOrEmpty(item.Name))
+                {
+                    results.Add(item.Name);
+                }
+            }
+        }
+        catch (Exception ex)
+        {
+            throw new Exception($"Error listing data lake paths: {ex.Message}", ex);
+        }
+
+        return results;
+    }
