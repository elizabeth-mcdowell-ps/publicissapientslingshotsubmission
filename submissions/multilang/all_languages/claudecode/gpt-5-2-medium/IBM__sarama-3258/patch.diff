diff --git a/compress.go b/compress.go
index bb52e96..f7871b1 100644
--- a/compress.go
+++ b/compress.go
@@ -13,7 +13,14 @@ import (
 var (
 	lz4WriterPool = sync.Pool{
 		New: func() interface{} {
-			return lz4.NewWriter(nil)
+			w := lz4.NewWriter(nil)
+			// Kafka brokers historically allocate the LZ4 decompression buffer based
+			// on the frame's max block size. The lz4/v4 writer defaults to 4MB blocks,
+			// which can cause significant memory pressure on brokers when many
+			// concurrent produce requests are received. Use a smaller block size to
+			// reduce the per-request decompression buffer requirement.
+			_ = w.Apply(lz4.BlockSizeOption(lz4.Block64Kb))
+			return w
 		},
 	}
 
