index 756650891d..38c9ace6da 100644
--- a/crates/hir/src/symbols.rs
+++ b/crates/hir/src/symbols.rs
@@ -125,6 +125,13 @@ impl<'a> SymbolCollector<'a> {
                 }
                 ModuleDefId::AdtId(AdtId::EnumId(id)) => {
                     this.push_decl(id, name, false, None);
+                    // Also index enum variants for workspace symbol search.
+                    this.with_container_name(Some(name.as_str().to_smolstr()), |s| {
+                        for variant in (crate::Enum { id }).variants(s.db) {
+                            let variant_name = variant.name(s.db);
+                            s.push_decl(variant.id, &variant_name, true, None);
+                        }
+                    });
                 }
                 ModuleDefId::AdtId(AdtId::UnionId(id)) => {
                     this.push_decl(id, name, false, None);
@@ -156,7 +163,12 @@ impl<'a> SymbolCollector<'a> {
                 }
                 // Don't index these.
                 ModuleDefId::BuiltinType(_) => {}
-                ModuleDefId::EnumVariantId(_) => {}
+                ModuleDefId::EnumVariantId(id) => {
+                    // Enum variants are not directly nameable in the module namespace,
+                    // but users expect them to be discoverable via workspace symbol search.
+                    // Treat them as associated items for search filtering purposes.
+                    this.push_decl(id, name, true, None);
+                }
             }
         };
 
