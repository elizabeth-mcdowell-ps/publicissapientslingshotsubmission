+export const ssgParams: SSGParamsMiddleware = (params) => {
+  let computed: SSGParams | undefined
+  return async (c, next) => {
+    // During SSG we may "probe" routes (e.g. app.fetch on the route template like `/shops/:id`).
+    // `ssgParams()` is only needed to collect params for generation, so compute it once.
+    if (!computed) {
+      computed = Array.isArray(params) ? params : await params(c)
+    }
+    ;(c.req.raw as AddedSSGDataRequest).ssgParams = computed
+    await next()
+  }
