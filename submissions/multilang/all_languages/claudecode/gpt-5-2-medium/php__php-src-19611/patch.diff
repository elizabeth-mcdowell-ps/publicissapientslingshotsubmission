diff --git a/Zend/zend_compile.c b/Zend/zend_compile.c
index 0a7ab7da1bd..649106842f0 100644
--- a/Zend/zend_compile.c
+++ b/Zend/zend_compile.c
@@ -2885,11 +2885,37 @@ static zend_result zend_try_compile_cv(znode *result, zend_ast *ast, uint32_t ty
 			return FAILURE;
 		}
 
+		/*
+		 * $http_response_header is a special, predefined local variable set by the HTTP wrapper.
+		 * This variable is deprecated (use http_get_last_response_headers() instead), but userland
+		 * code is allowed to declare a CV named $http_response_header (e.g. function parameters).
+		 *
+		 * Only emit a deprecation when reading the predefined variable, i.e. when the CV name is
+		 * first introduced by a read access (type == BP_VAR_R). If the CV was introduced by userland
+		 * (e.g. a parameter, foreach, assignment, etc.), then reading it should not warn.
+		 */
 		if (!CG(context).has_assigned_to_http_response_header && zend_string_equals_literal(name, "http_response_header")) {
+			/*
+			 * Suppress warning if the CV already exists (e.g. function parameter).
+			 * In that case this is a userland variable, not the predefined one.
+			 */
 			if (type == BP_VAR_R) {
-				zend_error(E_DEPRECATED,
-					"The predefined locally scoped $http_response_header variable is deprecated,"
-					" call http_get_last_response_headers() instead");
+				/*
+				 * If this CV already exists, it was introduced by userland (e.g. a parameter)
+				 * and should not trigger the predefined-variable deprecation.
+				 */
+				bool is_existing_userland_cv = false;
+				for (int i = 0; i < CG(active_op_array)->last_var; i++) {
+					if (CG(active_op_array)->vars[i] && zend_string_equals(CG(active_op_array)->vars[i], name)) {
+						is_existing_userland_cv = true;
+						break;
+					}
+				}
+				if (!is_existing_userland_cv) {
+					zend_error(E_DEPRECATED,
+						"The predefined locally scoped $http_response_header variable is deprecated,"
+						" call http_get_last_response_headers() instead");
+				}
 			} else if (type == BP_VAR_W) {
 				CG(context).has_assigned_to_http_response_header = true;
 			}
