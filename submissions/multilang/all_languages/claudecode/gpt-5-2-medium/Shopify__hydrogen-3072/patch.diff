index b56070be..703be871 100644
--- a/packages/hydrogen-react/src/parse-metafield.ts
+++ b/packages/hydrogen-react/src/parse-metafield.ts
@@ -63,8 +63,43 @@ export function parseMetafield<ReturnGeneric>(
       } as ReturnGeneric;
 
     // TODO: 'money' should probably be parsed even further to like `useMoney()`, but that logic needs to be extracted first so it's not a hook
+    case 'money': {
+      let parsedValue: unknown = null;
+      try {
+        parsedValue = parseJSON(metafield.value ?? '');
+      } catch (err) {
+        const parseError = `parseMetafield(): attempted to JSON.parse the 'metafield.value' property, but failed.`;
+        if (__HYDROGEN_DEV__) {
+          throw new Error(parseError);
+        } else {
+          console.error(`${parseError} Returning 'null' for 'parsedValue'`);
+        }
+        parsedValue = null;
+      }
+
+      // Storefront API returns money metafields as JSON with `currency_code`.
+      // Normalize to the MoneyV2 shape (`currencyCode`) to match Hydrogen types.
+      if (
+        parsedValue &&
+        typeof parsedValue === 'object' &&
+        'currency_code' in parsedValue &&
+        !('currencyCode' in parsedValue)
+      ) {
+        const money = parsedValue as {currency_code?: unknown; currencyCode?: unknown};
+        parsedValue = {
+          ...(parsedValue as Record<string, unknown>),
+          currencyCode: money.currency_code,
+        };
+        delete (parsedValue as Record<string, unknown>).currency_code;
+      }
+
+      return {
+        ...metafield,
+        parsedValue,
+      } as ReturnGeneric;
+    }
+
