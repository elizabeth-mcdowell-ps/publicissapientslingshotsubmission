+// RegisterBackupStorageLocationLastStatus records the last status of a backup storage location.
+func (m *ServerMetrics) RegisterBackupStorageLocationLastStatus(bslName string, lastStatus int64) {
+	// primary metric (namespaced under "velero")
+	if g, ok := m.metrics[backupStorageLocationLastStatus].(*prometheus.GaugeVec); ok {
+		g.WithLabelValues(bslName).Set(float64(lastStatus))
+	}
+	// legacy alias for backward compatibility
+	if g, ok := m.metrics[backupStorageLocationLastStatusAliasLegacy].(*prometheus.GaugeVec); ok {
+		g.WithLabelValues(bslName).Set(float64(lastStatus))
+	}
+}
