diff --git a/src/Orleans.Serialization.SystemTextJson/JsonCodec.cs b/src/Orleans.Serialization.SystemTextJson/JsonCodec.cs
index ab8ace8b2..3ade47a90 100644
--- a/src/Orleans.Serialization.SystemTextJson/JsonCodec.cs
+++ b/src/Orleans.Serialization.SystemTextJson/JsonCodec.cs
@@ -135,7 +135,22 @@ object IFieldCodec.ReadValue<TInput>(ref Reader<TInput> reader, Field field)
                         reader.ReadBytes(ref tempBuffer, (int)length);
                         var sequence = tempBuffer.AsReadOnlySequence();
                         var jsonReader = new Utf8JsonReader(sequence, _options.ReaderOptions);
-                        result = JsonSerializer.Deserialize(ref jsonReader, type, _options.SerializerOptions);
+
+                        // JsonValue.Create(...) instances are often JsonValuePrimitive<T> where T is a CLR primitive type.
+                        // System.Text.Json will deserialize those into a JsonValuePrimitive<JsonElement>, which cannot be
+                        // assigned back to the original runtime type and results in InvalidCastException.
+                        // To preserve compatibility, deserialize JsonNode/JsonValue payloads into JsonNode.
+                        if (typeof(JsonNode).IsAssignableFrom(type))
+                        {
+                            // Use JsonDocument+JsonNode conversion to avoid JsonValuePrimitive<T> rehydration issues.
+                            // JsonNode.Parse does not have a ReadOnlySequence overload on all TFMs.
+                            using var doc = JsonDocument.Parse(sequence, new JsonDocumentOptions { AllowTrailingCommas = _options.ReaderOptions.AllowTrailingCommas, CommentHandling = _options.ReaderOptions.CommentHandling, MaxDepth = _options.ReaderOptions.MaxDepth });
+                            result = JsonNode.Parse(doc.RootElement.GetRawText());
+                        }
+                        else
+                        {
+                            result = JsonSerializer.Deserialize(ref jsonReader, type, _options.SerializerOptions);
+                        }
                     }
                     finally
                     {
