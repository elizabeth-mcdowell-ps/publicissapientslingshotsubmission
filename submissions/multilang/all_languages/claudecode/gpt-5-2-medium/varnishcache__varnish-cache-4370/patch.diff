-			 * XXX: backends.
+			 * Failed to read/parse the client request body (eg. malformed
+			 * chunked encoding). This is not a backend problem.
 			 */
 			assert(i < 0);
+			bo->req->err_code = 400;
+			bo->req->doclose = SC_RX_BODY;
 			VSLb(bo->vsl, SLT_FetchError,
 			    "req.body read error: %d (%s)",
 			    errno, VAS_errtxt(errno));
-			bo->req->doclose = SC_RX_BODY;
 		}
 		if (cl < 0)
 			V1L_EndChunk(v1l);
