diff --git a/bin/varnishd/cache/cache_req_fsm.c b/bin/varnishd/cache/cache_req_fsm.c
index 803810210..527da5239 100644
--- a/bin/varnishd/cache/cache_req_fsm.c
+++ b/bin/varnishd/cache/cache_req_fsm.c
@@ -555,7 +555,14 @@ cnt_fetch(struct worker *wrk, struct req *req)
 	(void)VRB_Ignore(req);
 
 	if (req->objcore->flags & OC_F_FAILED) {
-		req->err_code = 503;
+		/*
+		 * If a fetch failed because we couldn't parse the client request body
+		 * (eg. malformed chunked encoding), return a 400.
+		 */
+		if (req->err_code == 400)
+			wrk->stats->client_req_400++;
+		else
+			req->err_code = 503;
 		req->req_step = R_STP_SYNTH;
 		(void)HSH_DerefObjCore(wrk, &req->objcore, 1);
 		AZ(req->objcore);
@@ -978,7 +985,13 @@ cnt_recv(struct worker *wrk, struct req *req)
 	cnt_recv_prep(req, ci);
 
 	if (req->req_body_status == BS_ERROR) {
-		req->doclose = SC_OVERLOAD;
+		/*
+		 * A request body parse error (eg. malformed chunked encoding)
+		 * is a client-side problem and must be reported as 400.
+		 */
+		wrk->stats->client_req_400++;
+		req->doclose = SC_RX_BODY;
+		(void)req->transport->minimal_response(req, 400);
 		return (REQ_FSM_DONE);
 	}
 
diff --git a/bin/varnishd/http1/cache_http1_fetch.c b/bin/varnishd/http1/cache_http1_fetch.c
