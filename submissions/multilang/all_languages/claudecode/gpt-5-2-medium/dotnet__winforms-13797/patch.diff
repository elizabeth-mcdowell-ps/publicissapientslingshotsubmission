+        //
+        // Use the full location relative to the parent (including scroll offsets and nesting).
+        Point origin = PointToScreen(Point.Empty);
+        Point parentOrigin = parent.PointToScreen(Point.Empty);
+        int dx = origin.X - parentOrigin.X;
+        int dy = origin.Y - parentOrigin.Y;
