+        // Detect whether we're completing a *place expression*, i.e. something that must be
+        // assignable (LHS of `=`/`+=`/etc). In such contexts, `&`/`&mut` ref-match completions are
+        // rarely helpful and can produce confusing entries.
+        let is_place_expr = token
+            .parent_ancestors()
+            .find_map(ast::Expr::cast)
+            .and_then(|expr| {
+                let parent = expr.syntax().parent()?;
+                let bin = ast::BinExpr::cast(parent)?;
+                let op = bin.op_kind()?;
+                let is_assign = matches!(op, ast::BinaryOp::Assignment { .. });
+                if !is_assign {
+                    return None;
+                }
+                Some(bin.lhs()? == expr)
+            })
+            .unwrap_or(false);
