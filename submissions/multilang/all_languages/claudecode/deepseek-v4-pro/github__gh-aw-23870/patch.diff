+			"        env:",
+			"          ENGINE_VERSION: " + version,
+			"        run: " + installCmd,
+		})
+	} else {
+		installCmd := fmt.Sprintf("npm install %s%s@%s", globalFlag, packageName, version)
+		steps = append(steps, GitHubActionStep{
+			"      - name: " + stepName,
+			"        run: " + installCmd,
+		})
+	}
 
 	return steps
 }
