+	// Watch for changes to NVIDIADriver resources that could affect other
+	// NVIDIADriver CRs. When any NVIDIADriver is created, updated, or deleted,
+	// the global nodeSelector conflict state may change, so all NVIDIADriver
+	// instances need to be reconciled to re-validate.
+	nvDriverMapFn := func(ctx context.Context, nd *nvidiav1alpha1.NVIDIADriver) []reconcile.Request {
+		logger := log.FromContext(ctx)
+		opts := []client.ListOption{}
+		list := &nvidiav1alpha1.NVIDIADriverList{}
+
+		err := mgr.GetClient().List(ctx, list, opts...)
