@@ -414,6 +414,19 @@ fn current_time_ms() -> Result<i64> {
 }
 
 fn map_db_error(error: &sqlx::Error) -> Error {
+    // Detect UNIQUE constraint violations (SQLite extended code 2067, Postgres code 23505)
+    // and map them to UniqueViolation so callers can surface user-friendly messages.
+    if let sqlx::Error::Database(db_err) = error {
+        // SQLite: code 2067 is SQLITE_CONSTRAINT_UNIQUE
+        // Postgres: code 23505 is unique_violation
+        if db_err.code() == Some(std::borrow::Cow::Borrowed("2067"))
+            || db_err.code() == Some(std::borrow::Cow::Borrowed("23505"))
+        {
+            return Error::unique_violation(format!(
+                "an object with this (object_type, name) already exists"
+            ));
+        }
+    }
     Error::execution(format!("database error: {error}"))
 }
