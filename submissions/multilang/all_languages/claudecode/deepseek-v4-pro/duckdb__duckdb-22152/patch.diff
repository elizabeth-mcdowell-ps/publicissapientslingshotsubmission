diff --git a/src/function/cast/list_casts.cpp b/src/function/cast/list_casts.cpp
index f0d5bc1..569db60 100644
--- a/src/function/cast/list_casts.cpp
+++ b/src/function/cast/list_casts.cpp
@@ -73,6 +73,29 @@ bool ListCast::ListToListCast(Vector &source, Vector &result, idx_t count, CastP
 	bool all_succeeded = cast_data.child_cast_info.Cast(source_cc, append_vector, source_size, child_parameters);
 	ListVector::SetListSize(result, source_size);
 	D_ASSERT(ListVector::GetListSize(result) == source_size);
+
+	// If child cast failed for some entries, propagate NULL to parent list entries
+	if (!all_succeeded && result.GetVectorType() == VectorType::FLAT_VECTOR) {
+		auto source_child_validity = source_cc.Validity(source_size);
+		auto result_child_validity = append_vector.Validity(source_size);
+		auto &result_validity = FlatVector::ValidityMutable(result);
+		auto result_list_data = FlatVector::GetData<list_entry_t>(result);
+		for (idx_t i = 0; i < count; i++) {
+			if (!result_validity.RowIsValid(i)) {
+				continue;
+			}
+			auto &list_entry = result_list_data[i];
+			for (idx_t c = 0; c < list_entry.length; c++) {
+				auto child_idx = list_entry.offset + c;
+				if (source_child_validity.IsValid(child_idx) &&
+				    !result_child_validity.IsValid(child_idx)) {
+					result_validity.SetInvalid(i);
+					break;
+				}
+			}
+		}
+	}
+
 	return all_succeeded;
 }
 
diff --git a/src/function/cast/struct_cast.cpp b/src/function/cast/struct_cast.cpp
index cc2063f..0ccb584 100644
--- a/src/function/cast/struct_cast.cpp
+++ b/src/function/cast/struct_cast.cpp
@@ -133,7 +133,31 @@ static bool StructToStructCast(Vector &source, Vector &result, idx_t count, Cast
 
 	source.Flatten(count);
 	auto &result_validity = FlatVector::ValidityMutable(result);
-	result_validity = FlatVector::ValidityMutable(source);
+	auto &source_validity = FlatVector::ValidityMutable(source);
+	result_validity = source_validity;
+
+	// If child casts failed for some entries, propagate the null state to the struct entries
+	if (!all_converted) {
+		for (idx_t i = 0; i < count; i++) {
+			if (!source_validity.RowIsValid(i)) {
+				continue; // Already invalid, no need to propagate
+			}
+			// Check if any child field became invalid when it was valid in the source
+			for (idx_t c = 0; c < cast_data.target_indexes.size(); c++) {
+				auto target_idx = cast_data.target_indexes[c];
+				auto source_idx = cast_data.source_indexes[c];
+				auto &target_child = target_children[target_idx];
+				auto &source_child = source_vectors[source_idx];
+				auto source_child_valid = source_child.Validity(count);
+				auto target_child_valid = target_child.Validity(count);
+				if (source_child_valid.IsValid(i) && !target_child_valid.IsValid(i)) {
+					result_validity.SetInvalid(i);
+					break;
+				}
+			}
+		}
+	}
+
 	result.Verify(count);
 	return all_converted;
 }
