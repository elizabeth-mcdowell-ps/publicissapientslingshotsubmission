 function getComplexComponent(useGetter = false) {
@@ -79,4 +79,76 @@ describe('onClickOutside', () => {
     await userEvent.click(other)
     expect(consoleSpy).toHaveBeenCalled()
   })
+
+  it('should detect iframe clicks inside shadow DOM with detectIframe option', async () => {
+    const handlerSpy = vi.fn()
+
+    // Create a shadow host with an iframe inside its shadow DOM
+    const shadowHost = document.createElement('div')
+    document.body.appendChild(shadowHost)
+    const shadowRoot = shadowHost.attachShadow({ mode: 'open' })
+    shadowRoot.innerHTML = '<iframe tabindex="0"></iframe>'
+
+    // Create target element
+    const targetEl = document.createElement('div')
+    targetEl.textContent = 'Inside'
+    document.body.appendChild(targetEl)
+
+    const stop = onClickOutside(targetEl, handlerSpy, {
+      detectIframe: true,
+    })
+
+    expect(handlerSpy).not.toHaveBeenCalled()
+
+    // Focus the iframe inside the shadow DOM
+    const shadowIframe = shadowRoot.querySelector<HTMLIFrameElement>('iframe')
+    expect(shadowIframe).toBeTruthy()
+    shadowIframe!.focus()
+
+    // Now document.activeElement should be the shadow host (not the iframe)
+    // and shadowRoot.activeElement should be the iframe
+    expect(document.activeElement).toBe(shadowHost)
+
+    // Simulate the window blur event
+    window.dispatchEvent(new FocusEvent('blur'))
+
+    // The blur handler uses setTimeout(0), so we need to wait
+    await new Promise(resolve => setTimeout(resolve, 10))
+
+    expect(handlerSpy).toHaveBeenCalled()
+
+    // Cleanup
+    stop()
+    document.body.removeChild(shadowHost)
+    document.body.removeChild(targetEl)
+  })
+
+  it('should not trigger blur handler if iframe is inside the target element', async () => {
+    const handlerSpy = vi.fn()
+
+    // Create target element with an iframe inside it
+    const targetEl = document.createElement('div')
+    targetEl.innerHTML = '<iframe></iframe>'
+    document.body.appendChild(targetEl)
+
+    const stop = onClickOutside(targetEl, handlerSpy, {
+      detectIframe: true,
+    })
+
+    expect(handlerSpy).not.toHaveBeenCalled()
+
+    // Focus the iframe that is inside the target
+    const iframe = targetEl.querySelector<HTMLIFrameElement>('iframe')
+    iframe!.focus()
+
+    // Simulate blur event — but the iframe is inside the target, so handler should NOT be called
+    window.dispatchEvent(new FocusEvent('blur'))
+    await new Promise(resolve => setTimeout(resolve, 10))
+
+    expect(handlerSpy).not.toHaveBeenCalled()
+
+    // Cleanup
+    stop()
+    document.body.removeChild(targetEl)
+  })
 })
