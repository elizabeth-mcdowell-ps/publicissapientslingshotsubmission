diff --git a/Zend/zend_compile.c b/Zend/zend_compile.c
index 0a7ab7da1bd..1afdf3abedf 100644
--- a/Zend/zend_compile.c
+++ b/Zend/zend_compile.c
@@ -2886,12 +2886,26 @@ static zend_result zend_try_compile_cv(znode *result, zend_ast *ast, uint32_t ty
 		}
 
 		if (!CG(context).has_assigned_to_http_response_header && zend_string_equals_literal(name, "http_response_header")) {
-			if (type == BP_VAR_R) {
-				zend_error(E_DEPRECATED,
-					"The predefined locally scoped $http_response_header variable is deprecated,"
-					" call http_get_last_response_headers() instead");
-			} else if (type == BP_VAR_W) {
-				CG(context).has_assigned_to_http_response_header = true;
+			/* Check if the variable already exists as a CV in the current op_array (e.g. it is a parameter).
+			 * In that case, it is NOT the special $http_response_header variable. */
+			zend_op_array *op_array = CG(active_op_array);
+			zend_ulong hash = zend_string_hash_val(name);
+			bool is_existing_cv = false;
+			for (int i = 0; i < op_array->last_var; i++) {
+				if (ZSTR_H(op_array->vars[i]) == hash
+				 && zend_string_equals(op_array->vars[i], name)) {
+					is_existing_cv = true;
+					break;
+				}
+			}
+			if (!is_existing_cv) {
+				if (type == BP_VAR_R) {
+					zend_error(E_DEPRECATED,
+						"The predefined locally scoped $http_response_header variable is deprecated,"
+						" call http_get_last_response_headers() instead");
+				} else if (type == BP_VAR_W) {
+					CG(context).has_assigned_to_http_response_header = true;
+				}
 			}
 		}
