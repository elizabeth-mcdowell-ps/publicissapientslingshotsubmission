+    // ── Props CLI tests ───────────────────────────────────────────────
+
+    #[test]
+    fn props_subcommand_is_parsed() {
+        let cli = Cli::try_parse_from(["zeroclaw", "props", "list"])
+            .expect("zeroclaw props list should parse");
+        match cli.command {
+            Commands::Props { props_command } => {
+                assert!(matches!(props_command, PropsCommand::List { .. }));
+            }
+            _ => panic!("expected Props command, got {:?}", cli.command),
+        }
+    }
+
+    #[test]
+    fn props_list_filter_parses() {
+        let cli =
+            Cli::try_parse_from(["zeroclaw", "props", "list", "--filter", "gateway"])
+                .expect("props list --filter should parse");
+        match cli.command {
+            Commands::Props { props_command } => match props_command {
+                PropsCommand::List { filter, secrets } => {
+                    assert_eq!(filter, Some("gateway".to_string()));
+                    assert!(!secrets);
+                }
+                other => panic!("expected List, got {:?}", other),
+            },
+            _ => panic!("expected Props command, got {:?}", cli.command),
+        }
+    }
+
+    #[test]
+    fn props_list_secrets_parses() {
+        let cli = Cli::try_parse_from(["zeroclaw", "props", "list", "--secrets"])
+            .expect("props list --secrets should parse");
+        match cli.command {
+            Commands::Props { props_command } => match props_command {
+                PropsCommand::List { filter, secrets } => {
+                    assert!(filter.is_none());
+                    assert!(secrets);
+                }
+                other => panic!("expected List, got {:?}", other),
+            },
+            _ => panic!("expected Props command, got {:?}", cli.command),
+        }
+    }
+
+    #[test]
+    fn props_get_parses() {
+        let cli = Cli::try_parse_from(["zeroclaw", "props", "get", "gateway.port"])
+            .expect("props get should parse");
+        match cli.command {
+            Commands::Props { props_command } => match props_command {
+                PropsCommand::Get { path } => assert_eq!(path, "gateway.port"),
+                other => panic!("expected Get, got {:?}", other),
+            },
+            _ => panic!("expected Props command, got {:?}", cli.command),
+        }
+    }
+
+    #[test]
+    fn props_set_with_value_parses() {
+        let cli = Cli::try_parse_from(["zeroclaw", "props", "set", "gateway.port", "9090"])
+            .expect("props set with value should parse");
+        match cli.command {
+            Commands::Props { props_command } => match props_command {
+                PropsCommand::Set { path, value } => {
+                    assert_eq!(path, "gateway.port");
+                    assert_eq!(value, Some("9090".to_string()));
+                }
+                other => panic!("expected Set, got {:?}", other),
+            },
+            _ => panic!("expected Props command, got {:?}", cli.command),
+        }
+    }
+
+    #[test]
+    fn props_init_parses() {
+        let cli = Cli::try_parse_from(["zeroclaw", "props", "init"])
+            .expect("props init should parse");
+        match cli.command {
+            Commands::Props { props_command } => match props_command {
+                PropsCommand::Init { section } => assert!(section.is_none()),
+                other => panic!("expected Init, got {:?}", other),
+            },
+            _ => panic!("expected Props command, got {:?}", cli.command),
+        }
+    }
+
+    #[test]
+    fn props_init_section_parses() {
+        let cli = Cli::try_parse_from(["zeroclaw", "props", "init", "channels.telegram"])
