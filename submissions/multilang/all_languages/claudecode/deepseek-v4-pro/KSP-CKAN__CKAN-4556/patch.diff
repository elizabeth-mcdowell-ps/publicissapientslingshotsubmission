+        /// <summary>
+        /// Checks whether a path is a subdirectory of another path.
+        /// Uses canonicalized full paths to avoid issues with relative paths,
+        /// symlinks, and trailing slashes.
+        /// </summary>
+        /// <param name="parentPath">The potential parent directory path</param>
+        /// <param name="childPath">The potential child directory path</param>
+        /// <returns>true if childPath is a subdirectory of parentPath</returns>
+        private static bool IsSubdirectoryOf(string parentPath, string childPath)
+        {
+            var canonicalParent = Path.GetFullPath(parentPath).TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar) + Path.DirectorySeparatorChar;
+            var canonicalChild  = Path.GetFullPath(childPath).TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar) + Path.DirectorySeparatorChar;
+
+            return canonicalChild.StartsWith(canonicalParent, Platform.PathComparison);
+        }
