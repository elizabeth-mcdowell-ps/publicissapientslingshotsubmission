diff --git a/src/Riok.Mapperly/Descriptors/MappingBuilders/CtorMappingBuilder.cs b/src/Riok.Mapperly/Descriptors/MappingBuilders/CtorMappingBuilder.cs
index 8cbec2d..59e7709 100644
--- a/src/Riok.Mapperly/Descriptors/MappingBuilders/CtorMappingBuilder.cs
+++ b/src/Riok.Mapperly/Descriptors/MappingBuilders/CtorMappingBuilder.cs
@@ -41,6 +41,21 @@ public static class CtorMappingBuilder
         if (ctor == null)
             return null;
 
+        // If a [MapperConstructor] is present on a different constructor,
+        // skip the copy constructor to respect the [MapperConstructor] attribute.
+        // This allows [MapperConstructor] to override copy constructor selection
+        // (e.g. when UseDeepCloning=true).
+        if (
+            !ctx.SymbolAccessor.HasAttribute<MapperConstructorAttribute>(ctor)
+            && namedTarget.InstanceConstructors.Any(c =>
+                ctx.SymbolAccessor.IsConstructorAccessible(c)
+                && ctx.SymbolAccessor.HasAttribute<MapperConstructorAttribute>(c)
+            )
+        )
+        {
+            return null;
+        }
+
         return new CtorMapping(ctx.Source, ctx.Target, ctx.InstanceConstructors.BuildForConstructor(ctor));
     }
