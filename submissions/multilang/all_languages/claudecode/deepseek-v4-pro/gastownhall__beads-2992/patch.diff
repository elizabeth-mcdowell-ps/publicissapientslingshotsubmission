+		thread_id VARCHAR(255) DEFAULT '',
+		PRIMARY KEY (issue_id, depends_on_id),
+		INDEX idx_wisp_dep_depends (depends_on_id)
+	)`,
+	`CREATE TABLE IF NOT EXISTS wisp_events (
