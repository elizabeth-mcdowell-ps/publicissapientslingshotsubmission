+// createIgnoredTablesInTx recreates dolt_ignore'd tables (wisps, wisp_*)
+// inside an existing transaction. These tables only exist in the working set
+// and are not persisted in commit history, so they must be recreated on every
+// Dolt engine restart. Safe to call repeatedly (uses CREATE TABLE IF NOT EXISTS).
+func createIgnoredTablesInTx(ctx context.Context, tx *sql.Tx) error {
+	for _, stmt := range wispTableSQL {
+		if _, err := tx.ExecContext(ctx, stmt); err != nil {
+			return fmt.Errorf("creating wisp table: %w", err)
+		}
+	}
+	return nil
+}
+
+// wispTableSQL contains the CREATE TABLE IF NOT EXISTS statements for all
