 }
+
+// isGeneralPattern checks if a pattern is general (matches a wide range of paths)
+func isGeneralPattern(pattern string) bool {
+	// Patterns like ^/(.*)$ should be considered general catch-alls
+	generalPatterns := []string{
+		`^/(.*)$`,
+		`^/.+$`,
+		`^/[^/]*$`,
+		`^/.*$`,
+	}
+
+	for _, gp := range generalPatterns {
+		if pattern == gp {
+			return true
+		}
+	}
+	return false
+}
