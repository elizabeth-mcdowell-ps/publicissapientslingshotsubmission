+			// If both have a rewrite target, prioritize specific patterns over general ones
+			iGeneral := isGeneralPattern(in[i].Path)
+			jGeneral := isGeneralPattern(in[j].Path)
+
+			if iGeneral && !jGeneral {
+				// j is more specific, so j should come BEFORE i (j has higher priority)
+				return false // j comes first
+			} else if !iGeneral && jGeneral {
+				// i is more specific, so i should come BEFORE j (i has higher priority)
+				return true // i comes first
