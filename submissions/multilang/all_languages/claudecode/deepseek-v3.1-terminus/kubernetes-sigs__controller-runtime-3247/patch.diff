+
+// drainErrChan drains the error channel to prevent goroutines from hanging
+// when trying to send errors after the context has been cancelled.
+func drainErrChan(errChan chan error) {
+	for {
+		select {
+		case <-errChan:
+			// Drain errors
+		default:
+			// No more errors to drain
+			return
+		}
+	}
+}
