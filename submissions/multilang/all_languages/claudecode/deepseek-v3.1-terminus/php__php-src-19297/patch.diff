diff --git a/ext/reflection/php_reflection.c b/ext/reflection/php_reflection.c
index 3a37304dc2d..268c17e1dc4 100644
--- a/ext/reflection/php_reflection.c
+++ b/ext/reflection/php_reflection.c
@@ -1056,6 +1056,27 @@ static void _property_string(smart_str *str, zend_property_info *prop, const cha
 		}
 	}
 
+	/* Add property hooks indication */
+	if (prop && prop->hooks) {
+		smart_str_appends(str, " { ");
+		if (prop->hooks[ZEND_PROPERTY_HOOK_GET]) {
+			if (prop->hooks[ZEND_PROPERTY_HOOK_GET]->common.fn_flags & ZEND_ACC_FINAL) {
+				smart_str_appends(str, "final ");
+			}
+			smart_str_appends(str, "get");
+			if (prop->hooks[ZEND_PROPERTY_HOOK_SET]) {
+				smart_str_appends(str, "; ");
+			}
+		}
+		if (prop->hooks[ZEND_PROPERTY_HOOK_SET]) {
+			if (prop->hooks[ZEND_PROPERTY_HOOK_SET]->common.fn_flags & ZEND_ACC_FINAL) {
+				smart_str_appends(str, "final ");
+			}
+			smart_str_appends(str, "set");
+		}
+		smart_str_appends(str, " }");
+	}
+
 	smart_str_appends(str, " ]\n");
 }
 /* }}} */
