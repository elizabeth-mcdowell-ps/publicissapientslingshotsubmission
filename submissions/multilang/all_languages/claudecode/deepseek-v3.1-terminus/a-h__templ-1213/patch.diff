+
+func TestRenderAttributesWithNonStringValues(t *testing.T) {
+	ctx := context.Background()
+
+	t.Run("integer value", func(t *testing.T) {
+		var buf bytes.Buffer
+		attrs := templ.Attributes{
+			"type":  "text",
+			"value": 42,
+		}
+
+		err := templ.RenderAttributes(ctx, &buf, attrs)
+		if err != nil {
+			t.Fatalf("RenderAttributes failed: %v", err)
+		}
+
+		result := buf.String()
+		expected := ` type="text" value="42"`
+		if result != expected {
+			t.Errorf("Expected %q, got %q", expected, result)
+		}
+	})
+
+	t.Run("float value", func(t *testing.T) {
+		var buf bytes.Buffer
+		attrs := templ.Attributes{
+			"type":  "number",
+			"value": 3.14,
+		}
+
+		err := templ.RenderAttributes(ctx, &buf, attrs)
+		if err != nil {
+			t.Fatalf("RenderAttributes failed: %v", err)
+		}
+
+		result := buf.String()
+		expected := ` type="number" value="3.14"`
+		if result != expected {
+			t.Errorf("Expected %q, got %q", expected, result)
+		}
+	})
+
+	t.Run("boolean value", func(t *testing.T) {
+		var buf bytes.Buffer
+		attrs := templ.Attributes{
+			"disabled": true,
+			"type":     "button",
+		}
+
+		err := templ.RenderAttributes(ctx, &buf, attrs)
+		if err != nil {
+			t.Fatalf("RenderAttributes failed: %v", err)
+		}
+
+		result := buf.String()
+		// Boolean attributes should render without value when true
+		expected := ` disabled type="button"`
+		if result != expected {
+			t.Errorf("Expected %q, got %q", expected, result)
+		}
+	})
+
+	t.Run("mixed types", func(t *testing.T) {
+		var buf bytes.Buffer
+		attrs := templ.Attributes{
+			"type":    "checkbox",
+			"id":      "check1",
+			"value":   123,
+			"checked": true,
+			"data-id": 456,
+		}
+
+		err := templ.RenderAttributes(ctx, &buf, attrs)
+		if err != nil {
+			t.Fatalf("RenderAttributes failed: %v", err)
+		}
+
+		result := buf.String()
+		// Note: attributes are sorted by key, so order is: checked, data-id, id, type, value
+		expected := ` checked data-id="456" id="check1" type="checkbox" value="123"`
+		if result != expected {
+			t.Errorf("Expected %q, got %q", expected, result)
+		}
+	})
+}
