diff --git a/include/fmt/format.h b/include/fmt/format.h
index 25153a4d..d45cd940 100644
--- a/include/fmt/format.h
+++ b/include/fmt/format.h
@@ -828,7 +828,9 @@ class basic_memory_buffer : public detail::buffer<T> {
  private:
   // Move data from other to this buffer.
   FMT_CONSTEXPR20 void move(basic_memory_buffer& other) {
-    alloc_ = std::move(other.alloc_);
+    if constexpr (std::allocator_traits<Allocator>::propagate_on_container_move_assignment::value) {
+      alloc_ = std::move(other.alloc_);
+    }
     T* data = other.data();
     size_t size = other.size(), capacity = other.capacity();
     if (data == other.store_) {
@@ -855,8 +857,27 @@ class basic_memory_buffer : public detail::buffer<T> {
   /// Moves the content of the other `basic_memory_buffer` object to this one.
   auto operator=(basic_memory_buffer&& other) noexcept -> basic_memory_buffer& {
     FMT_ASSERT(this != &other, "");
-    deallocate();
-    move(other);
+    if constexpr (std::allocator_traits<Allocator>::propagate_on_container_move_assignment::value) {
+      deallocate();
+      move(other);
+    } else {
+      if (alloc_ == other.alloc_) {
+        deallocate();
+        move(other);
+      } else {
+        // If allocators are different, copy the data instead of moving
+        auto size = other.size();
+        if (size > this->capacity()) {
+          deallocate();
+          reserve(size);
+        } else {
+          this->clear();
+        }
+        std::copy(other.begin(), other.end(), this->begin());
+        this->resize(size);
+        // Don't clear the source since we can't take ownership of its memory
+      }
+    }
     return *this;
   }
