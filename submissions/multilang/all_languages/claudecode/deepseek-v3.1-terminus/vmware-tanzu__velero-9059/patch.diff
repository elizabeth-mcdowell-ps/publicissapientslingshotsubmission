+// RegisterBackupStorageLocationLastStatus records the last status of the backup storage location.
+func (m *ServerMetrics) RegisterBackupStorageLocationLastStatus(name, namespace string, lastStatus int64) {
+	if g, ok := m.metrics[backupStorageLocationLastStatus].(*prometheus.GaugeVec); ok {
+		g.WithLabelValues(name, namespace).Set(float64(lastStatus))
+	}
+}
