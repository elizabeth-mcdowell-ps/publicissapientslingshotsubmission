+func TestTableOfContentsWithNestedPassthrough(t *testing.T) {
+	t.Parallel()
+
+	files := `
+-- hugo.toml --
+[markup.goldmark.extensions.passthrough]
+enable = true
+[markup.goldmark.extensions.passthrough.delimiters]
+inline = [['$', '$']]
+-- content/p1.md --
+---
+title: p1
+---
+#### **$a$**
+-- layouts/page.html --
+{{ .Summary }}
+{{ .TableOfContents }}
+`
+
+	b := hugolib.Test(t, files)
+
+	b.AssertFileContent("public/p1/index.html", `<li><a href="#heading">$a$</a></li>`)
+}
