+func hasPassthroughInline(n ast.Node) bool {
+	for c := n.FirstChild(); c != nil; c = c.NextSibling() {
+		if c.Kind() == passthroughAst.KindPassthroughInline || hasPassthroughInline(c) {
+			return true
+		}
+	}
+	return false
+}
