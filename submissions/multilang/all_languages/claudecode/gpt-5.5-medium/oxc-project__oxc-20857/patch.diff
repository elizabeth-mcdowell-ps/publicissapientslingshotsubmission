+fn is_expression_with_type_cast_comment(
+    expression: &Expression<'_>,
+    f: &Formatter<'_, '_>,
+) -> bool {
+    match expression {
+        Expression::ParenthesizedExpression(parenthesized) => {
+            is_expression_with_type_cast_comment(&parenthesized.expression, f)
+        }
+        _ => f
+            .comments()
+            .comments_before(expression.span().start)
+            .iter()
+            .any(|comment| f.comments().is_type_cast_comment(comment)),
+    }
+}
