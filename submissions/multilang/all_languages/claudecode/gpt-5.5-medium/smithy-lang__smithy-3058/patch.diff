+    /**
+     * Creates a component order that sorts shapes, traits, and metadata using a custom comparator.
+     *
+     * <p>Shape and trait components are provided to the comparator directly. Metadata components are provided
+     * as synthetic {@link ToShapeId} values whose shape ID is derived from the metadata key.
+     *
+     * @param comparator Comparator used to sort serialized components.
+     * @return Returns the custom component order.
+     */
+    public static ComparatorOrder comparator(Comparator<? super ToShapeId> comparator) {
+        return new ComparatorOrder(comparator);
+    }
+
+    /**
+     * Defines a custom component order using a {@link Comparator}.
+     */
+    public static final class ComparatorOrder {
+        private final Comparator<Shape> shapeComparator;
+        private final Comparator<? extends ToShapeId> traitComparator;
+        private final Comparator<Map.Entry<String, Node>> metadataComparator;
+
+        private ComparatorOrder(Comparator<? super ToShapeId> comparator) {
+            Objects.requireNonNull(comparator);
+            this.shapeComparator = (left, right) -> comparator.compare(left, right);
+            this.traitComparator = (left, right) -> comparator.compare(left, right);
+            this.metadataComparator = (left, right) -> comparator.compare(
+                    new MetadataComponent(left.getKey()),
+                    new MetadataComponent(right.getKey()));
+        }
+
+        private ComparatorOrder(
+                Comparator<Shape> shapeComparator,
+                Comparator<? extends ToShapeId> traitComparator,
+                Comparator<Map.Entry<String, Node>> metadataComparator
+        ) {
+            this.shapeComparator = Objects.requireNonNull(shapeComparator);
+            this.traitComparator = Objects.requireNonNull(traitComparator);
+            this.metadataComparator = Objects.requireNonNull(metadataComparator);
+        }
+
+        Comparator<Shape> shapeComparator() {
+            return shapeComparator;
+        }
+
+        @SuppressWarnings("unchecked")
+        <T extends FromSourceLocation & ToShapeId> Comparator<T> toShapeIdComparator() {
+            return (Comparator<T>) traitComparator;
+        }
+
+        Comparator<Map.Entry<String, Node>> metadataComparator() {
+            return metadataComparator;
+        }
+    }
+
+    private static final class MetadataComponent implements ToShapeId {
+        private final String key;
+
+        private MetadataComponent(String key) {
+            this.key = key;
+        }
+
+        @Override
+        public ShapeId toShapeId() {
+            return ShapeId.fromParts("smithy.metadata", key);
