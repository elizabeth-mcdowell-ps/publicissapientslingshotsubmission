diff --git a/pkg/workflow/copilot_installer.go b/pkg/workflow/copilot_installer.go
index 70ebb94..f930b92 100644
--- a/pkg/workflow/copilot_installer.go
+++ b/pkg/workflow/copilot_installer.go
@@ -24,10 +24,21 @@ func GenerateCopilotInstallerSteps(version, stepName string) []GitHubActionStep
 	// and does not use gh CLI, so GH_HOST does not affect the download. No step-level
 	// GH_HOST override is needed here; the correct host is already set in GITHUB_ENV
 	// by configure_gh_for_ghe.sh (or by the Derive GH_HOST step when DIFC proxy is active).
+	installVersion := version
 	stepLines := []string{
 		"      - name: " + stepName,
-		"        run: ${RUNNER_TEMP}/gh-aw/actions/install_copilot_cli.sh " + version,
 	}
+	if isWholeGitHubActionsExpression(version) {
+		// GitHub Actions evaluates the expression into the environment value before the
+		// shell runs. The shell command then uses the quoted env var instead of embedding
+		// the expression directly in the command line, avoiding shell injection.
+		installVersion = `"$ENGINE_VERSION"`
+		stepLines = append(stepLines,
+			"        env:",
+			"          ENGINE_VERSION: "+version,
+		)
+	}
+	stepLines = append(stepLines, "        run: ${RUNNER_TEMP}/gh-aw/actions/install_copilot_cli.sh "+installVersion)
 
 	return []GitHubActionStep{GitHubActionStep(stepLines)}
 }
diff --git a/pkg/workflow/dispatch_repository_validation.go b/pkg/workflow/dispatch_repository_validation.go
index 49a4678..67b8593 100644
--- a/pkg/workflow/dispatch_repository_validation.go
+++ b/pkg/workflow/dispatch_repository_validation.go
@@ -105,3 +105,8 @@ func (c *Compiler) validateDispatchRepository(data *WorkflowData, workflowPath s
 func isGitHubActionsExpression(value string) bool {
 	return strings.Contains(value, "${{")
 }
+
+func isWholeGitHubActionsExpression(value string) bool {
+	trimmed := strings.TrimSpace(value)
+	return strings.HasPrefix(trimmed, "${{") && strings.HasSuffix(trimmed, "}}")
+}
