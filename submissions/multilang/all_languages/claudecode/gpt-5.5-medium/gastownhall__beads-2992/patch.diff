 // migrateUp applies all embedded .up.sql migrations that haven't been applied yet.
 // Returns the number of migrations applied.
+func createIgnoredTables(ctx context.Context, tx *sql.Tx) error {
+	statements := []string{
+		`CREATE TABLE IF NOT EXISTS wisps LIKE issues`,
+		`CREATE TABLE IF NOT EXISTS wisp_dependencies LIKE dependencies`,
+		`CREATE TABLE IF NOT EXISTS wisp_labels LIKE labels`,
+		`CREATE TABLE IF NOT EXISTS wisp_events LIKE events`,
+		`CREATE TABLE IF NOT EXISTS wisp_comments LIKE comments`,
+	}
+	for _, stmt := range statements {
+		if _, err := tx.ExecContext(ctx, stmt); err != nil {
+			return fmt.Errorf("creating ignored table with %q: %w", stmt, err)
+		}
+	}
+	if _, err := tx.ExecContext(ctx, `CREATE INDEX IF NOT EXISTS idx_wisp_dep_type ON wisp_dependencies (type)`); err != nil {
+		return fmt.Errorf("creating wisp dependency type index: %w", err)
+	}
+	if _, err := tx.ExecContext(ctx, `CREATE INDEX IF NOT EXISTS idx_wisp_dep_type_depends ON wisp_dependencies (type, depends_on_id)`); err != nil {
+		return fmt.Errorf("creating wisp dependency type/depends index: %w", err)
+	}
+	return nil
+}
