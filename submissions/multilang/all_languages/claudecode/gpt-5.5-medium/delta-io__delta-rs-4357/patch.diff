+pub(crate) fn normalize_file_url_as_file_id(file_url: Url) -> crate::DeltaResult<String> {
+    let mut file_url = file_url;
+    let decoded_path = percent_encoding::percent_decode_str(file_url.path())
+        .decode_utf8()
+        .map_err(|e| DeltaTableError::InvalidTableLocation(e.to_string()))?
+        .into_owned();
+    file_url.set_path(&decoded_path);
     Ok(file_url.to_string())
 }
 
