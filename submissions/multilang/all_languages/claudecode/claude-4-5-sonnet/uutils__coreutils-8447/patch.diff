diff --git a/tests/by-util/test_mktemp.rs b/tests/by-util/test_mktemp.rs
index 35c27dff6..19fcc8c95 100644
--- a/tests/by-util/test_mktemp.rs
+++ b/tests/by-util/test_mktemp.rs
@@ -977,3 +977,20 @@ fn test_missing_short_tmpdir_flag() {
         .no_stdout()
         .stderr_contains("a value is required for '-p <DIR>' but none was supplied");
 }
+
+#[test]
+fn test_mktemp_empty_tmpdir() {
+    let scene = TestScenario::new(util_name!());
+    
+    // Test with -p ""
+    let result = scene.ucmd().arg("-p").arg("").succeeds();
+    let stdout = result.stdout_str().trim();
+    // Should create temp file in default temp directory
+    assert!(stdout.starts_with("/tmp/") || stdout.starts_with("/var/") || stdout.contains("tmp"));
+    
+    // Test with --tmpdir=""
+    let result = scene.ucmd().arg("--tmpdir=").succeeds();
+    let stdout = result.stdout_str().trim();
+    // Should create temp file in default temp directory
+    assert!(stdout.starts_with("/tmp/") || stdout.starts_with("/var/") || stdout.contains("tmp"));
+}
