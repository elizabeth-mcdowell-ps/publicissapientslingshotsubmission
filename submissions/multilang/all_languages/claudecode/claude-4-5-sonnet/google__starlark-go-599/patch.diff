diff --git a/resolve/resolve.go b/resolve/resolve.go
index 494811d..28dbf05 100644
--- a/resolve/resolve.go
+++ b/resolve/resolve.go
@@ -822,6 +822,13 @@ func (r *resolver) function(function *Function, pos syntax.Position) {
 	b := &block{function: function}
 	r.push(b)
 
+	// A nested function has its own loop/ifstmt context.
+	// Save and reset the loop/ifstmt counters.
+	savedLoops := r.loops
+	savedIfstmts := r.ifstmts
+	r.loops = 0
+	r.ifstmts = 0
+
 	var seenOptional bool
 	var star *syntax.UnaryExpr // * or *args param
 	var starStar *syntax.Ident // **kwargs ident
@@ -905,6 +912,10 @@ func (r *resolver) function(function *Function, pos syntax.Position) {
 	// Leave function block.
 	r.pop()
 
+	// Restore loop/ifstmt counters.
+	r.loops = savedLoops
+	r.ifstmts = savedIfstmts
+
 	// References within the function body to globals are not
 	// resolved until the end of the module.
 }
diff --git a/resolve/testdata/resolve.star b/resolve/testdata/resolve.star
index cb6385a..ff33f07 100644
--- a/resolve/testdata/resolve.star
+++ b/resolve/testdata/resolve.star
@@ -227,6 +227,29 @@ continue ### "continue not in a loop"
 
 pass
 
+---
+# break and continue must be in a loop, even in nested functions
+# (https://github.com/google/starlark-go/issues/...)
+
+def f():
+  for x in [1, 2, 3]:
+    def nested():
+      break ### "break not in a loop"
+
+def g():
+  for x in [1, 2, 3]:
+    def nested():
+      continue ### "continue not in a loop"
+
+# Break/continue inside a nested function with no outer loop
+def h():
+  def nested():
+    break ### "break not in a loop"
+
+def i():
+  def nested():
+    continue ### "continue not in a loop"
+
 ---
 # Positional arguments (and required parameters)
 # must appear before named arguments (and optional parameters).
