+#[test]
+fn full_help_argument_alone() {
+    // When --help is the only argument, it should display help
+    let result = new_ucmd!().arg("--help").succeeds();
+    let stdout = result.stdout_str();
+    assert!(stdout.contains("Usage:") || stdout.contains("Echo the STRING"));
+}
+
+#[test]
+fn full_help_argument_with_others() {
+    // When --help is not alone, it should be treated as a regular string
+    new_ucmd!()
+        .args(&["--help", "--help"])
+        .succeeds()
+        .stdout_is("--help --help\n");
+
+    new_ucmd!()
+        .args(&["--help", "-e"])
+        .succeeds()
+        .stdout_is("--help -e\n");
+
+    new_ucmd!()
+        .args(&["-e", "--help"])
+        .succeeds()
+        .stdout_is("--help\n");
+}
+
+#[test]
+fn full_version_argument_alone() {
+    // When --version is the only argument, it should display version
+    let result = new_ucmd!().arg("--version").succeeds();
+    let stdout = result.stdout_str();
+    assert!(stdout.contains("echo") || stdout.contains("coreutils"));
+}
+
+#[test]
+fn full_version_argument_with_others() {
+    // When --version is not alone, it should be treated as a regular string
+    new_ucmd!()
+        .args(&["--version", "--version"])
+        .succeeds()
+        .stdout_is("--version --version\n");
+
+    new_ucmd!()
+        .args(&["--version", "-e"])
+        .succeeds()
+        .stdout_is("--version -e\n");
+
+    new_ucmd!()
+        .args(&["-e", "--version"])
+        .succeeds()
+        .stdout_is("--version\n");
+}
