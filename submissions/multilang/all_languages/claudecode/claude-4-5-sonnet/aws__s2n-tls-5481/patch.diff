diff --git a/tls/s2n_signature_algorithms.c b/tls/s2n_signature_algorithms.c
index 749c4276d..927ee7bd3 100644
--- a/tls/s2n_signature_algorithms.c
+++ b/tls/s2n_signature_algorithms.c
@@ -188,6 +188,16 @@ S2N_RESULT s2n_signature_algorithm_select(struct s2n_connection *conn)
         chosen_sig_scheme = &conn->handshake_params.server_cert_sig_scheme;
     }
 
+    /* When RSA key exchange is used, no separate signature is required.
+     * The server proves ownership of the RSA certificate by encrypting/decrypting
+     * the premaster secret instead.
+     */
+    RESULT_ENSURE_REF(cipher_suite->key_exchange_alg);
+    if (cipher_suite->key_exchange_alg == &s2n_rsa) {
+        *chosen_sig_scheme = &s2n_null_sig_scheme;
+        return S2N_RESULT_OK;
+    }
+
     /* Before TLS1.2, signature algorithms were fixed instead of negotiated */
     if (conn->actual_protocol_version < S2N_TLS12) {
         RESULT_GUARD(s2n_signature_algorithms_get_legacy_default(conn, conn->mode, chosen_sig_scheme));
