diff --git a/bin/varnishd/cache/cache_req_fsm.c b/bin/varnishd/cache/cache_req_fsm.c
index 803810210..67cfe0fe6 100644
--- a/bin/varnishd/cache/cache_req_fsm.c
+++ b/bin/varnishd/cache/cache_req_fsm.c
@@ -1006,8 +1006,10 @@ cnt_recv(struct worker *wrk, struct req *req)
 
 	/* Attempts to cache req.body may fail */
 	if (req->req_body_status == BS_ERROR) {
-		req->doclose = SC_RX_BODY;
-		return (REQ_FSM_DONE);
+		wrk->stats->client_req_400++;
+		req->err_code = 400;
+		req->req_step = R_STP_SYNTH;
+		return (REQ_FSM_MORE);
 	}
 
 	recv_handling = wrk->vpi->handling;
diff --git a/bin/varnishd/http1/cache_http1_fetch.c b/bin/varnishd/http1/cache_http1_fetch.c
index e0c53b96b..14deddedf 100644
--- a/bin/varnishd/http1/cache_http1_fetch.c
+++ b/bin/varnishd/http1/cache_http1_fetch.c
@@ -162,6 +162,10 @@ V1F_SendReq(struct worker *wrk, struct busyobj *bo, uint64_t *ctr_hdrbytes,
 			    "req.body read error: %d (%s)",
 			    errno, VAS_errtxt(errno));
 			bo->req->doclose = SC_RX_BODY;
+			/* Bad request body from client should cause 400, not 503 */
+			bo->req->err_code = 400;
+			bo->err_code = 400;
+			bo->err_reason = "Bad Request";
 		}
 		if (cl < 0)
 			V1L_EndChunk(v1l);
