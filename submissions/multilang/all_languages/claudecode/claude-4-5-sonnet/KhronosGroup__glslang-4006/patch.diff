diff --git a/SPIRV/SpvBuilder.cpp b/SPIRV/SpvBuilder.cpp
index 5a5affac..313b88c4 100644
--- a/SPIRV/SpvBuilder.cpp
+++ b/SPIRV/SpvBuilder.cpp
@@ -2917,8 +2917,24 @@ Id Builder::createAccessChain(StorageClass storageClass, Id base, const std::vec
     Instruction* chain = new Instruction(getUniqueId(), typeId, Op::OpAccessChain);
     chain->reserveOperands(offsets.size() + 1);
     chain->addIdOperand(base);
-    for (int i = 0; i < (int)offsets.size(); ++i)
-        chain->addIdOperand(offsets[i]);
+    for (int i = 0; i < (int)offsets.size(); ++i) {
+        Id index = offsets[i];
+        // According to the SPIR-V spec, OpAccessChain indices are treated as signed.
+        // If the index is a small integer type (< 32 bits), we need to extend it to 32 bits
+        // to avoid it being treated incorrectly as a negative number.
+        Id indexTypeId = getTypeId(index);
+        if (isIntType(indexTypeId) || isUintType(indexTypeId)) {
+            int width = getScalarTypeWidth(indexTypeId);
+            if (width < 32) {
+                // Extend to 32-bit integer
+                // Use the appropriate conversion based on signedness
+                Id targetType = isUintType(indexTypeId) ? makeUintType(32) : makeIntType(32);
+                Op convOp = isUintType(indexTypeId) ? Op::OpUConvert : Op::OpSConvert;
+                index = createUnaryOp(convOp, targetType, index);
+            }
+        }
+        chain->addIdOperand(index);
+    }
     addInstruction(std::unique_ptr<Instruction>(chain));
 
     return chain->getResultId();
