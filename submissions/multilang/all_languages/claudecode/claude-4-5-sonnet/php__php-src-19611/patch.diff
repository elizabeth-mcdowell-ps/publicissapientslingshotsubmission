diff --git a/Zend/zend_compile.c b/Zend/zend_compile.c
index 0a7ab7da1bd..4c733c3ee31 100644
--- a/Zend/zend_compile.c
+++ b/Zend/zend_compile.c
@@ -7802,6 +7802,12 @@ static void zend_compile_params(zend_ast *ast, zend_ast *return_type_ast, uint32
 			zend_error_noreturn(E_COMPILE_ERROR, "Cannot use $this as parameter");
 		}
 
+		/* If a function parameter is named $http_response_header, mark it as assigned
+		 * to prevent deprecation warnings when the parameter is used in the function body */
+		if (zend_string_equals_literal(name, "http_response_header")) {
+			CG(context).has_assigned_to_http_response_header = true;
+		}
+
 		if (op_array->fn_flags & ZEND_ACC_VARIADIC) {
 			zend_error_noreturn(E_COMPILE_ERROR, "Only the last parameter can be variadic");
 		}
