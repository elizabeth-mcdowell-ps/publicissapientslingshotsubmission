diff --git a/client/clients/tso/dispatcher_test.go b/client/clients/tso/dispatcher_test.go
index a2b9384fb..3679b207a 100644
--- a/client/clients/tso/dispatcher_test.go
+++ b/client/clients/tso/dispatcher_test.go
@@ -380,3 +380,54 @@ func BenchmarkTSODispatcherHandleRequests(b *testing.B) {
 	// Don't count the time cost in `defer`
 	b.StopTimer()
 }
+
+// TestGoroutineLeakOnStreamError tests that when stream errors occur,
+// pending requests are properly cancelled to avoid goroutine leak
+func (s *testTSODispatcherSuite) TestGoroutineLeakOnStreamError() {
+	ctx := context.Background()
+
+	// Send a request and generate response to establish the stream is working
+	req1 := s.sendReq(ctx)
+	s.reqMustNotReady(req1)
+	s.streamInner.generateNext()
+	s.reqMustReady(req1)
+
+	// Send another request to make sure everything is stable
+	req1b := s.sendReq(ctx)
+	s.reqMustNotReady(req1b)
+	s.streamInner.generateNext()
+	s.reqMustReady(req1b)
+
+	// Now send a batch of requests
+	req2 := s.sendReq(ctx)
+	req3 := s.sendReq(ctx)
+	req4 := s.sendReq(ctx)
+
+	// Give a short time for requests to be collected
+	time.Sleep(20 * time.Millisecond)
+
+	// Now close the connection context
+	// This simulates a network error by canceling the stream context
+	s.dispatcher.closeContext(mockStreamURL)
+
+	// All requests should complete with errors (not timeout)
+	// If the bug exists, these will timeout because collected requests
+	// are not properly cancelled when stream error occurs
+	_, _, err2 := req2.waitTimeout(3 * time.Second)
+	s.re.Error(err2, "req2 should complete with error, not timeout")
+	if err2 != nil {
+		s.re.NotErrorIs(err2, context.DeadlineExceeded, "req2 timed out - indicates goroutine leak bug")
+	}
+
+	_, _, err3 := req3.waitTimeout(3 * time.Second)
+	s.re.Error(err3, "req3 should complete with error, not timeout")
+	if err3 != nil {
+		s.re.NotErrorIs(err3, context.DeadlineExceeded, "req3 timed out - indicates goroutine leak bug")
+	}
+
+	_, _, err4 := req4.waitTimeout(3 * time.Second)
+	s.re.Error(err4, "req4 should complete with error, not timeout")
+	if err4 != nil {
+		s.re.NotErrorIs(err4, context.DeadlineExceeded, "req4 timed out - indicates goroutine leak bug")
+	}
+}
