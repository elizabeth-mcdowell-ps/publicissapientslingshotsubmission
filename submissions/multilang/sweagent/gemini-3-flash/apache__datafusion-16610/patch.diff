+#[test]
+fn test_struct_of_struct_unparsing() -> Result<()> {
+    // Product Name is at metadata.product.name
+    let schema = Schema::new(vec![
+        Field::new("metadata", 
+            DataType::Struct(vec![
+                Field::new("product", 
+                    DataType::Struct(vec![
+                        Field::new("name", DataType::Utf8, false)
+                    ]).into(), 
+                false)
+            ]).into(), 
+        false),
+    ]);
+
+    let table_scan = table_scan(Some("query"), &schema, None)?.build()?;
+    
+    // We want to test metadata['product']['name']
+    // In DataFusion, this is represented as GetField(GetField(metadata, 'product'), 'name')
+    let expr = Expr::ScalarFunction(datafusion_expr::expr::ScalarFunction::new_udf(
+        datafusion_functions_nested::field::get_field_udf(),
+        vec![
+            Expr::ScalarFunction(datafusion_expr::expr::ScalarFunction::new_udf(
+                datafusion_functions_nested::field::get_field_udf(),
+                vec![
+                    col("metadata"),
+                    lit("product"),
+                ]
+            )),
+            lit("name"),
+        ]
+    ));
+
+    let plan = LogicalPlanBuilder::from(table_scan)
+        .project(vec![expr])?
+        .build()?;
+
+    let sql_ast = plan_to_sql(&plan)?;
+    
+    println!("SQL: {}", sql_ast.to_string());
+    
+    Ok(())
+}
