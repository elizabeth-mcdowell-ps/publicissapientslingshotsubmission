@@ -0,0 +1,22 @@
+use std::io::Error;
+use datafusion::prelude::{NdJsonReadOptions, SessionContext};
+use datafusion::sql::unparser::plan_to_sql;
+use datafusion::arrow::util::pretty::print_batches;
+
+#[tokio::main]
+async fn main() -> Result<(), Box<dyn std::error::Error>> {
+    let ctx = SessionContext::new();
+    ctx.register_json("query", "tests/fixtures/query.json", NdJsonReadOptions::default()).await?;
+
+    // The PR says SELECT query."message" but query.json only has "metadata".
+    // I'll adjust the query to match what's in query.json or just select metadata.
+    let df = ctx.sql(r#"SELECT metadata FROM query WHERE metadata['product']['name']  = 'Product Name'"#).await?;
+    let sql_ast = plan_to_sql(df.logical_plan());
+
+    match sql_ast {
+        Ok(ast) => println!("SQL: {}", ast.to_string()),
+        Err(e) => println!("Error: {:?}", e),
+    }
+
+    Ok(())
+}
