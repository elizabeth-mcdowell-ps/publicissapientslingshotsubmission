+package jira
+
+import (
+"context"
+"encoding/json"
+"io"
+"net/http"
+"net/http/httptest"
+"net/url"
+"testing"
+"time"
+
+commoncfg "github.com/prometheus/common/config"
+"github.com/prometheus/common/model"
+"github.com/prometheus/common/promslog"
+"github.com/stretchr/testify/require"
+
+"github.com/prometheus/alertmanager/config"
+"github.com/prometheus/alertmanager/notify"
+"github.com/prometheus/alertmanager/notify/test"
+)
+
+func TestSearchIssueWithReopenDuration(t *testing.T) {
+var capturedJQL string
+srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+if r.URL.Path == "/search" {
+body, _ := io.ReadAll(r.Body)
+var data issueSearch
+json.Unmarshal(body, &data)
+capturedJQL = data.JQL
+w.Write([]byte(`{"total": 0, "issues": []}`))
+}
+}))
+defer srv.Close()
+u, _ := url.Parse(srv.URL)
+
+cfg := &config.JiraConfig{
+Project:          "PROJ",
+ReopenDuration:   model.Duration(12 * time.Hour),
+ReopenTransition: "Reopen",
+APIURL:           &config.URL{URL: u},
+HTTPConfig:       &commoncfg.HTTPClientConfig{},
+}
+
+pd, _ := New(cfg, test.CreateTmpl(t), promslog.NewNopLogger())
+logger := pd.logger
+ctx := notify.WithGroupKey(context.Background(), "1")
+
+tmplTextFunc := func(tmpl string) (string, error) {
+return tmpl, nil
+}
+
+// Test case 1: Alert is firing, should search for closed issues within reopen_duration
+pd.searchExistingIssue(ctx, logger, "1", true, tmplTextFunc)
+
+expectedFiringJQL := `(resolutiondate is EMPTY OR resolutiondate >= -720m) and project="PROJ" and labels="ALERT{1}" order by status ASC,resolutiondate DESC`
+require.Equal(t, expectedFiringJQL, capturedJQL, "Firing alert should include reopen_duration in JQL")
+}
