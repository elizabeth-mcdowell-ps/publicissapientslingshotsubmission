+++ b/packages/svelte/repro.test.ts
@@ -0,0 +1,32 @@
+import { flushSync } from './packages/svelte/src/internal/client/reactivity/batch.js';
+import { effect_root, user_effect as effect } from './packages/svelte/src/internal/client/reactivity/effects.js';
+import { state } from './packages/svelte/src/internal/client/reactivity/sources.js';
+import { expect, test } from 'vitest';
+import { current_batch } from './packages/svelte/src/internal/client/reactivity/batch.js';
+
+
+test('Effect', () => {
+    let count = state(0);
+    const log = [];
+
+    const cleanup = effect_root(() => {
+        effect(() => {
+            log.push(count.v);
+            console.log('Effect ran, count is:', count.v);
+        });
+    });
+
+    // use flushSync to execute all pending effects synchronously
+    flushSync();
+    console.log('Log after first flushSync:', log);
+    expect(log).toEqual([0]);
+
+    count.v = 1;
+    console.log('Log after setting count.v = 1:', log);
+    console.log('Is batch active?', !!current_batch);
+    flushSync();
+    console.log('Log after second flushSync:', log);
+    expect(log).toEqual([0, 1]);
+
+    cleanup();
+});
