+var pkg = require( './../package.json' ).name;
+var stdevwd = require( './../lib/main.js' );
+
+
+// FUNCTIONS //
+
+/**
+* Creates a benchmark function.
+*
+* @private
+* @param {PositiveInteger} len - array length
+* @returns {Function} benchmark function
+*/
+function createBenchmark( len ) {
+var x = uniform( len, -10.0, 10.0 );
+return benchmark;
+
+function benchmark( b ) {
+v;
+i;
+
+( i = 0; i < b.iterations; i++ ) {
+= stdevwd( x.length, 1, x, 1 );
+( isnan( v ) ) {
+'should not return NaN' );
+( isnan( v ) ) {
+'should not return NaN' );
+'benchmark finished' );
+d();
+}
+}
+
+
+// MAIN //
+
+/**
+* Main execution sequence.
+*
+* @private
+*/
+function main() {
+var len;
+var min;
+var max;
+var f;
+var i;
+
+min = 1; // 10^min
+max = 6; // 10^max
+
+for ( i = min; i <= max; i++ ) {
+ = pow( 10, i );
+= createBenchmark( len );
+ch( pkg + ':len=' + len, f );
+}
+}
+
+main();
