--- /dev/null
+++ b/reproduce_issue.gleam
@@ -0,0 +1,19 @@
+import gleam/io
+
+pub fn bmc_packet(data: BitArray) {
+  case data {
+    <<
+      packet_size:16,
+      packet_data:bytes-size(packet_size-12),
+    >> -> {
+        io.print("Success")
+    }
+    _ -> {
+        io.print("Fail")
+    }
+  }
+}
+
+pub fn main() {
+    bmc_packet(<<16:16, 0:32>>)
+}
