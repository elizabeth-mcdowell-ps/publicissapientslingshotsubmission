diff --git a/fix.py b/fix.py
new file mode 100644
index 000000000..1a6ec5967
--- /dev/null
+++ b/fix.py
@@ -0,0 +1,35 @@
+import sys
+
+def replace_in_file(path, old_str, new_str):
+    with open(path, 'r') as f:
+        content = f.read()
+    if old_str not in content:
+        print(f"Error: old_str not found in {path}")
+        sys.exit(1)
+    new_content = content.replace(old_str, new_str)
+    with open(path, 'w') as f:
+        f.write(new_content)
+
+# Fix constants.go
+old_constants = '\tDeprecatedConsumesAnnotationKey  = "cluster-autoscaler.kubernetes.io/consume-provisioning-request"\n' + \
+                '\tDeprecatedClassNameAnnotationKey = "cluster-autoscaler.kubernetes.io/provisioning-class-name"\n' + \
+                '\tConsumesAnnotationKey            = "autoscaling.x-k8s.io/consume-provisioning-request"\n' + \
+                '\tClassNameAnnotationKey           = "autoscaling.x-k8s.io/provisioning-class-name"'
+
+new_constants = '\tConsumesAnnotationKey            = "autoscaling.x-k8s.io/consume-provisioning-request"\n' + \
+                '\tClassNameAnnotationKey           = "autoscaling.x-k8s.io/provisioning-class-name"'
+
+replace_in_file('/testbed/pkg/controller/admissionchecks/provisioning/constants.go', old_constants, new_constants)
+
+# Fix controller.go
+old_controller = '\t\t\tAnnotations: map[string]string{\n' + \
+                 '\t\t\t\tDeprecatedConsumesAnnotationKey:  pr.Name,\n' + \
+                 '\t\t\t\tDeprecatedClassNameAnnotationKey: pr.Spec.ProvisioningClassName,\n' + \
+                 '\t\t\t\tConsumesAnnotationKey:            pr.Name,\n' + \
+                 '\t\t\t\tClassNameAnnotationKey:           pr.Spec.ProvisioningClassName},'
+
+new_controller = '\t\t\tAnnotations: map[string]string{\n' + \
+                 '\t\t\t\tConsumesAnnotationKey:  pr.Name,\n' + \
+                 '\t\t\t\tClassNameAnnotationKey: pr.Spec.ProvisioningClassName},'
+
+replace_in_file('/testbed/pkg/controller/admissionchecks/provisioning/controller.go', old_controller, new_controller)
