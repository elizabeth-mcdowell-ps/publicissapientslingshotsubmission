+    private boolean isUnquotedCodeReference(String line, int valueStart, int valueEnd) {
+        int previousIndex = previousNonWhitespaceIndex(line, valueStart - 1);
+        if (previousIndex >= 0) {
+            char previous = line.charAt(previousIndex);
+            if (previous == '\'' || previous == '"') {
+                return false;
+            }
+        }
+
+        int nextIndex = nextNonWhitespaceIndex(line, valueEnd);
+        if (nextIndex >= 0) {
