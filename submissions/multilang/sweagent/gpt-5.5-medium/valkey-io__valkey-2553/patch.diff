diff --git a/src/defrag.c b/src/defrag.c
index 5228143bb..924d3cea5 100644
--- a/src/defrag.c
+++ b/src/defrag.c
@@ -1088,10 +1088,11 @@ static int computeDefragCycleUs(void) {
          *  Solving for D:
          *     D = P * W / (100 - P)
          *
-         * Note that dutyCycleUs addresses starvation.  If the wait time was long, we will compensate
-         *  with a proportionately long duty-cycle.  This won't significantly affect perceived
-         *  latency, because clients are already being impacted by the long cycle time which caused
-         *  the starvation of the timer. */
+         * This computation can grow very large after the timer is starved (for example while the
+         * event loop is blocked by a long command).  Don't try to catch up with one long duty cycle:
+         * active defrag is intended to run in short slices, and a long catch-up slice directly shows
+         * up as active-defrag-cycle latency.  Instead, cap the slice to the configured base duration;
+         * repeated short timer invocations can consume CPU when the event loop is available again. */
         dutyCycleUs = targetCpuPercent * waitedUs / (100 - targetCpuPercent);
 
         // Also adjust for any accumulated overage.
@@ -1103,6 +1104,8 @@ static int computeDefragCycleUs(void) {
              *  as part of the overage, and increase wait time between cycles. */
             defrag.timeproc_overage_us = server.active_defrag_cycle_us - dutyCycleUs;
             dutyCycleUs = server.active_defrag_cycle_us;
+        } else if (dutyCycleUs > server.active_defrag_cycle_us) {
+            dutyCycleUs = server.active_defrag_cycle_us;
         }
     }
     return dutyCycleUs;
