diff --git a/source/slang/slang-check-decl.cpp b/source/slang/slang-check-decl.cpp
index 61b1bd5..61d92bd 100644
--- a/source/slang/slang-check-decl.cpp
+++ b/source/slang/slang-check-decl.cpp
@@ -3200,6 +3200,18 @@ void SemanticsDeclBodyVisitor::checkVarDeclCommon(VarDeclBase* varDecl)
 {
     DiagnoseIsAllowedInitExpr(varDecl, getSink());
 
+    // Existential/interface-typed values require dynamic-dispatch lowering,
+    // which currently doesn't handle bare groupshared storage. Diagnose this
+    // during semantic checking rather than letting code emission ICE. Arrays
+    // are covered by unwrapping to their element type; aggregates with
+    // interface-typed members are intentionally still allowed because those are
+    // lowered correctly.
+    if (varDecl->findModifier<HLSLGroupSharedModifier>() &&
+        isInterfaceType(unwrapArrayType(varDecl->getType())))
+    {
+        getSink()->diagnose(Diagnostics::GroupsharedVarCannotHaveInterfaceType{.decl = varDecl});
+    }
+
     // Check for arrays of non-addressable types
     validateArrayElementTypeForVariable(varDecl);
 
