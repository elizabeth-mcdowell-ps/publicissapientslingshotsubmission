diff --git a/packages/autofmt/src/writer.rs b/packages/autofmt/src/writer.rs
index d9dfbd3..add1898 100644
--- a/packages/autofmt/src/writer.rs
+++ b/packages/autofmt/src/writer.rs
@@ -426,7 +426,16 @@ impl<'a> Writer<'a> {
         {
             let comments = self.accumulate_full_line_comments(brace.span.span().end());
             if !comments.is_empty() {
+                // At this point the multiline arms above have already started the line that will
+                // contain the closing brace and written its indentation. Full-line comments before
+                // the closing brace are logically part of the block body, so write them one level
+                // deeper than the closing brace. Remove the already-written closing indentation
+                // first; otherwise the first comment line gets the closing indentation in addition
+                // to its own indentation.
+                self.remove_trailing_tabs(self.out.indent_level);
+                self.out.indent_level += 1;
                 self.apply_line_comments(comments)?;
+                self.out.indent_level -= 1;
                 self.out.tab()?;
             }
         }
@@ -706,6 +715,15 @@ impl<'a> Writer<'a> {
         Ok(())
     }
 
+    fn remove_trailing_tabs(&mut self, mut tabs: usize) {
+        let indent = self.out.indent.indent_str();
+        while tabs > 0 && self.out.buf.ends_with(indent) {
+            let new_len = self.out.buf.len() - indent.len();
+            self.out.buf.truncate(new_len);
+            tabs -= 1;
+        }
+    }
+
     fn write_comments(&mut self, loc: LineColumn) -> Result {
         let comments = self.accumulate_full_line_comments(loc);
         self.apply_line_comments(comments)?;
