diff --git a/Mage.Sets/src/mage/cards/e/EstridsInvocation.java b/Mage.Sets/src/mage/cards/e/EstridsInvocation.java
index edb60348..5d5cfb4d 100644
--- a/Mage.Sets/src/mage/cards/e/EstridsInvocation.java
+++ b/Mage.Sets/src/mage/cards/e/EstridsInvocation.java
@@ -88,8 +88,18 @@ class EstridsInvocationEffect extends OneShotEffect {
             return false;
         }
         Card card = permanent.getMainCard();
-        player.moveCards(permanent, Zone.EXILED, source, game);
-        player.moveCards(card, Zone.BATTLEFIELD, source, game, false, false, true, null);
-        return true;
+        if (!player.moveCards(permanent, Zone.EXILED, source, game)) {
+            return false;
+        }
+        /*
+         * If Estrid's Invocation was copying an Aura, the custom copy effect can
+         * still apply briefly to last-known information while this ability is
+         * resolving. That leaves temporary Aura characteristics cached on the
+         * card id in exile, making the engine try to return the printed
+         * non-Aura card as an Aura with no enchant target. Clear those temporary
+         * characteristics before returning the actual card.
+         */
+        game.getState().removeMageObjectAttribute(card.getId());
+        return player.moveCards(card, Zone.BATTLEFIELD, source, game, false, false, true, null);
     }
 }
diff --git a/Mage.Tests/src/test/java/org/mage/test/cards/single/c18/EstridsInvocationAuraReproTest.java b/Mage.Tests/src/test/java/org/mage/test/cards/single/c18/EstridsInvocationAuraReproTest.java
