+    protected String getSemanticTextNodeValue(SemanticTextNode textNode) {
+        if (textNode == null || textNode.getColumns() == null || textNode.getColumns().isEmpty()) {
+            return textNode == null ? null : textNode.getValue();
+        }
+
+        StringBuilder value = new StringBuilder();
+        boolean hasWrittenLine = false;
+        for (TextColumn column : textNode.getColumns()) {
+            if (column == null || column.getBlocks() == null) {
+                continue;
+            }
+            for (TextBlock block : column.getBlocks()) {
+                if (block == null || block.getLines() == null) {
+                    continue;
+                }
+                for (TextLine line : block.getLines()) {
+                    String lineValue = getTextLineValue(line);
+                    if (hasWrittenLine) {
+                        appendTextLineSeparator(value);
+                    }
+                    value.append(lineValue);
+                    hasWrittenLine = true;
+                }
+            }
+        }
+
+        return hasWrittenLine ? value.toString() : textNode.getValue();
+    }
+
+    protected String getTextLineValue(TextLine line) {
+        if (line == null || line.getTextChunks() == null || line.getTextChunks().isEmpty()) {
+            return line == null ? "" : line.getValue();
+        }
+
+        StringBuilder value = new StringBuilder();
+        TextChunk previousChunk = null;
+        for (TextChunk chunk : line.getTextChunks()) {
+            if (chunk == null || chunk.getValue() == null || chunk.getValue().isEmpty()) {
+                continue;
+            }
+            if (shouldInsertSpaceBetween(previousChunk, chunk, value)) {
+                value.append(MarkdownSyntax.SPACE);
+            }
+            value.append(chunk.getValue());
+            previousChunk = chunk;
+        }
+
+        return value.toString();
+    }
+
+    private boolean shouldInsertSpaceBetween(TextChunk previousChunk, TextChunk currentChunk,
+                                             StringBuilder currentLine) {
+        if (previousChunk == null || currentLine.length() == 0) {
+            return false;
+        }
+        if (Character.isWhitespace(currentLine.charAt(currentLine.length() - 1)) ||
+            Character.isWhitespace(currentChunk.getValue().charAt(0)) ||
+            isPunctuationWithoutPrecedingSpace(currentChunk.getValue().charAt(0))) {
+            return false;
+        }
+
+        double gap = currentChunk.getBoundingBox().getLeftX() - previousChunk.getBoundingBox().getRightX();
+        double fontSize = Math.max(previousChunk.getFontSize(), currentChunk.getFontSize());
+        double threshold = Math.max(0.0, fontSize * TextChunkUtils.TEXT_LINE_SPACE_RATIO);
+        return gap > threshold;
+    }
+
+    private boolean isPunctuationWithoutPrecedingSpace(char ch) {
+        return ".,;:!?)]}%".indexOf(ch) >= 0;
+    }
+
+    private void appendTextLineSeparator(StringBuilder value) {
+        if (value.length() == 0) {
+            return;
+        }
+        TextChunkUtils.formatLineEnd(value);
+    }
