+// tocUnknownNodeRenderer registers a no-op renderer for all node kinds known at
+// render time. The TOC renderer intentionally uses a small renderer setup. When
+// rendering a heading's children, Goldmark still walks into nested nodes. If one
+// of those nested nodes comes from an extension not registered with this small
+// renderer, Goldmark's renderer indexes past the end of its render function
+// slice. Registering this high-priority catch-all lets the regular renderers
+// override the node kinds they know about, while unknown node kinds are simply
+// ignored and their children are still visited.
+type tocUnknownNodeRenderer struct{}
+
+func (r tocUnknownNodeRenderer) RegisterFuncs(reg renderer.NodeRendererFuncRegisterer) {
+	for kind := ast.NodeKind(1); isValidNodeKind(kind); kind++ {
+		reg.Register(kind, r.renderUnknown)
+	}
+}
+
+func (tocUnknownNodeRenderer) renderUnknown(util.BufWriter, []byte, ast.Node, bool) (ast.WalkStatus, error) {
+	return ast.WalkContinue, nil
+}
+
+func isValidNodeKind(kind ast.NodeKind) (ok bool) {
+	defer func() {
+		if recover() != nil {
+			ok = false
+		}
+	}()
+
+	_ = kind.String()
+	return true
+}
+
 type tocExtension struct {
 	options []renderer.Option
 }
