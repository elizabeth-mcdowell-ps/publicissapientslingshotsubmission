+    private String decodeBlob(String value) {
+        if (value == null || value.isEmpty()) {
+            return value;
+        }
+
+        // The ACM JSON 1.1 model defines certificate/key fields as blobs, so SDKs/CLI
+        // send them base64-encoded. Keep accepting the plain PEM strings that are
+        // convenient for hand-written requests and existing tests.
+        if (value.contains("-----BEGIN")) {
+            return value;
+        }
+
+        try {
+            return new String(Base64.getDecoder().decode(value), StandardCharsets.UTF_8);
+        } catch (IllegalArgumentException e) {
+            return value;
+        }
+    }
