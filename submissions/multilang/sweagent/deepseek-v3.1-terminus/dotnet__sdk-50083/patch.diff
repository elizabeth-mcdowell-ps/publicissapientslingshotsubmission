+#!/usr/bin/env python3
+import os
+import sys
+
+def check_file_exists(file_path):
+    """Check if a file exists"""
+    if os.path.exists(file_path):
+        print(f"✓ File exists: {file_path}")
+        return True
+    else:
+        print(f"✗ File missing: {file_path}")
+        return False
+
+def check_file_content(file_path, expected_content):
+    """Check if a file contains specific content"""
+    if not os.path.exists(file_path):
+        print(f"✗ File not found: {file_path}")
+        return False
+    
+    with open(file_path, 'r') as f:
+        content = f.read()
+        if expected_content in content:
+            print(f"✓ Found expected content in {file_path}")
+            return True
+        else:
+            print(f"✗ Expected content not found in {file_path}")
+            return False
+
+def main():
+    print("Testing Razor SDK Embedded ValidatableTypeAttribute Implementation")
+    print("=" * 60)
+    
+    # Base paths
+    razor_sdk_path = "/testbed/src/RazorSdk"
+    
+    # Check if required files exist
+    files_to_check = [
+        f"{razor_sdk_path}/Sdk/EmbeddedAttribute.cs",
+        f"{razor_sdk_path}/Sdk/ValidatableTypeAttribute.cs",
+        f"{razor_sdk_path}/Targets/Sdk.Razor.EmbeddedAttributes.targets",
+        f"{razor_sdk_path}/Targets/Sdk.Razor.CurrentVersion.props"
+    ]
+    
+    all_files_exist = True
+    for file_path in files_to_check:
+        if not check_file_exists(file_path):
+            all_files_exist = False
+    
+    print()
+    
+    # Check content of specific files
+    print("Checking file content...")
+    
+    # Check Sdk.Razor.CurrentVersion.props for property definitions
+    props_file = f"{razor_sdk_path}/Targets/Sdk.Razor.CurrentVersion.props"
+    expected_props = [
+        "_HasRazorFiles",
+        "GenerateEmbeddedValidatableTypeAttribute", 
+        "IncludeEmbeddedValidationGlobalUsing"
+    ]
+    
+    for prop in expected_props:
+        if check_file_content(props_file, prop):
+            print(f"  ✓ Property '{prop}' found in {props_file}")
+        else:
+            print(f"  ✗ Property '{prop}' not found in {props_file}")
+    
+    # Check Sdk.Razor.EmbeddedAttributes.targets for conditional compilation
+    embedded_targets = f"{razor_sdk_path}/Targets/Sdk.Razor.EmbeddedAttributes.targets"
+    expected_targets_content = [
+        "GenerateEmbeddedValidatableTypeAttribute",
+        "EmbeddedAttribute.cs",
+        "ValidatableTypeAttribute.cs",
+        "IncludeEmbeddedValidationGlobalUsing",
+        "Microsoft.Extensions.Validation.Embedded"
+    ]
+    
+    for content in expected_targets_content:
+        if check_file_content(embedded_targets, content):
+            print(f"  ✓ Content '{content}' found in embedded targets")
+        else:
+            print(f"  ✗ Content '{content}' not found in embedded targets")
+    
+    # Check Sdk.Razor.CurrentVersion.targets for conditional import
+    targets_file = f"{razor_sdk_path}/Targets/Sdk.Razor.CurrentVersion.targets"
+    if check_file_content(targets_file, "Sdk.Razor.EmbeddedAttributes.targets"):
+        print("  ✓ Embedded attributes targets import found in main targets file")
+    else:
+        print("  ✗ Embedded attributes targets import not found in main targets file")
+    
+    print()
+    print("=" * 60)
+    
+    if all_files_exist:
+        print("✓ All required files exist")
+        print("✓ Implementation appears to be correctly set up")
+        return 0
+    else:
+        print("✗ Some files are missing or content is incorrect")
+        return 1
+
+if __name__ == "__main__":
+    sys.exit(main())
