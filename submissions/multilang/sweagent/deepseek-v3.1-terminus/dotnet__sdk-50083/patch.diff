+#!/bin/bash
+
+check_file_exists() {
+    local file_path="$1"
+    if [ -f "$file_path" ]; then
+        echo "✓ File exists: $file_path"
+        return 0
+    else
+        echo "✗ File missing: $file_path"
+        return 1
+    fi
+}
+
+check_file_content() {
+    local file_path="$1"
+    local expected_content="$2"
+    
+    if [ ! -f "$file_path" ]; then
+        echo "✗ File not found: $file_path"
+        return 1
+    fi
+    
+    if grep -q "$expected_content" "$file_path"; then
+        echo "✓ Found expected content in $file_path"
+        return 0
+    else
+        echo "✗ Expected content not found in $file_path"
+        return 1
+    fi
+}
+
+echo "Testing Razor SDK Embedded ValidatableTypeAttribute Implementation"
+echo "============================================================"
+
+# Base paths
+razor_sdk_path="/testbed/src/RazorSdk"
+
+# Check if required files exist
+echo "Checking file existence..."
+files_to_check=(
+    "$razor_sdk_path/Sdk/EmbeddedAttribute.cs"
+    "$razor_sdk_path/Sdk/ValidatableTypeAttribute.cs"
+    "$razor_sdk_path/Targets/Sdk.Razor.EmbeddedAttributes.targets"
+    "$razor_sdk_path/Targets/Sdk.Razor.CurrentVersion.props"
+)
+
+all_files_exist=true
+for file_path in "${files_to_check[@]}"; do
+    if ! check_file_exists "$file_path"; then
+        all_files_exist=false
+    fi
+done
+
+echo
+
+# Check content of specific files
+echo "Checking file content..."
+
+# Check Sdk.Razor.CurrentVersion.props for property definitions
+props_file="$razor_sdk_path/Targets/Sdk.Razor.CurrentVersion.props"
+expected_props=(
+    "_HasRazorFiles"
+    "GenerateEmbeddedValidatableTypeAttribute"
+    "IncludeEmbeddedValidationGlobalUsing"
+)
+
+for prop in "${expected_props[@]}"; do
+    if check_file_content "$props_file" "$prop"; then
+        echo "  ✓ Property '$prop' found in $props_file"
+    else
+        echo "  ✗ Property '$prop' not found in $props_file"
+    fi
+done
+
+# Check Sdk.Razor.EmbeddedAttributes.targets for conditional compilation
+embedded_targets="$razor_sdk_path/Targets/Sdk.Razor.EmbeddedAttributes.targets"
+expected_targets_content=(
+    "GenerateEmbeddedValidatableTypeAttribute"
+    "EmbeddedAttribute.cs"
+    "ValidatableTypeAttribute.cs"
+    "IncludeEmbeddedValidationGlobalUsing"
+    "Microsoft.Extensions.Validation.Embedded"
+)
+
+for content in "${expected_targets_content[@]}"; do
