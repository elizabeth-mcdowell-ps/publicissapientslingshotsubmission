@@ -0,0 +1,41 @@
+use datafusion::prelude::SessionContext;
+use datafusion::sql::unparser::plan_to_sql;
+
+#[tokio::main]
+async fn main() -> Result<(), Box<dyn std::error::Error>> {
+    let ctx = SessionContext::new();
+    
+    // Create a mock table with struct data
+    let sql = r#"
+        CREATE TABLE query AS 
+        SELECT STRUCT(
+            STRUCT('Product Name' as name) as product
+        ) as metadata
+    "#;
+    ctx.sql(sql).await?;
+
+    // This should work with the fixed implementation
+    let df = ctx.sql(r#"SELECT query."metadata" FROM query WHERE metadata['product']['name'] = 'Product Name'"#).await?;
+    
+    match plan_to_sql(df.logical_plan()) {
+        Ok(sql_ast) => {
+            println!("Success! Generated SQL: {}", sql_ast.to_string());
+            
+            // Expected SQL should be something like:
+            // SELECT query.metadata FROM query WHERE (query.metadata.product.name = 'Product Name')
+            let expected_substring = "metadata.product.name";
+            if sql_ast.to_string().contains(expected_substring) {
+                println!("✓ Fix is working correctly!");
+            } else {
+                println!("⚠ Generated SQL doesn't contain expected nested field access pattern");
+                println!("Full generated SQL: {}", sql_ast.to_string());
+            }
+        }
+        Err(e) => {
+            println!("Error: {e}");
+            return Err(Box::new(e));
+        }
+    }
+
+    Ok(())
+}
