+fn main() {
+    // Analyze the get_field_to_sql function to understand the issue
+    println!("Analysis of the bug in get_field_to_sql function:");
+    println!("=================================================");
+    println!();
+    println!("Looking at the current implementation in datafusion/sql/src/unparser/expr.rs:");
+    println!();
+    println!("fn get_field_to_sql(&self, args: &[Expr]) -> Result<ast::Expr> {");
+    println!("    // ...");
+    println!("    match &args[0] {");
+    println!("        Expr::Column(col) => {");
+    println!("            // Handles column access like column.field");
+    println!("        }");
+    println!("        Expr::ScalarFunction(struct_expr) => {");
+    println!("            // Handles scalar function access ");
+    println!("        }");
+    println!("        _ => {");
+    println!("            internal_err!("get_field expects first argument to be column or scalar function, ...");");
+    println!("        }");
+    println!("    }");
+    println!("}");
+    println!();
+    println!("The problem:");
+    println!("============");
+    println!("When we have nested struct access like metadata['product']['name'],");
+    println!("the expression tree becomes:");
+    println!("   get_field(get_field(column('metadata'), 'product'), 'name')");
+    println!();
+    println!("The outer get_field call receives as its first argument:");
+    println!("   Expr::ScalarFunction(ScalarFunction { func: GetFieldFunc, args: [Column(metadata), Literal('product')] })");
+    println!();
+    println!("However, the current implementation only handles Expr::ScalarFunction for the FIRST level.");
+    println!("It doesn't handle the case where we have nested get_field calls.");
+    println!();
+    println!("The expected SQL should be:");
+    println!("   metadata.product.name");
+    println!();
+    println!("But the current code only handles:");
+    println!("   - Direct column access: metadata -> metadata.field");
+    println!("   - First-level struct function calls: struct_expr -> struct_expr.field");
+    println!("   - But NOT nested struct access: get_field(...) -> get_field(...).field");
+}
