--- /dev/null
+++ b/TestTimeoutFix.java
@@ -0,0 +1,36 @@
+import com.github.tomakehurst.wiremock.standalone.CommandLineOptions;
+
+public class TestTimeoutFix {
+    public static void main(String[] args) {
+        try {
+            System.out.println("Testing timeout option fix...");
+            
+            // Test case from PR description: --timeout 45000
+            CommandLineOptions options = new CommandLineOptions("--timeout", "45000");
+            long timeout = options.timeout();
+            System.out.println("Test 1 - Timeout value with --timeout 45000: " + timeout);
+            System.out.println("Expected: 45000");
+            System.out.println("Result: " + (timeout == 45000L ? "PASSED" : "FAILED"));
+            
+            // Test case from error description: --timeout 5000 
+            CommandLineOptions options2 = new CommandLineOptions("--timeout", "5000");
+            long timeout2 = options2.timeout();
+            System.out.println("\nTest 2 - Timeout value with --timeout 5000: " + timeout2);
+            System.out.println("Expected: 5000");
+            System.out.println("Result: " + (timeout2 == 5000L ? "PASSED" : "FAILED"));
+            
+            // Test default value when no timeout specified
+            CommandLineOptions options3 = new CommandLineOptions();
+            long timeout3 = options3.timeout();
+            System.out.println("\nTest 3 - Default timeout value: " + timeout3);
+            System.out.println("Expected: 50000 (DEFAULT_TIMEOUT)");
+            System.out.println("Result: " + (timeout3 == 50000L ? "PASSED" : "FAILED"));
+            
+            System.out.println("\nAll tests completed successfully!");
+            
+        } catch (Exception e) {
+            System.out.println("ERROR: " + e.getMessage());
+            e.printStackTrace();
+        }
+    }
+}
