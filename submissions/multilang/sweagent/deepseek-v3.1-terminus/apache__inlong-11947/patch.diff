+import java.net.URLDecoder;
+import java.nio.charset.StandardCharsets;
+
+public class TestUrlDecodeCharset {
+    public static void main(String[] args) {
+        // Test UTF-8 decoding (default)
+        String encodedUTF8 = "https%3A%2F%2Fapache.inlong.com%2Fsearch%3Fq%3Djava+url+encode";
+        
+        try {
+            String decodedUTF8 = URLDecoder.decode(encodedUTF8, StandardCharsets.UTF_8.name());
+            System.out.println("UTF-8 decoded: " + decodedUTF8);
+        } catch (Exception e) {
+            System.out.println("UTF-8 error: " + e.getMessage());
+        }
+        
+        // Test ISO-8859-1 decoding
+        try {
+            String decodedISO = URLDecoder.decode(encodedUTF8, "ISO-8859-1");
+            System.out.println("ISO-8859-1 decoded: " + decodedISO);
+        } catch (Exception e) {
+            System.out.println("ISO-8859-1 error: " + e.getMessage());
+        }
+        
+        // Test GBK decoding with Chinese characters
+        String encodedChinese = "%E4%B8%AD%E5%9B%BD"; // "中国" in GBK encoding
+        try {
+            String decodedGBK = URLDecoder.decode(encodedChinese, "GBK");
+            System.out.println("GBK decoded: " + decodedGBK);
+        } catch (Exception e) {
+            System.out.println("GBK error: " + e.getMessage());
+        }
+        
+        System.out.println("Test completed successfully!");
+    }
+}
