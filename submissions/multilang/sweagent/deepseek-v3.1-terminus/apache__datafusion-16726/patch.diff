@@ -31,7 +31,7 @@ use datafusion_common::tree_node::{Transformed, TransformedResult, TreeNode};
 use datafusion_common::{Result, Statistics};
 use datafusion_execution::TaskContext;
 use datafusion_physical_expr::Distribution;
-use datafusion_physical_expr_common::sort_expr::OrderingRequirements;
+use datafusion_physical_expr_common::sort_expr::{OrderingRequirements, PhysicalSortRequirement};
 use datafusion_physical_plan::projection::{
