@@ -141,8 +141,67 @@ impl DisplayAs for OutputRequirementExec {
                 write!(f, "OutputRequirementExec")
             }
             DisplayFormatType::TreeRender => {
-                // TODO: collect info
-                write!(f, "")
+                write!(f, "order_requirement=" )?;
+                
+                // Format order_requirement
+                match &self.order_requirement {
+                    Some(OrderingRequirements::Hard(alts)) => {
+                        if alts.is_empty() {
+                            write!(f, "None")?
+                        } else {
+                            write!(f, "Hard(")?;
+                            let mut first_alt = true;
+                            for alt in alts {
+                                if !first_alt {
+                                    write!(f, " | ")?;
+                                }
+                                first_alt = false;
+                                write!(f, "[")?;
+                                let mut first_req = true;
+                                for req in alt.iter() {
+                                    if !first_req {
+                                        write!(f, ", ")?;
+                                    }
+                                    first_req = false;
+                                    write!(f, "{}", req)?;
+                                }
+                                write!(f, "]")?;
+                            }
+                            write!(f, ")")?;
+                        }
+                    }
+                    Some(OrderingRequirements::Soft(alts)) => {
+                        if alts.is_empty() {
+                            write!(f, "None")?
+                        } else {
+                            write!(f, "Soft(")?;
+                            let mut first_alt = true;
+                            for alt in alts {
+                                if !first_alt {
+                                    write!(f, " | ")?;
+                                }
+                                first_alt = false;
+                                write!(f, "[")?;
+                                let mut first_req = true;
+                                for req in alt.iter() {
+                                    if !first_req {
+                                        write!(f, ", ")?;
+                                    }
+                                    first_req = false;
+                                    write!(f, "{}", req)?;
+                                }
+                                write!(f, "]")?;
+                            }
+                            write!(f, ")")?;
+                        }
+                    }
+                    None => {
+                        write!(f, "None")?
+                    }
+                };
+                
+                // Format dist_requirement
+                write!(f, ", dist_requirement={}", &self.dist_requirement)
             }
         }
     }
