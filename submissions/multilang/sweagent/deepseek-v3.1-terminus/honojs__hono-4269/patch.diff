+export const mergePath = (base, sub, ...rest) => {
+    if (rest.length) {
+        sub = mergePath(sub, ...rest);
+    }
+    return `${base?.[0] === '/' ? '' : '/'}${base}${sub === '/' ? '' : `${base?.at(-1) === '/' ? '' : '/'}${sub?.[0] === '/' ? sub.slice(1) : sub}`}`;
+};
