+// Test the fix by importing the built files
+import { Hono } from './dist/index.js';
+import { z } from 'zod';
+import { zValidator } from '@hono/zod-validator';
+
+const schema = z.object({ mock: z.string() });
+
+async function testFix() {
+  console.log('Testing the fix with Hono...\n');
+  
+  const app = new Hono();
+
+  // Create a route similar to the problematic one
+  app.post(
+    "/",
+    zValidator("header", schema),
+    zValidator("json", schema),
+    async (c) => {
+      try {
+        // This should work now
+        const text = await c.req.raw.clone().text();
+        console.log('✓ Successfully accessed cloned body text:', text);
+        return c.text("Hello Hono!");
+      } catch (error) {
+        console.error('✗ Error cloning request:', error.message);
+        return c.text("Error occurred", 500);
+      }
+    }
+  );
+
+  // Create a test request
+  const testReq = new Request('http://localhost:3000/', {
+    method: 'POST',
+    headers: { 
+      'Content-Type': 'application/json',
+      'mock': 'test-header'
+    },
+    body: JSON.stringify({ mock: 'test-json' })
+  });
+
+  try {
+    const resp = await app.fetch(testReq);
+    console.log('✓ Route handler executed successfully');
+    console.log('Response status:', resp.status);
+  } catch (error) {
+    console.error('✗ Route handler failed:', error.message);
+  }
+}
+
+testFix().catch(console.error);
