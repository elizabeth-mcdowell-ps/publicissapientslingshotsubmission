+                typeof nestedForm[key] !== 'object' ||
+                Array.isArray(nestedForm[key]) ||
+                nestedForm[key] instanceof File) {
+                nestedForm[key] = Object.create(null);
+            }
+            nestedForm = nestedForm[key];
+        }
+    });
+};
