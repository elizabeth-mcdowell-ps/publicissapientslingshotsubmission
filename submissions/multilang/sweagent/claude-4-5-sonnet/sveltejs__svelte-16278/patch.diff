+console.log('\n=== Testing prop with setter but no getter in onDestroy ===');
+
+// Simulate a parent component that passes a prop
+const parent_props = { checked: false };
+
+// Create a prop that has setter (PROPS_IS_UPDATED flag) but we never read it in the template
+// This is similar to: let { checked = false } = $props(); <button onclick={() => checked = !checked}>
+const checked_prop = prop(parent_props, 'checked', PROPS_IS_RUNES | PROPS_IS_UPDATED, false);
+
+// Log value in onDestroy (which uses teardown internally)
+let ondestroy_value = null;
+const eff = effect(() => {
+    // We don't read checked here (simulating no getter in template)
+    // But we write to it
+    checked_prop(true); // This triggers the setter
+    
+    return () => {
+        ondestroy_value = checked_prop(); // Read in teardown
+        console.log('onDestroy - checked value:', ondestroy_value);
+    };
+});
+
+flushSync();
+
+console.log('\nAfter first effect run, ondestroy_value should be defined');
+console.log('Expected: false or true, Got:', ondestroy_value);
+
+if (ondestroy_value === null) {
+    console.log('\n✗ TEST FAILED: Prop value is null in onDestroy');
+} else {
+    console.log('\n✓ TEST PASSED: Prop value is not null in onDestroy');
+}
