+/**
+ * Test climbing route CSS class generation
+ */
+
+// Mock the necessary parts
+const osmLifecyclePrefixes = {
+    'proposed': true,
+    'planned': true,
+    'construction': true,
+    'disused': true,
+    'abandoned': true,
+    'was': true,
+    'dismantled': true,
+    'razed': true,
+    'demolished': true,
+    'destroyed': true,
+    'removed': true,
+    'obliterated': true
+};
+
+function svgTagClasses() {
+    var primaries = [
+        'building', 'highway', 'railway', 'waterway', 'aeroway', 'aerialway',
+        'piste:type', 'boundary', 'power', 'amenity', 'natural', 'landuse',
+        'leisure', 'military', 'place', 'man_made', 'route', 'attraction',
+        'roller_coaster', 'building:part', 'indoor', 'climbing'
+    ];
+    var statuses = Object.keys(osmLifecyclePrefixes);
+    var secondaries = [
+        'oneway', 'bridge', 'tunnel', 'embankment', 'cutting', 'barrier',
+        'surface', 'tracktype', 'footway', 'crossing', 'service', 'sport',
+        'public_transport', 'location', 'parking', 'golf', 'type', 'leisure',
+        'man_made', 'indoor', 'construction', 'proposed'
+    ];
+
+    var getClassesString = function(t, value) {
+        var primary, status;
+        var i, j, k, v;
+
+        // in some situations we want to render perimeter strokes a certain way
+        var overrideGeometry;
+        if (/\bstroke\b/.test(value)) {
+            if (!!t.barrier && t.barrier !== 'no') {
+                overrideGeometry = 'line';
+            }
+        }
+
+        // preserve base classes (nothing with `tag-`)
+        var classes = value.trim().split(/\s+/)
+            .filter(function(klass) {
+                return klass.length && !/^tag-/.test(klass);
+            })
+            .map(function(klass) {  // special overrides for some perimeter strokes
+                return (klass === 'line' || klass === 'area') ? (overrideGeometry || klass) : klass;
+            });
+
+        // pick at most one primary classification tag..
+        for (i = 0; i < primaries.length; i++) {
+            k = primaries[i];
+            v = t[k];
+            if (!v || v === 'no') continue;
+
+            if (k === 'piste:type') {  // avoid a ':' in the class name
+                k = 'piste';
+            } else if (k === 'building:part') {  // avoid a ':' in the class name
+                k = 'building_part';
+            }
+
+            primary = k;
+            if (statuses.indexOf(v) !== -1) {   // e.g. `railway=abandoned`
+                status = v;
+                classes.push('tag-' + k);
+            } else {
+                classes.push('tag-' + k);
+                classes.push('tag-' + k + '-' + v);
+            }
+
+            break;
+        }
+
+        if (!primary) {
+            for (i = 0; i < statuses.length; i++) {
+                for (j = 0; j < primaries.length; j++) {
+                    k = statuses[i] + ':' + primaries[j];  // e.g. `demolished:building=yes`
+                    v = t[k];
+                    if (!v || v === 'no') continue;
+
+                    status = statuses[i];
+                    break;
+                }
+            }
+        }
+
+        // add at most one status tag, only if relates to primary tag..
+        if (!status) {
+            for (i = 0; i < statuses.length; i++) {
+                k = statuses[i];
+                v = t[k];
+                if (!v || v === 'no') continue;
+
+                if (v === 'yes') {   // e.g. `railway=rail + abandoned=yes`
+                    status = k;
+                } else if (primary && primary === v) {  // e.g. `railway=rail + abandoned=railway`
+                    status = k;
+                } else if (!primary && primaries.indexOf(v) !== -1) {  // e.g. `abandoned=railway`
+                    status = k;
+                    primary = v;
+                    classes.push('tag-' + v);
+                }  // else ignore e.g.  `highway=path + abandoned=railway`
+
+                if (status) break;
+            }
+        }
+
+        if (status) {
+            classes.push('tag-status');
+            classes.push('tag-status-' + status);
+        }
+
+        // add any secondary tags
+        for (i = 0; i < secondaries.length; i++) {
+            k = secondaries[i];
+            v = t[k];
+            if (!v || v === 'no' || k === primary) continue;
+            classes.push('tag-' + k);
+            classes.push('tag-' + k + '-' + v);
+        }
+
+        // ensure that classes for tags keys/values with special characters like spaces
+        // are not added to the DOM, because it can cause bizarre issues (#9448)
+        return classes
+            .filter(klass => /^[-_a-z0-9]+$/.test(klass))
+            .join(' ')
+            .trim();
+    };
+
+    return { getClassesString: getClassesString };
+}
+
+// Test cases
+console.log('\n=== Testing Climbing Route CSS Class Generation ===\n');
+
+const tagClasses = svgTagClasses();
+
+// Test 1: Basic climbing route
+console.log('Test 1: Basic climbing route');
+const test1 = tagClasses.getClassesString({ climbing: 'route', sport: 'climbing' }, 'line stroke');
+console.log('Tags: climbing=route, sport=climbing');
+console.log('Classes:', test1);
+console.log('Expected: line stroke tag-climbing tag-climbing-route tag-sport tag-sport-climbing');
+console.log('Match:', test1 === 'line stroke tag-climbing tag-climbing-route tag-sport tag-sport-climbing' ? '✓' : '✗');
+
+// Test 2: Climbing route on bridge
+console.log('\nTest 2: Climbing route on bridge');
+const test2 = tagClasses.getClassesString({ climbing: 'route', sport: 'climbing', bridge: 'yes' }, 'line stroke');
+console.log('Tags: climbing=route, sport=climbing, bridge=yes');
+console.log('Classes:', test2);
+console.log('Expected: line stroke tag-climbing tag-climbing-route tag-bridge tag-bridge-yes tag-sport tag-sport-climbing');
+console.log('Match:', test2 === 'line stroke tag-climbing tag-climbing-route tag-bridge tag-bridge-yes tag-sport tag-sport-climbing' ? '✓' : '✗');
+
+// Test 3: Climbing route in tunnel
+console.log('\nTest 3: Climbing route in tunnel');
+const test3 = tagClasses.getClassesString({ climbing: 'route', sport: 'climbing', tunnel: 'yes' }, 'line stroke');
+console.log('Tags: climbing=route, sport=climbing, tunnel=yes');
+console.log('Classes:', test3);
+console.log('Expected: line stroke tag-climbing tag-climbing-route tag-tunnel tag-tunnel-yes tag-sport tag-sport-climbing');
+console.log('Match:', test3 === 'line stroke tag-climbing tag-climbing-route tag-tunnel tag-tunnel-yes tag-sport tag-sport-climbing' ? '✓' : '✗');
+
+// Test 4: Compare with ladder (should have highway as primary)
+console.log('\nTest 4: Compare with ladder (highway=ladder)');
+const test4 = tagClasses.getClassesString({ highway: 'ladder' }, 'line stroke');
+console.log('Tags: highway=ladder');
+console.log('Classes:', test4);
+console.log('Expected: line stroke tag-highway tag-highway-ladder');
+console.log('Match:', test4 === 'line stroke tag-highway tag-highway-ladder' ? '✓' : '✗');
+
+// Test 5: Compare with aerialway (should have aerialway as primary)
+console.log('\nTest 5: Compare with aerialway (aerialway=chair_lift)');
+const test5 = tagClasses.getClassesString({ aerialway: 'chair_lift' }, 'line stroke');
+console.log('Tags: aerialway=chair_lift');
+console.log('Classes:', test5);
+console.log('Expected: line stroke tag-aerialway tag-aerialway-chair_lift');
+console.log('Match:', test5 === 'line stroke tag-aerialway tag-aerialway-chair_lift' ? '✓' : '✗');
+
+console.log('\n=== All Tests Complete ===\n');
