+echo "1. Checking if 'climbing' is in primaries list (tag_classes.js)..."
+if grep -q "climbing" /testbed/modules/svg/tag_classes.js; then
+    echo "   ✓ 'climbing' found in primaries list"
+else
+    echo "   ✗ 'climbing' NOT found in primaries list"
+    exit 1
+fi
+
+# Check if 'climbing' is in the built JS
+echo "2. Checking if 'climbing' is in built JavaScript..."
+if grep -q "climbing" /testbed/dist/iD.js; then
+    echo "   ✓ 'climbing' found in dist/iD.js"
+else
+    echo "   ✗ 'climbing' NOT found in dist/iD.js"
+    exit 1
+fi
+
+# Check if climbing route CSS exists in source
+echo "3. Checking if climbing route CSS exists in source (50_misc.css)..."
+if grep -q "tag-climbing-route" /testbed/css/50_misc.css; then
+    echo "   ✓ Climbing route CSS found in 50_misc.css"
+else
+    echo "   ✗ Climbing route CSS NOT found in 50_misc.css"
+    exit 1
+fi
+
+# Check if climbing route CSS exists in built CSS
+echo "4. Checking if climbing route CSS exists in built CSS..."
+COUNT=$(grep -c "tag-climbing-route" /testbed/dist/iD.css)
+if [ "$COUNT" -gt 0 ]; then
+    echo "   ✓ Climbing route CSS found in dist/iD.css ($COUNT occurrences)"
+else
+    echo "   ✗ Climbing route CSS NOT found in dist/iD.css"
+    exit 1
+fi
+
+# Check for specific CSS rules
+echo "5. Checking for specific CSS rules..."
+
+# Red color (#c55)
+if grep -q "stroke: #c55" /testbed/dist/iD.css && grep -q "tag-climbing-route" /testbed/dist/iD.css; then
+    echo "   ✓ Red color (#c55) found"
+else
+    echo "   ✗ Red color (#c55) NOT found"
+    exit 1
+fi
+
+# Dashed pattern (3, 3)
+if grep -B5 "stroke-dasharray: 3, 3" /testbed/dist/iD.css | grep -q "tag-climbing-route"; then
+    echo "   ✓ Dashed pattern (3, 3) found"
