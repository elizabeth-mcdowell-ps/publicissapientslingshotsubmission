@@ -0,0 +1,182 @@
+import { compile } from './packages/svelte/src/compiler/index.js';
+
+const tests = [
+  {
+    name: 'Loop index redeclared with same name',
+    code: `
+      {#each items as item, index}
+        <button onclick={(e) => {
+          const index = Number(e.currentTarget.dataset.index);
+          console.log(index);
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'Local const shadows loop variable'
+  },
+  {
+    name: 'Loop item redeclared with same name',
+    code: `
+      {#each items as item}
+        <button onclick={(e) => {
+          const item = e.currentTarget.value;
+          console.log(item);
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'Local const shadows loop variable'
+  },
+  {
+    name: 'Loop index used directly',
+    code: `
+      {#each items as item, index}
+        <button onclick={() => console.log(index)}>Click</button>
+      {/each}
+    `,
+    shouldHoist: false,
+    reason: 'References loop variable directly'
+  },
+  {
+    name: 'Loop item used directly',
+    code: `
+      {#each items as item}
+        <button onclick={() => console.log(item)}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'Hoisted with item passed as parameter'
+  },
+  {
+    name: 'Different variable name used',
+    code: `
+      {#each items as item, index}
+        <button onclick={(e) => {
+          const i = Number(e.currentTarget.dataset.index);
+          console.log(i);
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'No reference to loop variable'
+  },
+  {
+    name: 'Loop variable in attribute but not in handler',
+    code: `
+      {#each items as item, index}
+        <button data-index={index} onclick={(e) => {
+          const i = Number(e.currentTarget.dataset.index);
+          console.log(i);
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'Loop variable only in attribute, not in handler'
+  },
+  {
+    name: 'Nested scope with redeclaration',
+    code: `
+      {#each items as item}
+        <button onclick={() => {
+          {
+            const item = 'nested';
+            console.log(item);
+          }
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: false,
+    reason: 'Arrow function references loop variable (outer scope of block)'
+  },
+  {
+    name: 'Let declaration instead of const',
+    code: `
+      {#each items as item, index}
+        <button onclick={(e) => {
+          let index = Number(e.currentTarget.dataset.index);
+          console.log(index);
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'Local let shadows loop variable'
+  },
+  {
+    name: 'Var declaration',
+    code: `
+      {#each items as item, index}
+        <button onclick={(e) => {
+          var index = Number(e.currentTarget.dataset.index);
+          console.log(index);
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'Local var shadows loop variable'
+  },
+  {
+    name: 'Destructured loop variable',
+    code: `
+      {#each items as { id, name }}
+        <button onclick={(e) => {
+          const id = e.currentTarget.dataset.id;
+          console.log(id);
+        }}>Click</button>
+      {/each}
+    `,
+    shouldHoist: true,
+    reason: 'Local const shadows destructured loop variable'
+  }
+];
+
+console.log('Testing callback optimization edge cases...\n');
+
+let passed = 0;
+let failed = 0;
+
+for (const test of tests) {
+  try {
+    const source = `
+      <script>
+        let items = [1, 2, 3];
+      </script>
+      ${test.code}
+    `;
+    
+    const result = compile(source, {
+      filename: 'test.svelte',
+      generate: 'client'
+    });
+
+    const hasHoistedCallback = result.js.code.includes('var on_click');
+    const isHoisted = hasHoistedCallback;
+    const expected = test.shouldHoist;
+
+    if (isHoisted === expected) {
+      console.log(`✅ ${test.name}`);
+      console.log(`   ${test.reason}`);
+      passed++;
+    } else {
+      console.log(`❌ ${test.name}`);
+      console.log(`   Expected: ${expected ? 'HOISTED' : 'NOT HOISTED'}`);
+      console.log(`   Got: ${isHoisted ? 'HOISTED' : 'NOT HOISTED'}`);
+      console.log(`   Reason: ${test.reason}`);
+      failed++;
+    }
+  } catch (err) {
+    console.log(`❌ ${test.name}`);
+    console.log(`   Compilation error: ${err.message}`);
+    failed++;
+  }
+  console.log('');
+}
+
+console.log('='.repeat(60));
+console.log(`Results: ${passed} passed, ${failed} failed`);
+
+if (failed === 0) {
+  console.log('✅ All edge case tests passed!');
+} else {
+  console.log(`❌ ${failed} test(s) failed`);
+  process.exit(1);
+}
