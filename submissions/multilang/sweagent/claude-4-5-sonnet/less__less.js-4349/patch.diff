+<script>
+import Parent from './Parent.svelte';
+
+let count = $state(0);
+let count2 = $state(100);
+
+function handler() {
+count++;
+}
+
+function handler2() {
+count2++;
+}
+</script>
+
+<p>Count: {count}</p>
+<p>Count2: {count2}</p>
+<Parent onClick={handler} />
+
+<button onclick={() => {
+count = 50;
+}}>Reset count to 50</button>
+
+<button onclick={() => {
+count2 = 150;
+}}>Reset count2 to 150</button>
