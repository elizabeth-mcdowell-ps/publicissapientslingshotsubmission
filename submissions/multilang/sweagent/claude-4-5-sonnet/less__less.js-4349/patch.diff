+import { flushSync } from 'svelte';
+import { test } from '../../test';
+
+export default test({
+html: `
+<p>Count: 0</p>
+<p>Count2: 100</p>
+<button>Click</button>
+<button>Reset count to 50</button>
+<button>Reset count2 to 150</button>
+`,
+
+async test({ assert, target }) {
+const [clickBtn, resetBtn, reset2Btn] = target.querySelectorAll('button');
+
+// Click the button - should trigger handler and increment count
+flushSync(() => {
+clickBtn?.click();
+});
+
+assert.htmlEqual(
+target.innerHTML,
+`
+<p>Count: 1</p>
+<p>Count2: 100</p>
+<button>Click</button>
+<button>Reset count to 50</button>
+<button>Reset count2 to 150</button>
+`
+);
+
+// Reset count to 50
+flushSync(() => {
+resetBtn?.click();
+});
+
+assert.htmlEqual(
+target.innerHTML,
+`
+<p>Count: 50</p>
+<p>Count2: 100</p>
+<button>Click</button>
+<button>Reset count to 50</button>
+<button>Reset count2 to 150</button>
+`
+);
+
+// Click again - should increment from 50 to 51
+flushSync(() => {
+clickBtn?.click();
+});
+
+assert.htmlEqual(
+target.innerHTML,
+`
+<p>Count: 51</p>
+<p>Count2: 100</p>
+<button>Click</button>
+<button>Reset count to 50</button>
+<button>Reset count2 to 150</button>
+`
+);
+}
+});
