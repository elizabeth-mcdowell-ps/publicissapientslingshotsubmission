+            {
+                Sb.AppendLine("private static DataTable ToDataTable<T>(IEnumerable<T> items)");
+                Sb.AppendLine("{");
+                using (Sb.Indent())
+                {
+                    Sb.AppendLine("var dataTable = new DataTable();");
+                    Sb.AppendLine("var properties = typeof(T).GetProperties();");
