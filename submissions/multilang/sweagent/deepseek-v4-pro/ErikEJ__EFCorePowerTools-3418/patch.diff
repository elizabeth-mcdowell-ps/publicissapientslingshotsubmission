diff --git a/src/Core/RevEng.Core.80/Routines/Extensions/PostgresNpgsqlTypeExtensions.cs.bak b/src/Core/RevEng.Core.80/Routines/Extensions/PostgresNpgsqlTypeExtensions.cs.bak
