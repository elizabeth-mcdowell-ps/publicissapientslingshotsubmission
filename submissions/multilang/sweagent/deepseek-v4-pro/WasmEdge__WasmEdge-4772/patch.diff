diff --git a/lib/executor/helper.cpp b/lib/executor/helper.cpp
index 67f4f9f..9c07826 100644
--- a/lib/executor/helper.cpp
+++ b/lib/executor/helper.cpp
@@ -211,7 +211,22 @@ Executor::enterFunction(Runtime::StackManager &StackMgr,
     // Push local variables into the stack.
     for (auto &Def : Func.getLocals()) {
       for (uint32_t I = 0; I < Def.first; I++) {
-        StackMgr.push(ValueFromType(Def.second));
+        if (Def.second.isRefType() && !Def.second.isAbsHeapType()) {
+          // Normalize the type to the bottom abstract heap type so that null
+          // references always carry abstract types, as ref.cast/ref.test assume.
+          const auto &CompType =
+              (*Func.getModule()->getType(Def.second.getTypeIndex()))
+                  ->getCompositeType();
+          TypeCode BotType;
+          if (CompType.isFunc()) {
+            BotType = TypeCode::NullFuncRef;
+          } else {
+            BotType = TypeCode::NullRef;
+          }
+          StackMgr.push(RefVariant(ValType(TypeCode::RefNull, BotType)));
+        } else {
+          StackMgr.push(ValueFromType(Def.second));
+        }
       }
     }
 
