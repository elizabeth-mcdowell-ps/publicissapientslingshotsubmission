+package javax.annotation.processing;
+
+import java.lang.annotation.Documented;
+import java.lang.annotation.ElementType;
+import java.lang.annotation.Retention;
+import java.lang.annotation.RetentionPolicy;
+import java.lang.annotation.Target;
+
+/**
+ * Minimal emulation of {@code javax.annotation.processing.Generated}.
+ *
+ * <p>Some annotation processors (e.g. Dagger) generate sources that import this
+ * annotation. GWT's client-side compilation needs the type to exist on the
+ * source path, but the annotation itself is not used at runtime.
+ */
+@Documented
+@Retention(RetentionPolicy.SOURCE)
+@Target({ElementType.PACKAGE, ElementType.TYPE, ElementType.ANNOTATION_TYPE,
+    ElementType.METHOD, ElementType.CONSTRUCTOR, ElementType.FIELD,
+    ElementType.PARAMETER, ElementType.LOCAL_VARIABLE, ElementType.MODULE})
+public @interface Generated {
+  /** The value element MUST have the name of the code generator. */
+  String[] value();
+
+  /** Date when the source was generated. */
+  String date() default "";
+
+  /** Additional comments. */
+  String comments() default "";
+}
