+import re, pathlib
+
+def check_snapshot_text(text: str):
+    # Find ComplexProperty/ComplexCollection first arg type
+    bad = []
+    for m in re.finditer(r"\.Complex(Property|Collection)\(typeof\(([^)]+)\)", text):
+        kind, t = m.group(1), m.group(2).strip()
+        if t == 'Dictionary<string, object>':
+            bad.append((kind, t, m.start()))
+    return bad
+
+# Just ensure generator currently uses DefaultPropertyBagType in code
+p = pathlib.Path('src/EFCore.Design/Migrations/Design/CSharpSnapshotGenerator.cs')
+print('Has DefaultPropertyBagType in GenerateComplexProperty:', 'DefaultPropertyBagType' in p.read_text())
+
+# Print expected fix: should not always use DefaultPropertyBagType
+
diff --git a/reproduce.sh b/reproduce.sh
new file mode 100644
index 0000000000..45ec1665cb
--- /dev/null
+++ b/reproduce.sh
@@ -0,0 +1,14 @@
+#!/usr/bin/env bash
+set -euo pipefail
+FILE=src/EFCore.Design/Migrations/Design/CSharpSnapshotGenerator.cs
+# Fail if still hard-coded to DefaultPropertyBagType in ComplexProperty generation
+if grep -n "Append(\$\"typeof({Code.Reference(Model.DefaultPropertyBagType)}), \"" -n "$FILE" >/dev/null; then
+  echo "FAIL: still scaffolds Model.DefaultPropertyBagType" >&2
+  exit 1
+fi
+# Ensure it uses complexTypeClrType
+grep -n "complexTypeClrType" "$FILE" >/dev/null
+# Ensure ComplexProperty uses typeof({Code.Reference(complexTypeClrType)})
+grep -n "typeof({Code.Reference(complexTypeClrType)})," "$FILE" >/dev/null
+
+echo "OK"
