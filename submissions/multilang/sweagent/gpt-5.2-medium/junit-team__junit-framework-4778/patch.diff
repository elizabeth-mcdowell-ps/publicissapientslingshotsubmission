+#!/usr/bin/env bash
+set -euo pipefail
+./gradlew -q :jupiter-tests:test --tests org.junit.jupiter.engine.descriptor.ResourceAutoClosingTests 2>&1 | tee /tmp/repro.log
+# show only the specific warning lines
+grep -F "Type implements CloseableResource but not AutoCloseable" /tmp/repro.log || true
