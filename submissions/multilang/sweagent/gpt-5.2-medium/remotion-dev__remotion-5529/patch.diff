+import math
+
+# Reproduce logic in validate-even-dimensions-with-codec.ts (current behavior)
+def validate(width,height,scale,codec='h264',wantsImageSequence=False):
+    actualWidth = width*scale
+    actualHeight = height*scale
+    if wantsImageSequence:
+        return actualWidth, actualHeight
+    if codec not in ['h264-mkv','h264','h265','h264-ts']:
+        return actualWidth, actualHeight
+
+    if actualWidth % 1 != 0 and (actualWidth % 1 < 0.005 or actualWidth % 1 > 0.005):
+        actualWidth = round(actualWidth)
+    if actualHeight % 1 != 0 and (actualHeight % 1 < 0.005 or actualHeight % 1 > 0.005):
+        actualHeight = round(actualHeight)
+
+    if actualWidth % 2 != 0:
+        raise ValueError(f"width uneven: {actualWidth}")
+    if actualHeight % 2 != 0:
+        raise ValueError(f"height uneven: {actualHeight}")
+    return actualWidth, actualHeight
+
+if __name__=='__main__':
+    w,h,scale=4000,2592,0.35
+    print('input',w,h,scale)
+    print('scaled',w*scale,h*scale)
+    try:
+        print(validate(w,h,scale))
+    except Exception as e:
+        print('ERROR',e)
