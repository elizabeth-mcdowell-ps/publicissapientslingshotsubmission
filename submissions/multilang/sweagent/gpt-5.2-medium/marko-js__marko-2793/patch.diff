+import subprocess, textwrap, json, sys, tempfile, pathlib
+
+template = textwrap.dedent('''
+export interface Input {
+  duration: number;
+  value: () => void;
+}
+
+<let/timer=(0 as unknown as ReturnType<typeof setTimeout>)>
+
+<const/reset=() => {
+  if (timer) {
+    clearTimeout(timer);
+  }
+
+  timer = setTimeout(() => {
+    input.value();
+  }, input.duration);
+}>
+
+<return=reset>
+''')
+
+tmpdir = tempfile.mkdtemp(prefix='marko-repro-')
+path = pathlib.Path(tmpdir)/'template.marko'
+path.write_text(template)
+
+node_script = textwrap.dedent(f'''
+  const compiler = require("@marko/compiler");
+  const fs = require('fs');
+  const src = fs.readFileSync({json.dumps(str(path))}, 'utf8');
+  try {{
+    const res = compiler.compileSync(src, {json.dumps(str(path))}, {{ output: 'source', modules: 'esm', translator: require('@marko/runtime-tags/translator') }});
+    console.log(res.code);
+  }} catch (err) {{
+    console.error(String(err && err.stack || err));
+    process.exit(1);
+  }}
+''')
+
+res = subprocess.run(['node','-e', node_script], cwd='/testbed', capture_output=True, text=True)
+print('exit', res.returncode)
+print(res.stderr, file=sys.stderr)
+print(res.stdout)
