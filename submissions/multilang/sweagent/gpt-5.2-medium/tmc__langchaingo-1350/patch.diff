+import io
+import subprocess
+import textwrap
+
+def main():
+    # Simulate SSE stream where server sends an event line like: "data: {...}".
+    # The bug: parser trims only "data:" but not "data: ", leaving leading space,
+    # then json decoder sees leading ':' from a malformed split and errors.
+    # We'll craft a body that includes a line starting with 'data: :{...}'
+    # which can happen if upstream already stripped 'data' field incorrectly.
+
+    # We'll run a tiny Go snippet that calls parseStreamingChatResponse.
+    go = textwrap.dedent('''
+        package main
+
+        import (
+            "bytes"
+            "context"
+            "fmt"
+            "net/http"
+            oc "github.com/tmc/langchaingo/llms/openai/internal/openaiclient"
+        )
+
+        func main() {
+            body := bytes.NewBufferString("data: :{\\\"choices\\\":[{\\\"delta\\\":{\\\"content\\\":\\\"hi\\\"}}]}\\n\\n")
+            r := &http.Response{Body: ioNopCloser{body}}
+            _, err := oc.TestOnlyParseStreamingChatResponse(context.Background(), r, &oc.ChatRequest{})
+            fmt.Println(err)
+        }
+
+        type ioNopCloser struct{ *bytes.Buffer }
+        func (c ioNopCloser) Close() error { return nil }
+    ''')
+    open('/testbed/tmp_repro.go','w').write(go)
+    p = subprocess.run(['bash','-lc','cd /testbed && go run tmp_repro.go'],capture_output=True,text=True)
+    print(p.stdout)
+    print(p.stderr)
+
+if __name__ == '__main__':
+    main()
