diff --git a/src/analyzer.rs b/src/analyzer.rs
index 7a63e451..11a11d95 100644
--- a/src/analyzer.rs
+++ b/src/analyzer.rs
@@ -38,6 +38,13 @@ impl<'run, 'src> Analyzer<'run, 'src> {
     let mut imports = HashSet::new();
     let mut unstable_features = BTreeSet::new();
 
+    // Traverse imports in source order.
+    //
+    // Deduplication of variables and recipes uses `file_depth` and the order in
+    // which assignments are encountered. Using a stack with `pop()` reverses the
+    // order in which imports are visited, which can cause imported files to be
+    // analyzed before the importing file. That breaks scoping for imported
+    // recipes that reference variables defined in the importing file.
     let mut stack = Vec::new();
     let ast = asts.get(root).unwrap();
     stack.push(ast);
@@ -58,7 +65,8 @@ impl<'run, 'src> Analyzer<'run, 'src> {
           Item::Import { absolute, .. } => {
             if let Some(absolute) = absolute {
               if imports.insert(absolute) {
-                stack.push(asts.get(absolute).unwrap());
+                // Ensure the importing file is processed before its imports.
+                stack.insert(0, asts.get(absolute).unwrap());
               }
             }
           }
@@ -137,9 +145,13 @@ impl<'run, 'src> Analyzer<'run, 'src> {
         settings.allow_duplicate_recipes,
       )?;
 
+      // Recipes with the same unqualified name can appear in different modules.
+      // Deduplicate only if the recipes are in the same module.
       if deduplicated_recipes
         .get(recipe.name.lexeme())
-        .map_or(true, |original| recipe.file_depth <= original.file_depth)
+        .map_or(true, |original| {
+          recipe.namepath != original.namepath || recipe.file_depth <= original.file_depth
+        })
       {
         deduplicated_recipes.insert(recipe.clone());
       }
