+package com.alibaba.nacos.api.ai.model.mcp;
+
+/**
+ * Security scheme definition for MCP server, aligned with OpenAPI's securitySchemes.
+ *
+ * <p>Used by Higress Passthrough Authentication to describe how to extract auth information.
+ *
+ * @author nacos
+ */
+public class McpSecurityScheme {
+
+    /**
+     * Scheme id/name.
+     */
+    private String id;
+
+    /**
+     * OpenAPI scheme type, e.g. apiKey, http, oauth2, openIdConnect.
+     */
+    private String type;
+
+    /**
+     * For type=http, e.g. bearer, basic.
+     */
+    private String scheme;
+
+    /**
+     * For type=apiKey, where to pass the key, e.g. header/query/cookie.
+     */
+    private String in;
+
+    /**
+     * For type=apiKey, the parameter name.
+     */
+    private String name;
+
+    public String getId() {
+        return id;
+    }
+
+    public void setId(String id) {
+        this.id = id;
+    }
+
+    public String getType() {
+        return type;
+    }
+
+    public void setType(String type) {
+        this.type = type;
+    }
+
+    public String getScheme() {
+        return scheme;
+    }
+
+    public void setScheme(String scheme) {
+        this.scheme = scheme;
+    }
+
+    public String getIn() {
+        return in;
+    }
+
+    public void setIn(String in) {
+        this.in = in;
+    }
+
+    public String getName() {
+        return name;
+    }
+
+    public void setName(String name) {
+        this.name = name;
+    }
+}
