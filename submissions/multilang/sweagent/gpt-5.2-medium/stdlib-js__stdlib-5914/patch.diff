+'use strict';
+
+// MODULES //
+
+var isnan = require( '@stdlib/math/base/assert/is-nan' );
+
+
+// MAIN //
+
+/**
+* Calculates the range of a strided array via a callback function and using accessor protocol.
+*
+* @param {PositiveInteger} N - number of indexed elements
+* @param {Object} x - input array-like object supporting the accessor protocol
+* @param {integer} stride - index increment
+* @param {NonNegativeInteger} offset - starting index
+* @param {Callback} clbk - callback
+* @param {*} [thisArg] - execution context
+* @returns {number} range
+*/
+function rangeBy( N, x, stride, offset, clbk, thisArg ) {
+        var max;
+        var min;
+        var ix;
+        var v;
+        var i;
+
+        if ( N <= 0 ) {
+                return NaN;
+        }
+        if ( N === 1 || stride === 0 ) {
+                v = clbk.call( thisArg, x.get( offset ), 0, offset, x );
+                if ( v === void 0 || isnan( v ) ) {
+                        return NaN;
+                }
+                return 0.0;
+        }
+        ix = offset;
+        for ( i = 0; i < N; i++ ) {
+                min = clbk.call( thisArg, x.get( ix ), i, ix, x );
+                if ( min !== void 0 ) {
+                        break;
+                }
+                ix += stride;
+        }
+        if ( i === N ) {
+                return NaN;
+        }
+        max = min;
+        i += 1;
+        for ( i; i < N; i++ ) {
+                ix += stride;
+                v = clbk.call( thisArg, x.get( ix ), i, ix, x );
+                if ( v === void 0 ) {
+                        continue;
+                }
+                if ( isnan( v ) ) {
+                        return v;
+                }
+                if ( v < min ) {
+                        min = v;
+                } else if ( v > max ) {
+                        max = v;
+                }
+        }
+        return max - min;
+}
+
+
+// EXPORTS //
+
+module.exports = rangeBy;
