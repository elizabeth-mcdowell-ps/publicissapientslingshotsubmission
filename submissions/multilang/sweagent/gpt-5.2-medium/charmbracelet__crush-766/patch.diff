+++ b/repro.py
@@ -0,0 +1,45 @@
+import os, subprocess, tempfile, textwrap, json, sys, pathlib
+
+ROOT = pathlib.Path(__file__).resolve().parent
+
+def run(cmd, cwd):
+    return subprocess.check_output(cmd, cwd=cwd, text=True)
+
+def main():
+    with tempfile.TemporaryDirectory() as td:
+        repo = pathlib.Path(td)
+        (repo/".gitignore").write_text(".*\n")
+        (repo/"example.txt").write_text("test")
+        (repo/"another.go").write_text("more")
+
+        # small go program that calls fsext.ListDirectory
+        # Put the repro program *inside* the crush module so it can import internal/...
+        gp = ROOT/"repro_main.go"
+        gp.write_text(textwrap.dedent(f"""
+        package main
+
+        import (
+            "fmt"
+            "github.com/charmbracelet/crush/internal/fsext"
+        )
+
+        func main() {{
+            files, truncated, err := fsext.ListDirectory("{repo.as_posix()}", nil, 0)
+            fmt.Println("err:", err)
+            fmt.Println("truncated:", truncated)
+            fmt.Println("count:", len(files))
+            for _, f := range files {{
+                fmt.Println(f)
+            }}
+        }}
+        """))
+
+        try:
+            # Run from the module root so go can see go.mod
+            out = run(["go", "run", "./repro_main.go"], cwd=str(ROOT))
+            print(out)
+        finally:
+            gp.unlink(missing_ok=True)
+
+if __name__ == "__main__":
+    main()
