diff --git a/repro.py b/repro.py
new file mode 100644
index 00000000..144af83d
--- /dev/null
+++ b/repro.py
@@ -0,0 +1,30 @@
+import os, subprocess, tempfile, textwrap, pathlib
+
+def run(justfile_dir, env=None):
+    exe = pathlib.Path('/testbed/target/debug/just')
+    if not exe.exists():
+        subprocess.check_call(['cargo','build'], cwd='/testbed')
+    cmd = [str(exe), '--justfile', str(pathlib.Path(justfile_dir)/'justfile'), 'print-user']
+    out = subprocess.check_output(cmd, cwd=justfile_dir, env=env, text=True)
+    return out.strip()
+
+with tempfile.TemporaryDirectory() as d:
+    p = pathlib.Path(d)
+    (p/'.env').write_text('USER=from_dotenv\n')
+    (p/'justfile').write_text(textwrap.dedent('''\
+    set dotenv-load := true
+    print-user:
+      @echo $USER
+    '''))
+
+    env = os.environ.copy()
+    env['USER'] = 'from_env'
+    print('default:', run(p, env=env))
+
+    (p/'justfile').write_text(textwrap.dedent('''\
+    set dotenv-load := true
+    set dotenv-override := true
+    print-user:
+      @echo $USER
+    '''))
+    print('override setting:', run(p, env=env))
