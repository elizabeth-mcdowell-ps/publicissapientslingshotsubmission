new file mode 100644
index 000000000..86f47485b
--- /dev/null
+++ b/reproduce.py
@@ -0,0 +1,18 @@
+from pathlib import Path
+
+# This reproduction script checks that LinearElementEditor.handlePointerMove doesn't
+# create a new editingLinearElement object when nothing changed (alt not pressed and
+# lastUncommittedPoint already null).
+
+src = Path('packages/element/src/linearElementEditor.ts').read_text(encoding='utf8')
+
+# We expect an early-return when lastUncommittedPoint is already null in the !altKey branch.
+needed = 'if (!event.altKey)' in src and 'lastUncommittedPoint == null' in src
+
+print('Contains !altKey branch:', 'if (!event.altKey)' in src)
+print('Contains guard for lastUncommittedPoint null:', 'lastUncommittedPoint == null' in src or 'lastUncommittedPoint === null' in src)
+
+if not needed:
+    raise SystemExit('Expected guard not found; current code likely re-renders unnecessarily')
+
+print('OK')
