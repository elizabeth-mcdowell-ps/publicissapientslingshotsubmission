 {
@@ -616,7 +623,48 @@ int flb_mp_accessor_keys_remove(struct flb_mp_accessor *mpa,
     msgpack_sbuffer mp_sbuf;
     msgpack_packer mp_pck;
 
+    /*
+     * Thread-safety note:
+     *
+     * flb_mp_accessor (mpa) instances are commonly created once and then shared
+     * across multiple output workers/threads. This function used mpa->matches
+     * as mutable scratch space to store rule matches for the current record.
+     *
+     * When called concurrently, workers would race while resetting/populating
+     * mpa->matches, producing inconsistent removals.
+     *
+     * To make key removal deterministic, use thread-local storage for the
+     * matches array and temporarily point mpa->matches to it.
+     */
+    struct flb_mp_accessor_match *tl_matches;
+    size_t tl_matches_size;
+    struct flb_mp_accessor_match *orig_matches;
+
+    tl_matches = FLB_TLS_GET(mpa_tl_matches);
+    tl_matches_size = FLB_TLS_GET(mpa_tl_matches_size);
+
+    if (tl_matches == NULL || tl_matches_size < mpa->matches_size) {
+        if (tl_matches != NULL) {
+            flb_free(tl_matches);
+        }
+
+        tl_matches = flb_calloc(1, mpa->matches_size);
+        if (tl_matches == NULL) {
+            flb_errno();
+            return -1;
+        }
+
+        FLB_TLS_SET(mpa_tl_matches, tl_matches);
+        FLB_TLS_SET(mpa_tl_matches_size, mpa->matches_size);
+    }
+
+
+    orig_matches = mpa->matches;
+    mpa->matches = tl_matches;
+
+
     if (map->via.map.size == 0) {
