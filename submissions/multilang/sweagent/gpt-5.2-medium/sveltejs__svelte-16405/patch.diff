diff --git a/packages/svelte/src/logger.svelte.test.js b/packages/svelte/src/logger.svelte.test.js
new file mode 100644
index 000000000..cbeba7512
--- /dev/null
+++ b/packages/svelte/src/logger.svelte.test.js
@@ -0,0 +1,22 @@
+import { flushSync } from 'svelte';
+import { test, expect } from 'vitest';
+
+// Based on the Svelte docs for testing runes inside test files
+// https://svelte.dev/docs/svelte/testing#Unit-and-integration-testing-using-Vitest-Using-runes-inside-your-test-files
+
+test('Effect', () => {
+let count = $state(0);
+let log = $state([]);
+
+$effect(() => {
+log.value = [...log.value, count];
+});
+
+// use flushSync to execute all pending effects synchronously
+flushSync();
+expect(log.value).toEqual([0]);
+
+count = 1;
+flushSync();
+expect(log.value).toEqual([0, 1]);
+});
