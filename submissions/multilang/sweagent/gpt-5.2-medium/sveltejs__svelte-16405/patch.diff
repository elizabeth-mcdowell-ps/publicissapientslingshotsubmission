+import subprocess, os, sys
+
+# Run the specific test that checks rune effects flushing.
+# We call vitest via pnpm to use repo's configured toolchain.
+cmd = ["pnpm", "-s", "vitest", "run", "packages/svelte/src/reactivity/map.test.ts", "-t", "flushSync"]
+print("Running:", " ".join(cmd))
+proc = subprocess.run(cmd, cwd=os.path.dirname(__file__), text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
+print(proc.stdout)
+sys.exit(proc.returncode)
