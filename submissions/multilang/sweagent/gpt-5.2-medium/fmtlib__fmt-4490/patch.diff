diff --git a/include/fmt/format.h b/include/fmt/format.h
index 25153a4d..23c93364 100644
--- a/include/fmt/format.h
+++ b/include/fmt/format.h
@@ -827,20 +827,47 @@ class basic_memory_buffer : public detail::buffer<T> {
 
  private:
   // Move data from other to this buffer.
+  //
+  // For non-propagating allocators (e.g. std::pmr::polymorphic_allocator), we
+  // can only take ownership of other's storage if the allocators compare equal.
+  // Otherwise we fall back to copying, matching standard container behavior.
   FMT_CONSTEXPR20 void move(basic_memory_buffer& other) {
-    alloc_ = std::move(other.alloc_);
+    using traits = std::allocator_traits<Allocator>;
+    constexpr bool propagate = traits::propagate_on_container_move_assignment::value;
+
     T* data = other.data();
     size_t size = other.size(), capacity = other.capacity();
-    if (data == other.store_) {
-      this->set(store_, capacity);
-      detail::copy<T>(other.store_, other.store_ + size, store_);
-    } else {
-      this->set(data, capacity);
-      // Set pointer to the inline array so that delete is not called
-      // when deallocating.
-      other.set(other.store_, 0);
-      other.clear();
+
+    // For non-propagating allocators we can only steal storage if allocators are
+    // equal and the allocator type is equality comparable.
+    constexpr bool alloc_eq_comparable = requires(const Allocator& a,
+                                                  const Allocator& b) {
+      { a == b } -> std::convertible_to<bool>;
+    };
+
+    bool can_steal = propagate;
+    if (!can_steal) {
+      if constexpr (alloc_eq_comparable) can_steal = (alloc_ == other.alloc_);
     }
+
+    if (!can_steal || data == other.store_) {
+      // Copy into our own storage.
+      this->set(store_, SIZE);
+      this->resize(0);
+      this->try_reserve(size);
+      detail::copy<T>(other.data(), other.data() + size, this->data());
+      this->resize(size);
+      return;
+    }
+
+    // Allocators propagate or compare equal: transfer ownership of the storage.
+    if constexpr (propagate) alloc_ = std::move(other.alloc_);
+
+    this->set(data, capacity);
+    // Set pointer to the inline array so that delete is not called
+    // when deallocating.
+    other.set(other.store_, 0);
+    other.clear();
     this->resize(size);
   }
 
