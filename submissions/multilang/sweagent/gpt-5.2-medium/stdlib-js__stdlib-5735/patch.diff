+function createBenchmark( len ) {
+	var x = uniform( len, -10.0, 10.0, options );
+	return benchmark;
+
+	/**
+	* Benchmark function.
+	*
+	* @private
+	* @param {Benchmark} b - benchmark instance
+	*/
+	function benchmark( b ) {
+		var sum;
+		var i;
+
+		b.tic();
