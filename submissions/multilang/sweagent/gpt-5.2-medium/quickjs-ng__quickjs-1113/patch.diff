diff --git a/repro_typedarray_extend.py b/repro_typedarray_extend.py
new file mode 100644
index 0000000..db9be1f
--- /dev/null
+++ b/repro_typedarray_extend.py
@@ -0,0 +1,18 @@
+import subprocess, textwrap, os, sys
+
+qjs = '/testbed/build/qjs'
+js = textwrap.dedent('''
+var TypedArray = Object.getPrototypeOf(Uint8Array);
+print('TypedArray:', TypedArray);
+try {
+  var MyClass = class extends TypedArray {};
+  print('extended ok', MyClass);
+} catch (e) {
+  print('error:', e && e.name, e && e.message);
+}
+''')
+
+p = subprocess.run([qjs, '-e', js], capture_output=True, text=True)
+print(p.stdout)
+print(p.stderr, file=sys.stderr)
+sys.exit(p.returncode)
