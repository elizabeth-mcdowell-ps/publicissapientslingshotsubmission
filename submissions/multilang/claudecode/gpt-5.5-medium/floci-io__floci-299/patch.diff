+    public StreamDescription restoreStream(TableDefinition table, String region) {
+        String streamArn = table.getStreamArn();
+        if (streamArn == null || streamArn.isBlank()) {
+            return null;
+        }
+
+        String key = streamKey(region, table.getTableName());
+        StreamDescription existing = streams.get(key);
+        if (existing != null) {
+            records.computeIfAbsent(existing.getStreamArn(), ignored -> new ConcurrentLinkedDeque<>());
+            return existing;
+        }
+
+        StreamDescription sd = new StreamDescription();
+        sd.setStreamArn(streamArn);
+        sd.setStreamLabel(extractStreamLabel(streamArn));
+        sd.setStreamStatus(table.isStreamEnabled() ? "ENABLED" : "DISABLED");
+        sd.setStreamViewType(table.getStreamViewType());
+        sd.setTableName(table.getTableName());
+        sd.setCreationDateTime(table.getCreationDateTime());
+        sd.setStartingSequenceNumber(String.format("%021d", 1));
+
+        streams.put(key, sd);
+        records.putIfAbsent(streamArn, new ConcurrentLinkedDeque<>());
+        LOG.infov("Restored stream for table {0} in region {1}: {2}", table.getTableName(), region, streamArn);
+        return sd;
+    }
+
