+    private String extractStreamLabel(String streamArn) {
+        int streamMarker = streamArn.lastIndexOf("/stream/");
+        if (streamMarker < 0) {
+            return "";
+        }
+        return streamArn.substring(streamMarker + "/stream/".length());
+    }
