+    private Map<String, Object> prepareNamedParameters(DbNamedStatementParameters named) {
+        Map<String, Object> namedParameters = named.parameters();
+        Map<String, Object> params = new LinkedHashMap<>(namedParameters.size());
+        Map<String, Object> flattened = new LinkedHashMap<>();
+        namedParameters.forEach((name, value) -> {
+            NamedParameter normalized = normalizeNamedParameter(value);
+            params.put(name, normalized.value());
+            normalized.flattenedValues().forEach(flattened::putIfAbsent);
+        });
+        flattened.forEach(params::putIfAbsent);
+        return params;
+    }
+
+    private Object normalizeParameter(Object value) {
+        if (value == null || isScalar(value)) {
+            return value;
+        }
+        if (value instanceof Map<?, ?> map) {
+            return normalizeMap(map);
+        }
+        if (value instanceof Iterable<?> iterable) {
+            return normalizeList(iterable);
+        }
+        if (value.getClass().isArray()) {
+            return normalizeArray(value);
+        }
+        Object mapped = mappedValue(value);
+        return mapped != null ? mapped : value;
+    }
+
+    private NamedParameter normalizeNamedParameter(Object value) {
+        if (value == null || isScalar(value)) {
+            return NamedParameter.create(value);
+        }
+        if (value instanceof Map<?, ?> map) {
+            return NamedParameter.create(normalizeMap(map));
+        }
+        if (value instanceof Iterable<?> iterable) {
+            return NamedParameter.create(normalizeList(iterable));
+        }
+        if (value.getClass().isArray()) {
+            return NamedParameter.create(normalizeArray(value));
+        }
+        Object mapped = mappedValue(value);
+        if (mapped instanceof Map<?, ?> map) {
+            @SuppressWarnings("unchecked")
+            Map<String, Object> flattened = (Map<String, Object>) map;
+            return new NamedParameter(mapped, flattened);
+        }
+        return NamedParameter.create(value);
+    }
+
+    private Map<String, Object> normalizeMap(Map<?, ?> valueMap) {
+        Map<String, Object> result = new LinkedHashMap<>(valueMap.size());
+        valueMap.forEach((key, value) -> result.put(String.valueOf(key), normalizeParameter(value)));
+        return result;
+    }
+
+    private List<Object> normalizeList(Iterable<?> iterable) {
+        List<Object> result = new ArrayList<>();
+        iterable.forEach(value -> result.add(normalizeParameter(value)));
+        return result;
+    }
+
+    private List<Object> normalizeArray(Object value) {
+        int size = Array.getLength(value);
+        List<Object> result = new ArrayList<>(size);
+        for (int i = 0; i < size; i++) {
+            result.add(normalizeParameter(Array.get(value, i)));
+        }
+        return result;
+    }
+
+    private Object mappedValue(Object value) {
+        @SuppressWarnings("unchecked")
