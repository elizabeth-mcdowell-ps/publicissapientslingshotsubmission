+// ReplyComment posts a public reply to a comment conversation.
+func (c *APIClient) ReplyComment(ctx context.Context, commentID, content string) error {
+	body, _ := json.Marshal(SendMessageRequest{
+		Action:  "reply_comment",
+		Message: content,
+	})
+	url := fmt.Sprintf("%s/pages/%s/conversations/%s/messages", c.pageV1BaseURL, c.pageID, commentID)
+	if err := c.doRequest(ctx, http.MethodPost, url, bytes.NewReader(body)); err != nil {
+		return fmt.Errorf("pancake: reply comment: %w", err)
+	}
+	return nil
+}
