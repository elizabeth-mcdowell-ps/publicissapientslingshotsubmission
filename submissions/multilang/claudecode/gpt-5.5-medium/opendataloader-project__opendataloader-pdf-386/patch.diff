+    private static boolean areStackedHeaderOrFooterContents(IObject previousObject, IObject currentObject,
+                                                            boolean isHeaderDetection) {
+        BoundingBox previousBox = previousObject.getBoundingBox();
+        BoundingBox currentBox = currentObject.getBoundingBox();
+        if (previousBox == null || currentBox == null) {
+            return false;
+        }
+        double gap = isHeaderDetection ? previousBox.getBottomY() - currentBox.getTopY() :
+                currentBox.getBottomY() - previousBox.getTopY();
+        double maxHeight = Math.max(previousBox.getHeight(), currentBox.getHeight());
+        return gap <= maxHeight * 1.5;
+    }
