+    private boolean matchesAnyArrayField(JsonNode patternArray, Object eventValue) {
+        if (eventValue == null) {
+            return false;
+        }
+        if (eventValue instanceof Iterable<?> values) {
+            for (Object value : values) {
+                if (matchesArrayField(patternArray, value != null ? value.toString() : null)) {
+                    return true;
+                }
+            }
+            return false;
+        }
+        if (eventValue.getClass().isArray()) {
+            int length = Array.getLength(eventValue);
+            for (int i = 0; i < length; i++) {
+                Object value = Array.get(eventValue, i);
+                if (matchesArrayField(patternArray, value != null ? value.toString() : null)) {
+                    return true;
+                }
+            }
+            return false;
+        }
+        return matchesArrayField(patternArray, eventValue.toString());
+    }
