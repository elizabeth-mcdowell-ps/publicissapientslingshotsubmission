diff --git a/src/dict.h b/src/dict.h
index 698088ab9..beb6f45d6 100644
--- a/src/dict.h
+++ b/src/dict.h
@@ -77,10 +77,16 @@ typedef struct dictType {
     /* Flags */
     /* The 'no_value' flag, if set, indicates that values are not used, i.e. the
      * dict is a set. When this flag is set, it's not possible to access the
-     * value of a dictEntry and it's also impossible to use dictSetKey(). It 
-     * enables an optimization to store a key directly without an allocating 
+     * value of a dictEntry and it's also impossible to use dictSetKey(). It
+     * enables an optimization to store a key directly without an allocating
      * dictEntry in between, if it is the only key in the bucket. */
     unsigned int no_value:1;
+    /* Force the no_value optimization to allocate a dictEntry, even for buckets
+     * with a single key. This should be enabled for dicts that use the stored-key
+     * API with even-addressed keys whose low bits may collide with dict's internal
+     * pointer tags (for example kvobj keys), so dictGetKey() always receives an
+     * actual dictEntry pointer. */
+    unsigned int no_value_force_entry:1;
     /* This flag is required for `no_value` optimization since the optimization
      * reuses LSB bits as metadata */ 
     unsigned int keys_are_odd:1;
