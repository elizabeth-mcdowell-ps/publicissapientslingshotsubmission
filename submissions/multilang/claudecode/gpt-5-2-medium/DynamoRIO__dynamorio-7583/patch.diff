diff --git a/core/unix/signal.c b/core/unix/signal.c
index c5511fc2a..55b2949f4 100644
--- a/core/unix/signal.c
+++ b/core/unix/signal.c
@@ -5259,11 +5259,26 @@ record_pending_signal(dcontext_t *dcontext, int sig, kernel_ucontext_t *ucxt,
                 info->multiple_pending_units = true;
             if (info->num_pending >= DYNAMO_OPTION(max_pending_signals)) {
                 /* We're at the limit of our special heap: one more and it will try to
-                 * allocate a new unit, which is unsafe as it acquires locks.  We take
-                 * several steps: we notify the user; we check for this on delivery as
-                 * well and proactively allocate a new unit in a safer context.
-                 * XXX: Perhaps we should drop some signals here?
+                 * allocate a new unit, which is unsafe as it acquires locks.
+                 *
+                 * For non-realtime signals, the kernel will coalesce multiple pending
+                 * instances of the same signal.  If we're seeing many here, we're not
+                 * keeping up and continuing to enqueue can lead to lock acquisition in
+                 * a fragile context when the special heap grows.  Instead of risking
+                 * deadlocks, we drop additional signals once we hit the limit.
+                 *
+                 * For alarm-style signals we already cap the per-signal queue above.
                  */
+                if (sig < OFFS_RT) {
+                    /* Undo the allocation and count increment above. */
+                    special_heap_free(info->sigheap, pend);
+                    info->num_pending--;
+                    STATS_INC(num_signals_dropped);
+                    SYSLOG_INTERNAL_WARNING_ONCE("dropping pending signal due to max_pending_signals");
+                    /* Do not enqueue; treat as ignored like a duplicate non-rt. */
+                    ostd->processing_signal--;
+                    return;
+                }
                 DO_ONCE({
