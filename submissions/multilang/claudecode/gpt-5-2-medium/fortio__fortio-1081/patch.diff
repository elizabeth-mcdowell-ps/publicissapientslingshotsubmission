@@ -320,6 +320,13 @@ func (e *HistogramData) CalcPercentile(percentile float64) float64 {
 	for i := range e.Data {
 		cur := &e.Data[i]
 		if percentile <= cur.Percent {
+			// When all the samples fell into a single exported bucket, the bucket's
+			// End boundary can be far from the actual values (it is driven by the
+			// internal bucket boundaries). In that special case, interpolate would
+			// severely under-estimate percentiles (see issue with very small -r).
+			if len(e.Data) == 1 {
+				return e.Min
+			}
 			return cur.Start + (percentile-pp)/(cur.Percent-pp)*(cur.End-cur.Start)
