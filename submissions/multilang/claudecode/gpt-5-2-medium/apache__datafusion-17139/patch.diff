diff --git a/datafusion/functions-aggregate/src/average.rs b/datafusion/functions-aggregate/src/average.rs
index 46a8dbf95..33ebc1400 100644
--- a/datafusion/functions-aggregate/src/average.rs
+++ b/datafusion/functions-aggregate/src/average.rs
@@ -500,6 +500,31 @@ impl AggregateUDFImpl for Avg {
         ReversedUDAF::Identical
     }
 
+    fn simplify(&self) -> Option<datafusion_expr::function::AggregateFunctionSimplification> {
+        Some(Box::new(|mut af, _info| {
+            // Rewrite `AVG(DISTINCT <const>)` to `AVG(<const>)` when the argument
+            // is a constant expression. This enables other simplifications and
+            // avoids planning unsupported DISTINCT AVG for constant inputs.
+            if af.params.distinct
+                && af.params.filter.is_none()
+                && af.params.order_by.is_empty()
+                && af.params.args.len() == 1
+            {
+                let arg = &af.params.args[0];
+                // Consider `AVG(DISTINCT 4)` and similar constant expressions.
+                // We only need a conservative check here to avoid changing
+                // semantics of non-constant inputs.
+                let is_const = matches!(arg, Expr::Literal(_, _))
+                    || matches!(arg, Expr::Cast(c) if matches!(*c.expr, Expr::Literal(_, _)));
+
+                if is_const {
+                    af.params.distinct = false;
+                }
+            }
+            Ok(Expr::AggregateFunction(af))
+        }))
+    }
+
     fn documentation(&self) -> Option<&Documentation> {
         self.doc()
     }
