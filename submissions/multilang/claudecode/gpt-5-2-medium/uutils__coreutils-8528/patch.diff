diff --git a/src/uu/mv/src/mv.rs b/src/uu/mv/src/mv.rs
index b89290149..a0a567228 100644
--- a/src/uu/mv/src/mv.rs
+++ b/src/uu/mv/src/mv.rs
@@ -747,13 +747,21 @@ fn rename(
     }
 
     // "to" may no longer exist if it was backed up
-    if to.exists() && to.is_dir() {
-        // normalize behavior between *nix and windows
-        if from.is_dir() {
-            if is_empty_dir(to) {
-                fs::remove_dir(to)?;
-            } else {
-                return Err(io::Error::other(translate!("mv-error-directory-not-empty")));
+    // If "to" is a symlink to a directory, GNU mv does *not* treat it as a directory
+    // in the special "dir overwrites dir" handling; it simply replaces the symlink.
+    // Rust's Path::is_dir() follows symlinks, so we must be careful to only apply
+    // the directory-not-empty check when "to" is an actual directory entry.
+    if to.try_exists()? {
+        let to_meta = to.symlink_metadata()?;
+        let to_is_real_dir = to_meta.is_dir();
+        if to_is_real_dir {
+            // normalize behavior between *nix and windows
+            if from.is_dir() {
+                if is_empty_dir(to) {
+                    fs::remove_dir(to)?;
+                } else {
+                    return Err(io::Error::other(translate!("mv-error-directory-not-empty")));
+                }
             }
         }
     }
