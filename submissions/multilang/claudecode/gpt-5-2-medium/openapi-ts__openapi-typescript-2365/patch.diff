diff --git a/packages/openapi-metadata/src/decorators/api-operation.ts b/packages/openapi-metadata/src/decorators/api-operation.ts
index 99d210fc..99b243e6 100644
--- a/packages/openapi-metadata/src/decorators/api-operation.ts
+++ b/packages/openapi-metadata/src/decorators/api-operation.ts
@@ -1,4 +1,5 @@
 import { type OperationMetadata, OperationMetadataStorage } from "../metadata/operation.js";
+import { OperationParameterMetadataStorage } from "../metadata/operation-parameter.js";
 
 export type ApiOperationOptions = OperationMetadata;
 
@@ -10,6 +11,18 @@ export type ApiOperationOptions = OperationMetadata;
  */
 export function ApiOperation(options: ApiOperationOptions): MethodDecorator {
   return (target, propertyKey) => {
-    OperationMetadataStorage.defineMetadata(target, options, propertyKey);
+    // Operation-level metadata is stored separately from parameters/body/responses.
+    // However, `parameters` is part of OpenAPI's OperationObject, so when users
+    // provide it via @ApiOperation({ parameters: [...] }) we must also populate
+    // the dedicated parameter storage used by the document generator.
+    const { parameters, ...operation } = options as ApiOperationOptions & { parameters?: unknown };
+
+    OperationMetadataStorage.defineMetadata(target, operation as ApiOperationOptions, propertyKey);
+
+    if (parameters && Array.isArray(parameters) && parameters.length > 0) {
+      // Merge rather than define so it composes with @ApiParam/@ApiQuery/etc.
+      // and supports controller-level parameters.
+      OperationParameterMetadataStorage.mergeMetadata(target, parameters as any, propertyKey);
+    }
   };
 }
