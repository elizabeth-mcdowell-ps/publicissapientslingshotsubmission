diff --git a/src/uu/cp/src/platform/linux.rs b/src/uu/cp/src/platform/linux.rs
index 793890192..2efb69fe0 100644
--- a/src/uu/cp/src/platform/linux.rs
+++ b/src/uu/cp/src/platform/linux.rs
@@ -253,6 +253,14 @@ where
     let num_bytes_copied = buf_copy::copy_stream(&mut src_file, &mut dst_file)
         .map_err(|_| std::io::Error::from(std::io::ErrorKind::Other))?;
 
+    // If the source was a stream (e.g. stdin), we don't know its size upfront.
+    // Ensure that an existing regular destination file is truncated to exactly
+    // the number of bytes we just wrote, otherwise old trailing bytes may
+    // remain when the new content is shorter.
+    if !dest_is_stream {
+        dst_file.set_len(num_bytes_copied)?;
+    }
+
     Ok(num_bytes_copied)
 }
 
