+#[test]
+fn deref_assign_completion() {
+    // Test that completion after `*self = ` suggests the bare enum variants, not references
+    // This is a regression test for https://github.com/rust-lang/rust-analyzer/issues/XXXXX
+    //cov_mark::check!(expected_type_bin_expr);
+    check(
+        r#"
+enum State {
+    Stop(()),
+    Running(u32),
+}
+
+impl State {
+    fn test(&mut self) {
+        *self = $0;
+    }
+}
+"#,
+        expect![[r#"
+            en State                           State
+            me self.test()             fn(&mut self)
+            lc self                       &mut State
+            sp Self                            State
+            ev Self::Running(…)   Self::Running(u32)
+            ev Self::Stop(…)          Self::Stop(())
+            ev State::Running(…) State::Running(u32)
+            ev State::Stop(…)        State::Stop(())
+            bt u32                               u32
+            kw const
+            kw crate::
+            kw false
+            kw for
+            kw if
+            kw if let
+            kw loop
+            kw match
+            kw return
+            kw self::
+            kw true
+            kw unsafe
+            kw while
+            kw while let
+            ex State::Stop(())
+        "#]],
+    );
+}
