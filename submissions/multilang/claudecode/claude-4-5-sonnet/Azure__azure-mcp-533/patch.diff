diff --git a/core/src/AzureMcp.Core/Commands/Subscription/SubscriptionCommand.cs b/core/src/AzureMcp.Core/Commands/Subscription/SubscriptionCommand.cs
index 6915dcce..053c33b3 100644
--- a/core/src/AzureMcp.Core/Commands/Subscription/SubscriptionCommand.cs
+++ b/core/src/AzureMcp.Core/Commands/Subscription/SubscriptionCommand.cs
@@ -23,7 +23,47 @@ protected override void RegisterOptions(Command command)
     protected override TOptions BindOptions(ParseResult parseResult)
     {
         var options = base.BindOptions(parseResult);
-        options.Subscription = parseResult.GetValueForOption(_subscriptionOption);
+        var explicitSubscription = parseResult.GetValueForOption(_subscriptionOption);
+
+        // If explicit subscription is not provided, try to get from environment variable
+        if (string.IsNullOrWhiteSpace(explicitSubscription))
+        {
+            options.Subscription = Environment.GetEnvironmentVariable("AZURE_SUBSCRIPTION_ID");
+        }
+        else
+        {
+            options.Subscription = explicitSubscription;
+        }
+
         return options;
     }
+
+    public override ValidationResult Validate(CommandResult commandResult, CommandResponse? commandResponse = null)
+    {
+        // First perform base validation (which checks IsRequired options)
+        var result = base.Validate(commandResult, commandResponse);
+
+        // If base validation passed, check if subscription is actually present
+        // (it might have been populated from environment variable)
+        if (result.IsValid)
+        {
+            // Check if subscription value is missing
+            var subscriptionValue = commandResult.GetValueForOption(_subscriptionOption);
+            var envVarValue = Environment.GetEnvironmentVariable("AZURE_SUBSCRIPTION_ID");
+
+            if (string.IsNullOrWhiteSpace(subscriptionValue) && string.IsNullOrWhiteSpace(envVarValue))
+            {
+                result.IsValid = false;
+                result.ErrorMessage = "Missing Required options: --subscription (or set AZURE_SUBSCRIPTION_ID environment variable)";
+
+                if (commandResponse != null)
+                {
+                    commandResponse.Status = 400;
+                    commandResponse.Message = result.ErrorMessage;
+                }
+            }
+        }
+
+        return result;
+    }
 }
