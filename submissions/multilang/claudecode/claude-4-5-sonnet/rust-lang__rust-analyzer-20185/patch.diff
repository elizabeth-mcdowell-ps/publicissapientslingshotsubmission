+                    def,
+                    loc: dec_loc.clone(),
+                    container_name: self.current_container_name.clone(),
+                    is_alias: true,
+                    is_assoc: false,
+                    is_import: false,
+                    do_not_complete,
+                });
+            }
+        }
+
+        self.symbols.insert(FileSymbol {
+            name: name.symbol().clone(),
+            def,
+            container_name: self.current_container_name.clone(),
+            loc: dec_loc,
+            is_alias: false,
+            is_assoc: false,
+            is_import: false,
+            do_not_complete,
+        });
+    }
