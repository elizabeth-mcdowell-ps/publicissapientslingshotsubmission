+    private static Type GetDeserializationType(Type type)
+    {
+        // JsonValue and JsonNode types need special handling.
+        // When deserializing, we should use the base type (JsonValue or JsonNode) instead of the concrete type
+        // to avoid issues with JsonValuePrimitive<T> being deserialized as JsonValuePrimitive<JsonElement>.
+        // For example, JsonValuePrimitive<int> created with JsonValue.Create(1) should be deserialized as JsonValue,
+        // not as JsonValuePrimitive<int>, because System.Text.Json will incorrectly create JsonValuePrimitive<JsonElement>.
+
+        if (type == typeof(JsonArray) || type == typeof(JsonObject) || type == typeof(JsonElement) || type == typeof(JsonDocument))
+        {
+            return type;
+        }
+
+        if (typeof(JsonValue).IsAssignableFrom(type))
+        {
+            return typeof(JsonValue);
+        }
+
+        if (typeof(JsonNode).IsAssignableFrom(type))
+        {
+            return typeof(JsonNode);
+        }
+
+        return type;
+    }
+
