diff --git a/ext/reflection/php_reflection.c b/ext/reflection/php_reflection.c
index 3a37304dc2d..446e23f8a48 100644
--- a/ext/reflection/php_reflection.c
+++ b/ext/reflection/php_reflection.c
@@ -1054,6 +1054,37 @@ static void _property_string(smart_str *str, zend_property_info *prop, const cha
 			smart_str_appends(str, " = ");
 			format_default_value(str, default_value);
 		}
+
+		/* Display property hooks if present */
+		if (prop->hooks) {
+			bool has_get = prop->hooks[ZEND_PROPERTY_HOOK_GET] != NULL;
+			bool has_set = prop->hooks[ZEND_PROPERTY_HOOK_SET] != NULL;
+
+			if (has_get || has_set) {
+				smart_str_appends(str, " { ");
+
+				if (has_get) {
+					zend_function *get_hook = prop->hooks[ZEND_PROPERTY_HOOK_GET];
+					if (get_hook->common.fn_flags & ZEND_ACC_FINAL) {
+						smart_str_appends(str, "final ");
+					}
+					smart_str_appends(str, "get");
+					if (has_set) {
+						smart_str_appends(str, "; ");
+					}
+				}
+
+				if (has_set) {
+					zend_function *set_hook = prop->hooks[ZEND_PROPERTY_HOOK_SET];
+					if (set_hook->common.fn_flags & ZEND_ACC_FINAL) {
+						smart_str_appends(str, "final ");
+					}
+					smart_str_appends(str, "set");
+				}
+
+				smart_str_appends(str, " }");
+			}
+		}
 	}
 
 	smart_str_appends(str, " ]\n");
