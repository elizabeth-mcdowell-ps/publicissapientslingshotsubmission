+use crate::assert_erl;
+
+const RESULT_MODULE: &str = "
+pub fn map(over result: Result(a, e), with f: fn(a) -> b) -> Result(b, e) {
+  case result {
+    Ok(value) -> Ok(f(value))
+    Error(error) -> Error(error)
+  }
+}
+";
+
+#[test]
+fn inline_with_constant_reference() {
+    assert_erl!(
+        ("gleam_stdlib", "gleam/result", RESULT_MODULE),
+        "
+pub const Ssl = \"ssl\"
+
+pub fn main() {
+  result.map(Ok(Ssl), fn(x) { x })
+}
+"
+    );
+}
+
+#[test]
+fn inline_with_constant_reference() {
+    assert_erl!(
+        ("gleam_stdlib", "gleam/result", RESULT_MODULE),
+        "
+pub const Ssl = \"ssl\"
+
+pub fn main() {
+  result.map(Ok(Ssl), fn(x) { x })
+}
+"
+    );
+}
