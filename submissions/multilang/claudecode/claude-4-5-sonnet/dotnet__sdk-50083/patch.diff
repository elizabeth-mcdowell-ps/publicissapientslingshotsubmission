@@ -587,6 +600,32 @@ Copyright (c) .NET Foundation. All rights reserved.
     </ItemGroup>
   </Target>
 
+  <!-- Detect if the project has .razor files to enable embedded ValidatableTypeAttribute for .NET 10.0+ -->
+  <Target Name="_DetectRazorFiles"
+    BeforeTargets="CoreCompile"
+    DependsOnTargets="ResolveRazorComponentInputs"
+    Condition="'$(_TargetingNET100OrLater)' == 'true'">
+    <PropertyGroup>
+      <_HasRazorFiles Condition="'@(RazorComponent)' != ''">true</_HasRazorFiles>
+      <GenerateEmbeddedValidatableTypeAttribute Condition="'$(GenerateEmbeddedValidatableTypeAttribute)' == '' AND '$(_HasRazorFiles)' == 'true'">true</GenerateEmbeddedValidatableTypeAttribute>
+    </PropertyGroup>
+  </Target>
+
+  <!-- Include embedded attribute source files when enabled -->
+  <ItemGroup Condition="'$(GenerateEmbeddedValidatableTypeAttribute)' == 'true'">
+    <Compile Include="$(MSBuildThisFileDirectory)Embedded\EmbeddedAttribute.cs">
+      <Link>EmbeddedAttribute.cs</Link>
+    </Compile>
+    <Compile Include="$(MSBuildThisFileDirectory)Embedded\ValidatableTypeAttribute.cs">
+      <Link>ValidatableTypeAttribute.cs</Link>
+    </Compile>
+  </ItemGroup>
+
+  <!-- Include global using for embedded validation namespace -->
+  <ItemGroup Condition="'$(IncludeEmbeddedValidationGlobalUsing)' == 'true'">
+    <Using Include="Microsoft.Extensions.Validation.Embedded" />
+  </ItemGroup>
+
