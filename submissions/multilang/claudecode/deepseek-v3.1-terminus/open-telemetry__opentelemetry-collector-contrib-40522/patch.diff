+// reloadAgentConfig reloads the agent configuration using SIGHUP
+func (s *Supervisor) reloadAgentConfig() {
+	s.telemetrySettings.Logger.Debug("Reloading agent configuration using SIGHUP")
+	cfgState := s.cfgState.Load().(*configState)
+
+	// Write the new config to disk first
+	if err := os.WriteFile(s.agentConfigFilePath(), []byte(cfgState.mergedConfig), 0o600); err != nil {
+		s.telemetrySettings.Logger.Error("Failed to write agent config.", zap.Error(err))
+		return
+	}
+
+	// Send SIGHUP to reload config without restarting process
+	if err := s.commander.Reload(context.Background()); err != nil {
+		s.telemetrySettings.Logger.Error("Could not reload agent configuration", zap.Error(err))
+		// Fall back to restarting if reload fails
+		s.stopAgentApplyConfig()
+	}
+}
