diff --git a/compress.go b/compress.go
index bb52e96..0d29a87 100644
--- a/compress.go
+++ b/compress.go
@@ -13,7 +13,11 @@ import (
 var (
 	lz4WriterPool = sync.Pool{
 		New: func() interface{} {
-			return lz4.NewWriter(nil)
+			writer := lz4.NewWriter(nil)
+			// Apply smaller block size to reduce memory pressure on Kafka broker
+			// Default block size is 4MB which causes significant memory strain
+			writer.Apply(lz4.BlockSizeOption(lz4.Block64Kb))
+			return writer
 		},
 	}
 
