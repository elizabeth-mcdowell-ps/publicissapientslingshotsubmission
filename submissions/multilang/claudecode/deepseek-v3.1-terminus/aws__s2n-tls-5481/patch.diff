diff --git a/tls/s2n_signature_algorithms.c b/tls/s2n_signature_algorithms.c
index 749c4276d..16ba76912 100644
--- a/tls/s2n_signature_algorithms.c
+++ b/tls/s2n_signature_algorithms.c
@@ -194,6 +194,15 @@ S2N_RESULT s2n_signature_algorithm_select(struct s2n_connection *conn)
         return S2N_RESULT_OK;
     }
 
+    /* For RSA key exchange, no signature algorithm is needed since the server
+     * proves ownership by encrypting/decrypting the premaster secret.
+     * Set the signature scheme to NULL to indicate "None+None".
+     */
+    if (conn->mode == S2N_SERVER && cipher_suite->key_exchange_alg == &s2n_rsa) {
+        *chosen_sig_scheme = NULL;
+        return S2N_RESULT_OK;
+    }
+
     const struct s2n_signature_preferences *signature_preferences = NULL;
     RESULT_GUARD_POSIX(s2n_connection_get_signature_preferences(conn, &signature_preferences));
     RESULT_ENSURE_REF(signature_preferences);
