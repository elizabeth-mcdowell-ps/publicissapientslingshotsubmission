+// Global variable to store the child process for signal handling
+#[cfg(unix)]
+static mut CHILD_PROCESS: Option<Child> = None;
+
+#[cfg(unix)]
+extern "C" fn signal_handler(sig: libc::c_int) {
+    unsafe {
+        if let Some(ref mut child) = CHILD_PROCESS {
+            // Send the same signal to the child process group
+            let _ = child.send_signal_group(sig as usize);
+        }
+        // Exit with the signal number + 128 (standard Unix convention)
+        libc::_exit(128 + sig);
+    }
+}
