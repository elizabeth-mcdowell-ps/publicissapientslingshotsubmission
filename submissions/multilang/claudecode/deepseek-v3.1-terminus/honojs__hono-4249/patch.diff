+export const ssgParams: SSGParamsMiddleware = (params) => {
+  // Cache for callback results during SSG generation
+  let ssgParamsCache: SSGParams | undefined
+
+  return async (c, next) => {
+    const req = c.req.raw as AddedSSGDataRequest
+
+    // If we're in SSG context, use cached result or populate cache
+    if (isSSGContext(c)) {
+      if (ssgParamsCache === undefined) {
+        // First call in SSG context - execute callback and cache result
+        ssgParamsCache = Array.isArray(params) ? params : await params(c)
+      }
+      req.ssgParams = ssgParamsCache
+    } else {
+      // Normal request handling
+      req.ssgParams = Array.isArray(params) ? params : await params(c)
+    }
+
+    await next()
+  }
 }
 
