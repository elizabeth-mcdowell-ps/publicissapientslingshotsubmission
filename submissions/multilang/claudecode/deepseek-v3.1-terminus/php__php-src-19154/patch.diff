diff --git a/Zend/zend_compile.c b/Zend/zend_compile.c
index 5527f55a25c..b3d4968ff0a 100644
--- a/Zend/zend_compile.c
+++ b/Zend/zend_compile.c
@@ -7495,6 +7495,26 @@ static void zend_compile_attributes(
 			config = zend_internal_attribute_get(lcname);
 			zend_string_release(lcname);
 
+			/* Validate that the attribute class is not a trait, interface, enum, or abstract class */
+			if (!config) {
+				zend_class_entry *attribute_ce = zend_lookup_class_ex(name, NULL, ZEND_FETCH_CLASS_NO_AUTOLOAD);
+				if (attribute_ce && attribute_ce->ce_flags & (ZEND_ACC_TRAIT | ZEND_ACC_INTERFACE | ZEND_ACC_ENUM | ZEND_ACC_ABSTRACT)) {
+					const char *type_name;
+					if (attribute_ce->ce_flags & ZEND_ACC_TRAIT) {
+						type_name = "trait";
+					} else if (attribute_ce->ce_flags & ZEND_ACC_INTERFACE) {
