+/**
+ * Check whether a model ID is known in MODEL_CAPABILITY_TIER.
+ * Returns false for unknown models so the router can preserve explicit
+ * user configuration instead of assuming "heavy" and downgrading.
+ */
+function isKnownModel(modelId: string): boolean {
+  const bareId = modelId.includes("/") ? modelId.split("/").pop()! : modelId;
+  if (MODEL_CAPABILITY_TIER[bareId]) return true;
+  for (const [knownId] of Object.entries(MODEL_CAPABILITY_TIER)) {
+    if (bareId.includes(knownId) || knownId.includes(bareId)) return true;
+  }
+  return false;
+}
