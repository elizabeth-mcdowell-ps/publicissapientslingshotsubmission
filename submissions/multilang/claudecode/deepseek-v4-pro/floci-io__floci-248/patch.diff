@@ -226,6 +227,28 @@ public class AcmJsonHandler {
 
     // ============ Helper Methods ============
 
+    /**
+     * Decodes a blob value from the AWS JSON 1.1 protocol.
+     * The AWS CLI sends binary blobs as base64-encoded strings.
+     * If the value is valid base64, it is decoded to the original text.
+     * Otherwise, the value is returned as-is (it was sent as plain text).
+     *
+     * @param value The raw text value from the JSON request
+     * @return The decoded value if base64-encoded, or the original value
+     */
+    private static String decodeBlobJsonValue(String value) {
+        if (value == null) {
+            return null;
+        }
+        try {
+            byte[] decoded = java.util.Base64.getDecoder().decode(value);
+            return new String(decoded, StandardCharsets.UTF_8);
+        } catch (IllegalArgumentException e) {
+            // Not valid base64 - treat as plain text
+            return value;
+        }
+    }
