+
+/**
+ * Read a specific key from the LangGraph stream's custom state values.
+ * Mirrors the behavior of `useStream().values[key]` from `@langchain/react`.
+ *
+ * @param key - The state key to read (e.g. "todos", "files", "artifacts")
+ * @param defaultValue - Optional default value returned when the state key is undefined
+ *
+ * @example
+ * ```tsx
+ * import { useLangChainState } from "@assistant-ui/react-langchain";
+ *
+ * function TodoList() {
+ *   const todos = useLangChainState<Todo[]>("todos", []);
+ *
+ *   return (
+ *     <ul>
+ *       {todos.map((todo) => (
+ *         <li key={todo.id}>{todo.title}</li>
+ *       ))}
+ *     </ul>
+ *   );
+ * }
+ * ```
+ */
+export function useLangChainState<T>(key: string): T | undefined;
+export function useLangChainState<T>(key: string, defaultValue: T): T;
+export function useLangChainState<T>(
+  key: string,
+  defaultValue?: T,
+): T | undefined {
+  return useAuiState((s) => {
+    const extras = s.thread.extras;
+    if (!extras) return defaultValue;
+    const { values } = asLangChainRuntimeExtras(extras);
+    return (values[key] as T) ?? defaultValue;
+  });
+}
