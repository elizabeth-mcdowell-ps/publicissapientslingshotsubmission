diff --git a/iwyu.cc b/iwyu.cc
index ab2eef7..92902a8 100644
--- a/iwyu.cc
+++ b/iwyu.cc
@@ -5165,6 +5165,13 @@ class IwyuAstConsumer
   bool VisitFunctionDecl(FunctionDecl* decl) {
     if (CanIgnoreCurrentASTNode())
       return true;
+
+    if (decl->getTemplateSpecializationKind() ==
+        clang::TSK_ExplicitSpecialization) {
+      if (const FunctionTemplateDecl* tpl_decl = decl->getPrimaryTemplate())
+        ReportDeclUse(CurrentLoc(), tpl_decl);
+    }
+
     // If a function declaration specifies default arguments but not for
     // the last parameters, like this:
     // void Fn(int = 0, int);
