+	/**
+	 * Remove stored OAuth credentials for a provider while preserving API keys.
+	 * Returns true when a credential was removed.
+	 */
+	removeOAuthCredentials(provider: string): boolean {
+		const existing = this.getCredentialsForProvider(provider);
+		const apiKeys = existing.filter((credential) => credential.type === "api_key");
+		if (apiKeys.length === existing.length) return false;
+
+		this.providerRoundRobinIndex.delete(provider);
+		this.credentialBackoff.delete(provider);
+		this.providerBackoff.delete(provider);
+
+		if (apiKeys.length === 0) {
+			delete this.data[provider];
+			this.persistProviderChange(provider, undefined);
+			return true;
+		}
+
+		const updated = apiKeys.length === 1 ? apiKeys[0] : apiKeys;
+		this.data[provider] = updated;
+		this.persistProviderChange(provider, updated);
+		return true;
+	}
+
