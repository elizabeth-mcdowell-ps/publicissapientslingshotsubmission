+        private static bool IsSubdirectoryOf(string path, string parent)
+        {
+            var fullPath   = CKANPathUtils.NormalizePath(Path.GetFullPath(path));
+            var fullParent = CKANPathUtils.NormalizePath(Path.GetFullPath(parent));
+            var parentWithSeparator = fullParent.EndsWith("/", StringComparison.Ordinal)
+                ? fullParent
+                : $"{fullParent}/";
+            return fullPath.StartsWith(parentWithSeparator, Platform.PathComparison);
+        }
