diff --git a/librz/core/core.c b/librz/core/core.c
index 46a5129093..ea634ce978 100644
--- a/librz/core/core.c
+++ b/librz/core/core.c
@@ -1483,6 +1483,28 @@ RZ_API RzFlagItem *rz_core_flag_get_by_spaces(RzFlag *f, ut64 off) {
 		NULL);
 }
 
+static bool is_auto_aav_flag(RzFlagItem *flag) {
+	return flag && rz_str_startswith(flag->name, "aav.");
+}
+
+RZ_IPI ut64 rz_core_resolve_refptr_target(RzCore *core, ut64 addr, int refptr, bool big_endian) {
+	ut64 target = UT64_MAX;
+	if (refptr < 1 || !rz_io_read_i(core->io, addr, &target, refptr, big_endian)) {
+		return UT64_MAX;
+	}
+	if (!is_auto_aav_flag(rz_core_flag_get_by_spaces(core->flags, target))) {
+		return target;
+	}
+	ut64 indirect_target = UT64_MAX;
+	if (rz_io_read_i(core->io, target, &indirect_target, refptr, big_endian)) {
+		RzFlagItem *indirect_flag = rz_core_flag_get_by_spaces(core->flags, indirect_target);
+		if (indirect_flag && !is_auto_aav_flag(indirect_flag)) {
+			return indirect_target;
+		}
+	}
+	return target;
+}
+
