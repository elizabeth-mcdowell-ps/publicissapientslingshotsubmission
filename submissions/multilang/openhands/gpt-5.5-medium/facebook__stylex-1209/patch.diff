+function isVarFunction(key: string): boolean {
+  return key.startsWith('var(') && key.endsWith(')');
+}
+
+function isConditionalKey(key: string): boolean {
+  return (
+    key === 'default' ||
+    key.startsWith(':') ||
+    key.startsWith('@') ||
+    isVarFunction(key)
+  );
+}
+
+function keyPathContainsStyleProperty(
+  keyPath: $ReadOnlyArray<string>,
+): boolean {
+  return keyPath.some((key) => !isConditionalKey(key));
+}
