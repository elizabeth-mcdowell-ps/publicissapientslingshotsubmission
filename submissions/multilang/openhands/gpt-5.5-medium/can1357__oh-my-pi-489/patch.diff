+const OPENAI_RESPONSES_PROVIDER_SESSION_STATE_PREFIX = "openai-responses";
+
+class OpenAIResponsesProviderSessionState implements ProviderSessionState {
+	nativeHistoryReplaySince: number;
+
+	constructor(nativeHistoryReplaySince: number) {
+		this.nativeHistoryReplaySince = nativeHistoryReplaySince;
+	}
+
+	close(): void {}
+}
+
+function getOpenAIResponsesProviderSessionStateKey(model: Model<"openai-responses">): string {
+	return `${OPENAI_RESPONSES_PROVIDER_SESSION_STATE_PREFIX}:${model.provider}`;
+}
+
+function getOpenAIResponsesNativeHistoryReplaySince(
+	model: Model<"openai-responses">,
+	providerSessionState: Map<string, ProviderSessionState> | undefined,
+): number {
+	if (!providerSessionState) return Number.NEGATIVE_INFINITY;
+	const state = providerSessionState.get(getOpenAIResponsesProviderSessionStateKey(model)) as
+		| OpenAIResponsesProviderSessionState
+		| undefined;
+	return state?.nativeHistoryReplaySince ?? Number.POSITIVE_INFINITY;
+}
+
+function canReplayOpenAIResponsesHistory(
+	message: { timestamp?: number },
+	nativeHistoryReplaySince: number,
+): boolean {
+	if (nativeHistoryReplaySince === Number.NEGATIVE_INFINITY) return true;
+	return typeof message.timestamp === "number" && message.timestamp >= nativeHistoryReplaySince;
+}
+
+function markOpenAIResponsesProviderSessionActive(
+	model: Model<"openai-responses">,
+	providerSessionState: Map<string, ProviderSessionState> | undefined,
+	nativeHistoryReplaySince: number,
+): void {
+	if (!providerSessionState) return;
+	const key = getOpenAIResponsesProviderSessionStateKey(model);
+	if (!providerSessionState.has(key)) {
+		providerSessionState.set(key, new OpenAIResponsesProviderSessionState(nativeHistoryReplaySince));
+	}
+}
