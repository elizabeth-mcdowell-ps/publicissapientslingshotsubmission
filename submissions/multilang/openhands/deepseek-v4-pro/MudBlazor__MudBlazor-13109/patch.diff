diff --git a/src/MudBlazor.UnitTests.Viewer/TestComponents/Select/SingleSelectWithCustomComparerTest.razor b/src/MudBlazor.UnitTests.Viewer/TestComponents/Select/SingleSelectWithCustomComparerTest.razor
new file mode 100644
index 0000000..b7121a9
--- /dev/null
+++ b/src/MudBlazor.UnitTests.Viewer/TestComponents/Select/SingleSelectWithCustomComparerTest.razor
@@ -0,0 +1,27 @@
+<MudPopoverProvider />
+
+<MudSelect T="string" Label="Test"
+           SelectedValues="_selected" SelectedValuesChanged="SelectedChanged"
+           Comparer="_comparer">
+    <MudSelectItem Value="@("1")">test1</MudSelectItem>
+    <MudSelectItem Value="@("2")">test2</MudSelectItem>
+</MudSelect>
+
+@code {
+    public static string __description__ = "Single select with custom comparer and initial SelectedValues should display the selected value.";
+
+    private readonly IEqualityComparer<string?> _comparer = new DelegateEqualityComparer<string?>(
+        (a, b) => string.Equals(a, b, StringComparison.OrdinalIgnoreCase),
+        x => x?.GetHashCode(StringComparison.OrdinalIgnoreCase) ?? 0);
+
+    private HashSet<string?> _selected = new() { "1" };
+
+    private void SelectedChanged(IReadOnlyCollection<string?>? newSelected)
+    {
+        _selected.Clear();
+        if (newSelected is not null)
+        {
+            _selected.UnionWith(newSelected);
+        }
+    }
+}
\ No newline at end of file
