+    /**
+     * Decodes a blob field that may be base64-encoded per AWS JSON 1.1 protocol.
+     * If the value is null, returns null. If the value looks like PEM (starts with
+     * "-----BEGIN"), returns it as-is. Otherwise, attempts base64 decode.
+     */
+    private String decodeBlob(String value) {
+        if (value == null) return null;
+        if (value.startsWith("-----BEGIN")) return value;
+        try {
+            return new String(Base64.getDecoder().decode(value));
+        } catch (IllegalArgumentException e) {
+            return value;
+        }
+    }
