diff --git a/src/server.c b/src/server.c
index a144001b1..4a9bbf4e8 100644
--- a/src/server.c
+++ b/src/server.c
@@ -1729,7 +1729,10 @@ void whileBlockedCron(void) {
     mstime_t latency;
     latencyStartMonitor(latency);
 
-    defragWhileBlocked();
+    /* Only defragment during AOF loading. Defrag during RDB/replication loading
+     * (which involves flushing old data and loading new data) can corrupt the
+     * database if defrag runs concurrently with the flush operation. */
+    if (isAOFLoadingContext()) defragWhileBlocked();
 
     /* Update memory stats during loading (excluding blocked scripts) */
     if (server.loading) cronUpdateMemoryStats();
diff --git a/tests/unit/test_defrag_repl_crash.tcl b/tests/unit/test_defrag_repl_crash.tcl
new file mode 100644
index 000000000..73274d227
--- /dev/null
+++ b/tests/unit/test_defrag_repl_crash.tcl
@@ -0,0 +1,55 @@
+# Test that active defrag doesn't crash during replica sync db flush
+# This reproduces issue #14267
+
+start_server {tags {"repl external:skip"} overrides {save ""}} {
+    set master_host [srv 0 host]
+    set master_port [srv 0 port]
+    set master [srv 0 client]
+
+    # Populate master with hash data that has HFE entries
+    $master config set hash-max-listpack-entries 32
+    $master config set hash-max-listpack-value 64
+
+    for {set i 0} {$i < 5000} {incr i} {
+        $master hset hash:$i field1 value1 field2 value2 field3 value3
+        $master hexpire hash:$i 3600 FIELDS 1 field1
+    }
+
+    start_server {overrides {save ""}} {
+        set replica [srv 0 client]
+
+        # Enable active defrag
+        $replica config set hz 100
+        $replica config set activedefrag yes
+        $replica config set active-defrag-threshold-lower 5
+        $replica config set active-defrag-cycle-min 65
+        $replica config set active-defrag-cycle-max 75
+        $replica config set active-defrag-ignore-bytes 2mb
+
+        # Add some data to the replica first
+        for {set i 0} {$i < 100000} {incr i} {
+            $replica set key:$i value:$i
+        }
+
+        # Create memory fragmentation by deleting some keys
+        for {set i 0} {$i < 50000} {incr i 2} {
+            $replica del key:$i
+        }
+
+        # Now trigger replica sync - this will:
+        # 1. Flush the old data (triggering defrag via whileBlockedCron)
+        # 2. Load new data from master
+        $replica replicaof $master_host $master_port
+
+        # Wait for sync to complete
+        wait_for_sync $replica
+
+        # Verify data was loaded correctly
+        assert_equal [$replica dbsize] 5000
+        assert_equal [$replica hget hash:0 field1] value1
+
+        $replica replicaof no one
+    }
+}
+
+puts "Test passed: Active defrag during replica sync flush did not crash"
