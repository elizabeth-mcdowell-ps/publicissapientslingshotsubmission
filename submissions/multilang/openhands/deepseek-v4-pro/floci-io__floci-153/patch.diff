--- a/src/test/java/io/github/hectorvent/floci/services/sqs/SqsIntegrationTest.java
+++ b/src/test/java/io/github/hectorvent/floci/services/sqs/SqsIntegrationTest.java
@@ -306,4 +306,81 @@ class SqsIntegrationTest {
             .body(containsString("QueueDoesNotExist"))
             .body(not(containsString("AWS.SimpleQueueService.NonExistentQueue")));
     }
+
+    @Test
+    void jsonProtocol_sendMessageToQueueUrlPath() {
+        // Create a queue first via query protocol
+        String testQueueUrl = given()
+            .contentType("application/x-www-form-urlencoded")
+            .formParam("Action", "CreateQueue")
+            .formParam("QueueName", "json-path-test-queue")
+        .when()
+            .post("/")
+        .then()
+            .statusCode(200)
+            .extract().xmlPath().getString("CreateQueueResponse.CreateQueueResult.QueueUrl");
+
+        // Extract the path from the queue URL (e.g., /000000000000/json-path-test-queue)
+        String queuePath = testQueueUrl.substring(testQueueUrl.indexOf("/", 8)); // after http://host
+
+        // Send JSON 1.0 request to the queue URL path — this is what some AWS SDKs do
+        given()
+            .config(RestAssured.config().encoderConfig(
+                EncoderConfig.encoderConfig()
+                    .encodeContentTypeAs("application/x-amz-json-1.0", ContentType.TEXT)))
+            .contentType("application/x-amz-json-1.0")
+            .header("X-Amz-Target", "AmazonSQS.SendMessage")
+            .body("{\"QueueUrl\":\"" + testQueueUrl + "\",\"MessageBody\":\"hello from json path\"}")
+        .when()
+            .post(queuePath)
+        .then()
+            .statusCode(200)
+            .body(containsString("MessageId"));
+
+        // Clean up
+        given()
+            .contentType("application/x-www-form-urlencoded")
+            .formParam("Action", "DeleteQueue")
+            .formParam("QueueUrl", testQueueUrl)
+        .when()
+            .post("/");
+    }
+
+    @Test
+    void jsonProtocol_getQueueAttributesViaQueueUrlPath() {
+        // Create a queue first via query protocol
+        String testQueueUrl = given()
+            .contentType("application/x-www-form-urlencoded")
+            .formParam("Action", "CreateQueue")
+            .formParam("QueueName", "json-attr-test-queue")
+        .when()
+            .post("/")
+        .then()
+            .statusCode(200)
+            .extract().xmlPath().getString("CreateQueueResponse.CreateQueueResult.QueueUrl");
+
+        String queuePath = testQueueUrl.substring(testQueueUrl.indexOf("/", 8));
+
+        // Send JSON 1.0 request to the queue URL path
+        given()
+            .config(RestAssured.config().encoderConfig(
+                EncoderConfig.encoderConfig()
+                    .encodeContentTypeAs("application/x-amz-json-1.0", ContentType.TEXT)))
+            .contentType("application/x-amz-json-1.0")
+            .header("X-Amz-Target", "AmazonSQS.GetQueueAttributes")
+            .body("{\"QueueUrl\":\"" + testQueueUrl + "\",\"AttributeNames\":[\"All\"]}")
+        .when()
+            .post(queuePath)
+        .then()
+            .statusCode(200)
+            .body(containsString("QueueArn"));
+
+        // Clean up
+        given()
+            .contentType("application/x-www-form-urlencoded")
+            .formParam("Action", "DeleteQueue")
+            .formParam("QueueUrl", testQueueUrl)
+        .when()
+            .post("/");
+    }
