diff --git a/src/MudBlazor.UnitTests.Viewer/TestComponents/FileUpload/FileUploadDragLeaveCustomContentTest.razor b/src/MudBlazor.UnitTests.Viewer/TestComponents/FileUpload/FileUploadDragLeaveCustomContentTest.razor
new file mode 100644
index 0000000..839c393
--- /dev/null
+++ b/src/MudBlazor.UnitTests.Viewer/TestComponents/FileUpload/FileUploadDragLeaveCustomContentTest.razor
@@ -0,0 +1,39 @@
+<MudFileUpload T="IBrowserFile"
+               DragAndDrop="true"
+               tabindex="-1"
+               @bind-Dragging="@_dragging"
+               @ondragleave="@OnDragLeave">
+    <CustomContent>
+        <MudPaper Height="300px"
+                  Outlined="true"
+                  Class="@_dragClass"
+                  @ondragenter="@OnDragEnter"
+                  @onclick="@context.OpenFilePickerAsync">
+            <MudText Typo="Typo.h6">Drag and drop files here or click</MudText>
+        </MudPaper>
+    </CustomContent>
+</MudFileUpload>
+
+@code {
+    public static string __description__ = "Reproduces the bug where @ondragleave on MudFileUpload doesn't fire when DragAndDrop=true with CustomContent.";
+
+    private const string DefaultDragClass = "relative rounded-lg border-2 border-dashed pa-4 mud-width-full mud-height-full";
+    private string _dragClass = DefaultDragClass;
+    private bool _dragging;
+    public bool DragLeaveFired { get; private set; }
+    public bool DragEnterFired { get; private set; }
+
+    private void OnDragEnter()
+    {
+        DragEnterFired = true;
+        _dragClass = $"{DefaultDragClass} mud-border-primary";
+        _dragging = true;
+    }
+
+    private void OnDragLeave()
+    {
+        DragLeaveFired = true;
+        _dragClass = DefaultDragClass;
+        _dragging = false;
+    }
+}
\ No newline at end of file
