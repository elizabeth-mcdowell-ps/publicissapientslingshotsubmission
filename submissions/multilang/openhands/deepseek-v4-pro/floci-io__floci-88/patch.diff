+    private boolean isVirtualHostedRequest(HttpHeaders httpHeaders) {
+        String host = httpHeaders.getHeaderString("Host");
+        if (host == null) return false;
+        if (!host.contains(".localhost") && !host.contains(".s3.")) return false;
+        String hostName = host.contains(":") ? host.substring(0, host.indexOf(':')) : host;
+        String firstPart = hostName.substring(0, hostName.indexOf('.'));
+        return !firstPart.equalsIgnoreCase("s3") && !firstPart.equalsIgnoreCase("localhost");
