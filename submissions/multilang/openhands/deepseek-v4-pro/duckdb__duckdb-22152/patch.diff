diff --git a/src/function/cast/list_casts.cpp b/src/function/cast/list_casts.cpp
index f0d5bc1..56107bc 100644
--- a/src/function/cast/list_casts.cpp
+++ b/src/function/cast/list_casts.cpp
@@ -73,6 +73,43 @@ bool ListCast::ListToListCast(Vector &source, Vector &result, idx_t count, CastP
 	bool all_succeeded = cast_data.child_cast_info.Cast(source_cc, append_vector, source_size, child_parameters);
 	ListVector::SetListSize(result, source_size);
 	D_ASSERT(ListVector::GetListSize(result) == source_size);
+
+	if (!all_succeeded && parameters.nullify_parent) {
+		auto source_child_validity = source_cc.Validity(source_size);
+		auto result_child_validity = append_vector.Validity(source_size);
+		if (result.GetVectorType() == VectorType::CONSTANT_VECTOR) {
+			// Check if any child element went from valid to invalid
+			auto ldata = ConstantVector::GetData<list_entry_t>(result);
+			if (ConstantVector::IsNull(result)) {
+				return all_succeeded;
+			}
+			auto &list_entry = ldata[0];
+			for (idx_t j = list_entry.offset; j < list_entry.offset + list_entry.length; j++) {
+				if (source_child_validity.IsValid(j) && !result_child_validity.IsValid(j)) {
+					ConstantVector::SetNull(result);
+					fprintf(stderr, "ListToListCast: nullified constant result at child idx %lu\n", (unsigned long)j);
+					break;
+				}
+			}
+		} else {
+			auto ldata = FlatVector::GetData<list_entry_t>(result);
+			auto &result_validity = FlatVector::ValidityMutable(result);
+			for (idx_t i = 0; i < count; i++) {
+				if (!result_validity.RowIsValid(i)) {
+					continue;
+				}
+				auto &list_entry = ldata[i];
+				for (idx_t j = list_entry.offset; j < list_entry.offset + list_entry.length; j++) {
+					if (source_child_validity.IsValid(j) && !result_child_validity.IsValid(j)) {
+						result_validity.SetInvalid(i);
+						fprintf(stderr, "ListToListCast: nullified row %lu at child idx %lu\n", (unsigned long)i, (unsigned long)j);
+						break;
+					}
+				}
+			}
+		}
+	}
+
 	return all_succeeded;
 }
 
