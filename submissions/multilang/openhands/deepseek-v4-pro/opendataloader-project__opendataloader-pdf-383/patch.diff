+import org.verapdf.wcag.algorithms.entities.IObject;
+import org.verapdf.wcag.algorithms.entities.content.TextChunk;
+import org.verapdf.wcag.algorithms.entities.content.TextLine;
+import org.verapdf.wcag.algorithms.entities.geometry.BoundingBox;
+import org.verapdf.wcag.algorithms.semanticalgorithms.containers.StaticContainers;
+import org.opendataloader.pdf.processors.TextLineProcessor;
+
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * Comprehensive test for word concatenation issue.
+ * Tests that spaces are correctly inserted between text chunks.
+ */
+public class ReproTest {
+    static int passed = 0;
+    static int failed = 0;
+
+    public static void main(String[] args) {
+        StaticContainers.setIsIgnoreCharactersWithoutUnicode(false);
+        StaticContainers.setIsDataLoader(true);
+
+        testSmallGapBelowThreshold();
+        testWordGapsNearThreshold();
+        testOverlappingChunks();
+        testLargeGap();
+        testExactlyAdjacentChunks();
+        testVerySmallGap();
+        testChunkSortingWithGap();
+        testMultipleChunksMixedGaps();
+
+        System.out.println("\n=== " + passed + " passed, " + failed + " failed ===");
+        if (failed > 0) {
+            System.exit(1);
+        }
+    }
+
+    static void check(String name, boolean condition, String detail) {
+        if (condition) {
+            System.out.println("PASS: " + name + (detail.isEmpty() ? "" : " - " + detail));
+            passed++;
+        } else {
+            System.out.println("FAIL: " + name + (detail.isEmpty() ? "" : " - " + detail));
+            failed++;
+        }
+    }
+
+    // Test 1: Chunks with gap just below old threshold (fontSize * 0.17)
+    // fontSize=10, old threshold=1.7. Gap=1.5 was below old threshold.
+    static void testSmallGapBelowThreshold() {
+        List<IObject> contents = new ArrayList<>();
+        TextChunk chunk1 = new TextChunk(new BoundingBox(0, 10.0, 100.0, 30.0, 110.0),
+            "Evolution", 10, 100.0);
+        TextChunk chunk2 = new TextChunk(new BoundingBox(0, 31.5, 100.0, 50.0, 110.0),
+            "Of", 10, 100.0);
+        contents.add(chunk1);
+        contents.add(chunk2);
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        check("Small gap (1.5pt, below old 1.7 threshold)",
+            value.contains(" "),
+            "got: '" + value + "'");
+    }
+
+    // Test 2: Chunks with word-like gaps near threshold
+    static void testWordGapsNearThreshold() {
+        List<IObject> contents = new ArrayList<>();
+        TextChunk chunk1 = new TextChunk(new BoundingBox(0, 10.0, 100.0, 50.0, 112.0),
+            "Evolution", 12, 100.0);
+        TextChunk chunk2 = new TextChunk(new BoundingBox(0, 52.0, 100.0, 65.0, 112.0),
+            "Of", 12, 100.0);
+        TextChunk chunk3 = new TextChunk(new BoundingBox(0, 67.0, 100.0, 95.0, 112.0),
+            "Search", 12, 100.0);
+        contents.add(chunk1);
+        contents.add(chunk2);
+        contents.add(chunk3);
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        check("Word gaps near threshold", !value.equals("EvolutionOfSearch"),
+            "got: '" + value + "'");
+    }
+
+    // Test 3: Overlapping chunks - no space expected
+    static void testOverlappingChunks() {
+        List<IObject> contents = new ArrayList<>();
+        contents.add(new TextChunk(new BoundingBox(0, 10.0, 30.0, 20.0, 40.0),
+            "test", 10, 30.0));
+        contents.add(new TextChunk(new BoundingBox(0, 20.0, 30.0, 30.0, 40.0),
+            "test", 10, 30.0));
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        check("Overlapping chunks", value.equals("testtest"),
+            "got: '" + value + "'");
+    }
+
+    // Test 4: Existing behavior - large gap
+    static void testLargeGap() {
+        List<IObject> contents = new ArrayList<>();
+        TextChunk chunk1 = new TextChunk(new BoundingBox(0, 10.0, 300.0, 30.0, 310.0),
+            "A:", 10, 300.0);
+        TextChunk chunk2 = new TextChunk(new BoundingBox(0, 50.0, 300.0, 150.0, 310.0),
+            "answer text", 10, 300.0);
+        contents.add(chunk1);
+        contents.add(chunk2);
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        check("Large gap", value.contains("A:") && value.contains("answer text") && !value.equals("A:answer text"),
+            "got: '" + value + "'");
+    }
+
+    // Test 5: Exactly adjacent chunks (rightX == leftX of next) - no space
+    static void testExactlyAdjacentChunks() {
+        List<IObject> contents = new ArrayList<>();
+        contents.add(new TextChunk(new BoundingBox(0, 10.0, 30.0, 20.0, 40.0),
+            "Hel", 10, 30.0));
+        contents.add(new TextChunk(new BoundingBox(0, 20.0, 30.0, 35.0, 40.0),
+            "lo", 10, 30.0));
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        check("Exactly adjacent chunks", value.equals("Hello"),
+            "got: '" + value + "'");
+    }
+
+    // Test 6: Very small gap (0.1pt) should get a space
+    static void testVerySmallGap() {
+        List<IObject> contents = new ArrayList<>();
+        contents.add(new TextChunk(new BoundingBox(0, 10.0, 30.0, 20.0, 40.0),
+            "word1", 10, 30.0));
+        contents.add(new TextChunk(new BoundingBox(0, 20.1, 30.0, 40.0, 40.0),
+            "word2", 10, 30.0));
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        check("Very small gap (0.1pt)", value.contains(" "),
+            "got: '" + value + "'");
+    }
+
+    // Test 7: Chunks sorted by leftX with gap between them (issue #150)
+    static void testChunkSortingWithGap() {
+        List<IObject> contents = new ArrayList<>();
+        TextChunk contentChunk = new TextChunk(new BoundingBox(0, 100.0, 300.0, 200.0, 310.0),
+            "content", 10, 300.0);
+        TextChunk labelChunk = new TextChunk(new BoundingBox(0, 10.0, 300.0, 40.0, 310.0),
+            "Q:", 10, 300.0);
+        contents.add(contentChunk);
+        contents.add(labelChunk);
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        check("Chunk sorting with gap", value.startsWith("Q:"),
+            "got: '" + value + "'");
+    }
+
+    // Test 8: Multiple chunks with mixed gaps
+    static void testMultipleChunksMixedGaps() {
+        List<IObject> contents = new ArrayList<>();
+        // chunk1 ends at 50, chunk2 starts at 50 (adjacent) -> no space
+        contents.add(new TextChunk(new BoundingBox(0, 10.0, 30.0, 50.0, 40.0),
+            "Lexical", 10, 30.0));
+        // chunk2 ends at 62, chunk3 starts at 70 -> gap of 8 -> space!
+        contents.add(new TextChunk(new BoundingBox(0, 50.0, 30.0, 62.0, 40.0),
+            "Search", 10, 30.0));
+        contents.add(new TextChunk(new BoundingBox(0, 70.0, 30.0, 100.0, 40.0),
+            "Traditional", 10, 30.0));
+
+        List<IObject> result = TextLineProcessor.processTextLines(contents);
+        TextLine line = (TextLine) result.get(0);
+        String value = line.getValue();
+        // "LexicalSearch" adjacent then " Traditional" with space
+        check("Mixed gaps - adjacent then gap",
+            value.equals("LexicalSearch Traditional"),
+            "got: '" + value + "'");
+    }
+}
